{"name":"Goblins Consertadores","type":"poder","img":"icons/skills/trades/construction-carpentry-hammer-gray.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">Goblins especialmente pequenos rastejam por dentro dos dutos do colosso fazendo reparos, sendo a fonte da cura acelerada do construto. Por estarem dentro do colosso, os goblins s&atilde;o imunes a dano, mas ainda podem ser afetados por efeitos mentais. Eles possuem Vontade +3 (mas recebem a resist&ecirc;ncia a magia do colosso) e, se forem afetados por qualquer condi&ccedil;&atilde;o, a cura acelerada deixa de funcionar.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"ability","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"effects":[{"label":"Cura Acelerada","icon":"icons/skills/trades/construction-carpentry-hammer-gray.webp","origin":"Item.n59OF2MBGj6wtLFB","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"rounds":1,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"MCUvln3aGbaEJM8o","changes":[{"key":"roll","mode":0,"value":"20","priority":null}],"transfer":true}],"flags":{},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666321513948,"modifiedTime":1666924944491,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"_id":"n59OF2MBGj6wtLFB","folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3}}
{"name":"Ordens","type":"poder","img":"icons/magic/control/control-influence-rally-purple.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">O sargento grita ordens para seus aliados em alcance m&eacute;dio. Eles recebem +1 em testes de per&iacute;cia at&eacute; o fim da cena.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"ability","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"effects":[{"label":"Ordens","icon":"icons/magic/control/control-influence-rally-purple.webp","origin":"Item.sE935B47ySWD4Lus","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":true}},"duration":{"rounds":1,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"UcIlQrTeNdGpbtXO","changes":[{"key":"system.modificadores.pericias.geral","mode":2,"value":"1","priority":null}],"transfer":false}],"flags":{},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666321513948,"modifiedTime":1666924944495,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"_id":"sE935B47ySWD4Lus","folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3}}

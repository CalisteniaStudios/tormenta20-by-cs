{"name":"Aura Aterradora","type":"poder","img":"icons/magic/control/fear-fright-monster-purple-blue.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">A simples vis&atilde;o de um drag&atilde;o adulto ou mais velho amedronta o mais valente dos aventureiros. Uma criatura que comece seu turno em alcance longo do drag&atilde;o fica apavorada (se tiver 4 n&iacute;veis ou menos) ou abalada (se tiver 5 n&iacute;veis ou mais) at&eacute; o fim da cena (Vontade evita). Uma criatura que passe no teste de resist&ecirc;ncia fica imune a esta habilidade por um dia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"passive","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"long","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":"Vontade evita"},"rolls":[],"tipo":"racial","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"effects":[{"label":"Abalado","icon":"systems/tormenta20/icons/conditions/abalado.svg","origin":"Item.e31Rv6abHQNaulQA","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":true}},"duration":{"rounds":99,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"au3nOz2MtQ2H9g1b","changes":[],"transfer":false},{"label":"Apavorado","icon":"systems/tormenta20/icons/conditions/abalado.svg","origin":"Item.e31Rv6abHQNaulQA","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":true}},"duration":{"rounds":99,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"99RlGk3AHuiCfoFE","changes":[],"transfer":false}],"flags":{},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","cre
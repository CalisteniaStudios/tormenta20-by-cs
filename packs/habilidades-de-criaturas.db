{"name":"Espinhos","type":"poder","img":"icons/creatures/abilities/stinger-spine-horn-blood.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">A mant&iacute;cora dispara [[/r 1d4]] espinhos de sua cauda. Cada espinho atinge uma criatura em alcance m&eacute;dio, causando <a class=\"inline-roll roll\" data-mode=\"roll\" data-flavor=\"\" data-formula=\"1d8+7\">1d8+7</a> pontos de dano de perfura&ccedil;&atilde;o (Ref CD 22 reduz &agrave; metade). Recarga (movimento)</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":"Reflexos Metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["1d8+7","",""]],"versatil":""}],"tipo":"ability","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"effects":[],"flags":{},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666321513948,"modifiedTime":1666924944489,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"_id":"eFLZeNkSYcTwoLcn","folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3}}

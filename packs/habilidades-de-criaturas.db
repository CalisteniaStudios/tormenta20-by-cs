{"name":"Olhar Petrificante","type":"poder","img":"icons/magic/perception/eye-slit-orange.webp","effects":[{"label":"Lento","icon":"systems/tormenta20/icons/conditions/lento.svg","origin":"Item.gzTi2g0xClcXNUA6","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":true}},"duration":{"rounds":1,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"TnXSqqNFVOJ9W9KA","changes":[],"transfer":false},{"label":"Petrificado","icon":"systems/tormenta20/icons/conditions/petrificado.svg","origin":"Item.bhkJXAarWpRCeJaI","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"rounds":1,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"GAVSDa8Qij9ymMpB","changes":[],"transfer":false}],"flags":{"core":{"sourceId":"Compendium.tormenta20.poderes.gzTi2g0xClcXNUA6"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">No in&iacute;cio de seu turno, cada personagem em alcance curto do basilisco deve fazer um teste de Reflexos (CD 18). Se passar, desvia o olhar. Se falhar, fica lento. Se j&aacute; estiver lento, fica petrificado permanentemente. Um personagem pode fechar os olhos para ficar imune a esta habilidade, mas sofrer&aacute; os efeitos de estar cego. Efeitos que removem paralisia revertem a petrifica&ccedil;&atilde;o. Metamorfose.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":"Fortitude"},"rolls":[],"tipo":"racial","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"_stats":{"syste
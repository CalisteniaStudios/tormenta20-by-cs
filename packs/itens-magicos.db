{"name":"Braceletes de Bronze","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bracelete-bronze.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.VBjVXrxkC1a7P2t3"},"cf":{"id":"temp_rcbo1jvt5cb","path":"Itens Mágicos#/CF_SEP/Acessórios","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Estes braceletes protegem seu usuário com um campo de força invisível, porém tangível. Você recebe +4 em Defesa, cumulativo com outros itens mágicos, mas não com armaduras.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":16500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":4,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000105,"modifiedTime":1666309841030,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"pceRDlAjYWp8TrAr"}

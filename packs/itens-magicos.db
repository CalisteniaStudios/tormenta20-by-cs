{"name":"Bainha Mágica","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bainha-magica.webp","system":{"description":{"value":"<p>Esta bainha de couro curtido e prata muda de tamanho para acomodar qualquer arma corpo a corpo. Voc&ecirc; pode lan&ccedil;ar @UUID[Compendium.tormenta20.magias.YDxLaaDhfXOkSfnF]{Arma M&aacute;gica} em qualquer arma na bainha sem pagar seu custo em PM.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":3000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[]},"effects":[],"flags":{"cf":{"id":"temp_rcbo1jvt5cb","path":"Itens Mágicos#/CF_SEP/Acessórios","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1666197179765,"modifiedTime":1666309841002,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"gSUt4YB9m41Jg7EN"}

{"name":"Punhal Traiçoeiro","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/punhal-traicoeiro.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.1ZXiPXFQmdWUr51u"},"cf":{"id":"temp_9sqgpxz2gz","path":"Itens Mágicos#/CF_SEP/Armas","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>adaga assassina formidável venenosa</strong> tem l&acirc;mina negra e ondulada. Você pode gastar uma ação padrão e 2 PM para transformar o punhal traiçoeiro em um objeto inofensivo de tamanho similar, como uma colher ou pena. Nenhuma magia é capaz de detectar essa transformação. Transformar o punhal em arma é uma ação livre.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d4","perfuracao",""],["@for","",""],["+2","perfuracao",""]],"versatil":""}],"criticoM":19,"criticoX":2,"lancinante":false,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":true,"dst":false,"dms":false,"dup":false,"lev":true,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":true,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":true,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000086,"modifiedTime":1666309841513,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"5kSByNPBb7cP1vvC"}
{"name":"Vassoura Voadora","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/vassoura-voadora.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.lH4WuC99PGlKzRgc"},"cf":{"id":"temp_rcbo1jvt5cb","path":"Itens Mágicos#/CF_SEP/Acessórios","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Com um comando, esta vassoura flutua, fornecendo deslocamento de voo 12m. A vassoura e pode carregar 2 criaturas Médias (ou 200kg). Se você estiver em alcance longo da vassoura, pode comandar o voo dela.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000112,"modifiedTime":1666309841329,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"6P2FLpQLZdRFzHlu"}

{"name":"Lanterna da Revelação","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/lanterna-da-revelacao.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.01uzk8l2pN2tDIfq"},"cf":{"id":"temp_rcbo1jvt5cb","path":"Itens Mágicos#/CF_SEP/Acessórios","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este item funciona como um lampião normal, mas sua luz revela todas as criaturas e objetos invisíveis em alcance curto.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000084,"modifiedTime":1666309841213,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"4SuRhQwtdEBybRS3"}
{"name":"Avalanche","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/avalanche.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.JWcrwkfQSIVnD9SR"},"cf":{"id":"temp_9sqgpxz2gz","path":"Itens Mágicos#/CF_SEP/Armas","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este machado de guerra de gelo eterno congelante formidável fornece resistência a fogo 10. Você pode gastar uma ação padrão e 6 PM para brandi-lo acima de sua cabeça e invocar uma tempestade de gelo que afeta alcance curto ao seu redor. Criaturas na área recebem camuflagem e sofrem [[/r 3d6]] pontos de dano de impacto e [[/r 3d6]] pontos de frio por rodada. Você não sofre os efeitos nocivos da tempestade (o dano e a chance de falha pela camuflagem) e pode gastar 1 PM no início de cada um de seus turnos para mantê-la.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":6,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d12","corte",""],["@for","",""],["+2+2","corte",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"-","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":6},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000094,"modifiedTime":1666309841423,"lastModifiedBy
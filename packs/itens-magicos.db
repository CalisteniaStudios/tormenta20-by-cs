{"name":"Tapete Voador","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/tapete-voador.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.xvnLFzKVvqZPFOSM"},"cf":{"id":"temp_rcbo1jvt5cb","path":"Itens Mágicos#/CF_SEP/Acessórios","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Com um comando, este tapete flutua, fornecendo deslocamento de voo 12m. O tapete tem 3m x 3m e pode carregar seis criaturas Médias (ou 600kg). Se você estiver em alcance longo do tapete, pode comandar o voo dele.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000119,"modifiedTime":1666309841305,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"EQTzar8KU8XAS0gC"}

{"name":"Tomo da Compreensão","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/tomo-da-compreensao.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.z8YmxSob2luUuWeM"},"cf":{"id":"temp_rcbo1jvt5cb","path":"Itens Mágicos#/CF_SEP/Acessórios","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este livro volumoso contém ensinamentos para tornar o leitor mais cenatrado e aguçar sua percepção, mas também possui um poderoso efeito mágico. Funciona como um Manual do Bom Exercício, mas fornece +1 de Sabedoria.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000121,"modifiedTime":1666309841312,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"3IZIQhZW7aqpkWu8"}
{"name":"Espada Baronial","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/espada-baronial.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.zKL5mWuHBsXAm4Fy"},"cf":{"id":"temp_9sqgpxz2gz","path":"Itens Mágicos#/CF_SEP/Armas","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Estas espadas longas de guarda reta eram dadas por reis-imperadores a vassalos dignos. Uma espada baronial fornece +1 em testes de ataque e rolagens de dano. Este bônus aumenta em +1 se você possuir um código de conduta (de honra, do herói...), for devoto da Justiça ou for treinado em Nobreza. Os bônus são cumulativos — um personagem com um código de conduta, devoto da Justiça e treinado em Nobreza recebe +4 em ataque e dano.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["1","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","impacto",""],["@for","",""],["1","impacto",""]],"versatil":""}],"criticoM":19,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664314000121,"modifiedTime":1666309841455,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9s
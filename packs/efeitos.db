ias.semataque&quot;}\">\n<h3>data.modificadores.pericias.semataque</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia Sem Luta/Pontaria&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia Sem Luta/Pontaria</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.ataque&quot;}\">\n<h3>data.modificadores.pericias.ataque</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Luta E Pontaria&quot;}\">\n<div style=\"float: left;\">Testes de Luta E Pontaria</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.resistencia&quot;}\">\n<h3>data.modificadores.pericias.resistencia</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Fortitude/Reflexos/Vontade&quot;}\">\n<div style=\"float: left;\">Testes de Fortitude/Reflexos/Vontade</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.atr.for&quot;}\">\n<h3>data.modificadores.pericias.atr.for</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia de For&ccedil;a&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia de For&ccedil;a</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.atr.des&quot;}\">\n<h3>data.modificadores.pericias.atr.des</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia de Destreza&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia de Destreza</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.atr.con&quot;}\">\n<h3>data.modificadores.pericias.atr.con</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia de Constitui&ccedil;&atilde;o&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia de Constitui&ccedil;&atilde;o</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.atr.int&quot;}\">\n<h3>data.modificadores.pericias.atr.int</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia de Intelig&ecirc;ncia&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia de Intelig&ecirc;ncia</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.atr.sab&quot;}\">\n<h3>data.modificadores.pericias.atr.sab</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia de Sabedoria&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia de Sabedoria</div>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"border: 1px solid #cccccc; overflow: hidden; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;data.modificadores.pericias.atr.car&quot;}\">\n<h3>data.modificadores.pericias.atr.car</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 16px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Testes de Per&iacute;cia de Carisma&quot;}\">\n<div style=\"float: left;\">Testes de Per&iacute;cia de Carisma</div>\n</td>\n</tr>\n</tbody>\n</table>\n<p>&nbsp;</p>\n<h3 style=\"text-align: right;\">@JournalEntry[lhWNmOhzR7CjtqYq] &gt;&gt;</h3>"}
{"_id":"dSnAe42oig5BjrPA","name":"EFEITOS","permission":{"default":0,"JFtT9SXKYANnmHAy":3},"flags":{"exportSource":{"world":"0t20","system":"tormenta20","coreVersion":"0.7.9","systemVersion":"1.1.33"}},"content":"<h1>EFEITOS</h1>\n<h3>Efeitos &eacute; aquilo que modifica uma ou mais caracter&iacute;sticas de um personagem. Uma condi&ccedil;&atilde;o como Desprevenido, um buff proveniente de um poder ou magia como F&uacute;ria e Armadura Arcana.</h3>\n<p style=\"font-size: 14px;\">&nbsp;</p>\n<p style=\"font-size: 14px;\">EFEITOS S&Oacute; FUNCIONAM EM TOKENS COM FICHAS (ATORES) LINKADAS</p>\n<p style=\"font-size: 14px;\">&nbsp;</p>\n<p style=\"font-size: 14px;\">Para Aplicar um Efeito basta ter um token selecionado e clicar no bot&atilde;o do efeito no chat.</p>\n<table style=\"width: 82.0058%;\" border=\"1\">\n<tbody>\n<tr>\n<td style=\"width: 35.9215%;\"><img src=\"worlds/0t20/art/efeitos-00.PNG\" alt=\"\" width=\"259\" height=\"229\" /></td>\n<td style=\"width: 39.2344%;\">\n<h3><img style=\"font-size: 14px;\" src=\"worlds/0t20/art/efeitos-01.PNG\" alt=\"\" width=\"291\" height=\"178\" /></h3>\n</td>\n</tr>\n<tr>\n<td style=\"width: 35.9215%;\"><img style=\"background-color: rgba(0, 0, 0, 0.05);\" src=\"worlds/0t20/art/efeitos-02.PNG\" alt=\"\" width=\"259\" height=\"229\" /></td>\n<td style=\"width: 39.2344%;\">\n<h3>&nbsp;Forma Fer&oacute;z da um b&ocirc;nus de +6 em For&ccedil;a, al&eacute;m d e outros b&ocirc;nus.</h3>\n</td>\n</tr>\n</tbody>\n</table>\n<p style=\"font-size: 14px;\">&nbsp;</p>\n<h3>Um efeito ativo aparece como um &iacute;cone no token, e tamb&eacute;m na aba Efeitos da ficha do Personagem.</h3>\n<p><img style=\"background-color: rgba(0, 0, 0, 0.05);\" src=\"worlds/0t20/art/efeitos-03.PNG\" alt=\"\" width=\"902\" height=\"363\" /></p>\n<h3>Atrav&eacute;s da Aba Efeitos &eacute; poss&iacute;vel gerenciar os efeitos de um personagem, Adicionar novos, Ativar/Desativar, Editar e Excluir.</h3>\n<h3>&nbsp;</h3>\n<h3>Efeitos Inativos n&atilde;o fazem altera&ccedil;&otilde;es nos personagens.</h3>\n<h3>Efeitos Passivos n&atilde;o possuem dura&ccedil;&atilde;o.</h3>\n<h3>Efeitos Tempor&aacute;rios seram removidos autom&aacute;ticamente se as configura&ccedil;&otilde;es de dura&ccedil;&atilde;o estiverem corretas.</h3>\n<h3>Efeitos de Uso / Aprimoramentos s&atilde;o explicados em @JournalEntry[lhWNmOhzR7CjtqYq]</h3>\n<p>&nbsp;</p>\n<h3 style=\"text-align: right;\">@JournalEntry[f5qz7eWorseoVn7H] &gt;&gt;</h3>\n<p>&nbsp;</p>\n<p>&nbsp;</p>\n<div>&nbsp;</div>\n<div>&nbsp;</div>\n<div>&nbsp;</div>"}
{"_id":"9EWl81e9keurmcy8","name":"CONFIGURAÇÕES DE EFEITOS DO T20","permission":{"default":0,"JFtT9SXKYANnmHAy":3},"flags":{"exportSource":{"world":"0t20","system":"tormenta20","coreVersion":"0.7.9","systemVersion":"1.1.33"}},"content":"<h3>Em Tormenta20 um efeito que possui aprimoramentos n&atilde;o tranfere seus efeitos para o Personagem, ao inv&eacute;z disso, quando a habilidade &eacute; utilizada um novo efeito &eacute; gerado com os efeitos b&aacute;sicos e os aprimoramentos aplicados.</h3>\n<h3>Peguemos F&uacute;ria por exemplo.</h3>\n<p><img src=\"worlds/0t20/art/efeitos-07.PNG\" alt=\"\" width=\"623\" height=\"484\" /></p>\n<h3>F&uacute;ria poss&uacute;i 2 efeitos.</h3>\n<ul>\n<li>\n<h3>Um efeito tempor&aacute;rio \"F&uacute;ria\". Esse &eacute; o efeito base da habilidade, fornecendo +2 de ataque e dano.</h3>\n</li>\n<li>\n<h3>Um efeito de uso \"Aumenta os b&ocirc;nus em +1\". Aqui est&atilde;o as configura&ccedil;&otilde;es do aprimoramento.&nbsp;</h3>\n</li>\n</ul>\n<h3>*Efeitos de Uso s&atilde;o os aprimoramentos de uma habilidade.</h3>\n<p><img src=\"worlds/0t20/art/efeitos-08.PNG\" alt=\"\" width=\"561\" height=\"561\" /></p>\n<p>&nbsp;</p>\n<h3>Um Efeito de Uso/Aprimoramento tem algumas configura&ccedil;&otilde;es diferentes.</h3>\n<p><img src=\"worlds/0t20/art/efeitos-09.PNG\" alt=\"\" width=\"560\" height=\"509\" /></p>\n<ul>\n<li>\n<h3><strong>Efeito Interrompido:</strong>&nbsp; &eacute; na verdade a configura&ccedil;&atilde;o que determina se aquele aprimoramento vai ser aplicado sempre (Ainda n&atilde;o implementado por completo);</h3>\n</li>\n<li>\n<h3><strong>Transferir Efeito para o Ator:</strong> quando um aprimoramento for aplic&aacute;vel em outros items, diferentes dele pr&oacute;prio, &eacute; necess&aacute;rio tranferir este efeito para o Personagem, para que ele fique dispon&iacute;vel.</h3>\n</li>\n<li>\n<h3><strong>Aplicav&eacute;l em:</strong> configura onde este aprimoramento ir&aacute; aparecer (Ao usar uma habilidade com o SHIFT pressionado).&nbsp;</h3>\n</li>\n<li>\n<h3><strong>Permite M&uacute;ltiplas Aplica&ccedil;&otilde;es:</strong> caso o aprimoramento possa ser aplicado diversas vezes. Assim o b&ocirc;nus fornecido ser&aacute; multiplicado pela quantidade de aplica&ccedil;&otilde;es.</h3>\n</li>\n<li>\n<h3><strong>Custo:</strong> o custo daquele aprimoramento especifico.</h3>\n</li>\n</ul>\n<p><img src=\"worlds/0t20/art/efeitos-10.PNG\" alt=\"\" width=\"593\" height=\"299\" /></p>\n<p>&nbsp;</p>\n<h2>CAMPOS ESPECIFICOS DE APRIMORAMENTOS</h2>\n<h3>Efeitos de Uso/Aprimoramentos tamb&eacute;m possuem algumas configura&ccedil;&otilde;es diferentes de efeitos.</h3>\n<h3>Peguemos Golpe Divino para exemplificar.</h3>\n<p>&nbsp;</p>\n<p>&nbsp;</p>\n<table dir=\"ltr\" style=\"table-layout: fixed; font-size: 10pt; font-family: Arial; width: 427px; border-collapse: collapse; border: none; height: 431px;\" border=\"1\" cellspacing=\"0\" cellpadding=\"0\"><colgroup><col style=\"width: 143px;\" width=\"100\" /><col style=\"width: 481px;\" width=\"100\" /></colgroup>\n<tbody>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;$dano&quot;}\">\n<h3>$dano</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Aplica altera&ccedil;&otilde;es na rolagem de dano&quot;}\">\n<div>Aplica altera&ccedil;&otilde;es na rolagem de dano</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;$ataque&quot;}\">\n<h3>$ataque</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Aplica altera&ccedil;&otilde;es na rolagem de Ataque&quot;}\">\n<div>Aplica altera&ccedil;&otilde;es na rolagem de Ataque</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;roll&quot;}\">\n<h3>roll</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Aplica altera&ccedil;&otilde;es na rolagem (Poderes/Magias)&quot;}\">\n<div>Aplica altera&ccedil;&otilde;es na rolagem (Poderes/Magias)</div>\n</td>\n</tr>\n<tr style=\"height: 29px;\">\n<td style=\"height: 29px;\">\n<h3>@NOME#</h3>\n</td>\n<td style=\"height: 29px;\">\n<div>Aplica a latera&ccedil;&atilde;o em outro aprimoramento, NOME deve ser o nome do ITEM daquele aprimoramento. Ap&oacute;s a # deve incluir o campo alterado.</div>\n</td>\n</tr>\n<tr style=\"height: 14px;\">\n<td style=\"height: 14px;\">$passos</td>\n<td style=\"height: 14px;\">Aumenta/Diminui o dano da arma pela quantidade de passos especificada.</td>\n</tr>\n<tr style=\"height: 14px;\">\n<td style=\"height: 14px;\">&nbsp;</td>\n<td style=\"height: 14px;\">&nbsp;</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;alcance&quot;}\">\n<h3>alcance</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera o alcance daquela habilidade&quot;}\">\n<div>Altera o alcance daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;alvo&quot;}\">\n<h3>alvo</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera o alvo daquela habilidade&quot;}\">\n<div>Altera o alvo daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;area&quot;}\">\n<h3>area</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera a area daquela habilidade&quot;}\">\n<div>Altera a area daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;execucao&quot;}\">\n<h3>execucao</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera a execucao daquela habilidade&quot;}\">\n<div>Altera a execucao daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;duracao&quot;}\">\n<h3>duracao</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera a duracao daquela habilidade&quot;}\">\n<div>Altera a duracao daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;resistencia&quot;}\">\n<h3>resistencia</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera a resistencia daquela habilidade&quot;}\">\n<div>Altera a resistencia daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;atrRes&quot;}\">\n<h3>atrRes</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera o atributo da CD da resist&ecirc;ncia daquela habilidade&quot;}\">\n<div>Altera o atributo da CD da resist&ecirc;ncia daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;cd&quot;}\">\n<h3>cd</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera a cd daquela habilidade&quot;}\">\n<div>Altera a cd daquela habilidade</div>\n</td>\n</tr>\n<tr style=\"height: 14px;\">\n<td style=\"height: 14px;\">&nbsp;</td>\n<td style=\"height: 14px;\">&nbsp;</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;criticoM&quot;}\">\n<h3>criticoM</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera a margem de cr&iacute;tico do ataque&quot;}\">\n<h3>Altera a margem de cr&iacute;tico do ataque</h3>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;criticoX&quot;}\">\n<h3>criticoX</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera o multiplicador de cr&iacute;tico do ataque&quot;}\">\n<h3>Altera o multiplicador de cr&iacute;tico do ataque</h3>\n</td>\n</tr>\n<tr style=\"height: 24px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;tipo&quot;}\">\n<h3>tipo</h3>\n</td>\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera o tipo do ataque&quot;}\">\n<h3>Altera o tipo do ataque</h3>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;alcance&quot;}\">\n<h3>alcance</h3>\n</td>\n<td style=\"border-width: 1px; border-style: solid; border-color: #cccccc transparent #cccccc #cccccc; border-image: initial; overflow: visible; padding: 2px 3px; vertical-align: bottom; height: 24px;\" data-sheets-value=\"{&quot;1&quot;:2,&quot;2&quot;:&quot;Altera o alcance do ataque&quot;}\">\n<h3>Altera o alcance do ataque</h3>\n</td>\n</tr>\n</tbody>\n</table>\n<h3>&nbsp;</h3>\n<h3>Os campos de $ataque / $dano / roll possuem intera&ccedil;&otilde;es especificas no modo Customizar:</h3>\n<table style=\"width: 99.1477%; height: 146px;\" border=\"1\">\n<tbody>\n<tr style=\"height: 47px;\">\n<td style=\"height: 47px;\">\n<h3>d#</h3>\n</td>\n<td style=\"height: 47px;\">\n<h3>&nbsp;Altera o dado original para o novo. (IE. Arma Sagrada muda o dano de Golpe Divino de d8 para d12)</h3>\n</td>\n</tr>\n<tr style=\"height: 67px;\">\n<td style=\"height: 67px;\">\n<h3>#dX</h3>\n<h3>#dX+#</h3>\n</td>\n<td style=\"width: 75.2174%; height: 67px;\">\n<h3>&nbsp;Adiciona mais dados a rolagem. O B&ocirc;nus &eacute; opcional.</h3>\n<h3>Multiplicar&aacute; a quantidade de dados/b&ocirc;nus pela quandidade de aplica&ccedil;&otilde;es.</h3>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"width: 24.0663%; height: 16px;\">\n<h3>@###</h3>\n<h3>@car</h3>\n</td>\n<td style=\"width: 75.2174%; height: 16px;\">\n<h3>Incluir&aacute; o valor da caracter&iacute;stica do personagem na rolagem.</h3>\n</td>\n</tr>\n<tr style=\"height: 16px;\">\n<td style=\"width: 24.0663%; height: 16px;\">\n<h3>roll</h3>\n</td>\n<td style=\"width: 75.2174%; height: 16px;\">\n<h3>Incluir&aacute; a rolagem do Item pai.</h3>\n</td>\n</tr>\n</tbody>\n</table>\n<p>&nbsp;</p>"}

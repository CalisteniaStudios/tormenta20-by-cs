{"name":"Balas","type":"consumivel","img":"systems/tormenta20/icons/itens/equipamentos/balas.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.3kWjlkSaIAiYa4lm"},"cf":{"id":"temp_7ekue8ikoq7","path":"Equipamentos#/CF_SEP/Munição (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Uma bolsa com 20 balas (pequenas esferas de chumbo) e p&oacute;lvora. Recarregar uma pistola ou um mosquete &eacute; uma a&ccedil;&atilde;o padr&atilde;o.</p>","chat":"","unidentified":""},"source":"T20, pg. 151 (JdA)","equipado":false,"carregado":true,"peso":0.025,"espacos":1,"qtd":20,"preco":20,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772391,"modifiedTime":1666309921658,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"hLYaSkwJWpJ1EQAv"}
{"name":"Saco de Dormir","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/saco-de-dormir.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.ohZXRVN8Ji4Z1uSm"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um colch&atilde;o com uma coberta fina o bastante para ser enrolada e amarrada, &eacute; especialmente &uacute;til para aventureiros, que nunca sabem onde v&atilde;o passar a noite. Dormir ao relento&nbsp; sem um acampamento e um saco de dormir diminui sua recupera&ccedil;&atilde;o de PV e PM (veja a p&aacute;gina 106).</p>","chat":"","unidentified":""},"source":"T20, pg. 155/157 (JdA)","equipado":false,"carregado":true,"peso":2.5,"espacos":1,"qtd":1,"preco":1,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772420,"modifiedTime":1666309921445,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"hU3o208mVECwpUdF"}
{"name":"Bomba","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/bomba.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.tvG1l6hpNOc7XnP8"},"cf":{"id":"temp_ny1leo0jgec","path":"Equipamentos#/CF_SEP/Alquímicos (FINALIZADO)#/CF_SEP/Preparados","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Uma granada rudimentar, popular entre goblins e usu&aacute;rios de p&oacute;lvora. Para usar a bomba, voc&ecirc; precisa empunh&aacute;-la, gastar uma a&ccedil;&atilde;o de movimento para acender seu pavio e ent&atilde;o uma a&ccedil;&atilde;o padr&atilde;o para arremess&aacute;-la em um ponto em alcance curto. Criaturas a at&eacute; 3m desse ponto sofrem 6d6 pontos de dano de impacto. Um teste de Reflexos (CD Des) reduz o dano &agrave; metade.&nbsp;</p>","chat":"","unidentified":""},"source":"T20, pg. 160 (JdA)","equipado":false,"carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":50,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"full","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"","area":"explosão 3m","resistencia":{"pericia":"","atributo":"des","bonus":null,"txt":"Reflexos reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["6d6","",""]],"versatil":""}],"tipo":"alchemy","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312773031,"modifiedTime":1666309920924,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"hVEBUdASmuwWZf0c"}

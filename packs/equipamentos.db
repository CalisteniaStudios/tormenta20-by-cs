{"name":"Instrumento Musical","type":"equipamento","img":"systems/tormenta20/icons/itens/gerais/instrumento-musical.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">Um instrumento t&iacute;pico, como um bandolim, flauta ou lira.</p>\n<p style=\"text-align: justify;\">Instrumentos musicais. Tais itens s&atilde;o de grande import&acirc;ncia para bardos e possuem as regras a seguir.</p>\n<p style=\"text-align: justify;\">&bull; Voc&ecirc; precisa empunhar um instrumento musical com as duas m&atilde;os para receber seus benef&iacute;cios e para usar M&uacute;sicas de Bardo (veja a p&aacute;gina 45).</p>\n<p style=\"text-align: justify;\">&bull; Instrumentos musicais podem ser usados como esot&eacute;ricos por bardos (permitindo que lance magias usando a m&atilde;o que empunha o instrumento).</p>\n<p style=\"text-align: justify;\">&bull; Instrumentos musicais podem receber melhorias de ferramentas (contam como itens ligados a Atua&ccedil;&atilde;o) e de esot&eacute;ricos (mas afetam apenas magias lan&ccedil;adas por bardos).</p>","chat":"","unidentified":""},"source":"T20, pg. 158 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":35,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"effects":[],"flags":{"core":{"sourceId":"Item.48AZOSnlc4gRYffv"},"cf":{"id":"temp_bvf5qf1aglo","path":"Equipamentos#/CF_SEP/Ferramentas (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1663512910780,"modifiedTime":1666309921561,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"yswk4DL590gvaKd6"}

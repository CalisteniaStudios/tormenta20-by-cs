{"name":"Mosquete","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/mosquete.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.UCovm0cenCi7hgvf"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma arma de fogo de uso difícil, mas com poder devastador. Recarregar um mosquete é uma ação padrão. Exige as duas mãos.</p>","chat":"","unidentified":""},"source":"T20, pg. 150 (JdA)","equipado":0,"carregado":true,"peso":4,"espacos":2,"qtd":1,"preco":500,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["pont","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["2d8","perfuracao",""],["","",""]],"versatil":""}],"criticoM":19,"criticoX":3,"lancinante":false,"alcance":"medium","tipoUso":"fog","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":true,"dms":true,"dup":false,"lev":false,"mun":true,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":true,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772407,"modifiedTime":1666309921351,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"VXJ9QSCMkO885tH7"}
{"name":"Chicote","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/chicote.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.j9gfVNTufgCPJ2AN"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta arma pode ser usada para atacar inimigos a até 4,5m e pode se enroscar nas mãos, pernas ou armas de seus adversários. O chicote é uma arma ágil e versátil, fornecendo +2 em testes para derrubar ou desarmar.</p>","chat":"","unidentified":""},"source":"T20, pg. 147 (JdA)","equipado":0,"carregado":true,"peso":1,"espacos":1,"qtd":1,"preco":2,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d3","corte",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"exo","propriedades":{"ada":false,"agi":true,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":true,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772417,"modifiedTime":1666309921226,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"WGHRYh9QpJuTUFe0"}

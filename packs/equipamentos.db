{"name":"Flauta Mística","type":"equipamento","img":"systems/tormenta20/icons/itens/gerais/flauta-mistica.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">Um instrumento delicado, repleto de runas e pequenas gemas m&iacute;sticas. Um bardo que empunhe este item aumenta a CD para resistir &agrave;s magias lan&ccedil;adas por ele em +1. Conta como um instrumento musical.</p>","chat":"","unidentified":""},"source":"T20, pg. 158 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":150,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"effects":[{"label":"Flauta Mística: aumenta em +1 a CD para resistir às suas magias de bardo.","icon":"icons/svg/upgrade.svg","origin":"Item.48AZOSnlc4gRYffv","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":false,"skill":false,"ability":false,"power":true,"spell":false,"consumable":false,"items":"","aumenta":false,"custo":""}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"bQoexW1WrGdPD7pS","changes":[{"key":"cd","mode":2,"value":"1","priority":0}],"transfer":true}],"flags":{"cf":{"id":"temp_bvf5qf1aglo","path":"Equipamentos#/CF_SEP/Ferramentas (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1663512910780,"modifiedTime":1666309921555,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"fwnIczBJfSCMYQJq"}
{"name":"Bomba de Fumaça","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/bomba-fumaca.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.jChv6jdqw0QvRFaW"},"cf":{"id":"temp_ny1leo0jgec","path":"Equipamentos#/CF_SEP/Alquímicos (FINALIZADO)#/CF_SEP/Preparados","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um saco de estopa com um pavio contendo p&oacute;lvora especial que faz mais fuma&ccedil;a do que fogo. Para us&aacute;-la, voc&ecirc; precisa empunh&aacute;-la, gastar uma a&ccedil;&atilde;o de movimento para acender seu pavio e uma a&ccedil;&atilde;o padr&atilde;o para arremess&aacute;-la em um ponto em alcance curto. Ela gera uma nuvem de fuma&ccedil;a espessa de 6m de raio, que obscurece a vis&atilde;o &mdash; criaturas a at&eacute; 1,5m t&ecirc;m camuflagem e criaturas a partir de 3m t&ecirc;m camuflagem total.&nbsp;</p>","chat":"","unidentified":""},"source":"Guia NPC, pg. 20 (1.1)","equipado":false,"carregado":true,"peso":0,"espacos":0.5,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"full","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"","area":"esfera 6m","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"alchemy","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772417,"modifiedTime":1666309920931,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"fxYTOhjdMMP3sDWh"}

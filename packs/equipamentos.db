{"name":"Algemas","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/algemas.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.lkNT2EjekhRIb5vt"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um par de algemas para criaturas M&eacute;dias. Prender uma criatura que n&atilde;o esteja indefesa exige empunhar a algema, agarrar o alvo (veja &ldquo;Manobras de Combate&rdquo;, no Cap&iacute;tulo 5) e vencer um novo teste de agarrar contra ela. Voc&ecirc; pode prender os dois pulsos da pessoa (&ndash;5 em testes que exijam o uso das m&atilde;os, impede conjura&ccedil;&atilde;o) ou um dos pulsos dela em um objeto im&oacute;vel adjacente, caso haja, para impedir que ela se mova. Escapar das algemas exige uma a&ccedil;&atilde;o completa e um teste de @UUID[Compendium.tormenta20.pericias.hWto9ixrLcAV5Pg9]{Acrobacia} contra CD 30 ou For&ccedil;a (CD 25) &mdash; ou ter as chaves...</p>","chat":"","unidentified":""},"source":"T20, pg. 155 (JdA)","equipado":false,"carregado":true,"peso":1,"espacos":1,"qtd":1,"preco":15,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772419,"modifiedTime":1666309921396,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"GMX3U7etJIXScvAh"}
{"name":"Costela de Lich","type":"equipamento","img":"systems/tormenta20/icons/itens/gerais/costela-de-lich.webp","effects":[{"label":"Costela de Lich: Causa +1d6 pontos de dano de trevas.","icon":"icons/svg/upgrade.svg","origin":"Item.FLmuXN3wg9KxC3BH","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":true,"consumable":false,"items":"","aumenta":false,"custo":""}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"H6DQFuSF71NcRSIr","changes":[{"key":"dano","mode":2,"value":"1d6","priority":0}],"transfer":true}],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.WAObGl5rjxba8J8s"},"cf":{"id":"temp_9fjgkw532bu","path":"Equipamentos#/CF_SEP/Esotéricos (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Esta varinha &eacute; feita a partir do osso de um morto-vivo. Suas magias causam +1d6 pontos de dano de trevas. Se estiver empunhando esta varinha voc&ecirc; n&atilde;o recupera PV por efeitos m&aacute;gicos de cura.</p>","chat":"","unidentified":""},"source":"T20, pg. 160 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":300,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"esoterico","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1663377681721,"modifiedTime":1666309921492,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"H6R44YqqNi4neH0s"}
{"name":"Lança montada","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/lanca-montada.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.HZyncQBfcntF9cF1"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\"> A lança montada é uma arma alongada. Se você estiver montado, pode usá-la com apenas uma mão. Além disso, quando usada numa investida montada, causa +2d8 pontos de dano (não multiplicados em caso de acerto crítico).</p>","chat":"","unidentified":""},"source":"T20, pg. 148 (JdA)","equipado":0,"carregado":true,"peso":6,"espacos":2,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","perfuracao",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772399,"modifiedTime":1666309921297,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"HkWdHfzG2WsWiuaI"}

{"name":"Traje de viagem estrangeiro","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/traje-de-viagem-estrangeiro.webp","system":{"description":{"value":"<p style=\"text-align:justify;\"><strong>[Item de Origem]</strong>&nbsp;<br /><br /><br /><br /><br /><br /><br /><br /><br /><br /><br /><br /><br /><br /><br /><br /></p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":5,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","chatFlavor":"","tags":[]},"effects":[],"flags":{"tormenta20":{"version":"1.3.0.0"},"core":{"sourceId":"Compendium.world.equipamentos-extra.rGk7oiMnyZNFdNNJ"},"exportSource":{"world":"tormentaverse","system":"tormenta20","coreVersion":"10.286","systemVersion":"1.4.006"},"cf":{"id":"temp_uzls0b6ai2","path":"Equipamentos#/CF_SEP/Tesouro","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1666309921893,"modifiedTime":1666309921893,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"JJt7JxcykHutovR1"}
{"name":"Besta leve","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/besta-leve.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.dUtNefh57IswhzOr"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um arco montado sobre uma coronha de madeira com um gatilho, a besta leve &eacute; uma arma que dispara virotes com grande pot&ecirc;ncia. Recarregar uma besta leve &eacute; uma a&ccedil;&atilde;o de movimento.</p>","chat":"","unidentified":""},"source":"T20, pg. 146 (JdA)","equipado":0,"carregado":true,"peso":3,"espacos":1,"qtd":1,"preco":35,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["pont","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","perfuracao",""],["","",""]],"versatil":""}],"criticoM":19,"criticoX":2,"lancinante":false,"alcance":"medium","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":true,"dms":true,"dup":false,"lev":false,"mun":true,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":true,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772412,"modifiedTime":1666309921206,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"JbyCuakaa2GWrEWN"}
{"name":"Corda (10m)","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/corda.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.zhN019SNUiYzz3aU"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um rolo com 10 metros de corda de c&acirc;nhamo, o mesmo tipo usado em navios. Possui diversas utilidades: pode ajudar a descer um buraco ou muro (+5 em testes de Atletismo nessas situa&ccedil;&otilde;es), amarrar pessoas etc. Dar um n&oacute; firme ou especial (por exemplo, capaz de deslizar, se desfazer com um pux&atilde;o etc.) exige um teste de Destreza (CD 15). Arrebentar a corda exige 2 pontos de dano de corte ou uma a&ccedil;&atilde;o padr&atilde;o e um teste de For&ccedil;a (CD 20).</p>","chat":"","unidentified":""},"source":"T20, pg. 155 (JdA)","equipado":false,"carregado":true,"peso":5,"espacos":1,"qtd":1,"preco":1,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312773035,"modifiedTime":1666309921414,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"JmsG3Od2Lsg1iOZq"}
{"name":"Barraca","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/barraca.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.k9mpsAd6FWQjqYpB"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Esta barraca de lona conta como um saco de dormir para duas pessoas e fornece +2 em testes de @UUID[Compendium.tormenta20.pericias.dyePg3NS95So0yEJ]{Sobreviv&ecirc;ncia} para acampar</p>","chat":"","unidentified":""},"source":"T20, pg. 155 (JdA)","equipado":false,"carregado":true,"peso":10,"espacos":1,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772418,"modifiedTime":1666309921407,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"JnCBnZtP26H7QixI"}
{"name":"Essência de mana","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/essencia-mana.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.JC6bm2uh4g7oaGge"},"cf":{"id":"temp_ny1leo0jgec","path":"Equipamentos#/CF_SEP/Alquímicos (FINALIZADO)#/CF_SEP/Preparados","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Esta po&ccedil;&atilde;o feita de ervas raras e compostos alqu&iacute;micos recupera energia pessoal. Beber a ess&ecirc;ncia de mana &eacute; uma a&ccedil;&atilde;o padr&atilde;o e recupera 1d4 pontos de mana.&nbsp;</p>","chat":"","unidentified":""},"source":"T20, pg. 160 (JdA)","equipado":false,"carregado":true,"peso":0.1,"espacos":0.5,"qtd":1,"preco":50,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["1d4","curapm",""]],"versatil":""}],"tipo":"alchemy","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772400,"modifiedTime":1666309920948,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"Jw7QimCi5fyrv0TA"}

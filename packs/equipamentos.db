{"name":"Estojo de Disfarces","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/estojo-de-disfarces.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.7d9rOIGNdGSTnXUG"},"cf":{"id":"temp_bvf5qf1aglo","path":"Equipamentos#/CF_SEP/Ferramentas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um conjunto de cosm&eacute;ticos, tintas para cabelo e algumas pr&oacute;teses simples (como bigodes e narizes falsos). Um personagem sem este item sofre &ndash;5 em testes de Engana&ccedil;&atilde;o para disfarce.</p>","chat":"","unidentified":""},"source":"T20, pg. 158 (JdA)","equipado":false,"carregado":true,"peso":4,"espacos":1,"qtd":1,"preco":50,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772393,"modifiedTime":1666309921551,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"5YMr1IT22pLmsUwT"}

{"name":"Pomada Protetora","type":"consumivel","img":"icons/tools/laboratory/powder-red.webp","effects":[{"label":"Pomada Protetora","icon":"icons/tools/laboratory/powder-red.webp","origin":"Item.TpFcF3HAhwJCC4Dc","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":true}},"duration":{"rounds":1,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"BMe6AL3Cyl2TDKai","changes":[{"key":"system.tracos.resistencias.dano.value","mode":2,"value":"5","priority":null}],"transfer":false}],"flags":{"importid":"FgiuAq113l5TME26","tormenta20":{"version":"1.3.0.0"},"scene-packer":{"sourceId":"Item.disSPX53Qj7k0hX1","defaultPermission":2,"hash":"0c94dca0522e05c64fe2111068ec30b239cb9ad3"},"cf":{"id":"temp_d8ssm4k6t7f","path":"Jornada Heróica","color":"#000000"},"core":{"sourceId":"Compendium.world.world-arielton-1663050699947.M3UqIweaAq34i7Jk"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Uma pasta espessa e cinzenta que deixa a pele dura como pedra. Espalhar a pasta &eacute; uma a&ccedil;&atilde;o completa e fornece resist&ecirc;ncia a dano 5 por uma cena. Of&iacute;cio (alquimia) CD 25.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":300,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"alchemy","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1663051712013,"modifiedTime"
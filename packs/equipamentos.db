{"name":"Elixir do Amor","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/elixir-do-amor.webp","system":{"description":{"value":"<p>Um humanoide que beba este l&iacute;quido adocicado fica apaixonado pela primeira criatura que enxergar (condi&ccedil;&atilde;o enfeiti&ccedil;ado; Vontade CD Car anula). O efeito dura 1d3 dias.</p>","chat":"","unidentified":""},"source":"T20, pg. 160 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":0.5,"qtd":1,"preco":100,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"alchemy","uses":{"autoDestroy":false},"origin":"","tags":[],"chatFlavor":"","subtipo":""},"effects":[],"flags":{"cf":{"id":"temp_ny1leo0jgec","path":"Equipamentos#/CF_SEP/Alquímicos (FINALIZADO)#/CF_SEP/Preparados","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664981211816,"modifiedTime":1666309920941,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"eB4GP6ywIppQpPlM"}

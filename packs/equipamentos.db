{"name":"Machado táurico","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/machado-taurico.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.INnoDDDGvmHKvnlM"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma haste comprida com uma lâmina extremamente grossa na ponta, esta é uma arma ancestral dos minotauros. Um machado táurico é muito grande para ser usado sem treinamento especial; por isso, é uma arma exótica. Além disso, por ser pesado e desbalanceado, impõe –2 em testes de ataque.</p>","chat":"","unidentified":""},"source":"T20, pg. 149 (JdA)","equipado":0,"carregado":true,"peso":12,"espacos":2,"qtd":1,"preco":50,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["-2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["2d8","corte",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"-","tipoUso":"exo","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772400,"modifiedTime":1666309921330,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"6qqqlqZ5jqcbtoz1"}

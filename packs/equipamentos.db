{"name":"Lançador Alquímico","type":"tesouro","img":"icons/weapons/guns/gun-green.webp","effects":[],"flags":{"tormenta20":{"version":"1.3.0.0"},"core":{"sourceId":"Compendium.world.equipamentos-extra.reYqIJOcSHCN43ov"},"scene-packer":{"sourceId":"Item.GWYwnWyn5ybZftJB","defaultPermission":2,"hash":"dddcad93073620ddf123326ed3c32a92e4fa563f"},"cf":{"id":"temp_d8ssm4k6t7f","path":"Jornada Heróica","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este cano grosso com uma empunhadura e gatilho pode ser carregado com um item alqu&iacute;mico ou po&ccedil;&atilde;o como uma a&ccedil;&atilde;o padr&atilde;o. Disparar o lan&ccedil;ador exige as duas m&atilde;os e uma a&ccedil;&atilde;o padr&atilde;o e gera o efeito do item carregado nele em alcance m&eacute;dio. Of&iacute;cio (armeiro) CD 20. (Nota: este item n&atilde;o conta como arma para modifica&ccedil;&otilde;es e encantos.)</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":3,"espacos":1,"qtd":1,"preco":540,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1663051713974,"modifiedTime":1666310330193,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"3IIaL6EsLbpPrzRo"}

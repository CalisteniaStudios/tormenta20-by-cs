{"name":"Brunea","type":"equipamento","img":"systems/tormenta20/icons/itens/equipamentos/brunea.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.0Zlo3JJpJsaZwyNS"},"cf":{"id":"temp_rj7c2nwsol","path":"Equipamentos#/CF_SEP/Armaduras (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Colete de couro coberto com plaquetas de metal sobrepostas, como escamas de um peixe. Por ser barata de produzir, é a armadura mais utilizada por soldados de infantaria e guardas de castelo.</p>","chat":"","unidentified":""},"source":"T20, pg. 154 (JdA)","equipado":false,"carregado":true,"peso":15,"espacos":5,"qtd":1,"preco":50,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":5,"penalidade":-2,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772389,"modifiedTime":1666309921112,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"8H9dax1gnq9aqfJC"}

{"name":"Cajado de batalha","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/cajado-de-batalha.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.YSeDHrsCHQBtD2jP"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Um cajado de madeira forte, reforçado com chapas de metal nas pontas. é uma arma discreta, usada por andarilhos que não querem levantar suspeitas ou parecer ameaçadores. O cajado de batalha é uma arma dupla.</p>","chat":"","unidentified":""},"source":"Guia NPC, pg. 16 (1.1)","equipado":0,"carregado":true,"peso":4,"espacos":2,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","impacto",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":true,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":true,"leve":false,"municao":false,"versatil":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"encantos":{"lancinante":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772409,"modifiedTime":1666309921220,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"tXX6s3qvqkTAS4fP"}

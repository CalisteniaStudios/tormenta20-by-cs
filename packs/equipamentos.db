{"name":"Funda","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/funda.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.DjqrTflaHyUetx0k"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma simples tira de couro usada para arremessar balas de metal. Na falta de munição adequada, pode disparar pedras comuns, mas o dano é reduzido em um passo. Recarregar uma funda é uma ação de movimento. Ao contrário de outras armas de disparo, você aplica seu modificador de Força a rolagens de dano com uma funda.</p>","chat":"","unidentified":""},"source":"T20, pg. 148 (JdA)","equipado":0,"carregado":true,"peso":0.25,"espacos":1,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["pont","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d4","impacto",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"medium","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":true,"dms":false,"dup":false,"lev":false,"mun":true,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":false,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772395,"modifiedTime":1666309921277,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"XoDhOytzDFl6KaJO"}
{"name":"Varinha Arcana","type":"equipamento","img":"systems/tormenta20/icons/itens/gerais/varinha-arcana.webp","effects":[{"label":"Varinha Arcana: A CD para resistir às suas magias arcanas aumenta em +1.","icon":"icons/svg/upgrade.svg","origin":"Item.FLmuXN3wg9KxC3BH","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":true,"consumable":false,"items":"","aumenta":false,"custo":""}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"H6DQFuSF71NcRSIr","changes":[{"key":"cd","mode":2,"value":"1","priority":0}],"transfer":true}],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.WAObGl5rjxba8J8s"},"cf":{"id":"temp_9fjgkw532bu","path":"Equipamentos#/CF_SEP/Esotéricos (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Uma varinha t&iacute;pica, feita de madeira de boa qualidade e entalhada com runas. A CD para resistir a suas magias arcanas aumenta em +1.</p>","chat":"","unidentified":""},"source":"T20, pg. 160 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":100,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"esoterico","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1663377681721,"modifiedTime":1666309921520,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"Y5b874t8XuYJVExG"}
{"name":"Maça de guerra","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/maca-de-guerra.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.nv2dOJuba2y2O5TE"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma versão mais perigosa da maça comum, com uma cabeça formada por grandes placas de metal. O peso da maça de guerra torna seu golpe poderoso, mas desajeitado, impondo &ndash;2 em testes de ataque. Uma maça de guerra é muito pesada e desbalanceada para ser usada sem treinamento especial, por isso é uma arma exótica.</p>","chat":"","unidentified":""},"source":"Guia NPC, pg. 23 (1.1)","equipado":0,"carregado":true,"peso":6,"espacos":1,"qtd":1,"preco":25,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["-2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d12","impacto",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"","tipoUso":"exo","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"encantos":{"lancinante":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772420,"modifiedTime":1666309921307,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"YA2HkdJ8vtERyuEW"}
{"name":"Alfange","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/alfange.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.zdzrCLMsiO2LJYiS"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma versão maior da cimitarra, esta espada de lâmina larga e curva é bastante usada por guerreiros do deserto.</p>","chat":"","unidentified":""},"source":"T20, pg. 146 (JdA)","equipado":0,"carregado":true,"peso":4,"espacos":2,"qtd":1,"preco":75,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["2d4","corte",""],["@for","",""]],"versatil":""}],"criticoM":18,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312773035,"modifiedTime":1666309921179,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"YOvIspOAi3HMbrMi"}

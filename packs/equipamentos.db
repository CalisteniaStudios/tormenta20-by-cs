{"name":"Cajado Arcano","type":"arma","img":"systems/tormenta20/icons/itens/gerais/cajado-arcano.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.HyJBwTLK0vY5F1Vp"},"cf":{"id":"temp_9fjgkw532bu","path":"Equipamentos#/CF_SEP/Esotéricos (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um cajado t&iacute;pico, feito de madeira de boa qualidade e entalhado com runas. O limite de PM que voc&ecirc; pode gastar em magias arcanas e a CD para resistir a elas aumentam em +1. Para fornecer seus benef&iacute;cios, um cajado precisa ser empunhado com as duas m&atilde;os. Ele pode ser usado como arma, com as estat&iacute;sticas de um bord&atilde;o.</p>","chat":"","unidentified":""},"source":"T20, pg. 160 (JdA)","equipado":0,"carregado":true,"peso":2,"espacos":2,"qtd":1,"preco":1000,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","impacto",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":true,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":true,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772399,"modifiedTime":1666309921475,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"nS7JdUdKJ9SY0bCZ"}
{"name":"Água benta","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/agua-benta.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.labWwyXiXHl7JvE0"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Produzida com a magia @UUID[Compendium.tormenta20.magias.ZzDo9khqHDty1iDV]{Aben&ccedil;oar Alimentos}, esta &aacute;gua sagrada &eacute; um poderoso recurso na luta contra o mal. Para usar a &aacute;gua benta, voc&ecirc; gasta uma a&ccedil;&atilde;o padr&atilde;o e escolhe um morto-vivo, dem&ocirc;nio ou diabo em alcance curto (a &aacute;gua benta &eacute; inofensiva contra outras criaturas). O alvo sofre 2d10 pontos de dano de luz (Reflexos CD Sab reduz &agrave; metade).</p>","chat":"","unidentified":""},"source":"T20, pg. 155 (JdA)","equipado":false,"carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":null,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"des","bonus":null,"txt":"Reflexos reduz a metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d10","luz",""]],"versatil":""}],"tipo":"alchemy","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772418,"modifiedTime":1666309921392,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"nei6IKPKFP5xvx2n"}

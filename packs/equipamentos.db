{"name":"Arco longo","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/arco-longo.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.B1hiWU8eEI1NHwcv"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este arco reforçado tem a altura de uma pessoa. Ao contrário da versão curta, é primariamente uma arma de guerra. Por ter uma puxada pesada, permite que você aplique seu modificador de Força às rolagens de dano. Exige as duas mãos e não pode ser usado se você estiver montado.</p>","chat":"","unidentified":""},"source":"T20, pg. 146 (JdA)","equipado":0,"carregado":true,"peso":1.5,"espacos":2,"qtd":1,"preco":100,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["pont","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","perfuracao",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"medium","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":true,"dms":true,"dup":false,"lev":false,"mun":true,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":true,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772394,"modifiedTime":1666309921191,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"Pm57TXV6EHvsHCOu"}
{"name":"Lampião","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/lampiao.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.hSNkEKLoTHuywNya"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Um cilindro com uma al&ccedil;a e duas portinholas. Uma chama alimentada por &oacute;leo &eacute; acesa dentro do cilindro e uma das portinholas aberta deixa a luz sair. Acender um lampi&atilde;o &eacute; uma a&ccedil;&atilde;o padr&atilde;o e sua luz ilumina um raio com alcance m&eacute;dio. Um frasco de &oacute;leo (veja abaixo) dura uma cena.</p>","chat":"","unidentified":""},"source":"T20, pg. 155 (JdA)","equipado":false,"carregado":true,"peso":1,"espacos":1,"qtd":1,"preco":7,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772416,"modifiedTime":1666309921424,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"PwQ8MipudsvCi7xS"}
{"name":"Machado de batalha","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/machado-de-batalha.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.v5HYdRxOsBcnXATP"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Adaptado do machado de lenhador, este não é um instrumento para corte de árvores, mas sim uma arma capaz de causar ferimentos terríveis.</p>","chat":"","unidentified":""},"source":"T20, pg. 149 (JdA)","equipado":0,"carregado":true,"peso":3,"espacos":1,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","corte",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312773032,"modifiedTime":1666309921322,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"QCtulGU5d1Xt0X4w"}
{"name":"Espelho","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/espelho.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.o5AfIxUf49F8UHv4"},"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Al&eacute;m de garantir que voc&ecirc; esteja apresent&aacute;vel, este pequeno espelho de metal polido possui diversas utilidades, como observar cantos e fazer sinais de luz.</p>","chat":"","unidentified":""},"source":"T20, pg. 155 (JdA)","equipado":false,"carregado":true,"peso":0.25,"espacos":1,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772420,"modifiedTime":1666309921421,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"QIw2uql5FwBqrF17"}

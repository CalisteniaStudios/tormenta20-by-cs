{"name":"Batata Ambiciosa","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/batata-ambiciosa.webp","system":{"description":{"value":"<p style=\"text-align: justify;\">Batatas cortadas em tiras e mergulhadas em &oacute;leo fervente. Gordurentas e pouco nutritivas, s&atilde;o o tipo de prato que s&oacute; &eacute; servido numa metr&oacute;pole. Apesar disso, s&atilde;o uma unanimidade! Gostosas, deixam qualquer um empolgado para realizar fa&ccedil;anhas. Voc&ecirc; recebe +1d6 num &uacute;nico teste a sua escolha realizado nesse dia.</p>\n<p style=\"text-align: justify;\">Para n&atilde;o esquecer, deixe 1d6 em cima da sua ficha. De prefer&ecirc;ncia, amarelo.</p>","chat":"","unidentified":""},"source":"T20, pg. 162 (JdA)","equipado":false,"carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":2,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"food","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""},"effects":[{"label":"Batata Ambiciosa: Soma +1d6 em um único  teste a sua escolha.","icon":"icons/svg/upgrade.svg","origin":"Item.MT4QgnaAwWgr4pet","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":true,"skill":true,"ability":true,"power":false,"spell":false,"consumable":false,"items":"","aumenta":false,"custo":""}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"mhMNYFNWFT6UyhFS","changes":[{"key":"roll","mode":2,"value":"1d6","priority":0}],"transfer":true},{"label":"Batata Ambiciosa","icon
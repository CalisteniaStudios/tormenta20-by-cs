{"name":"Beladona","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/veneno.webp","effects":[{"label":"Beladona","icon":"systems/tormenta20/icons/itens/gerais/veneno.webp","origin":"Item.5D42HnDgEirhlxS5","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"rounds":3,"startTime":null,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"geUCxtXFwXidnoZg","changes":[],"transfer":false}],"flags":{"scene-packer":{"sourceId":"Item.TuPjWGAvbeedIJhb","defaultPermission":2,"hash":"45611845a538afe14423f5017dc46d7b2023722b"},"cf":{"id":"temp_b87ebqsxtka","path":"Equipamentos#/CF_SEP/Alquímicos (FINALIZADO)#/CF_SEP/Venenos","color":"#000000"},"core":{"sourceId":"Compendium.world.world-arielton-1663050699947.VGBm2dAZLK1naAkz"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Planta extremamente t&oacute;xica que afeta o sistema nervoso da v&iacute;tima.</p>\n<p style=\"text-align: justify;\"><strong>Tipo: </strong><em>Ingest&atilde;o.</em></p>\n<p style=\"text-align: justify;\"><strong>Efeito:</strong><em>&nbsp;v&iacute;tima fica paralisada (lenta) por 3 rodadas. </em></p>\n<p style=\"text-align: justify;\"><em>A CD para fabricar e para </em><em>resistir a este veneno aumenta em +5.</em></p>","chat":"","unidentified":""},"source":"T20, pg. 161 (JdA)","equipado":false,"carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":1500,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"alchemy","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":""}
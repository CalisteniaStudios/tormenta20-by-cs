{"name":"Armadura completa","type":"equipamento","img":"systems/tormenta20/icons/itens/equipamentos/armadura-completa.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.CTeeKAq8zZlaJTpA"},"cf":{"id":"temp_rj7c2nwsol","path":"Equipamentos#/CF_SEP/Armaduras (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">A mais forte e pesada das armaduras, formada por placas de metal forjadas e encaixadas de modo a cobrir o corpo inteiro. Inclui manoplas e grevas (luvas e botas metálicas, respectivamente), um elmo com viseira e uma túnica acolchoada para ser usada sob as placas. Correias e fivelas distribuem o peso da armadura pelo corpo inteiro. </p><p style=\"text-align:justify;\">Esta armadura precisa ser feita sob medida para cada usuário; um ferreiro cobra T$ 200 para adaptar uma armadura completa a um novo usuário.</p>","chat":"","unidentified":""},"source":"T20, pg. 154 (JdA)","equipado":false,"carregado":true,"peso":25,"espacos":5,"qtd":1,"preco":3000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":10,"penalidade":-5,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772395,"modifiedTime":1666309921102,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"peQqXBnAxiAs9gHf"}

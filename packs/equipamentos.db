{"name":"Traje de viajante","type":"equipamento","img":"systems/tormenta20/icons/itens/gerais/traje-de-viajante.webp","system":{"description":{"value":"<p>Inclui botas, cal&ccedil;as ou saias, cinto, camisa de linho e capa com capuz. A roupa padr&atilde;o de aventureiros.</p>","chat":"","unidentified":""},"source":"T20, pg. 159 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[]},"effects":[],"flags":{"cf":{"id":"temp_p21okdc8ku","path":"Equipamentos#/CF_SEP/Vestuário (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1665688198494,"modifiedTime":1666309922255,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"aSYwLONgjI7DfpWS"}

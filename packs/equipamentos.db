{"name":"Corrente de espinhos","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/corrente-de-espinhos.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.sbeOrX6B3VZIuQcL"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta arma pode ser usada para atacar inimigos a até 4,5m e pode se enroscar nas mãos, pernas ou armas de seus adversários. A corrente de espinhos é uma arma ágil, dupla e versátil, fornecendo +2 em testes para derrubar ou desarmar.</p>","chat":"","unidentified":""},"source":"T20, pg. 147 (JdA)","equipado":0,"carregado":true,"peso":5,"espacos":2,"qtd":1,"preco":25,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["2d4","corte",""],["@for","",""]],"versatil":""}],"criticoM":19,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"exo","propriedades":{"ada":false,"agi":true,"alo":false,"arr":false,"dst":false,"dms":false,"dup":true,"lev":false,"mun":false,"ver":true,"adaptavel":false,"agil":true,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":true,"leve":false,"municao":false,"versatil":true},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772422,"modifiedTime":1666309921240,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"xrZWOBDfKTWctv9B"}
{"name":"Escudo pesado (Arma)","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/escudo-pesado.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.w5MOK5PvKvRjH9pM"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Você pode usar um escudo como uma arma marcial, mas perde seu bônus na Defesa até o próximo turno.</p>","chat":"","unidentified":""},"source":"T20, pg. 152 (JdA)","equipado":0,"carregado":true,"peso":7,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","impacto",""],["","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312773033,"modifiedTime":1666309921251,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"yFQGK7HzVuIDFPRY"}

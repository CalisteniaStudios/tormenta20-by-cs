{"name":"Carroça","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/carroca.webp","system":{"description":{"value":"<p>Ve&iacute;culo de duas ou quatro rodas, aberto, normalmente usado para transportar cargas pesadas. &Eacute; puxada por dois cavalos ou um trobo. Inclui os arreios necess&aacute;rios para controlar os animais. Uma carro&ccedil;a tem tamanho Grande, deslocamento 9m, Defesa 8 (+ Des do condutor), 50 PV e pode carregar at&eacute; 4 criaturas M&eacute;dias ou 80 espa&ccedil;os.</p>","chat":"","unidentified":""},"source":"T20, pg. 163 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","chatFlavor":"","tags":[]},"effects":[],"flags":{"exportSource":{"world":"tormentaverse","system":"tormenta20","coreVersion":"10.286","systemVersion":"1.4.006"},"cf":{"id":"temp_3lai3bm2krw","path":"Equipamentos#/CF_SEP/Veiculos (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1666309921947,"modifiedTime":1666309921947,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"QZ0jG3V6hihYcg4s"}

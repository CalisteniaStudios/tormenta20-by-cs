{"name":"Símbolo Sagrado","type":"equipamento","img":"systems/tormenta20/icons/itens/gerais/simbolo-sagrado.webp","system":{"description":{"value":"<p>Um medalh&atilde;o de madeira ou metal com o s&iacute;mbolo de uma divindade. Voc&ecirc; precisa estar vestindo (normalmente com uma corrente ao redor do pesco&ccedil;o) ou empunhando um s&iacute;mbolo sagrado para usar qualquer poder concedido.</p>","chat":"","unidentified":""},"source":"T20, pg. 157 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":5,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[]},"effects":[],"flags":{"cf":{"id":"temp_57ujw9z1h0g","path":"Equipamentos#/CF_SEP/Equipamento de Aventura (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1665712733997,"modifiedTime":1666309921451,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"9wbDfKCp0r5qlrfL"}
{"name":"Alabarda","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/alabarda.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.p7MZK1XnNPSXxbmy"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma haste de madeira com 2m de comprimento e uma lâmina de machado na ponta. A alabarda é uma arma alongada.</p>","chat":"","unidentified":""},"source":"T20, pg. 146 (JdA)","equipado":0,"carregado":true,"peso":6,"espacos":2,"qtd":1,"preco":10,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d10","corte",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":3,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":true,"arr":false,"dst":false,"dms":true,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":true,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772421,"modifiedTime":1666309921175,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"AI8GLavqULSyiqiS"}

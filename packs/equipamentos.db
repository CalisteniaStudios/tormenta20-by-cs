{"name":"Canoa","type":"tesouro","img":"systems/tormenta20/icons/itens/gerais/canoa.webp","system":{"description":{"value":"<p><span class=\"fontstyle0\">Constru&iacute;da a partir de um &uacute;nico tronco de &aacute;rvore, &eacute; a mais simples das embarca&ccedil;&otilde;es.</span> </p>","chat":"","unidentified":""},"source":"T20, pg. 163 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":50,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","chatFlavor":"","tags":[]},"effects":[],"flags":{"exportSource":{"world":"tormentaverse","system":"tormenta20","coreVersion":"10.286","systemVersion":"1.4.006"},"cf":{"id":"temp_3lai3bm2krw","path":"Equipamentos#/CF_SEP/Veiculos (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1666309921944,"modifiedTime":1666309921944,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"QapcXPmySu8wLjYl"}
{"name":"Gelo eterno","type":"consumivel","img":"systems/tormenta20/icons/itens/gerais/gelo-eterno.webp","system":{"description":{"value":"<p><strong style=\"text-align: justify;\">[Material Especial]</strong></p>\n<p><span style=\"text-align: justify;\">As g&eacute;lidas Montanhas Gélidas produzem gelo que nunca derrete. Expedi&ccedil;&otilde;es de aventureiros exploram essa regi&atilde;o glacial perigosa &agrave; ca&ccedil;a deste material fant&aacute;stico.<br><strong>Arma.</strong> Causa +2 pontos de dano por frio.<br><strong>Armadura e Escudo.</strong> Fornece redu&ccedil;&atilde;o de fogo: armaduras leves e escudos, resist&ecirc;ncia 5; armaduras pesadas, resist&ecirc;ncia 10.<br><strong>Es&oacute;terico.</strong> Quando causa dano com uma magia de frio, voc&ecirc; pode rolar novamente qualquer resultado 1.</span></p>\n<p>&nbsp;</p>\n<p><span class=\"fontstyle0\"><strong style=\"text-align: justify;\">Pre&ccedil;os:</strong></span></p>\n<p><span class=\"fontstyle0\"><span style=\"text-align: justify;\">Armas +T$ 600&nbsp;</span></span></p>\n<p><span class=\"fontstyle0\"><span style=\"text-align: justify;\">Armaduras pesadas e Esot&eacute;ricos +T$ 3000</span></span></p>\n<p><span class=\"fontstyle0\"><span style=\"text-align: justify;\">Armaduras leves e Escudo&nbsp; +T$ 1500</span></span></p>","chat":"","unidentified":""},"source":"T20, pg. 166 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":3000,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"none","alvo":"","area":"","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":""},"rolls":[],"tipo":"material","uses":{"autoDestroy":false},"origin":"","chatFlavor":"","subtipo":"","tags":[]},"effects":[],"flags":{"cf":{"id":"temp_1oypueabvvx","path":"Equipamentos#/CF_SEP/Materiais Especiais (FINALIZADO)","color":"#000000"}},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664672283730,"modifiedTime":1666309921626,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"QtubHIDfvOyLos29"}
{"name":"Florete","type":"arma","img":"systems/tormenta20/icons/itens/equipamentos/florete.webp","effects":[],"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.r3tlhprPUh8qHesx"},"cf":{"id":"temp_3wrif20qtb","path":"Equipamentos#/CF_SEP/Armas (FINALIZADO)","color":"#000000"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">A l&acirc;mina leve e fina desta espada torna a arma muito precisa. O florete &eacute; uma arma <em>&aacute;gil</em>.</p>","chat":"","unidentified":""},"source":"T20, pg. 148 (JdA)","equipado":0,"carregado":true,"peso":1,"espacos":1,"qtd":1,"preco":20,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","perfuracao",""],["@for","",""]],"versatil":""}],"criticoM":18,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":true,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":true,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"chatFlavor":"","consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"origin":"","tags":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.100","coreVersion":"10.288","createdTime":1664312772422,"modifiedTime":1666309921269,"lastModifiedBy":"tIn9sSkrT3mDWirx"},"folder":null,"sort":0,"ownership":{"default":0,"tIn9sSkrT3mDWirx":3},"_id":"QuLPlO9USnMwgSs8"}

{"_id":"m8Iw8iH1H0OkWeYj","name":"Granada de Névoa","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-granada.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"YJPXaSxyaKsQMBct","core":{"sourceId":"Compendium.tormenta20.pocoes.m8Iw8iH1H0OkWeYj"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Uma n&eacute;voa espessa eleva-se de um ponto a sua escolha, obscurecendo toda a vis&atilde;o &mdash; criaturas a at&eacute; 1,5m t&ecirc;m camuflagem leve e criaturas a partir de 3m t&ecirc;m camuflagem total. Um vento forte dispersa a n&eacute;voa em 4 rodadas e um vendaval a dispersa em 1 rodada. Esta magia n&atilde;o funciona sob a &aacute;gua.</p>","unidentified":""},"source":"T20, pg. 200 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"","area":"nuvem com 6m de raio e 6m de altura","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"potion","chatFlavor":"","origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"encantos":{},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007042,"modifiedTime":1666924579093,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}

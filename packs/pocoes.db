{"_id":"wAbbICpd57DcDV9s","name":"Poção de Visão Mística","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"ftoLBv4EpBqkv4lv","core":{"sourceId":"Compendium.tormenta20.pocoes.wAbbICpd57DcDV9s"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Seus olhos brilham com uma luz azul e passam a enxergar auras m&aacute;gicas. Este efeito &eacute; similar ao uso de Misticismo para detectar magia, mas voc&ecirc; detecta todas as auras m&aacute;gicas em alcance m&eacute;dio e recebe todas as informa&ccedil;&otilde;es sobre elas sem gastar a&ccedil;&otilde;es. Al&eacute;m disso, voc&ecirc; pode gastar uma a&ccedil;&atilde;o de movimento para descobrir se uma criatura que possa perceber em alcance m&eacute;dio &eacute; capaz de lan&ccedil;ar magias e qual a aura gerada pelas magias de c&iacute;rculo mais alto que ela pode lan&ccedil;ar.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007044,"modifiedTime":1666662581661,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}

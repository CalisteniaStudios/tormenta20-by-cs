{"_id":"ApeazL6hVnTroAOz","name":"Poção de Compreensão","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"yIFKWiEHZsBlRudR","core":{"sourceId":"Compendium.tormenta20.pocoes.ApeazL6hVnTroAOz"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Essa magia lhe confere compreens&atilde;o sobrenatural. Voc&ecirc; pode tocar um texto e entender as palavras mesmo que n&atilde;o conhe&ccedil;a o idioma. Se tocar numa criatura inteligente, pode se comunicar com ela mesmo que n&atilde;o tenham um idioma em comum. Se tocar uma criatura n&atilde;o inteligente, como um animal, pode perceber seus sentimentos. Voc&ecirc; tamb&eacute;m pode gastar uma a&ccedil;&atilde;o de movimento para ouvir os pensamentos de uma criatura tocada (voc&ecirc; &ldquo;ouve&rdquo; o que o alvo est&aacute; pensando), mas um alvo involunt&aacute;rio tem direito a um teste de Vontade para proteger seus pensamentos e evitar este efeito.</p>","unidentified":""},"source":"T20, pg. 184 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 criatura ou texto","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula (veja descrição)."},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007035,"modifiedTime":1666924579093,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"LkTy80bVtw0jegr3","name":"Poção de Físico Divino (três atributos)","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"Gluy7zblmGMN4x7z","core":{"sourceId":"Compendium.tormenta20.pocoes.LkTy80bVtw0jegr3"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo se torna uma vers&atilde;o mais poderosa de si mesmo. O alvo recebe +4 em For&ccedil;a, Destreza ou Constitui&ccedil;&atilde;o, a sua escolha. Esse aumento n&atilde;o oferece PV ou PM adicionais.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":1080,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007036,"modifiedTime":1666662581660,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"LnW6eVQyg7hhefHt","name":"Poção de Vitalidade Fantasma","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"ZgilGkxpnLRFD3li","core":{"sourceId":"Compendium.tormenta20.pocoes.LnW6eVQyg7hhefHt"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; suga energia vital da terra, recebendo 2d8 pontos de vida tempor&aacute;rios. Os PV tempor&aacute;rios desaparecem ao final da cena.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"2d8","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d8","",""]],"versatil":""}],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007036,"modifiedTime":1666662581661,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"RYMxcUZXKLWCCSff","name":"Óleo de Alterar Tamanho","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"DKOjpT1k1R8t7sTf","core":{"sourceId":"Compendium.tormenta20.pocoes.RYMxcUZXKLWCCSff"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia aumenta ou diminui o tamanho de um item mundano em at&eacute; tr&ecirc;s categorias (um objeto Enorme vira Pequeno, por exemplo). Voc&ecirc; tamb&eacute;m pode mudar a consist&ecirc;ncia do item, deixando-o r&iacute;gido como pedra ou flex&iacute;vel como seda (isso n&atilde;o altera sua RD ou PV, apenas suas propriedades f&iacute;sicas).</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"special","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007036,"modifiedTime":1666662581657,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"Rfqa9MsOHuXLMg9D","name":"Poção de Metamorfose","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"UAZ8IUCkXrL99jEl","core":{"sourceId":"Compendium.tormenta20.pocoes.Rfqa9MsOHuXLMg9D"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; muda sua apar&ecirc;ncia e forma &mdash; incluindo seu equipamento &mdash; para qualquer outra criatura, existente ou imaginada. Independentemente da forma escolhida, voc&ecirc; recebe +20 em testes de Engana&ccedil;&atilde;o para disfarce. Caracter&iacute;sticas n&atilde;o mencionadas n&atilde;o mudam.</p>\n<p style=\"text-align:justify;\">Se mudar para uma forma humanoide, pode mudar o tipo de dano f&iacute;sico de suas armas (se usa uma ma&ccedil;a e transform&aacute;- la em espada longa, ela pode causar dano de corte, por exemplo). Se quiser, pode assumir uma forma humanoide com uma categoria de tamanho acima ou abaixo da sua; nesse caso aplique os modificadores em Furtividade e testes de manobra.</p>\n<p style=\"text-align:justify;\">Se mudar para outras formas, voc&ecirc; pode escolher uma Forma Selvagem do druida (veja no Cap&iacute;tulo 1). Nesse caso voc&ecirc; n&atilde;o pode atacar com suas armas, falar ou lan&ccedil;ar magias at&eacute; voltar ao normal, mas recebe uma ou mais armas naturais e os b&ocirc;nus da forma selvagem escolhida.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007037,"modifiedTime":1666662581660,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"TrQw6O1ebgl4AGvY","name":"Poção de Curar Ferimentos (2d8+2 PV)","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"vLjabZkJvi8qyRBq","core":{"sourceId":"Compendium.tormenta20.pocoes.TrQw6O1ebgl4AGvY"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada.</p>","unidentified":""},"source":"T20, pg. 189 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"2d8+2","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d8+2","",""]],"versatil":""}],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2
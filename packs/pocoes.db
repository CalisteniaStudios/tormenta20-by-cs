{"_id":"lUvXanXBUKxGOd2M","name":"Óleo de Arma Mágica","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"rg3IVDXFfQ21aY5e","core":{"sourceId":"Compendium.tormenta20.pocoes.lUvXanXBUKxGOd2M"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">A arma fornece +1 nos testes de ataque e rolagens de dano e &eacute; considerada m&aacute;gica (n&atilde;o cumulativo com b&ocirc;nus de encantos). Caso voc&ecirc; esteja empunhando a arma, pode usar seu atributo-chave de magias em vez do atributo original nos testes de ataque (n&atilde;o cumulativo com efeitos que somam este atributo).</p>","unidentified":""},"source":"T20, pg. 181 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 arma","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null}
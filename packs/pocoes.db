{"_id":"02q1pu5Oyj3LtvZx","name":"Poção de Concentração de Combate (cena)","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"vEWUeZsapLe9fyPa","core":{"sourceId":"Compendium.tormenta20.pocoes.02q1pu5Oyj3LtvZx"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; amplia sua percep&ccedil;&atilde;o, antecipando movimentos dos inimigos e achando brechas em sua defesa. Quando faz um ataque, voc&ecirc; rola dois dados e usa o melhor resultado.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007030,"modifiedTime":1666662581658,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"28yPkXVQIVmlfF3W","name":"Óleo de Armamento da Natureza","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"QMcRY4Wtv0GxPKj8","core":{"sourceId":"Compendium.tormenta20.pocoes.28yPkXVQIVmlfF3W"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; fortalece uma arma mundana primitiva (sem custo em T$, como bord&atilde;o, clava, funda ou tacape), uma arma natural ou um ataque desarmado. O dano da arma aumenta em um passo e ela &eacute; considerada m&aacute;gica para prop&oacute;sitos de resist&ecirc;ncia a dano. Ao lan&ccedil;ar a magia, voc&ecirc; pode mudar o tipo de dano da arma (escolhendo entre corte, impacto ou perfura&ccedil;&atilde;o).</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"1 arma (veja texto)","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007030,"modifiedTime":1666662581658,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"4oSYUfK8BYgEP2Ep","name":"Óleo de Vestimenta da Fé","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"grOFLzFB3JJLe1HH","core":{"sourceId":"Compendium.tormenta20.pocoes.4oSYUfK8BYgEP2Ep"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; fortalece uma indument&aacute;ria com o poder de sua f&eacute;. Isso aumenta o b&ocirc;nus de Defesa de uma armadura ou escudo em +2 (isso &eacute; uma melhoria no item, portanto &eacute; cumulativa com outras magias). No caso de um traje, ele passa a oferecer +2 na Defesa e continua contando como se voc&ecirc; n&atilde;o estivesse usando armadura.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"special","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007031,"modifiedTime":1666662581658,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"5SnRRfXhW6BiJ5h0","name":"Poção de Camuflagem llusória","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"h2XYk6iU2BzXyThe","core":{"sourceId":"Compendium.tormenta20.pocoes.5SnRRfXhW6BiJ5h0"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo fica com sua imagem nublada, como se vista atrav&eacute;s de um l&iacute;quido, recebendo os efeitos de camuflagem.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007031,"modifiedTime":1666662581658,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"5sxPQieeeYZYbJAZ","name":"Óleo de Abençoar Alimentos","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"BUzpwb4EBL6WLcBv","core":{"sourceId":"Compendium.tormenta20.pocoes.5sxPQieeeYZYbJAZ"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; purifica e aben&ccedil;oa uma por&ccedil;&atilde;o de comida ou dose de bebida. Isso torna um alimento sujo, estragado ou envenenado pr&oacute;prio para consumo. Al&eacute;m disso, se for consumido at&eacute; o final da dura&ccedil;&atilde;o, o alimento oferece 5 PV tempor&aacute;rios ou 1 PM tempor&aacute;rio (al&eacute;m de quaisquer b&ocirc;nus que j&aacute; oferecesse). B&ocirc;nus de alimenta&ccedil;&atilde;o duram um dia e cada personagem s&oacute; pode receber um b&ocirc;nus de alimenta&ccedil;&atilde;o por dia.</p>","unidentified":""},"source":"T20, pg. 178 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"potion","chatFlavor":"","origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"encantos":{},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007031,"modifiedTime":1666924579093,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"6olGswsHYsq8aiGw","name":"Óleo de Arma Mágica (+3)","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"UcMbfH4Xfbqv4TfR","core":{"sourceId":"Compendium.tormenta20.pocoes.6olGswsHYsq8aiGw"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">A arma fornece um b&ocirc;nus de +3 nos testes de ataque e rolagens de dano e &eacute; considerada m&aacute;gica. Caso voc&ecirc; esteja empunhando a arma, pode usar seu atributo-chave de magias em vez do atributo original nos testes de ataque.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":750,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 arma","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007032,"modifiedTime":1666662581658,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"7MWQRNmlsHSYPZT1","name":"Poção de Velocidade","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"9kItCwvT9pYqwJlw","core":{"sourceId":"Compendium.tormenta20.pocoes.7MWQRNmlsHSYPZT1"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo pode realizar uma a&ccedil;&atilde;o padr&atilde;o ou de movimento adicional por turno. Esta a&ccedil;&atilde;o n&atilde;o pode ser usada para lan&ccedil;ar magias e ativar engenhocas.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"potion","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007032,"modifiedTime":1666662581661,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"8MZOwDXGchwZ0Jkp","name":"Poção de Mente Divina","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"ER5eNh1d0nfbz8l8","core":{"sourceId":"Compendium.tormenta20.pocoes.8MZOwDXGchwZ0Jkp"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; traz inspira&ccedil;&atilde;o divina &agrave; mente do alvo. Escolha entre Intelig&ecirc;ncia, Sabedoria ou Carisma. O alvo recebe +4 no atributo escolhido. Esse aumento n&atilde;o oferece PV, PM ou per&iacute;cias adicionais.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007032,"modifiedTime":1666662581660,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"8zETItgIUrQgW0ck","name":"Poção de Purificação","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"6JMxVrEE4vYD062E","core":{"sourceId":"Compendium.tormenta20.pocoes.8zETItgIUrQgW0ck"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Seu toque purifica a criatura tocada. Esta magia remove uma das seguintes condi&ccedil;&otilde;es: abalado, apavorado, alquebrado, atordoado, cego, confuso, debilitado, enjoado, envenenado, esmorecido, exausto, fascinado, fatigado, fraco, frustrado, lento, ofuscado, paralisado, pasmo ou surdo.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007033,"modifiedTime":1666662581660,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"9FkEtT2rpDxBZmEQ","name":"Poção de Disfarce Ilusório","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"jOAFrC7nRUcwP1Nv","core":{"sourceId":"Compendium.tormenta20.pocoes.9FkEtT2rpDxBZmEQ"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; muda a apar&ecirc;ncia do alvo, incluindo seu equipamento. Isso inclui altura, peso, tom de pele, cor de cabelo, timbre de voz etc. O alvo recebe +10 em testes de Engana&ccedil;&atilde;o para disfarce. O alvo n&atilde;o recebe novas habilidades (voc&ecirc; pode ficar parecido com outra ra&ccedil;a, mas n&atilde;o ganhar&aacute; as habilidades dela), nem modifica o equipamento (uma espada longa disfar&ccedil;ada de bord&atilde;o continua funcionando e causando dano como uma espada).</p>","unidentified":""},"source":"T20, pg. 191 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade desacredita"},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007034,"modifiedTime":1666924579093,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"A4wH7EMrKzOtlt3Q","name":"Poção de Primor Atlético","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"a1iRT1U0lGhjjOP7","core":{"sourceId":"Compendium.tormenta20.pocoes.A4wH7EMrKzOtlt3Q"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; modifica os limites f&iacute;sicos do alvo, que recebe deslocamento +9m e +10 em testes de Atletismo.</p>","unidentified":""},"source":"T20, pg. 201 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"subtipo":""},"ownership":{"default":0},"_stats":{"system
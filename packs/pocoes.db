{"_id":"WrtZs4ql74DKHLKm","name":"Poção de Resistência a Energia","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"4lzrFnC7eC9UQLcB","core":{"sourceId":"Compendium.tormenta20.pocoes.WrtZs4ql74DKHLKm"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Ao lan&ccedil;ar esta magia, escolha entre &aacute;cido, eletricidade, fogo, frio, luz ou trevas. O alvo recebe redu&ccedil;&atilde;o de dano 10 contra o tipo de dano escolhido.</p>","unidentified":""},"source":"T20, pg. 204 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","
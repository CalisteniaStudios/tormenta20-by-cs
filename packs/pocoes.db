{"_id":"XgRYUChRMmaCzVdw","name":"Granada de Área Escorregadia","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-granada.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"mnnGRo0lz2sjIzli","core":{"sourceId":"Compendium.tormenta20.pocoes.XgRYUChRMmaCzVdw"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia recobre uma superf&iacute;cie com uma subst&acirc;ncia gordurosa e escorregadia. Criaturas na &aacute;rea devem passar na resist&ecirc;ncia para n&atilde;o cair. Nas rodadas seguintes, criaturas que tentem movimentar- se pela &aacute;rea devem fazer testes de Acrobacia para equil&iacute;brio (CD 10). &Aacute;rea Escorregadia pode tornar um item escorregadio. Uma criatura segurando um objeto afetado deve passar na resist&ecirc;ncia para n&atilde;o deixar o item cair cada vez que us&aacute;-lo.</p>","unidentified":""},"source":"T20, pg. 180 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"ou","alcance":"short","alvo":"","area":"Quadrado de 3m ou 1 objeto","resistencia":{"pericia":"","atributo":"","bonus":0,"txt":"Reflexos (veja texto)"},"rolls":[],"tipo":"potion","chatFlavor":"","origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"encantos":{},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007038,"modifiedTime":1666924579092,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"YrcnZsYGhSYovuVN","name":"Poção de Suporte Ambiental","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"otT1phmWJx5SP0Bv","core":{"sourceId":"Compendium.tormenta20.pocoes.YrcnZsYGhSYovuVN"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia garante a sobreviv&ecirc;ncia em ambientes hostis. O alvo fica imune aos efeitos de calor e frio extremos, pode respirar na &aacute;gua se respirar ar (ou vice-versa) e n&atilde;o sufoca em fuma&ccedil;a densa.</p>","unidentified":""},"source":"T20, pg. 207 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"special","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007038,"modifiedTime":1666924579094,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"ZYU4TTCb2Eod8CyD","name":"Poção de Aparência Perfeita","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"p2csjjUHvaKo0D8T","core":{"sourceId":"Compendium.tormenta20.pocoes.ZYU4TTCb2Eod8CyD"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia lhe concede um rosto idealizado, porte f&iacute;sico garboso, voz melodiosa e olhar sedutor, deixando-o mais atraente e confi&aacute;vel. Enquanto a magia estiver ativa, seu Carisma torna-se 20 (ou recebe um b&ocirc;nus de +4, caso seja 20 ou maior) e voc&ecirc; recebe +5 nos testes de Diplomacia e Engana&ccedil;&atilde;o. Quando a magia acaba, quaisquer observadores percebem a mudan&ccedil;a e tendem a suspeitar de voc&ecirc;. Da mesma maneira, pessoas que o viram sob o efeito da magia sentir&atilde;o que &ldquo;algo est&aacute; errado&rdquo; ao v&ecirc;-lo em condi&ccedil;&otilde;es normais. Quando a cena acabar, voc&ecirc; pode gastar os PM da magia novamente como uma a&ccedil;&atilde;o livre para mant&ecirc;-la ativa. Este efeito n&atilde;o fornece PV ou PM adicionais.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007038,"modifiedTime":1666662581658,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"cF4QKw8RShT0h7O7","name":"Óleo de Escuridão","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"e47vDMjn1gUylju9","core":{"sourceId":"Compendium.tormenta20.pocoes.cF4QKw8RShT0h7O7"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">O alvo emana sombras em uma &aacute;rea com 6m de raio. Criaturas dentro da &aacute;rea recebem camuflagem leve por escurid&atilde;o leve. As sombras n&atilde;o podem ser iluminadas por nenhuma fonte de luz natural. O objeto pode ser guardado (em um bolso, por exemplo) para interromper a escurid&atilde;o, que voltar&aacute; a funcionar caso o objeto seja revelado. Se lan&ccedil;ar a magia num objeto de uma criatura involunt&aacute;ria, ela tem direito a um teste de Vontade para anul&aacute;-la. Escurid&atilde;o anula Luz.</p>","unidentified":""},"source":"T20, pg. 193 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 alvo","area":"6m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula (veja texto)"},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"subtipo":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007039,"modifiedTime":1666924579093,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"cLTZXcoMq9C8oNpB","name":"Poção de Escudo da Fé (cena)","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"TzVFigI9tao5A35P","core":{"sourceId":"Compendium.tormenta20.pocoes.cLTZXcoMq9C8oNpB"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Um escudo m&iacute;stico se manifesta momentaneamente para bloquear um golpe. O alvo recebe +2 na Defesa.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007039,"modifiedTime":1666662581659,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"denQPHbRznsXm0uy","name":"Poção de Voz Divina","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"A1DUSOQ1hqvUqKoN","core":{"sourceId":"Compendium.tormenta20.pocoes.denQPHbRznsXm0uy"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; pode conversar com criaturas de qualquer ra&ccedil;a e tipo: animal, construto, esp&iacute;rito, humanoide, monstro ou morto-vivo. Pode fazer perguntas e entende suas respostas, mesmo sem um idioma em comum ou se a criatura n&atilde;o for capaz de falar, mas respeitando os limites da Intelig&ecirc;ncia dela. A atitude dessas criaturas n&atilde;o &eacute; alterada, mas voc&ecirc; pode usar a per&iacute;cia Diplomacia para tentar mudar sua atitude.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":270,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007039,"modifiedTime":1666662581661,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"fFpSZAPGZDUVJNOG","name":"Poção de Enfeitiçar","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"EWy6g3IJ51M7z3G0","core":{"sourceId":"Compendium.tormenta20.pocoes.fFpSZAPGZDUVJNOG"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo da poção fica enfeitiçado pela primeira criatura que enxergar.</p><p style=\"text-align:justify;\">Esta magia torna o alvo prestativo (veja a p&aacute;gina 118). Ele n&atilde;o fica sob seu controle, mas percebe suas palavras e a&ccedil;&otilde;es da maneira mais favor&aacute;vel poss&iacute;vel. Voc&ecirc; recebe um b&ocirc;nus de +10 em testes de Diplomacia com a v&iacute;tima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resist&ecirc;ncia. Se voc&ecirc; ou seus aliados tomarem qualquer a&ccedil;&atilde;o hostil contra o alvo, a magia &eacute; dissipada e o alvo retorna &agrave; atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"1 humanoide","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314007040,"modifiedTime":1666662581659,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"ffDA6IdF1QAMWu8L","name":"Óleo de Tranca Arcana","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/pocao-oleo.webp","effects":[],"folder":null,"sort":0,"flags":{"importid":"xqzpBKr1mwiyoxFv","core":{"sourceId":"Compendium.tormenta20.pocoes.ffDA6IdF1QAMWu8L"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia tranca uma porta ou outro item que possa ser aberto ou fechado (como um ba&uacute;, caixa etc.), aumentando a CD de testes de For&ccedil;a ou Ladinagem para abri-lo em +10. Voc&ecirc; pode abrir livremente sua pr&oacute;pria tranca sem problemas.</p>","unidentified":""},"source":"T20, pg. 209 (JdA)","carregado":true,"peso":0.5,"espacos":0.5,"qtd":1,"preco":30,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"action","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"special","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 objeto Grande ou menor","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"ammo","chatFlavor":"","melhorias":{"accurate":null,"pungent":null,"cruel":null,"atrocious":null,"balanced":null,"harmonized":null,"injection":null,"massive":null,"specialmaterial":null,"scope":null,"precise":null,"golden":null,"gems":null,"discreet":null,"macabre":null},"encantos":{"keen":null,"bane":null,"throwable":null,"assassin":null,"seeking":null,"frost":null,"caster":null,"corrosive":null,"dancing":null,"defending":null,"destructive":null,"lacerating":null,"draining":null,"shock":null,"energy":null,"excruciating":null,"flaming":null,"formidable":null,"lancinating":null,"magnificent":null,"merciful":null,"unholy":null,"holy":null,"bloodthirsty":null,"thundering":null,"sepulchral":null,"speed":null,"poisonous":null},"origin":"","tags":[],"chatGif":"","upgrades":{"melhoria1"
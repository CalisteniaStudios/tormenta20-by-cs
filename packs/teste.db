{"name":"Seta Infalível","permission":{"default":0,"00oJEM7kMYaaklHr":3},"type":"magia","data":{"description":"Favorita entre arcanistas iniciantes, esta magia lança duas setas de energia que causando 1d4+1 pontos de dano de essência cada. Você pode lançar as setas em alvos diferentes ou concentrá-las num mesmo alvo. Caso você possua um bônus no dano de magias, como pelo poder Arcano de Batalha, ele é aplicado em apenas uma seta (o bônus vale para a magia, não cada alvo).","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"d8","description":"muda as setas para lanças de energia que surgem e caem do céu. Cada lança causa 1d8+1 pontos de dano de essência. Requer 2o círculo.","_id":"","id":"4f1993d0-d011-44e3-9a85-79faa0fd0f88","ativo":false},{"custo":"2","tipo":"Muda","formula":"3d4+3","description":"muda o número de setas/lanças para três.","_id":"","id":"7fe88142-9665-4a86-8eba-ac6578774a46","ativo":false},{"custo":"4","tipo":"Muda","formula":"5d4+5","description":"muda o número de setas/lanças para cinco. Requer 2o círculo.","_id":"","id":"17af8e12-bf58-43e6-8c99-e09778a6bd42","ativo":false},{"custo":"9","tipo":"Muda","formula":"10d4+10","description":"muda o número de setas/lanças para dez. Requer 4o círculo.","_id":"","id":"602c207c-17c5-442a-ba6b-c67eb1edafa2","ativo":false}],"alcance":"Médio","alvo":"até 2 criaturas","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Evocação","efeito":"2d4+2","execucao":"_deprecated","custo":"_deprecated"},"flags":{"core":{"sourceId":"Item.MXN6umhJ8krpE1QT"}},"img":"systems/tormenta20/icons/magias/seta-infalivel.webp","effects":[{"_id":"VYBI9Lb4yiHEuKZJ","flags":{"onuse":true,"t20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"2","durationScene":false}},"changes":[{"key":"roll","value":"d8
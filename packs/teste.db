}],"disabled":false,"duration":{"startTime":null,"seconds":86400,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"systems/tormenta20/icons/magias/vestimenta-da-fe.webp","label":"Vestimenta da Fé - Armadura/Traje","origin":"Item.NZqzbFxdi5rQhO04","tint":"","transfer":false}],"_id":"RqNhj0MwrUwWuMb5"}
{"name":"Curar Ferimentos","permission":{"default":0,"00oJEM7kMYaaklHr":3},"type":"magia","data":{"description":"Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.\n\n","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"-","description":"em vez do normal, estabiliza uma criatura.","_id":"","id":"8ec8bbe2-b543-401a-a115-7f390f3c4ed3","ativo":false},{"custo":"0","tipo":"Truque","formula":"1d8","description":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","_id":"","id":"b18deddf-a288-4e58-aad7-d26a1af32780","ativo":false},{"custo":"1","tipo":"Aumenta","formula":"1d8+1","description":"aumenta a cura em +1d8+1.","_id":"","id":"8f1b2389-8976-4575-8851-d726d7042fba","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"também remove uma condição de fadiga do alvo.","_id":"","id":"c526f528-0e2d-4058-b268-e0585516c228","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para curto.","_id":"","id":"d96838f2-e083-4a61-b7ef-e0de354fefc8","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para curto e o alvo para criaturas escolhidas.","_id":"","id":"7179b5d9-b224-4fa7-a2a3-35378434efbc","ativo":false},{"custo":"2","tipo":"Muda","ativo":false,"formula":"d10","description":"Aumenta a cura para d10","id":"99b91cc6-75d4-4999-8113-1dac744c530b","_id":""},{"custo":"0","tipo":"Aumenta","ativo":false,"formula":"+1","description":"Aspecto da primavera","id":"6cefac6f-0929-4572-9dfb-a92a8554c2d5","_id":""}],"alcance":"Toque","alvo":"1 criatura","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"int","cd":0,"tipo":"Divina","circulo":"1","preparada":false,"escola":"Evocação","e
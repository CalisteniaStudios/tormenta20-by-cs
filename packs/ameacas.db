tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"dano","value":"1d8+1","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a cura em +1d8+1.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false,"tint":null},{"_id":"xncd3c6sRimZD4nY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"também remove uma condição de fadiga do alvo.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false,"tint":null},{"_id":"8NiPKz2Ks17aIGcT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false,"tint":null},{"_id":"lcjBzJa7QT1xtM5I","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5,"priority":null},{"key":"alvo","value":"criaturas escolhidas","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"2d8+2","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d8+2","",""]],"versatil":""}],"tipo":"div","circulo":"1","preparada":false,"escola":"evo","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"CrlRqw6XyHHOi0lc","name":"Enfeitiçar","type":"magia","sort":1300001,"flags":{"core":{"sourceId":"Item.ARP9yn6keaH9aNKt"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/enfeiticar.webp","effects":[{"_id":"wuyNqXeAYnTZxLx7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"dxAz8LEQoWisbo0a","name":"Dissipar Magia","type":"magia","sort":1100001,"flags":{"core":{"sourceId":"Item.LnZpwedvAkmScrZG"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/dissipar-magia.webp","effects":[{"_id":"kKZ6L0mhMN53y13e","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"area","value":"esfera com 9m de raio","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5º círculo.","origin":"Compendium.tormenta20.magias.rfTGYwrXLjcIAIP5","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você dissipa outras magias que estejam ativas, como se sua duração tivesse acabado. Note que efeitos de magias instantâneas não podem ser dissipados (não se pode dissipar uma Bola de Fogo ou Relâmpago depois que já causaram dano...). Se lançar essa magia em uma criatura ou área, faça um teste de Misticismo; você anula as magias com CD igual ou menor que o resultado do teste. Se lançada contra um item mágico, o transforma em um item mundano por 1d6 rodadas (sem teste de resistência).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"medium","alvo":"1 criatura ou 1 objeto mágico ou esfera com 3m de raio","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"abj","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WqSil1VVS1FgBEma","name":"Velocidade","type":"magia","sort":1400001,"flags":{"core":{"sourceId":"Item.MtmFzJIsEiXnAzhU"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/velocidade.webp","effects":[{"_id":"lYxiSwCe3djsAOE6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas no alcance","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas no alcance. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false,"tint":null},{"_id":"wb7wmP9NbM1Q2Bxg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5,"priority":null},{"key":"alvo","value":"você","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para você. Você acelera sua mente, além de seu corpo. A ação adicional pode ser usada para lançar magias e ativar engenhocas. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo pode realizar uma ação padrão ou de movimento adicional por turno. Esta ação não pode ser usada para lançar magias e ativar engenhocas.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"9jAXys7BRV2ddq67","name":"Globo de Invulnerabilidade","type":"magia","sort":300001,"flags":{"core":{"sourceId":"Item.MPYbDZ1cP0y6Ju9Z"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/globo-de-invulnerabilidade.webp","effects":[{"_id":"ISjEFb9TeFb2uUPU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para afetar magias de até 3º círculo. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.CuGpzSLGUTtD7TLq","transfer":false,"tint":null},{"_id":"S0J0CYNGoCjJHcOH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para afetar magias de até 4º círculo. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.CuGpzSLGUTtD7TLq","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você é envolto por uma esfera mágica brilhante com 3m de raio, que detém qualquer magia de 2º círculo ou menor. Nenhuma magia pode ser lançada contra um alvo dentro do globo e magias de área não o penetram. No entanto, magias ainda podem ser lançadas de dentro para fora. Dissipar Magia só dissipa o globo se for usada diretamente sobre você, não o afetando se usada em área. Efeitos mágicos não são dissipados quando entram na esfera, apenas suprimidos (voltam a funcionar fora do globo, caso sua duração não tenha acabado). O globo é imóvel e não tem efeito sobre criaturas ou objetos. Após lançá-lo, você pode entrar ou sair livremente.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"abj","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"NEemCi5LvDyYEVYA","name":"Metamorfose","type":"poder","sort":2000001,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Um drag&atilde;o pode se transformar em outras criaturas, como a magia Metamorfose. Eles costumam usar esta habilidade para se infiltrar em sociedades humanoides, aprender sobre seus costumes ou apenas quando n&atilde;o querem ser reconhecidos. Um drag&atilde;o morto reverte &agrave; sua forma original.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[],"tipo":"classe","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":100001,"flags":{"exportSource":{"world":"andreverse-t20","system":"tormenta20","coreVersion":"0.6.6","systemVersion":"0.9.71"},"editing":false,"tormenta20":{"sheet":{},"lvlconfig":{"pv":{},"pm":{}},"version":"1.3.0.0"},"core":{"sourceId":"Compendium.tormenta20.ameacas.eHAHgDlAXql7oMgP"}},"system":{"atributos":{"for":{"value":37,"bonus":0,"base":13,"racial":0},"des":{"value":13,"bonus":0,"base":1,"racial":0},"con":{"value":27,"bonus":0,"base":8,"racial":0},"int":{"value":19,"bonus":0,"base":4,"racial":0},"sab":{"value":19,"bonus":0,"base":4,"racial":0},"car":{"value":16,"bonus":0,"base":3,"racial":0}},"attributes":{"cd":18,"pv":{"value":306,"min":-500,"max":306,"temp":0},"pm":{"value":21,"min":0,"max":21,"temp":0},"movement":{"burrow":0,"climb":0,"fly":24,"swim":0,"walk":12,"unit":"m","hover":false},"defesa":{"base":36,"value":37,"outros":0,"atributo":"des","pda":0,"bonus":["0"],"condi
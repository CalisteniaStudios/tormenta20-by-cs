ps://i.imgur.com/vmKGLjd.png","tint":null,"scaleX":1,"scaleY":1,"offsetX":0,"offsetY":0,"rotation":0},"sight":{"angle":360,"enabled":true,"range":30,"brightness":1,"visionMode":"basic","color":null,"attenuation":0.1,"saturation":0,"contrast":0},"detectionModes":[]},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.002","coreVersion":"10.283","createdTime":1661997945970,"modifiedTime":1661997973462,"lastModifiedBy":"izTN2S0Mlytej3sI"}}
{"_id":"XxD1i2mq6QdiJmzP","name":"Engenho de Guerra Goblin","type":"npc","img":"systems/tormenta20/icons/ameacas/engenho.webp","items":[{"_id":"F6U9EBLCK5k7cThb","name":"Arsenal de Engenhocas","type":"poder","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O engenho de guerra possui v&aacute;rias engenhocas operadas por sua fren&eacute;tica tripula&ccedil;&atilde;o. Sempre que esta habilidade &eacute; usada, role [[/r 1d6]] quatro vezes. O resultado de cada dado indica qual engenhoca &eacute; ativada. Resultados repetidos s&atilde;o desperdi&ccedil;ados &mdash; isso significa que mais de um goblin tentou usar uma mesma engenhoca, perdendo sua a&ccedil;&atilde;o. <br /><br /><strong>1) Canh&atilde;o el&eacute;trico. </strong>O engenho dispara um raio em uma linha com alcance m&eacute;dio. Criaturas na &aacute;rea sofrem 8d8 pontos de dano de eletricidade (Reflexos CD 23 reduz &agrave; metade).</p>\n<p style=\"text-align:justify;\"><strong>2) Balestra &aacute;cida. </strong>O engenho dispara um virote de &aacute;cido em uma criatura em alcance m&eacute;dio. O alvo sofre 8d6 pontos de dano de &aacute;cido e fica coberto por muco corrosivo, sofrendo 8d6 pontos de dano de &aacute;cido no in&iacute;cio de seu pr&oacute;ximo turno (Reflexos CD 23 reduz &agrave; metade e evita o muco).</p>\n<p style=\"text-align:justify;\"><strong>3) Foles. </strong>O engenho dispara labaredas em um cone de alcance curto. Criaturas na &aacute;rea sofrem 6d6 pontos de dano de fogo e ficam em chamas (Reflexos CD 23 reduz &agrave; metade e evita as chamas).</p>\n<p style=\"text-align:justify;\"><strong>4) L&acirc;mina girat&oacute;ria. </strong>O engenho faz um ataque corpo a corpo em cada criatura adjacente (ataque +20, dano 4d6+10, 19, corte).</p>\n<p style=\"text-align:justify;\"><strong>5) Po&ccedil;a de &oacute;leo. </strong>O engenho vaza &oacute;leo escorregadio e inflam&aacute;vel. Todas as criaturas em alcance curto ficam vulner&aacute;veis a fogo at&eacute; se limparem (o que exige uma a&ccedil;&atilde;o completa) e caem no ch&atilde;o. Um teste de Reflexos contra CD 23 evita ambos os efeitos.</p>\n<p style=\"text-align:justify;\"><strong>6) Reparos emergenciais. </strong>O engenho recupera 20 PV</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["1d6",""]]}],"tipo":"classe","subtipo":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"1d6","chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"oIO0jaKHvjmPtSMJ","name":"Tripulação","type":"poder","sort":200000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"Se o engenho de guerra for destruído, 1d6 goblins salteadores escapam de seus escombros e surgem no início da rodada seguinte.","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"",
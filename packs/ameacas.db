","atrDan":"0","dano":"1d4","atqBns":"20","danoBns":"4","criticoM":19,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":true,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":true,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"systems/tormenta20/icons/itens/adaga.webp","effects":[]},{"_id":"winOZp4g9sU6TzJV","name":"Ataque Furtivo","type":"poder","data":{"description":"<p><br />Uma vez por rodada, a cultista da trai&ccedil;&atilde;o causa +[[/r 5d6]] pontos de dano com ataques corpo a corpo, ou &agrave; dist&acirc;ncia em alcance curto, contra alvos desprevenidos ou que ela esteja flanqueando.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"5d6","tipo":"classe","subtipo":"","chatFlavor":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"jgyeFCeJPx9sg89q","name":"Olhar Atordoante","type":"poder","data":{"description":"A cultista força uma criatura em alcance curto a fazer um teste de Fortitude (CD 22). Se a criatura falhar, fica atordoada por 1 rodada. Se passar, fica imune a esta habilidade por um dia.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"movimento","custo":"1","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"vRPbQJMY9x5NBgnv","name":"Veneno de Medusa","type":"poder","data":{"description":"<p><br />[[/r 2d12]] pontos de dano por rodada durante [[/r 2d4]] rodadas (Fort CD 23 reduz &agrave; metade).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"2d12","tipo":"classe","subtipo":"","chatFlavor":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"TKnUKvKsfajyLI2D","name":"Arma Mágica","type":"magia","data":{"description":"<p style=\"text-align: justify;\">A arma fornece um b&ocirc;nus de +1 nos testes de ataque e rolagens de dano e &eacute; considerada m&aacute;gica. Caso voc&ecirc; esteja empunhando a arma, pode usar seu atributo-chave de magias em vez do atributo original nos testes de ataque.</p>","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","_id":"","id":"d237dacd-e691-4a93-a6df-19f38c7a3582","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"a arma passa a causar +1d6 de dano de ácido, eletricidade, fogo ou frio, escolhido no momento em que a magia é lançada.","_id":"","id":"0913741d-c3bf-492f-8483-ddf9fb990477","ativo":false}],"alcance":"Toque","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 arma","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"","atrRes":"sab","cd":0,"tipo":"Universal","circulo":"1","preparada":false,"escola":"Transmutação","efeito":""},"sort":500000,"flags":{"core":{"sourceId":"Item.GHPogramaHOYtMYH"}},"img":"systems/tormenta20/icons/magias/arma-magica.webp","effects":[{"_id":"CsxccmtGU6cmoFwn","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.pericias.ataque","value":"+1","mode":2},{"key":"data.modificadores.dano.geral","value":"+1","mode":2}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","origin":"Item.N0VolSuZqafQ4qdh","tint":"","transfer":false},{"_id":"2B720KAGoTazOT5e","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.dano.geral","value":"+1d6","mode":2}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"a arma passa a causar +1d6 de dano de ácido, eletricidade, fogo ou frio, escolhido no momento em que a magia é lançada.","origin":"Item.N0VolSuZqafQ4qdh","tint":"","transfer":false},{"_id":"85lRgNinVfaYI51X","flags":{"t20":{"onuse":false,"durationScene":true}},"changes":[{"key":"data.modificadores.pericias.ataque","value":"+1","mode":2},{"key":"data.modificadores.dano.geral","value":"+1","mode":2}],"disabled":false,"duration":{"startTime":null,"seconds":null,"rounds":999,"turns":null,"startRound":null,"startTurn":null},"icon":"systems/tormenta20/icons/magias/arma-magica.webp","label":"Arma Mágica","origin":"Item.N0VolSuZqafQ4qdh","tint":"","transfer":false}]},{"_id":"u8dm4X03xi1HepOB","name":"Comando","type":"magia","data":{"description":"<p>Você dá uma ordem irresistível, que o alvo deve ser capaz de ouvir (mas não precisa entender). Se falhar na resistência, ele deve obedecer ao comando em seu próprio turno da melhor maneira possível. Escolha um dos efeitos.</p><p><i>Fuja:</i> o alvo gasta seu turno se afastando de você (usando todas as suas ações).</p><p><i>Largue:</i> o alvo solta quaisquer itens que esteja segurando e não pode pegá-los novamente até o início de seu próximo turno. Como esta é uma ação livre, ele ainda pode executar outras ações (exceto pegar aquilo que largou).</p><p><i>Pare:</i> o alvo fica pasmo (não pode fazer ações, exceto reações).</p><p><i>Senta:</i> com uma ação livre, o alvo senta no chão (se estava pendurado ou voando, desce até o chão). Ele pode fazer outras ações, mas não se levantar até o início de seu próximo turno. </p><p><i>Venha:</i> o alvo gasta seu turno se aproximando de você (usando todas as suas ações).</p>","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura.","_id":"","id":"e525b111-4d4d-4bbc-86bb-7aabe0670f8b","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta a quantidade de alvos em +1","_id":"","id":"f7f61147-efcc-4acd-b19b-e70812260cfe","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 humanóide","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"1 rodada","unidade":"outra"},"resistencia":"Vontade anula","atrRes":"sab","cd":0,"tipo":"Divina","circulo":"1","preparada":false,"escola":"Encantamento","efeito":""},"sort":600000,"flags":{"core":{"sourceId":"Item.DClEXhRqbdmK0hPw"}},"img":"systems/tormenta20/icons/magias/comando.webp","effects":[{"_id":"goAzE0oaWGOVE9Gm","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false},{"_id":"UuprzsbsDv72xAxP","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta a quantidade de alvos em +1","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false}]},{"_id":"oG7LEqMihxxNTZfp","name":"Curar Ferimentos","type":"magia","data":{"description":"<p>Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.</p>","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"em vez do normal, estabiliza uma criatura.","_id":"","id":"8ec8bbe2-b543-401a-a115-7f390f3c4ed3","ativo":false},{"custo":"0","tipo":"Truque","formula":"","description":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","_id":"","id":"b18deddf-a288-4e58-aad7-d26a1af32780","ativo":false},{"custo":"1","tipo":"Aumenta","formula":"1d8+1","description":"aumenta a cura em +1d8+1.","_id":"","id":"8f1b2389-8976-4575-8851-d726d7042fba","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"também remove uma condição de fadiga do alvo.","_id":"","id":"c526f528-0e2d-4058-b268-e0585516c228","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para curto.","_id":"","id":"d96838f2-e083-4a61-b7ef-e0de354fefc8","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para curto e o alvo para criaturas escolhidas.","_id":"","id":"7179b5d9-b224-4fa7-a2a3-35378434efbc","ativo":false}],"alcance":"Toque","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 criatura","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"sab","cd":0,"tipo":"Divina","circulo":"1","preparada":false,"escola":"Evocação","efeito":"2d8+2"},"sort":700000,"flags":{"core":{"sourceId":"Item.galK4UUS6FxYz22S"}},"img":"systems/tormenta20/icons/magias/curar-ferimentos.webp","effects":[{"_id":"iwzkb3ErKCkqeI1D","flags":{"t20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, estabiliza uma criatura.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"E5Ynb8D45IFPkqGc","flags":{"t20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alvo","value":"1 morto-vivo","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"T7W1dpep8KKLNdPQ","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"roll","value":"1d8+1","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta a cura em +1d8+1.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"xncd3c6sRimZD4nY","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"também remove uma condição de fadiga do alvo.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"8NiPKz2Ks17aIGcT","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"lcjBzJa7QT1xtM5I","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false}]},{"_id":"7MoDf8WiwRRTklwf","name":"Escuridão","type":"magia","data":{"description":"<p>O alvo emana sombras em uma área com 6m de raio. Criaturas dentro da área recebem camuflagem por escuridão. As sombras não podem ser iluminadas por nenhuma fonte de luz natural. O objeto pode ser guardado (em um bolso, por exemplo) para interromper a escuridão, que voltará a funcionar caso o objeto seja revelado. Se lançar a magia num objeto de uma criatura involuntária, ela tem direito a um teste de Vontade para anulá-la. Escuridão anula Luz.</p>","aprimoramentos":[{"custo":"1","tipo":"Aumenta","formula":"","description":"aumenta a área da escuridão em +1,5m de raio.","_id":"","id":"6e91d427-3d2b-4d9f-a0ee-663dbaff1946","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o efeito para fornecer camuflagem total por escuridão.","_id":"","id":"7ecb20e2-3c7e-4ee0-99c9-ba946a75f94d","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia.","_id":"","id":"bc5c1c57-41d1-4324-b61a-0c2c8e086cb4","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura e a resistência para Fortitude parcial. Você lança a magia nos olhos do alvo, que fica cego pela cena. Se passar na resistência, fica cego por 1 rodada. Requer 2º círculo.","_id":"","id":"f1f28cab-5c31-411c-ad5d-d2ce45f7caee","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para pessoal e o alvo para você. Em vez do normal, você é coberto por sombras, recebendo +10 em testes de Furtividade e camuflagem por escuridão. Requer 2º círculo.","_id":"","id":"a09ad58f-4421-4d1e-baab-7cddac66ff04","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 objeto","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade anula (veja texto)","atrRes":"sab","cd":0,"tipo":"Universal","circulo":"1","preparada":false,"escola":"Necromancia","efeito":""},"sort":
","unidentified":""},"source":"","ativacao":{"execucao":"free","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["1d20+29","",""]],"versatil":""}],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WHkxeD2MnBwO3ygV","name":"Aura de Calor","type":"poder","sort":300000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Quando enfurecida, esta criatura emana um calor intenso. No in&iacute;cio de cada turno da centopeia-drag&atilde;o, todas as criaturas em alcance curto sofrem [[/r 4d6+9]] pontos de dano de fogo.</p>","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["4d6+9","",""]],"versatil":""}],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"UhfILDsyLh3rbdzp","name":"Engolir","type":"poder","sort":400000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Se a centopeia-drag&atilde;o come&ccedil;ar seu turno agarrando uma criatura M&eacute;dia ou menor, poder&aacute; fazer um teste de agarrar contra ela. Se vencer, engole a criatura. Uma criatura engolida continua agarrada e sofre [[/r 2d6+12]] pontos de dano de impacto, mais [[/r 4d6+9]] pontos de dano de fogo, no in&iacute;cio de cada turno da centopeia-drag&atilde;o. Uma criatura engolida pode escapar causando 20 pontos de dano ao est&ocirc;mago da centopeia-drag&atilde;o (Defesa 10). Isso faz com que a criatura seja regurgitada e fique ca&iacute;da na frente da centopeia-drag&atilde;o.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d6+12","",""]],"versatil":""}],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":100001,"flags":{"editing":false,"tormenta20":{"sheet":{},"lvlconfig":{"pv":{},"pm":{}},"version":"1.3.0.0"},"core":{"sourceId":"Compendium.tormenta20.ameacas.pjva1IeZE58nGNxn"}},"system":{"atributos":{"for":{"value":35,"bonus":0,"base":12,"racial":0},"des":{"value":17,"bonus":0,"base":3,"racial":0},"con":{"value":29,"bonus":0,"base":9,"racial":0},"int":{"value":2,"bonus":0,"base":-4,"racial":0},"sab":{"value":12,"bonus":0,"ba
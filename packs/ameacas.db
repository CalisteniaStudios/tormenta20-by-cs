"},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","aprimoramentos":[{"custo":"7","tipo":"Muda","formula":"","description":"muda o alvo para criaturas escolhidas no alcance. Requer 4º círculo.","_id":"","id":"3e10b140-fc6f-4aa1-8465-27f8139f017b","ativo":false},{"custo":"7","tipo":"Muda","formula":"","description":"muda o alcance para pessoal e o alvo para você. Você acelera sua mente, além de seu corpo. A ação adicional pode ser usada para lançar magias e ativar engenhocas. Requer 4º círculo.","_id":"","id":"97d21fdc-a5c6-4d9b-b0ef-ff4640f3249b","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"9jAXys7BRV2ddq67","name":"Globo de Invulnerabilidade","type":"magia","sort":300001,"flags":{"core":{"sourceId":"Item.MPYbDZ1cP0y6Ju9Z"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/globo-de-invulnerabilidade.webp","effects":[{"_id":"ISjEFb9TeFb2uUPU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para afetar magias de até 3º círculo. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.CuGpzSLGUTtD7TLq","transfer":false,"tint":null},{"_id":"S0J0CYNGoCjJHcOH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para afetar magias de até 4º círculo. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.CuGpzSLGUTtD7TLq","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você é envolto por uma esfera mágica brilhante com 3m de raio, que detém qualquer magia de 2º círculo ou menor. Nenhuma magia pode ser lançada contra um alvo dentro do globo e magias de área não o penetram. No entanto, magias ainda podem ser lançadas de dentro para fora. Dissipar Magia só dissipa o globo se for usada diretamente sobre você, não o afetando se usada em área. Efeitos mágicos não são dissipados quando entram na esfera, apenas suprimidos (voltam a funcionar fora do globo, caso sua duração não tenha acabado). O globo é imóvel e não tem efeito sobre criaturas ou objetos. Após lançá-lo, você pode entrar ou sair livremente.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"abj","aprimoramentos":[{"custo":"4","tipo":"Muda","formula":"","description":"muda o efeito para afetar magias de até 3º círculo. Requer 4º círculo.","_id":"","id":"da61770a-8fb9-4ee1-9807-3cc4673b7d32","ativo":false},{"custo":"9","tipo":"Muda","formula":"","description":"muda o efeito para afetar magias de até 4º círculo. Requer 5º círculo.","_id":"","id":"0a46ba17-b879-4faf-a3d7-95a4bf62a06c","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"NEemCi5LvDyYEVYA","name":"Metamorfose","type":"poder","sort":2000001,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effe
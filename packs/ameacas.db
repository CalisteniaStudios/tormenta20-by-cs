"tipo":"","subtipo":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"gwXSwBVMJBSoY2tB","name":"Concentração de Combate","type":"magia","data":{"description":"<p>Você amplia sua percepção, antecipando movimentos dos inimigos e achando brechas em sua defesa. Quando faz um ataque, você rola dois dados e usa o melhor resultado.</p>","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"muda a execução para padrão e a duração para cena. Requer 2º círculo.","_id":"","id":"5520261d-b9e8-4e23-80e5-ddc3c6e67af5","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"além do normal, ao atacar você, um inimigo deve rolar dois dados e usar o pior resultado. Requer 3º círculo.","_id":"","id":"cf1cba3e-5aff-4cde-a3b6-300cfb7eac4a","ativo":false},{"custo":"9","tipo":"Muda","formula":"","description":"muda a execução para padrão, o alcance para curto, o alvo para criaturas escolhidas e a duração para cena. Requer 4º círculo.","_id":"","id":"e66653e3-9795-46c0-9c9f-bbe9043034d9","ativo":false},{"custo":"14","tipo":"Muda","formula":"","description":"muda a execução para padrão e a duração para 1 dia. Além do normal, você recebe um sexto sentido que o avisa de qualquer perigo ou ameaça. Você fica imune às condições surpreendido e desprevenido e recebe +10 em Defesa e Reflexos. Requer 5º círculo.","_id":"","id":"2bc4cff3-69ec-4acc-b91d-b52c75491d50","ativo":false}],"alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"Você","area":"","ativacao":{"execucao":"livre","custo":1,"condicao":""},"duracao":{"valor":"1 rodada","unidade":"outra"},"resistencia":"","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Adivinhação","efeito":""},"sort":400000,"flags":{"core":{"sourceId":"Item.1UBi6j1FJdnCdLH1"}},"img":"systems/tormenta20/icons/magias/concentracao-de-combate.webp","effects":[{"_id":"LvHT31M1UBY6eqIL","flags":{"t20":{"onuse":true,"self":true,"custo
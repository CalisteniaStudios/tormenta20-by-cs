:0},"von":{"label":"Vontade","value":14,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0,"temp":0,"bonus":0,"penalidade":0}},"periciasCustom":{},"resistencias":"imune a acertos críticos, ácido, doença, eletricidade, fogo, frio, luz, metamorfose, paralisia, petrificação, sono, trevas e veneno. não precisam respirar, alimentar-se e dormir.","tamanho":"Colossal","detalhes":{"biografia":"","dinheiro":{"tt":0,"to":0,"tp":0,"tc":0,"tl":0},"carga":0},"sentidos":"visão no escuro","equipament":"","deslocamento":{"base":9,"bonus":0,"penalidade":0,"total":9,"cond":"nao","subst":0,"descricao":""},"referencias":[],"modificadores":{"atributos":{"bonus":0,"penalidade":0,"geral":0,"fisicos":0,"mentais":0,"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0},"pericias":{"bonus":0,"penalidade":0,"geral":0,"semataque":0,"ataque":0,"resistencia":0,"atr":{"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0}},"ataques":{"bonus":0,"penalidade":0},"custosPM":{"bonus":0,"penalidade":0},"dano":{"geral":0,"cac":0,"ad":0,"mag":0},"custoPM":0},"biography":"","treasure":""},"sort":100001,"flags":{"exportSource":{"world":"andreverse-t20","system":"tormenta20","coreVersion":"0.6.6","systemVersion":"0.9.71"},"editing":false},"img":"systems/tormenta20/icons/amea%C3%A7as/besouro_aberrante.webp","token":{"flags":{},"name":"Besouro Aberrante","displayName":50,"img":"systems/tormenta20/icons/amea%C3%A7as/besouro_aberrante.webp","tint":"","width":6,"height":6,"scale":1.5,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":true,"dimSight":0,"brightSight":30,"dimLight":0,"brightLight":0.1,"sightAngle":360,"lightAngle":360,"lightColor":"#530609","lightAlpha":0.25,"lightAnimation":{"type":"emanation","speed":5,"intensity":5},"actorId":"FF9PpLugg4L34Jh1","actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.pv"},"bar2":{"attribute":""},"randomImg":false},"items":[{"_id":"06aeQPQVJUsINKVI","name":"Pancada","type":"arma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"4d6","atqBns":"40","danoBns":"17","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"a1THeP3wHEem0FXL","name":"Passar por Cima","type":"poder","data":{"description":"<p>O besouro aberrante percorre at&eacute; o dobro do seu deslocamento, passando por qualquer criatura Enorme ou menor. Uma criatura atropelada sofre [[/r 10d8+25]] pontos de dano (Ref CD 42 reduz &agrave; metade).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"completa","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"10d8+25","tipo":"classe","subtipo":"","chatFlavor":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"cDogxmFfF4ig5X3R","name":"Carapaça","type":"poder","data":{"description":"A carapaça do besouro aberrante reduz todo dano de corte, impacto e perfuração que ele sofre pela metade e fornece resistência a magia +10. Se o besouro aberrante passar num teste de resistência contra magia, ela é revertida contra o conjurador. Apesar de resistente, a caparaça de um besouro aberrante possui pontos fracos, que podem ser encontrados com uma ação de movimento e um teste de Percepção (CD 25). Um personagem que encontre um ponto fraco pode atacar a criatura com –5 no teste de ataque, mas, se acertar, ignora as proteções da carapaça.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"rn2DvzgTGXmRWg6T","name":"Jato de Ácido","type":"poder","data":{"description":"<p>O besouro aberrante dispara um jato corrosivo que atinge um cone com alcance m&eacute;dio. Criaturas na &aacute;rea sofrem [[/r 10d8+10]] pontos de dano de &aacute;cido (Ref CD 35 reduz &agrave; metade).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"movimento","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"10d8+10","tipo":"classe","subtipo":"","chatFlavor":""},"sort":500000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"D47gCp6whXKUhZpl","name":"Insanidade da Tormenta","type":"poder","data":{"description":"<p>Uma criatura que veja um ou mais Aberrantes deve fazer um teste de Vontade (CD 21). Se falhar, fica frustrada. Se falhar por 10 ou mais, fica confusa por [[/r 1d4]] rodadas e esmorecida. Se passar, fica imune a esta habilidade por um dia.&nbsp;</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":"","chatFlavor":""},"sort":300000,"flags":{"core":{"sourceId":"Item.UgJdJ1kBwIz45TUw"}},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"RpKpx0B8aYn0duOj","name":"Percepção Temporal","type":"poder","data":{"description":"<p><span style=\"left: 316.502px; top: 500.84px; font-size: 16.4667px; font-family: serif; transform: scaleX(1.10602);\">Um Aberrante soma </span><span style=\"left: 117.921px; top: 521.641px; font-size: 16.4667px; font-family: serif; transform: scaleX(1.10829);\">seu modificador de Sabedoria em testes de </span><span style=\"left: 117.921px; top: 542.441px; font-size: 16.4667px; font-family: serif; transform: scaleX(1.09028);\">ataque, Defesa e Reflexos. (J&aacute; incluso)</span></p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":""},"sort":500000,"flags":{"core":{"sourceId":"Item.EeQpLbppHvxDo1tJ"}},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"QSCDuM5ww45a5i7b","name":"Visão Ampla","type":"poder","data":{"description":"<p>Um aberrante recebe +5 em Percep&ccedil;&atilde;o e n&atilde;o pode ser flanqueado.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":""},"sort":400000,"flags":{"core":{"sourceId":"Item.Y128atZDMYoR9vjs"}},"img":"icons/svg/mystery-man.svg","effects":[]}],"effects":[]}

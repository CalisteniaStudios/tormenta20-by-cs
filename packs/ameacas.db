{"_id":"ZjAV3NXuB0ZROCHs","name":"Aranha Gigante","type":"npc","img":"https://i.imgur.com/c1KdQpM.png","items":[{"_id":"vSiBFyuzECuCuLzT","name":"Mordida","type":"arma","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"Aplica Veneno.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20",""],["luta",""],[0,""]]},{"key":"dano0","name":"Dano","type":"dano","parts":[["1d8",""],["@for",""]]}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"","tipoUso":"nat","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false,"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false},"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d8","atqBns":"12","danoBns":"5","tipo":"","custo":0,"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":"","ativacao":{"custo":null}},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"jg36Ay9GlBGIsWni","name":"Teia","type":"poder","sort":200000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"A aranha gigante dispara teia em uma área de 3m de lado em alcance curto. Criaturas na área ficam enredadas (Reflexos CD 17 evita). Uma criatura enredada pode se soltar com uma ação completa e um teste de Força ou Acrobacia (CD 20) ou cortando a teia (cada espaço de 1,5m de teia tem 5 PV e RD 5). Fogo queima a teia em duas rodadas (e liberta as criaturas), mas causa 1d6 pontos de dano de fogo por rodada a todas as criaturas nela. A aranha gigante também pode usar a teia para cobrir uma área quadrada com 6m de lado. Por sua semitransparência, a teia é difícil de ver (Percepção CD 20) até ser tarde demais. Uma criatura que entre na área fica enredada. A aranha pode andar na própria teia sem se enredar. Ela percebe automaticamente (como se tivesse percepção às cegas) qualquer criatura na teia.","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":"2","qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"","subtipo":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WHkxeD2MnBwO3ygV","name":"Veneno","type":"poder","sort":300000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Condi&ccedil;&atilde;o fraco (Fort CD 18 anula).</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units
 por 1 rodada. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.Bt364TPpNUI1QVPP","transfer":false,"tint":null},{"_id":"FJgSE1Jwz7HbX1zB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5,"priority":null},{"key":"alvo","value":"você","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para você. Em vez do normal, você é coberto por sombras, recebendo +10 em testes de Furtividade e camuflagem por escuridão. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.Bt364TPpNUI1QVPP","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo emana sombras em uma área com 6m de raio. Criaturas dentro da área recebem camuflagem por escuridão. As sombras não podem ser iluminadas por nenhuma fonte de luz natural. O objeto pode ser guardado (em um bolso, por exemplo) para interromper a escuridão, que voltará a funcionar caso o objeto seja revelado. Se lançar a magia num objeto de uma criatura involuntária, ela tem direito a um teste de Vontade para anulá-la. Escuridão anula Luz.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 objeto","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula (veja texto)"},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"q9e131If4ETJdu70","name":"Enxame de Pestes","type":"magia","sort":1500001,"flags":{"core":{"sourceId":"Item.4e59kyZdikq2FgSd"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/enxame-de-pestes.webp","effects":[{"_id":"rUhHEtwTUVmlsDd2","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d12","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d12.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null},{"_id":"P4pirBwD7xETNzpw","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"resistencia","value":"Reflexos reduz à metade","mode":5,"priority":null},{"key":"dano","value":"3d12","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas maiores, como gatos, guaxinins, compsognatos ou kobolds. Ele causa 3d12 pontos de dano (a sua escolha entre corte, impacto ou perfuração). O resto da magia segue normal.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null},{"_id":"DHpBmH5U3daYrDVC","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de enxames em +1. Eles não podem ocupar o mesmo espaço. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null},{"_id":"ieUdi5tA1oF9QhoP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"resistencia","value":"Reflexos reduz à metade","mode":5,"priority":null},{"key":"dano","value":"5d12","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas elementais. Ele causa 5d12 pontos do dano (a sua escolha entre ácido, eletricidade, fogo ou frio). O resto da magia segue normal. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você conjura um enxame de criaturas a sua escolha, como besouros, gafanhotos, mosquitos, ratos, morcegos ou serpentes, que surge em um ponto a sua escolha. O enxame pode passar pelo espaço de outras criaturas e não impede que outras criaturas entrem no espaço dele. No final de cada um de seus turnos, o enxame causa 2d12 pontos de dano de veneno a qualquer criatura em seu espaço (Fortitude reduz à metade). Você pode gastar uma ação de movimento para mover o enxame com deslocamento de 12m.</p>","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"medium","alvo":"","area":"1 enxame Médio (quadrado de 1,5m)","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"Convocação","origin":"","tags":[],"chatFlavor":"","chatGif":""},"owner
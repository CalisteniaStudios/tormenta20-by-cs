,"st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"pon":{"label":"Pontaria","value":0,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"ref":{"label":"Reflexos","value":19,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"rel":{"label":"Religião","value":0,"atributo":"sab","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"sob":{"label":"Sobrevivência","value":0,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"von":{"label":"Vontade","value":20,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0}},"periciasCustom":{"0":{"label":"Cavalgar","nome":"pericia","value":13},"1":{"label":"Intimidação","nome":"pericia","value":17},"2":{"label":"Guerra","nome":"pericia","value":14},"3":{"label":"Nobreza","nome":"pericia","value":14}},"resistencias":"cura acelerada 20, resistência a dano 10, resistência a magia +5","tamanho":"Colossal","deslocamento":"12m (8q)","detalhes":{"biografia":"","dinheiro":{"tt":0,"to":0,"tp":0,"tc":0},"carga":0},"sentidos":"","equipament":""},"sort":100001,"flags":{},"img":"systems/tormenta20/icons/ameaças/Monstro.webp","token":{"flags":"","name":"Colosso Supremo","displayName":0,"img":"systems/tormenta20/icons/ameaças/Monstro_token.webp","tint":"","width":4,"height":4,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":false,"dimSight":0,"brightSight":0,"dimLight":0,"brightLight":0,"sightAngle":360,"lightAngle":360,"lightColor":"","lightAlpha":1,"actorId":"WMcZXuIIRzCPzr6a","actorLink":false,"actorData":{},"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.pv"},"bar2":{"attribute":"attributes.pm"},"randomImg":false},"items":[{"_id":"vSiBFyuzECuCuLzT","flags":{},"name":"Espada titânica","type":"arma","img":"icons/svg/mystery-man.svg","data":{"description":"","pericia":"lut","dano":"4d12","atrDan":"for","criticoM":19,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"atqBns":45,"danoBns":"15","peso":0,"qtd":1,"preco":0,"tipoUso":"simples"},"sort":100000},{"_id":"qsnU9NvGAhcLn8Oi","flags":{},"name":"Balistas","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":" Um colosso supremo possui duas balistas, uma em cada ombro. Cada balista é tripulada por soldados que a carregam e a disparam em rodadas alternadas (bônus de ataque +13, 6d8 pontos de dano de perfuração, crítico 19, alcance médio). É possível atacar as tripulações para impedir os disparos. Cada tripulação possui Defesa 26, 50 pontos de vida e usa os testes de resistência do colosso.","roll":"","tipo":"","ativacao":{"execucao":"livre","custo":0}},"sort":0},{"_id":"bTua2ujDZx5B698y","flags":{},"name":"Fumos Tóxicos","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Uma criatura que comece seu turno em alcance curto do colosso sofre 4d6 pontos de dano de veneno e fica enjoada (Fortitude CD 30 evita).","roll":"4d6","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":100000},{"_id":"64LhGQcbLshnJU3y","flags":{},"name":"Goblins Consertadores","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Goblins especialmente pequenos rastejam por dentro dos dutos do colosso fazendo reparos, o que fornece ao construto cura acelerada 20. Por estarem dentro do construto, os goblins são imunes a dano, mas ainda podem ser afetados por efeitos mentais. Eles possuem Vontade +2 (mas recebem a resistência a magia do colosso) e, se forem afetados por qualquer condição, a cura acelerada deixa de funcionar.","roll":"","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":200000},{"_id":"nrWEwtD2npplXxdh","flags":{},"name":"Jato de Chamas","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"O colosso dispara um jato de chamas que atinge um cone com alcance médio. Criaturas na área sofrem 8d8+10 pontos de dano de fogo (Ref CD 35 reduz à metade).","roll":"8d8+10","tipo":"","ativacao":{"execucao":"movimento","custo":0}},"sort":400000},{"_id":"vkFhQQj07PRcCPTs","flags":{},"name":"Passar por Cima","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"O colosso percorre até o dobro do seu deslocamento, passando por qualquer criatura Grande ou menor. Uma criatura atropelada sofre 6d8+15 pontos de dano de impacto (Reflexos CD 30 reduz à metade).","roll":"6d8+15","tipo":"","ativacao":{"execucao":"completa","custo":0}},"sort":400000},{"_id":"iDCDsckgPLVcHUrw","flags":{},"name":"Varrer","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Uma vez por rodada, quando o colosso supremo faz um ataque corpo a corpo e reduz os pontos de vida do alvo para 0 ou menos, pode realizar um ataque adicional contra outra criatura dentro do seu alcance. Esse ataque usa os mesmos bônus de ataque e dano, mas os dados devem ser rolados novamente.","roll":"","tipo":"","ativacao":{"execucao":"livre","custo":0}},"sort":400000}]}

":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"tra","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","_id":"","id":"d237dacd-e691-4a93-a6df-19f38c7a3582","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"a arma passa a causar +1d6 de dano de ácido, eletricidade, fogo ou frio, escolhido no momento em que a magia é lançada.","_id":"","id":"0913741d-c3bf-492f-8483-ddf9fb990477","ativo":false}],"atrRes":"sab","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"u8dm4X03xi1HepOB","name":"Comando","type":"magia","sort":600000,"flags":{"core":{"sourceId":"Item.DClEXhRqbdmK0hPw"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/comando.webp","effects":[{"_id":"goAzE0oaWGOVE9Gm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false,"tint":null},{"_id":"UuprzsbsDv72xAxP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a quantidade de alvos em +1","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você dá uma ordem irresistível, que o alvo deve ser capaz de ouvir (mas não precisa entender). Se falhar na resistência, ele deve obedecer ao comando em seu próprio turno da melhor maneira possível. Escolha um dos efeitos.</p><p style=\"text-align:justify;\"><i>Fuja:</i> o alvo gasta seu turno se afastando de você (usando todas as suas ações).</p><p style=\"text-align:justify;\"><i>Largue:</i> o alvo solta quaisquer itens que esteja segurando e não pode pegá-los novamente até o início de seu próximo turno. Como esta é uma ação livre, ele ainda pode executar outras ações (exceto pegar aquilo que largou).</p><p style=\"text-align:justify;\"><i>Pare:</i> o alvo fica pasmo (não pode fazer ações, exceto reações).</p><p style=\"text-align:justify;\"><i>Senta:</i> com uma ação livre, o alvo senta no chão (se estava pendurado ou voando, desce até o chão). Ele pode fazer outras ações, mas não se levantar até o início de seu próximo turno. </p><p style=\"text-align:justify;\"><i>Venha:</i> o alvo gasta seu turno se aproximando de você (usando todas as suas ações).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"1 rodada","units":"special","special":"","valor":"1 rodada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"enc","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura.","_id":"","id":"e525b111-4d4d-4bbc-86bb-7aabe0670f8b","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta a quantidade de alvos em +1","_id":"","id":"f7f61147-efcc-4acd-b19b-e70812260cfe","ativo":false}],"atrRes":"sab","cd":0},"ownership":{"default":0},"_
avor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"s72jIPdYgAFLgbuJ","name":"Enfeitiçar","type":"magia","sort":1300001,"flags":{"core":{"sourceId":"Item.ARP9yn6keaH9aNKt"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/enfeiticar.webp","effects":[{"_id":"wuyNqXeAYnTZxLx7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"B1IA6n2acw7SSW2l","name":"Dissipar Magia","type":"magia","sort":1100001,"flags":{"core":{"sourceId":"Item.LnZpwedvAkmScrZG"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/dissipar-magia.webp","effects":[{"_id":"kKZ6L0mhMN53y13e","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"area","value":"esfera com 9m de raio","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5º círculo.","origin":"Compendium.tormenta20.magias.rfTGYwrXLjcIAIP5","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você dissipa outras magias que estejam ativas, como se sua duração tivesse acabado. Note que efeitos de magias instantâneas não podem ser dissipados (não se pode dissipar uma Bola de Fogo ou Relâmpago depois que já causaram dano...). Se lançar essa magia em uma criatura ou área, faça um teste de Misticismo; você anula as magias com CD igual ou menor que o resultado do teste. Se lançada contra um item mágico, o transforma em um item mundano por 1d6 rodadas (sem teste de resistência).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"medium","alvo":"1 criatura ou 1 objeto mágico ou esfera com 3m de raio","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"abj","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"6FRcHxFEmIQSHoLP","name":"Velocidade","type":"magia","sort":1400001,"flags":{"core":{"sourceId":"Item.MtmFzJIsEiXnAzhU"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/velocidade.webp","effects":[{"_id":"lYxiSwCe3djsAOE6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas no alcance","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas no alcance. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false,"tint":null},{"_id":"wb7wmP9NbM1Q2Bxg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5,"priority":null},{"key":"alvo","value":"você","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para você. Você acelera sua mente, além de seu corpo. A ação adicional pode ser usada para lançar magias e ativar engenhocas. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo pode realizar uma ação padrão ou de movimento adicional por turno. Esta ação não pode ser usada para lançar magias e ativar engenhocas.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"xxEdeJWpsvjgdfdE","name":"Globo de Invulnerabilidade","type":"magia","sort":300001,"flags":{"core":{"sourceId":"Item.MPYbDZ1cP0y6Ju9Z"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/globo-de-invulnerabilidade.webp","effects":[{"_id":"ISjEFb9TeFb2uUPU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para afetar magias de até 3º círculo. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.CuGpzSLGUTtD7TLq","transfer":false,"tint":null},{"_id":"S0J0CYNGoCjJHcOH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para afetar magias de até 4º círculo. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.CuGpzSLGUTtD7TLq","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você é envolto por uma esfera mágica brilhante com 3m de raio, que detém qualquer magia de 2º círculo ou menor. Nenhuma magia pode ser lançada contra um alvo dentro do globo e magias de área não o penetram. No entanto, magias ainda podem ser lançadas de dentro para fora. Dissipar Magia só dissipa o globo se for usada diretamente sobre você, não o afetando se usada em área. Efeitos mágicos não são dissipados quando entram na esfera, apenas suprimidos (voltam a funcionar fora do globo, caso sua duração não tenha acabado). O globo é imóvel e não tem efeito sobre criaturas ou objetos. Após lançá-lo, você pode entrar ou sair livremente.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"abj","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"HDBEk6vSuLUkcCzQ","name":"Libertação","type":"magia","sort":1900001,"flags":{"core":{"sourceId":"Item.IsMRX6mBUU29lKo7"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/libertacao.webp","effects":[{"_id":"BU5LpJQ6K0yU6b69","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo pode caminhar sobre a água ou outros líquidos com seu deslocamento normal. Entretanto, isso não protege contra qualquer efeito que o líquido possa causar (o alvo pode andar sobre lava, mas ainda vai sofrer dano).","origin":"Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ","transfer":false,"tint":null},{"_id":"u8bzRTaoDhpbpzhf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTim
al e o alvo para área: explosão com 6m de raio. Você dispara raios pelas pontas dos dedos que afetam todas as criaturas na área.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Arcos elétricos envolvem sua mão, causando 2d8+2 pontos de dano de eletricidade. Se o alvo usa armadura de metal (ou carrega muito metal, a critério do mestre), sofre uma penalidade de –5 no teste de resistência.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"2d8+2","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d8+2",""]]}],"tipo":"arc","circulo":"1","preparada":false,"escola":"evo","aprimoramentos":[{"custo":"1","tipo":"Aumenta","formula":"1d8","description":"aumenta o dano em 1d8+1.","_id":"","id":"44210768-e2a1-4493-9cb9-d162c0ecd83d","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"como parte da execução da magia, você faz um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia.","_id":"","id":"8787d101-abc5-4647-9605-f554e96fc0cd","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para pessoal e o alvo para área: explosão com 6m de raio. Você dispara raios pelas pontas dos dedos que afetam todas as criaturas na área.","_id":"","id":"9310bdb5-f994-4e3d-ac5b-f000356ac4f1","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":
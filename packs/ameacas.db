ias.W3wssZ36rMtbMPaA","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Favorita entre arcanistas iniciantes, esta magia lança duas setas de energia que causando 1d4+1 pontos de dano de essência cada. Você pode lançar as setas em alvos diferentes ou concentrá-las num mesmo alvo. Caso você possua um bônus no dano de magias, como pelo poder Arcano de Batalha, ele é aplicado em apenas uma seta (o bônus vale para a magia, não cada alvo).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"2d4+2","alcance":"medium","alvo":"até 2 criaturas","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d4+2","",""]],"versatil":""}],"tipo":"arc","circulo":"1","preparada":false,"escola":"evo","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ExAmOdMJxwr928HA","name":"Relâmpago","type":"magia","sort":1000001,"flags":{"core":{"sourceId":"Item.9jTiP3egh02qOole"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/relampago.webp","effects":[{"_id":"XIxcAX2dWaFDGsfG","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6.","origin":"Compendium.tormenta20.magias.BfYpxjs0NeqhAs8q","transfer":false,"
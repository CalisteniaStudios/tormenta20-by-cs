il":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"jg36Ay9GlBGIsWni","name":"Agarrar Aprimorado","type":"poder","data":{"description":"Quando a centopeia-dragão acerta um ataque de mordida, pode usar a manobra agarrar (bônus +29).","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"1d20+29","tipo":"classe","subtipo":"","chatFlavor":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"WHkxeD2MnBwO3ygV","name":"Aura de Calor","type":"poder","data":{"description":"<p>Quando enfurecida, esta criatura emana um calor intenso. No in&iacute;cio de cada turno da centopeia-drag&atilde;o, todas as criaturas em alcance curto sofrem [[/r 4d6+9]] pontos de dano de fogo.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"4d6+9","tipo":"classe","subtipo":"","chatFlavor":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"UhfILDsyLh3rbdzp","name":"Engolir","type":"poder","data":{"description":"<p>Se a centopeia-drag&atilde;o come&ccedil;ar seu turno agarrando uma criatura M&eacute;dia ou menor, poder&aacute; fazer um teste de agarrar contra ela. Se vencer, engole a criatura. Uma criatura engolida continua agarrada e sofre [[/r 2d6+12]] pontos de dano de impacto, mais [[/r 4d6+9]] pontos de dano de fogo, no in&iacute;cio de cada turno da centopeia-drag&atilde;o. Uma criatura engolida pode escapar causando 20 pontos de dano ao est&ocirc;mago da centopeia-drag&atilde;o (Defesa 10). Isso faz com que a criatura seja regurgitada e fique ca&iacute;da na frente da centopeia-drag&atilde;o.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"padrao","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"2d6+12","tipo":"classe","subtipo":"","chatFlavor":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]}],"effects":[]}

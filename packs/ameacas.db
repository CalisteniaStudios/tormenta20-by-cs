"","ativacao":{"execucao":"padrao","custo":"4"}},"sort":500000},{"_id":"WmG4wzk6kNGvvvhy","flags":{},"name":"Veneno","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"4d12 pontos de dano por rodada durante 2d4 rodadas (Fort CD 31 reduz à metade).","roll":"4d12","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":600000}]}

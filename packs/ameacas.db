peso":6,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d12","atqBns":"12","danoBns":"9","criticoM":20,"criticoX":3,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"marcial","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"systems/tormenta20/icons/itens/machado-de-guerra.webp","effects":[]},{"_id":"2CubQOiCnWZARpcp","name":"Abençoar Arma","type":"poder","data":{"description":"Até o fim da cena, o arauto usa o bônus de Sabedoria no lugar de Força para testes de ataque e rolagens de dano com o machado de guerra; o dano dessa arma aumenta em um passo e se torna mágico. Suas estatísticas se tornam ataque +15 (3d6+12, x3).","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"movimento","custo":"3","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"K9RzGyBEILe89ba2","name":"Fúria Divina","type":"poder","data":{"description":"O arauto entra em fúria até o fim da cena, ou até passar uma rodada inteira sem atacar ou ser alvo de um efeito (ataque, habilidade, magia...) hostil. Ele recebe +2 nos testes de ataque e rolagens de dano corpo a corpo, mas não pode fazer nenhuma ação que exija calma e concentração.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":"2","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"yPh0GJaaWp3Fooek","name":"Prece de Combate","type":"poder","data":{"description":"Quando lança uma magia divina com tempo de conjuração de uma ação padrão tendo como alvo ele mesmo, o arauto reduz o tempo para uma ação de movimento.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"2 pm","custo":"2","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"O1YCZa1ByiGNS62L","name":"Tropas Goblinóides","type":"poder","data":{"description":"O arauto invoca 1d4+1 goblinoides em espaços desocupados em alcance curto. Ele pode usar uma ação de movimento para fazer os goblinoides andarem (deslocamento 9m) ou uma ação padrão para fazê-los causar dano a criaturas adjacentes (1d6+1 pontos de dano de corte cada). Os goblinoides têm For 14, Des 14, 6 PV e não têm valor de Defesa ou testes de resistência (qualquer efeito os acerta automaticamente). Eles não agem sem receber uma ordem e desaparecem quando morrem ou no fim da cena.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"completa","custo":2,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":"","chatFlavor":""},"sort":500000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"ZIPpdCDRJwL4yBA2","name":"Amedrontar","type":"magia","data":{"description":"<p style=\"text-align: justify;\">O alvo &eacute; envolvido por energias sombrias assustadoras. Se falhar na resist&ecirc;ncia, fica apavorado por 1d4 rodadas, depois abalado. Se passar, fica abalado por 1d4 rodadas.</p>","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"muda o alvo para criatura de ND 2 ou menor.","_id":"","id":"af3efe8c-a41e-4
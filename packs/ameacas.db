cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"3SjPOyh8C1hqbFAy","name":"Especialista em Encantamento","type":"poder","data":{"description":"A CD para resistir às magias de encantamento do feitor aumenta em +2.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"qhHq8xQxRGJIQ2rU","name":"Natureza Vegetal","type":"poder","data":{"description":"O finntroll é afetado por habilidades e magias que afetam plantas.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":600000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"o5k6gNT6IDKY77e3","name":"Regeneração Vegetal","type":"poder","data":{"description":"O finntroll recupera 5 pontos de vida. Esta habilidade não cura dano de ácido e fogo e não pode ser usada quando o finntroll está exposto à luz do sol ou similar.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"movimento","custo":"1","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":700000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"ZvEoI10JKwqqOZka","name":"Sensibilidade à Luz","type":"poder","data":{"description":"Quando exposto à luz do sol ou similar, o finntroll fica ofuscado.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":800000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"qZTFKKWiZqtswVQL","name":"Adaga Mental","type":"magia","data":{"description":"<p style=\"text-align: justify;\">Voc&ecirc; manifesta e dispara uma adaga imaterial contra a mente do alvo, que sofre 2d6 pontos de dano mental e fica pasmo por uma rodada. Se passar no teste de resist&ecirc;ncia, sofre apenas metade do dano e n&atilde;o fica pasmo.</p>","aprimoramentos":[{"custo":"1","tipo":"Outros","formula":"","description":"você lança a magia sem gesticular ou pronunciar palavras e a adaga se torna invisível. Se o alvo falhar no teste de resistência, não percebe que você lançou uma magia contra ele.","_id":"","id":"7fd3267c-b821-4105-88a9-6770c3d97051","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Além do normal, você “finca” a adaga na mente do alvo. Enquanto a magia durar, você sabe a direção e localização do alvo, desde que ele esteja no mesmo mundo.","_id":"","id":"46a8c4ef-97f6-474a-8997-37de47e4617b","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"1d6","description":"aumenta o dano em +1d6.","_id":"","id":"569737a7-15c9-4ef8-985e-b33211c22334","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 criatura","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"Vontade parcial","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Encantamento","efeito":"2d6"},"sort":900000,"flags":{"core":{"sourceId":"Item.E9UitKPfwJPDlA04"}},"img":"systems/tormenta20/icons/magias/adaga-mental.webp","effects":[{"_id":"fORHsYOz2U1D8N5k","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"você lança a magia sem gesticular ou pronunciar palavras e a adaga se torna invisível. Se o alvo falhar no teste de resistência, não percebe que você lançou uma magia contra ele.","origin":"Item.IQrZTuimhJHEW9at","transfer":false},{"_id":"EkX61NpwVj1yC0Mo","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Além do normal, você “finca” a adaga na mente do alvo. Enquanto a magia durar, você sabe a direção e localização do alvo, desde que ele esteja no mesmo mundo.","origin":"Item.IQrZTuimhJHEW9at","tint":"","transfer":false},{"_id":"MeJCcH3OCS1Y12zZ","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"roll","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Item.IQrZTuimhJHEW9at","tint":"","transfer":false},{"_id":"Qb05w1R82YFgBoIB","flags":{"t20":{"onuse":false,"durationScene":false}},"changes":[],"disabled":false,"duration":{"startTime":null,"seconds":null,"rounds":1,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/aura.svg","label":"Pasmo","origin":"Item.IQrZTuimhJHEW9at","tint":"","transfer":false}]},{"_id":"wn4iqUnvc8xMvg1C","name":"Armadura Arcana","type":"magia","data":{"description":"<p style=\"text-align: justify;\">Esta magia cria uma pel&iacute;cula protetora invis&iacute;vel, mas tang&iacute;vel, fornecendo +4 na Defesa. Esse b&ocirc;nus &eacute; cumulativo com outras magias, mas n&atilde;o com b&ocirc;nus fornecido por armaduras.</p>","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual.","_id":"","id":"074ea668-ba8c-463a-b59f-e18ba5b21be9","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus na Defesa em +1.","_id":"","id":"8bf9652c-e245-4392-990b-6e92cb6e4aaf","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Requer 2o círculo.","_id":"","id":"ad230447-7151-4fc0-9a91-b36c6d6e1e57","ativo":false}],"alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"Você","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Abjuração","efeito":""},"sort":1000000,"flags":{"core":{"sourceId":"Item.tgkYUPq9MY1YItoL"}},"img":"systems/tormenta20/icons/magias/armadura-arcana.webp","effects":[{"_id":"W1WgvYbVsADr5MNL","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"execucao","value":"reacao","mode":5},{"key":"data.defesa.temp","value":2,"mode":2},{"key":"duracao","value":"1 turno","mode":5}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual.","origin":"Item.6tacmHJDvuMoxe8v","tint":"","transfer":false},{"_id":"cOarntwGdXunJRyH","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.defesa.temp","value":1,"mode":2}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus na Defesa em +1.","origin":"Item.6tacmHJDvuMoxe8v","tint":"","transfer":false},{"_id":"CRwrKNwVnkcuyYGR","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Requer 2º círculo.","origin":"Item.6tacmHJDvuMoxe8v","tint":"","transfer":false},{"_id":"DXFHELXQkzrakHqN","flags":{"t20":{"onuse":false,"durationScene":true}},"changes":[{"key":"data.defesa.temp","value":4,"mode":2}],"disabled":false,"duration":{"startTime":null,"seconds":null,"rounds":999,"turns":null,"startRound":null,"startTurn":null},"icon":"systems/tormenta20/icons/magias/armadura-arcana.webp","label":"Armadura Arcana","origin":"Item.6tacmHJDvuMoxe8v","tint":"","transfer":false}]},{"_id":"ysxlb0cWlvge4hsp","name":"Enfeitiçar","type":"magia","data":{"description":"<p>Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","_id":"","id":"07ab3013-a5c5-4805-ae1e-b87017f48c42","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","_id":"","id":"79758da9-d2f9-4b71-896e-763d309d8bb6","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta todos os alvos dentro do alcance.","_id":"","id":"16407353-737b-43b1-a0e1-f1373f8af7c2","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 humanóide","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade anula","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Encantamento","efeito":""},"sort":1300001,"flags":{"core":{"sourceId":"Item.ARP9yn6keaH9aNKt"}},"img":"systems/tormenta20/icons/magias/enfeiticar.webp","effects":[{"_id":"wuyNqXeAYnTZxLx7","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false}]},{"_id":"t3DSGzNsJ3n4VnQW","name":"Desespero Esmagador","type":"magia","data":{"description":"<p>Humanoides na área são acometidos de grande tristeza, adquirindo as condições fraco e frustrado. Se passarem na resistência, adquirem essas condições por uma rodada.</p>","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"em vez do normal, as condições adquiridas são debilitado e esmorecido.","_id":"","id":"a80ba20c-9864-4b65-8ea7-5930ac196ce5","ativo":false},{"custo":"3","tipo":"Muda","formula":"","description":"em vez do normal, afeta qualquer tipo de criatura.","_id":"","id":"8682ed43-d291-4292-a7c3-c889a1415e4f","ativo":false},{"custo":"3","tipo":"Outros","formula":"","description":"além do normal, criaturas que falhem na resistência ficam aos prantos (em termos de jogo, adquirem a condição pasmo) por 1 rodada. Requer 3º círculo.","_id":"","id":"b14507aa-db8d-4479-9c73-55d9d453633d","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"Cone de 6 metros","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade parcial","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"2","preparada":false,"escola":"Encantamento","efeito":""},"sort":300001,"flags":{"core":{"sourceId":"Item.l9gxrlKYBkmJLnXZ"}},"img":"systems/tormenta20/icons/magias/desespero-esmagador.webp","effects":[{"_id":"6fhmY20GSejtqLgU","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"condicao","value":"debilitado","mode":0},{"key":"condicao","value":"esmorecido","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, as condições adquiridas são debilitado e esmorecido.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false},{"_id":"HsX3fBjwZwMTO2bb","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, afeta qualquer tipo de criatura.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false},{"_id":"SFqxKl2kgQ69jfzA","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"condicao","value":"pasmo","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas que falhem na resistência ficam aos prantos (em termos de jogo, adquirem a condição pasmo) por 1 rodada. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false}]},{"_id":"VaC92MTkyO038aR7","name":"Marca da Obediência","type":"magia","data":{"description":"<p>Você toca uma criatura, gravando uma marca mística no corpo dela enquanto profere uma ordem, como “não ataque a mim ou meus aliados”, “siga-me” ou “não saia desta sala”. A criatura deve seguir essa ordem, gastando todas as ações de seu turno para isso. A ordem não pode ser genérica demais (como “ajude-me”, por exemplo), nem forçar o alvo a atos suicidas. A cada rodada, o alvo pode fazer um teste de Vontade. Se passar, a magia é dissipada.</p>","aprimoramentos":[{"custo":"3","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Se não estiver em combate, a criatura só pode fazer o teste de Vontade a cada hora. Requer 3º círculo.","_id":"","id":"6d48162f-481f-4a13-a32d-a2802a5017cc","ativo":false},{"custo":"3","tipo":"Outros","formula":"","description":"sempre que o alvo fizer o teste de Vontade e falhar, a marca causa 3d6 pontos de dano mental. Requer 3º círculo.","_id":"","id":"e7235974-968e-4f92-b643-6b251edb897d","ativo":false}],"alcance":"Toque","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 criatura","area":"","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade anula","atrRes":"int","cd":0,"tipo":"Universal","circulo":"2","preparada":false,"escola":"Encantamento","efeito":""},"sort":2800001,"flags":{"core":{"sourceId":"Item.pB3WzScFl0ui0omo"}},"img":"systems/tormenta20/icons/magias/marca-da-obediencia.webp","effects":[{"_id":"eoNg1u879WuUyEhh","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Se não estiver em combate, a criatura só pode fazer o teste de Vontade a cada hora. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.6wASxSXLtFzQcy8V","transfer":false},{"_id":"IlQu5F0jyHJGsMQP","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"sempre que o alvo fizer o teste de Vontade e falhar, a marca causa 3d6 pontos de dano mental. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.6wASxSXLtFzQcy8V","transfer":false}]},{"_id":"7gDJoDN2jAleEnew","name":"Relâmpago","type":"magia","data":{"description":"<p>Você dispara um poderoso raio que causa 6d6 pontos de dano de eletricidade em todas as criaturas e objetos livres na área.</p>","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"2d6","description":"aumenta o dano em +2d6.","_id":"","id":"9ab881f3-675d-45fb-b9a2-946e777af869","ativo":false},{"custo":"3","tipo":"Muda","formula":"6d6","description":"muda a área para alvo (criaturas escolhidas). Em vez do normal, você dispara vários relâmpagos, um para cada alvo escolhido, causando 6d6 pontos de dano de eletricidade. Requer 3º círculo.","_id":"","id":"0daa768e-6656-4e1a-8c33-4f4a60ab80b5","ativo":false}],"alcance":"Médio","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"linha","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"Reflexos reduz à metade","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"2","preparada":false,"escola":"Evocação","efeito":"6d6"},"sort":2900001,"flags":{"core":{"sourceId":"Item.9jTiP3egh02qOole"}},"img":"systems/tormenta20/icons/magias/relampago.webp","effects":[{"_id":"XIxcAX2dWaFDGsfG","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"roll","value":"2d6","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6.","origin":"Compendium.tormenta20.magias.BfYpxjs0NeqhAs8q","transfer":false},{"_id":"UbfkJ2MbLTgN5Aci","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"area","value":"alvo (criaturas escolhidas)","mode":5},{"key":"roll","value":"6d6","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a área para alvo (criaturas escolhidas). Em vez do normal, você dispara vários relâmpagos, um para cada alvo escolhido, causando 6d6 pontos de dano de eletricidade. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.BfYpxjs0NeqhAs8q","transfer":false}]}],"effects":[]}

Item.6tacmHJDvuMoxe8v","tint":null,"transfer":false},{"_id":"DXFHELXQkzrakHqN","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":true}},"changes":[{"key":"system.attributes.data.attributes.data.attributes.defesa.bonuss","value":"4","mode":2,"priority":null}],"disabled":false,"duration":{"startTime":null,"rounds":999,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"icon":"systems/tormenta20/icons/magias/armadura-arcana.webp","label":"Armadura Arcana","origin":"Item.6tacmHJDvuMoxe8v","tint":null,"transfer":false}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma pel&iacute;cula protetora invis&iacute;vel, mas tang&iacute;vel, fornecendo +4 na Defesa. Esse b&ocirc;nus &eacute; cumulativo com outras magias, mas n&atilde;o com b&ocirc;nus fornecido por armaduras.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"abj","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"YJCQegVbs54ndkHE","name":"Raio do Enfraquecimento","type":"magia","sort":1400000,"flags":{"core":{"sourceId":"Item.JfNM4D7BR0mPG1zh"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/raio-do-enfraquecimento.webp","effects":[{"_id":"h9YSgDixO3JIQakZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode"
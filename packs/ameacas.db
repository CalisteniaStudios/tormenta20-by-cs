m ao final da cena. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.505PykOz1CmG2CU3","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você suga energia vital da terra, recebendo 2d8 pontos de vida temporários. Os PV temporários desaparecem ao final da cena.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"nec","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"1d8","description":"aumenta os PV temporários recebidos em +1d8.","_id":"","id":"67b48eab-94a1-4671-967a-dc20a965914a","ativo":false},{"custo":"5","tipo":"Muda","formula":"1d8","description":"muda o alvo para área: esfera com 6m de raio centrada em você e a resistência para Fortitude reduz à metade. Em vez do normal, você suga energia das criaturas vivas na área, causando 1d8 pontos de dano de trevas e recebendo PV temporários iguais ao dano total causado. Os PV temporários desaparecem ao final da cena. Requer 2º círculo.","_id":"","id":"3beb5444-7f07-4a06-8b9b-301208c2a7db","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"RYHhxHfrZ5swGQay","name":"Conjurar Mortos-Vivos","type":"magia","sort":1500000,"flags":{"core":{"sourceId":"Item.FfIZiBV2pHK3ddJG"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/conjurar-mortos-vivos.webp","effects":[{"_id":"4qjvv6kmamN4fee7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de mortos-vivos conjurados em +1.","origin":"Compendium.tormenta20.magias.5ZjS4bVvSxWNpBL9","transfer":false,"tint":null},{"_id":"NgMgwIWCx2QWJ9yq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez de esqueletos, conjura carniçais. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.5ZjS4bVvSxWNpBL9","transfer":false,"tint":null},{"_id":"4O6MhQ318Rz4ggO0","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez de esqueletos, conjura sombras. Requer 4º círculo.\n\nCarniçal: como o esqueleto, mas tem For 16, Des 16, 12 PV e causa 1d8+3 pontos de dano de trevas mais 1d8 pontos de dano de veneno. Além disso, criaturas atingidas por um carniçal devem passar num teste de Fortitude (CD igual à da magia) ou ficam paralisadas por 1 rodada. Uma criatura que passe no teste de resistência fica imune à paralisia dos carniçais por 24 horas.\n\nSombra: como o esqueleto, mas tem a habilidade incorpóreo, Des 18, 30 PV e causa 1d10 pontos de dano de trevas mais 1d10 pontos de dano de frio. Além disso, criaturas vivas atingidas por uma sombra devem passar num teste de Fortitude (CD igual à da magia) ou perdem 1d4 PM. Sombras perdem a habilidade incorpóreo quando expostas à luz do sol.","origin":"Compendium.tormenta20.magias.5ZjS4bVvSxWNpBL9","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Seis esqueletos de tamanho Médio feitos de energia negativa emergem do chão em espaços desocupados escolhidos por você dentro do alcance. Você pode usar uma ação de movimento para fazer os mortos-vivos andarem (eles têm deslocamento 9m) ou uma ação padrão para fazê-los causar dano a criaturas adjacentes (1d6+2 pontos de dano de trevas cada). Os esqueletos têm For 14, Des 14 e todos os outros atributos nulos; eles têm 1 PV, não têm valor de Defesa ou testes de resistência, falham automaticamente em qualquer teste oposto e são imunes a atordoamento, dano não letal, doença, encantamento, fadiga, frio, ilusão, paralisia, sono e veneno. Eles desaparecem quando são reduzidos a 0 PV ou no fim da cena. Os mortos-vivos não agem sem receber uma ordem. Usos criativos para criaturas invocadas fora de combate ficam a critério do mestre.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"6 mortos-vivos","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"nec","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o número de mortos-vivos conjurados em +1.","_id":"","id":"8a4bc6cc-1aba-4aca-bc1c-7376ed01e516","ativo":false},{"custo":"3","tipo":"Outros","formula":"","description":"em vez de esqueletos, conjura carniçais. Requer 3º círculo.","_id":"","id":"c464e0b3-e298-4aba-b9ac-111ade5d3bed","ativo":false},{"custo":"7","tipo":"Outros","formula":"","description":"em vez de esqueletos, conjura sombras. Requer 4º círculo.\n\nCarniçal: como o esqueleto, mas tem For 16, Des 16, 12 PV e causa 1d8+3 pontos de dano de trevas mais 1d8 pontos de dano de veneno. Além disso, criaturas atingidas por um carniçal devem passar num teste de Fortitude (CD igual à da magia) ou ficam paralisadas por 1 rodada. Uma criatura que passe no teste de resistência fica imune à paralisia dos carniçais por 24 horas.\n\nSombra: como o esqueleto, mas tem a habilidade incorpóreo, Des 18, 30 PV e causa 1d10 pontos de dano de trevas mais 1d10 pontos de dano de frio. Além disso, criaturas vivas atingidas por uma sombra devem passar num teste de Fortitude (CD igual à da magia) ou perdem 1d4 PM. Sombras perdem a habilidade incorpóreo quando expostas à luz do sol.","_id":"","id":"4bba376f-2d03-433b-b917-c162ad811507","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"AwaoowiJVe89HF2S","name":"Toque Vampírico","type":"magia","sort":1600000,"flags":{"core":{"sourceId":"Item.pXsAXnZf1UW8Jc1z"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/toque-vampirico.webp","effects":[{"_id":"5E8DwOxwvQNlJJN4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"como parte da execução da magia, você pode fazer um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia, e recupera pontos de vida iguais à metade do dano da magia.","origin":"Compendium.tormenta20.magias.6KvwDBikOdbzhRGv","transfer":false,"tint":null},{"_id":"Fp3cotDEql0E2Dur","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"2d
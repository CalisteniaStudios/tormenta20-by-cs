,"effects":[],"folder":null,"system":{"description":{"value":"Até o fim da cena, o arauto usa o bônus de Sabedoria no lugar de Força para testes de ataque e rolagens de dano com o machado de guerra; o dano dessa arma aumenta em um passo e se torna mágico. Suas estatísticas se tornam ataque +15 (3d6+12, x3).","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"K9RzGyBEILe89ba2","name":"Fúria Divina","type":"poder","sort":300000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"O arauto entra em fúria até o fim da cena, ou até passar uma rodada inteira sem atacar ou ser alvo de um efeito (ataque, habilidade, magia...) hostil. Ele recebe +2 nos testes de ataque e rolagens de dano corpo a corpo, mas não pode fazer nenhuma ação que exija calma e concentração.","unidentified":""},"source":"","ativacao":{"execucao":"free","custo":2,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_sta
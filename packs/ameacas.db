{"_id":"4bdMgKDWlnZ7SaO1","name":"Cavaleiro Supremacista","type":"npc","img":"systems/tormenta20/icons/ameacas/cavaleiro_supre.webp","items":[{"_id":"vSiBFyuzECuCuLzT","name":"Espada bastarda","type":"arma","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/itens/espada-bastarda.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Maior e mais pesada que a espada longa, esta arma é tradicionalmente usada pelos cavaleiros de Bielefeld. A espada bastarda é uma arma adaptável. É muito grande para ser usada com uma só mão sem treinamento especial; por isso é uma arma exótica. Ela pode ser usada como uma arma marcial de duas mãos.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":3,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20",""],["luta",""],[4,""]]},{"key":"dano0","name":"Dano","type":"dano","parts":[["3d6",""],["@for",""],[9,""]]}],"criticoM":19,"criticoX":3,"lancinante":false,"alcance":"","tipoUso":"exo","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false,"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false},"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"3d6","atqBns":"25","danoBns":"15","tipo":"","custo":0,"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":"","ativacao":{"custo":null}},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"qsnU9NvGAhcLn8Oi","name":"Cavaleiro Mistico","type":"poder","sort":0,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"descriptio
ria deve vencer um teste de Vontade oposto contra o vampiro ou ficará sob o controle dele até que ele a liberte ou seja destruído.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":null,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"classe","subtipo":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"wWsB33owU7307ZJ0","name":"Drenar Sangue","type":"poder","sort":300000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O vampiro drena sangue de uma criatura viva que esteja agarrando. Isso exige um acerto num ataque desarmado (bônus de +20) e causa 4d6 pontos de dano. Para cada ponto de dano causado, o vampiro recupera 1 PV.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":null,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"classe","subtipo":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"core
el. É muito grande para ser usada com uma só mão sem treinamento especial; por isso é uma arma exótica. Ela pode ser usada como uma arma marcial de duas mãos.</p>","peso":3,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"3d6","atqBns":"25","danoBns":"15","criticoM":19,"criticoX":3,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"exotica","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"systems/tormenta20/icons/itens/espada-bastarda.webp","effects":[]},{"_id":"qsnU9NvGAhcLn8Oi","name":"Cavaleiro Mistico","type":"poder","data":{"description":"O cavaleiro pode lançar magias arcanas de armadura sem precisar de testes de Misticismo. Além disso, quando usa a ação atacar para fazer um ataque corpo a corpo, pode pagar 1 PM para lançar uma magia com execução padrão como uma ação livre. Ele ainda precisa pagar o custo em PM da magia.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":0,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"kcgE2dXnmUqesUAr","name":"Ódio Puro","type":"poder","data":{"description":"Um supremacista recebe +5 em testes de Vontade quando está seguindo ordens de um superior (qualquer supremacista com ND maior) e +2 em rolagens de dano contra humanoides não humanos.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"bTua2ujDZx5B698y","name":"Magia Acelerada","type":"poder","data":{"description":" Quando lança uma magia com execução de ação completa ou menor, o cavaleiro muda a execução dela para livre. Ele só pode usar este poder uma vez por rodada.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":" livre","custo":"4","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"mBfgfcazE6LhxcXA","name":"Concentração de Combate","type":"magia","data":{"description":"<p>Você amplia sua percepção, antecipando movimentos dos inimigos e achando brechas em sua defesa. Quando faz um ataque, você rola dois dados e usa o melhor resultado.</p>","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"muda a execução para padrão e a duração para cena. Requer 2º círculo.","_id":"","id":"5520261d-b9e8-4e23-80e5-ddc3c6e67af5","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"além do normal, ao atacar você, um inimigo deve rolar dois dados e usar o pior resultado. Requer 3º círculo.","_id":"","id":"cf1cba3e-5aff-4cde-a3b6-300cfb7eac4a","ativo":false},{"custo":"9","tipo":"Muda","formula":"","description":"muda a execução para padrão, o alcance para curto, o alvo para criaturas escolhidas e a duração para cena. Requer 4º círculo.","_id":"","id":"e66653e3-9795-46c0-9c9f-bbe9043034d9","ativo":false},{"custo":"14","tipo":"Muda","formula":"","description":"muda a execução para padrão e a duração para 1 dia. Além do normal, você recebe um sexto sentido que o avisa de qualquer perigo ou ameaça. Você fica imune às condições surpreendido e desprevenido e recebe +10 em Defesa e Reflexos. Requer 5º círculo.","_id":"","id":"2bc4cff3-69ec-4acc-b91d-b52c75491d50","ativo":false}],"alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"Você","area":"","ativacao":{"execucao":"livre","custo":1,"condicao":""},"duracao":{"valor":"1 rodada","unidade":"outra"},"resistencia":"","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Adivinhação","efeito":""},"sort":400000,"flags":{"core":{"sourceId":"Item.1UBi6j1FJdnCdLH1"}},"img":"systems/tormenta20/icons/magias/concentracao-de-combate.webp","effects":[{"_id":"LvHT31M1UBY6eqIL","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"execucao","value":"padrão","mode":5},{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a execução para padrão e a duração para cena. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"2XHxvPBjrqijXw9I","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"além do normal, ao atacar você, um inimigo deve rolar dois dados e usar o pior resultado. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"NrEAsxaqpXAWVZ5d","flags":{"t20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"execucao","value":"padrão","mode":5},{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5},{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a execução para padrão, o alcance para curto, o alvo para criaturas escolhidas e a duração para cena. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"Q9xwXkqN6t3iEhBD","flags":{"t20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[{"key":"execucao","value":"padrão","mode":5},{"key":"duracao","value":"1 dia","mode":5},{"key":"condicao","value":"surpreendido","mode":0},{"key":"condicao","value":"desprevenido","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a execução para padrão e a duração para 1 dia. Além do normal, você recebe um sexto sentido que o avisa de qualquer perigo ou ameaça. Você fica imune às condições surpreendido e desprevenido e recebe +10 em Defesa e Reflexos. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false}]},{"_id":"2JUaqzK86fyvLfaW","name":"Toque Chocante","type":"magia","data":{"description":"<p>Arcos elétricos envolvem sua mão, causando 2d8+2 pontos de dano de eletricidade. Se o alvo usa armadura de metal (ou carrega muito metal, a critério do mestre), sofre uma penalidade de –5 no teste de resistência.</p>","aprimoramentos":[{"custo":"1","tipo":"Aumenta","formula":"1d8","description":"aumenta o dano em 1d8+1.","_id":"","id":"44210768-e2a1-4493-9cb9-d162c0ecd83d","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"como parte da execução da magia, você faz um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia.","_id":"","id":"8787d101-abc5-4647-9605-f554e96fc0cd","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para pessoal e o alvo para área: explosão com 6m de raio. Você dispara raios pelas pontas dos dedos que afetam todas as criaturas na área.","_id":"","id":"9310bdb5-f994-4e3d-ac5b-f000356ac4f1","ativo":false}],"alcance":"Toque","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 criatura","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"Fortitude reduz à metade","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Evocação","efeito":"2d8+2"},"sort":500000,"flags":{"core":{"sourceId":"Item.8bINHKgmg0uVS0QQ"}},"img":"systems/tormenta20/icons/magias/toque-chocante.webp","effects":[{"_id":"YyP4qNu40Ggkwz0a","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"roll","value":"1d8","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em 1d8+1.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false},{"_id":"jKiy3mRU5EbSl9LA","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"como parte da execução da magia, você faz um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false},{"_id":"oIteVo1ef18mDkof","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"área: explosão com 6m de raio","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para área: explosão com 6m de raio. Você dispara raios pelas pontas dos dedos que afetam todas as criaturas na área.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false}]},{"_id":"k77xAfS1KQBEHISc","name":"Dissipar Magia","type":"magia","data":{"description":"<p>Você dissipa outras magias que estejam ativas, como se sua duração tivesse acabado. Note que efeitos de magias instantâneas não podem ser dissipados (não se pode dissipar uma Bola de Fogo ou Relâmpago depois que já causaram dano...). Se lançar essa magia em uma criatura ou área, faça um teste de Misticismo; você anula as magias com CD igual ou menor que o resultado do teste. Se lançada contra um item mágico, o transforma em um item mundano por 1d6 rodadas (sem teste de resistência).</p>","aprimoramentos":[{"custo":"12","tipo":"Muda","formula":"","description":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5º círculo.","_id":"","id":"5e8f8155-211c-45e8-adab-2f2f727384e7","ativo":false}],"alcance":"Médio","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 criatura ou 1 objeto mágico ou esfera com 3m de raio","area":"","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"int","cd":0,"tipo":"Universal","circulo":"2","preparada":false,"escola":"Abjuração","efeito":""},"sort":1100001,"flags":{"core":{"sourceId":"Item.LnZpwedvAkmScrZG"}},"img":"systems/tormenta20/icons/magias/dissipar-magia.webp","effects":[{"_id":"kKZ6L0mhMN53y13e","flags":{"t20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"area","value":"esfera com 9m de raio","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5º círculo.","origin":"Compendium.tormenta20.magias.rfTGYwrXLjcIAIP5","transfer":false}]},{"_id":"Dq0Hhp2qiobehjj3","name":"Relâmpago","type":"magia","data":{"description":"<p>Você dispara um poderoso raio que causa 6d6 pontos de dano de eletricidade em todas as criaturas e objetos livres na área.</p>","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"2d6","description":"aumenta o dano em +2d6.","_id":"","id":"9ab881f3-675d-45fb-b9a2-946e777af869","ativo":false},{"custo":"3","tipo":"Muda","formula":"6d6","description":"muda a área para alvo (criaturas escolhidas). Em vez do normal, você dispara vários relâmpagos, um para cada alvo escolhido, causando 6d6 pontos de dano de eletricidade. Requer 3º círculo.","_id":"","id":"0daa768e-6656-4e1a-8c33-4f4a60ab80b5","ativo":false}],"alcance":"Médio","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"linha","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"Reflexos reduz à metade","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"2","preparada":false,"escola":"Evocação","efeito":"6d6"},"sort":1200001,"flags":{"core":{"sourceId":"Item.9jTiP3egh02qOole"}},"img":"systems/tormenta20/icons/magias/relampago.webp","effects":[{"_id":"XIxcAX2dWaFDGsfG","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"roll","value":"2d6","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6.","origin":"Compendium.tormenta20.magias.BfYpxjs0NeqhAs8q","transfer":false},{"_id":"UbfkJ2MbLTgN5Aci","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"area","value":"alvo (criaturas escolhidas)","mode":5},{"key":"roll","value":"6d6","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a área para alvo (criaturas escolhidas). Em vez do normal, você dispara vários relâmpagos, um para cada alvo escolhido, causando 6d6 pontos de dano de eletricidade. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.BfYpxjs0NeqhAs8q","transfer":false}]},{"_id":"sfWpmldN9pOBzwYf","name":"Velocidade","type":"magia","data":{"description":"<p>O alvo pode realizar uma ação padrão ou de movimento adicional por turno. Esta ação não pode ser usada para lançar magias e ativar engenhocas.</p>","aprimoramentos":[{"custo":"7","tipo":"Muda","formula":"","description":"muda o alvo para criaturas escolhidas no alcance. Requer 4º círculo.","_id":"","id":"3e10b140-fc6f-4aa1-8465-27f8139f017b","ativo":false},{
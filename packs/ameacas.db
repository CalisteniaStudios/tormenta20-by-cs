da":false,"treinado":0,"treino":0,"outros":0,"notes":"","mod":0,"temp":0,"bonus":0,"penalidade":0}},"periciasCustom":[],"resistencias":"cura acelerada 10, resistência a dano 10/luz, Imunidade  a  doenças,  fadiga,  sangramento,  sono  e  venenos;  não  precisa  respirar,  alimentar-se e dormir; sofre dano por magias de cura e recupera PV com dano de trevas;","tamanho":"Medio","detalhes":{"biografia":"","dinheiro":{"tt":0,"to":0,"tp":0,"tc":0,"tl":0},"carga":0},"referencias":[],"modificadores":{"atributos":{"bonus":0,"penalidade":0,"geral":0,"fisicos":0,"mentais":0,"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0},"pericias":{"bonus":0,"penalidade":0,"geral":0,"semataque":0,"ataque":0,"resistencia":0,"atr":{"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0}},"ataques":{"bonus":0,"penalidade":0},"custosPM":{"bonus":0,"penalidade":0},"dano":{"geral":0,"cac":0,"ad":0,"mag":0},"custoPM":0},"sentidos":"visão no escuro","biography":"","equipament":"Armadura completa delicada de mitral, espada longa certeira e precisa de mitral","treasure":"Dobro.","deslocamento":{"base":9,"bonus":0,"penalidade":0,"total":9,"cond":"nao","subst":0,"descricao":""},"atributoChave":"car"},"sort":100001,"flags":{"editing":false},"img":"https://i.imgur.com/hEo02H9.png","token":{"flags":{},"name":"Vampiro","displayName":0,"img":"https://i.imgur.com/hEo02H9.png","tint":"","width":1,"height":1,"scale":1.1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":true,"dimSight":0,"brightSight":18,"dimLight":0,"brightLight":0,"sightAngle":360,"lightAngle":360,"lightColor":"","lightAlpha":1,"lightAnimation":{"type":"","speed":5,"intensity":5},"actorId":"d5Im71VWcxIz9xKM","actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":""},"bar2":{"attribute":""},"randomImg":false},"items":[{"_id":"DKFyKWrBq6jDLgUE","name":"Espada longa","type":"arma","data":{"description":"<p>Arma típica de soldados e guerreiros, esta espada de dois gumes tem lâmina reta medindo entre 80cm e 1m.</p>","peso":2,"qtd":1,"preco":15,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d8","atqBns":"25","danoBns":"8","criticoM":17,"criticoX":2,"lancinante":false,"tipo":"Corte","alcance":"-","custo":0,"tipoUso":"marcial","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.LirOBCaOzAEWQpFk"}},"img":"systems/tormenta20/icons/itens/espada-longa.webp","effects":[]},{"_id":"DDizJyFYleWOXJFX","name":"Cria","type":"poder","data":{"description":"<p>O vampiro faz uma criatura morta pela habilidade Drenar Sangue se erguer como um vampiro na noite seguinte. A cria deve vencer um teste de Vontade oposto contra o vampiro ou ficará sob o controle dele até que ele a liberte ou seja destruído.</p>","alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"padrao","custo":null,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"wWsB33owU7307ZJ0","name":"Drenar Sangue","type":"poder","data":{"description":"<p>O vampiro drena sangue de uma criatura viva que esteja agarrando. Isso exige um acerto num ataque desarmado (bônus de +20) e causa 4d6 pontos de dano. Para cada ponto de dano causado, o vampiro recupera 1 PV.</p>","alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"padrao","custo":null,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"JnkAP0TfO1qC0F24","name":"Forma de Morcego","type":"poder","data":{"description":"<p>O vampiro se transforma em um morcego. Ele adquire tamanho Minúsculo (o que fornece +5 em Furtividade e -5 em testes de manobra) e recebe deslocamento de voo 12m. Seu equipamento é absorvido (retornando quando ele volta ao normal) e suas outras estatísticas não são alteradas. A transformação dura quanto tempo ele desejar, mas termina caso faça um ataque, lance uma magia ou sofra dano.</p>","alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"padrao","custo":null,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"Rjj2kksVhIxXeSoP","name":"Presença Majestosa","type":"poder","data":{"description":"<p>Quando uma criatura ataca o vampiro, deve passar em um teste de Vontade (CD 27) ou não conseguirá machucá-lo e perderá a ação.</p>","alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"reacao","custo":2,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":""},"sort":500000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"9OfE4RveXO9eupyc","name":"Sensibilidade ào Sol","type":"poder","data":{"description":"<p>Quando exposto a luz solar direta, o vampiro fica ofuscado e sofre [[/r 6d6]] pontos de dano por rodada (ignora a resist&ecirc;ncia a dano do vampiro).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"6d6","tipo":"classe","subtipo":"","chatFlavor":""},"sort":600000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"sMy32z2XohFTuWT5","name":"Garra","type":"arma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d4","atqBns":"20","danoBns":"6","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"chatFlavor":""},"sort":1800001,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"xe40sK4yQLoL3hZB","name":"Enfeitiçar","type":"magia","data":{"description":"<p>Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","_id":"","id":"07ab3013-a5c5-4805-ae1e-b87017f48c42","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","_id":"","id":"79758da9-d2f9-4b71-896e-763d309d8bb6","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta todos os alvos dentro do alcance.","_id":"","id":"16407353-737b-43b1-a0e1-f1373f8af7c2","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 humanóide","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade anula","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Encantamento","efeito":""},"sort":1300001,"flags":{"core":{"sourceId":"Item.ARP9yn6keaH9aNKt"}},"img":"systems/tormenta20/icons/magias/enfeiticar.webp","effects":[{"_id":"wuyNqXeAYnTZxLx7","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false}]},{"_id":"GY5SeJDpyjeq8cdS","name":"Hipnotismo","type":"magia","data":{"description":"<p>Suas palavras e movimentos ritmados deixam as criaturas fascinadas. Esta magia só afeta criaturas que possam perceber você. Se usar esta magia em combate, os alvos recebem +5 em seus testes de resistência.</p>","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"muda o alvo para 1 criatura e a duração para 1 rodada. Em vez de fascinado, o alvo fica pasmo. Uma criatura só pode ser afetada por este truque uma vez por cena.","_id":"","id":"6785cdf8-7808-4eec-826e-13d9f36869df","ativo":false},{"custo":"1","tipo":"Outros","formula":"","description":"como o normal, mas se passarem na resistência os alvos não saberão que foram alvos de uma magia.","_id":"","id":"a22d0833-d721-4995-8ba8-e2f94dd12472","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para cena.","_id":"","id":"f08e96c1-68cb-4a43-98a0-f932eafca2f7","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para médio.","_id":"","id":"8fa3d786-b239-48a9-9519-60578f42b0a4","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"afeta alvos de ND 5 ou menor. Requer 2º círculo.","_id":"","id":"a295368f-80cc-4b6e-bb03-6b55e5adca76","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta alvos de ND 10 ou menor. Requer 3º círculo.","_id":"","id":"5ba2b055-82f8-42e9-9567-0bf41a2705a2","ativo":false},{"custo":"9","tipo":"Outros","formula":"","description":"afeta alvos de ND 15 ou menor. Requer 4º círculo.","_id":"","id":"a5b87763-2f18-4c48-8152-50353fe18c6d","ativo":false},{"custo":"14","tipo":"Outros","formula":"","description":"afeta alvos de qualquer ND. Requer 5º círculo.","_id":"","id":"d4aceea0-30d1-4150-adf5-c8cee495baa4","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"criaturas escolhidas de ND 2 ou menor","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"1d4 rodadas","unidade":"outra"},"resistencia":"Vontade anula","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Encantamento","efeito":""},"sort":600001,"flags":{"core":{"sourceId":"Item.JGfGGFDkpUiiIkvg"}},"img":"systems/tormenta20/icons/magias/hipnotismo.webp","effects":[{"_id":"0qnDVKlJ4Y6vIqzN","flags":{"t20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5},{"key":"duracao","value":"1 rodada","mode":5},{"key":"condicao","value":"fascinado","mode":0},{"key":"condicao","value":"pasmo","mode":0}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura e a duração para 1 rodada. Em vez de fascinado, o alvo fica pasmo. Uma criatura só pode ser afetada por este truque uma vez por cena.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"jN9vw5EXuCc5hmMq","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"como o normal, mas se passarem na resistência os alvos não saberão que foram alvos de uma magia.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"n2XIwlHRUXWsyWoe","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda a duração para cena.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"yU9cKxRGtCBztsFj","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"médio","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para médio.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"fkKKvRKmx4fLgSzp","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 5 ou menor. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"9h8Bd2cCqHTlY8pk","flags":{"t20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 10 ou menor. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"3nAshgPzsnzLHb6y","flags":{"t20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 15 ou menor. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"TcMcIJl3ParLiqKj","flags":{"t20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de qualquer ND. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false}]},{"_id":"yvChlnUmUlw8klFe","name":"Sussurros Insanos","type":"magia","data":{"description":"<p>Você murmura palavras desconexas que afetam a mente do alvo. O alvo fica confuso.</p>","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o número de alvos em +1.","_id":"","id":"1a362091-d71e-4e2f-bff6-c110349e43b5","ativo":false},{"custo":"3","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura.","_id":"","id":"b4ad5a13-6950-4a80-a983-828185e0a43b","ativo":false},{"custo":"12","tipo":"Muda","formula":"","description":"muda o alvo para criaturas escolhidas. Requer 5º círculo.","_id":"","id":"4708eca9-efae-489f-92c1-fa3b0c0c2ddf","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 humanoide","area":"","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade anula","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"2","preparada":false,"escola":"Encantamento","efeito":""},"sort":1900001,"flags":{"core":{"sourceId":"Item.j3ykT4OMk0qP8PSg"}},"img":"systems/tormenta20/icons/magias/sussurros-insanos.webp","effects":[{"_id":"a91Qq4uJWCt9BaHJ","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.s9z7z8KtujpICCZw","transfer":false},{"_id":"n4P4UlD5bQRhtzIh","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.s9z7z8KtujpICCZw","transfer":false},{"_id":"Yiwe30aN5lDHb5mk","flags":{"t20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.s9z7z8KtujpICCZw","transfer":false}]},{"_id":"6vq1x4dGEj5FEpPk","name":"Imobilizar","type":"magia","data":{"description":"<p>O alvo fica paralisado; se passar na resistência, em vez disso fica lento. A cada rodada, pode gastar uma ação completa para fazer um novo teste de Vontade. Se passar, se liberta do efeito.</p>","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda o alvo para 1 espírito.","_id":"","id":"46d8b25c-7e3f-44f8-ab45-810d2282710d","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o número de alvos em +1.","_id":"","id":"3b4b7c74-d243-4e72-856e-6ce42cd42492","ativo":false},{"custo":"3","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura. Requer 4º círculo","_id":"","id":"20c67c79-b7ef-4461-9444-d5855c022bb7","ativo":false}],"alcance":"Curto","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 humanóide ou animal","area":"","ativacao":{"execucao":"padrao","custo":6,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"Vontade parcial","atrRes":"int","cd":0,"tipo":"Universal","circulo":"3","preparada":false,"escola":"Encantamento","efeito":""},"sort":900001,"flags":{"core":{"sourceId":"Item.PpdYrxI9UwSNot2P"}},"img":"systems/tormenta20/icons/magias/imobilizar.webp","effects":[{"_id":"fSTTlBXholQ6WJhC","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito.","origin":"Compendium.tormenta20.magias.vwpjRRdyR0iHI1TH","transfer":false},{"_id":"czmZboVVWzbVD2om","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.vwpjRRdyR0iHI1TH","transfer":false},{"_id":"50yF4EBxvj43Q4M7","flags":{"t20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura. Requer 4º círculo","origin":"Compendium.tormenta20.magias.vwpjRRdyR0iHI1TH","transfer":false}]},{"_id":"A8SUPgcr8J9Zvljf","name":"Toque Vampírico","type":"magia","data":{"description":"<p>Sua mão brilha com energia sombria, causando 6d6 pontos de dano de trevas. Você recupera pontos de vida iguais à metade do dano causado (se causou algum dano).</p>","aprimoramentos":[{"custo":"1","tipo":"Outros","formula":"","description":"como parte da execução da magia, você pode fazer um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia, e recupera pontos de vida iguais à metade do dano da magia.","_id":"","id":"8da7ae35-4b1c-4ac4-a7cb-7f991c586cba","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"2d6","description":"aumenta o dano em +2d6.","_id":"","id":"0de74972-d593-495f-a45d-e70a0d0f6f1d","ativo":false},{"custo":"2","tipo":"Muda","formula":"3d6","description":"muda o alcance para pessoal, o alvo para você e a duração para cena. Em vez do normal, a cada rodada você pode gastar uma ação padrão para tocar 1 criatura e causar 3d6 pontos de dano. Você recupera pontos de vida iguais à metade do dano causado. Requer 3º círculo.","_id":"","id":"b43be2d5-060d-414a-9425-b8af5eb6d013","ativo":false}],"alcance":"Toque","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"1 criatura","area":"","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":"instant"},"resistencia":"Fortitude reduz à metade","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"2","preparada":false,"escola":"Necromancia","efeito":"6d6"},"sort":2000001,"flags":{"core":{"sourceId":"Item.pXsAXnZf1UW8Jc1z"}},"img":"systems/tormenta20/icons/magias/toque-vampirico.webp","effects":[{"_id":"5E8DwOxwvQNlJJN4","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{},"icon":"icons/svg/upgrade.svg","label":"como parte da execução da magia, você pode fazer um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia, e recupera pontos de vida iguais à metade do dano da magia.","origin":"Compendium.tormenta20.magias.6KvwDBikOdbzhRGv","transfer":false},{"_id":"Fp3cotDEql0E2Dur","flags":{"t20":{"onuse":true,"self":true,"custo":"2","aume
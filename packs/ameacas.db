{"_id":"WMcZXuIIRzCPzr6a","name":"Colosso Supremo","type":"npc","img":"systems/tormenta20/icons/ameacas/colosso-supremo.png","items":[{"_id":"vSiBFyuzECuCuLzT","name":"Espada titânica","type":"arma","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20","",""],["luta","",""],["4","",""]],"versatil":""},{"key":"dano0","name":"Dano","type":"dano","parts":[["4d12","",""],["@for","",""],["15","",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"dup":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false,"lancinating":false},"chatFlavor":"","ativacao":{"custo":null,"condicao":"","execucao":"","qtd":"","special":""},"origin":"","tags":[],"chatGif":"","consume":{"amount":0,"mpMultiplier":false,"target":"","type":""},"upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"proficiencia":"simples","proposito":"corpo-a-corpo","empunhadura":"uma","size":"normal"},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"qsnU9NvGAhcLn8Oi","name":"Balistas","type":"poder","sort":0,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Um colosso supremo possui duas balistas, uma em cada ombro. Cada balista &eacute; tripulada por soldados que a carregam e a disparam em rodadas alternadas (b&ocirc;nus de ataque [[/r 1d20+13]], [[/r 6d8]] pontos de dano de perfura&ccedil;&atilde;o, cr&iacute;tico 19, alcance m&eacute;dio). &Eacute; poss&iacute;vel atacar as tripula&ccedil;&otilde;es para impedir os disparos. Cada tripula&ccedil;&atilde;o possui Defesa 26, 50 pontos de vida e usa os testes de resist&ecirc;ncia do colosso.</p>","unidentified":""},"source":"","ativacao":{"execucao":"free","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"bTua2ujDZx5B698y","name":"Fumos Tóxicos","type":"poder","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Uma criatura que comece seu turno em alcance curto do colosso sofre [[/r 4d6]] pontos de dano de veneno e fica enjoada (Fortitude CD 30 evita).</p>","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["4d6","",""]],"versatil":""}],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"64LhGQcbLshnJU3y","name":"Goblins Consertadores","type":"poder","sort":200000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"Goblins especialmente pequenos rastejam por dentro dos dutos do colosso fazendo reparos, o que fornece ao construto cura acelerada 20. Por estarem dentro do construto, os goblins são imunes a dano, mas ainda podem ser afetados por efeitos mentais. Eles possuem Vontade +2 (mas recebem a resistência a magia do colosso) e, se forem afetados por qualquer condição, a cura acelerada deixa de funcionar.","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"nrWEwtD2npplXxdh","name":"Jato de Chamas","type":"poder","sort":400000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O colosso dispara um jato de chamas que atinge um cone com alcance m&eacute;dio. Criaturas na &aacute;rea sofrem [[/r 8d8+10]] pontos de dano de fogo (Ref CD 35 reduz &agrave; metade).</p>","unidentified":""},"source":"","ativacao":{"execucao":"
:false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você dispara um raio púrpura que drena as forças do alvo. Se falhar na resistência, o alvo fica fatigado. Se passar, fica vulnerável.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"vzpaRLT3xUieS5Um","name":"Vitalidade Fantasma","type":"magia","sort":1500000,"flags":{"core":{"sourceId":"Item.7FppkWUX7ku2V1qt"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/vitalidade-fantasma.webp","effects":[{"_id":"8ky11WxusJyBeRiV","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d8","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os PV temporários recebidos em +1d8.","origin":"Compendium.tormenta20.magias.505PykOz1CmG2CU3","transfer":false,"tint":null},{"_id":"FQSR5xVzMWSV6cjs","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"área: esfera com 6m de raio centrada em você","mode":5,"priority":null},{"key":"resistencia","value":"Fortitude reduz à metade","mode":5,"priority":null},{"key":"dano","value":"1d8","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para área: esfera com 6m de raio centrada em você e a resistência para Fortitude reduz à metade. Em vez do normal, você suga energia das criaturas vivas na área, causando 1d8 pontos de dano de trevas e recebendo PV temporários iguais ao dano total causado. Os PV temporários desaparecem ao final da cena. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.505PykOz1CmG2CU3","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você suga energia vital da terra, recebendo 2d8 pontos de vida temporários. Os PV temporários desaparecem ao final da cena.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"0apXtJxzT7EwURbu","name":"Conjurar Mortos-Vivos","type":"magia","sort":1600000,"flags":{"core":{"sourceId":"Item.FfIZiBV2pHK3ddJG"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/conjurar-mortos-vivos.webp","effects":[{"_id":"4qjvv6kmamN4fee7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de mortos-vivos conjurados em +1.","origin":"Compendium.tormenta20.magias.5ZjS4bVvSxWNpBL9","transfer":false,"tint":null},{"_id":"NgMgwIWCx2QWJ9yq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez de esqueletos, conjura carniçais. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.5ZjS4bVvSxWNpBL9","transfer":false,"tint":null},{"_id":"4O6MhQ318Rz4ggO0","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez de esqueletos, conjura sombras. Requer 4º círculo.\n\nCarniçal: como o esqueleto, mas tem For 16, Des 16, 12 PV e causa 1d8+3 pontos de dano de trevas mais 1d8 pontos de dano de veneno. Além disso, criaturas atingidas por um carniçal devem passar num teste de Fortitude (CD igual à da magia) ou ficam paralisadas por 1 rodada. Uma criatura que passe no teste de resistência fica imune à paralisia dos carniçais por 24 horas.\n\nSombra: como o esqueleto, mas tem a habilidade incorpóreo, Des 18, 30 PV e causa 1d10 pontos de dano de trevas mais 1d10 pontos de dano de frio. Além disso, criaturas vivas atingidas por uma sombra devem passar num teste de Fortitude (CD igual à da magia) ou perdem 1d4 PM. Sombras perdem a habilidade incorpóreo quando expostas à luz do sol.","origin":"Compendium.tormenta20.magias.5ZjS4bVvSxWNpBL9","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Seis esqueletos de tamanho Médio feitos de energia negativa emergem do chão em espaços desocupados escolhidos por você dentro do alcance. Você pode usar uma ação de movimento para fazer os mortos-vivos andarem (eles têm deslocamento 9m) ou uma ação padrão para fazê-los causar dano a criaturas adjacentes (1d6+2 pontos de dano de trevas cada). Os esqueletos têm For 14, Des 14 e todos os outros atributos nulos; eles têm 1 PV, não têm valor de Defesa ou testes de resistência, falham automaticamente em qualquer teste oposto e são imunes a atordoamento, dano não letal, doença, encantamento, fadiga, frio, ilusão, paralisia, sono e veneno. Eles desaparecem quando são reduzidos a 0 PV ou no fim da cena. Os mortos-vivos não agem sem receber uma ordem. Usos criativos para criaturas invocadas fora de combate ficam a critério do mestre.</p>","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"6 mortos-vivos","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"mlkthgNrJvlATi1f","name":"Toque Vampírico","type":"magia","sort":1700000,"flags":{"core":{"sourceId":"Item.pXsAXnZf1UW8Jc1z"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/toque-vampirico.webp","effects":[{"_id":"5E8DwOxwvQNlJJN4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"como parte da execução da magia, você pode fazer um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia, e recupera pontos de vida iguais à metade do dano da magia.","origin":"Compendium.tormenta20.magias.6KvwDBikOdbzhRGv","transfer":false,"tint":null},{"_id":"Fp3cotDEql0E2Dur","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6.","origin":"Compendium.tormenta20.magias.6KvwDBikOdbzhRGv","transfer":false,"tint":null},{"_id":"F7eldvQNlVrQTK7z","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5,"priority":null},{"key":"alvo","value":"você","mode":5,"priority":null},{"key":"duracao","value":"Cena","mode":5,"priority":null},{"key":"dano","value":"3d6","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal, o alvo para você e a duração para cena. Em vez do normal, a cada rodada você pode gastar uma ação padrão para tocar 1 criatura e causar 3d6 pontos de dano. Você recupera pontos de vida iguais à metade do dano causado. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.6KvwDBikOdbzhRGv","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Sua mão brilha com energia sombria, causando 6d6 pontos de dano de trevas. Você recupera pontos de vida iguais à metade do dano causado (se causou algum dano).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"6d6","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["6d6","",""]],"versatil":""}],"tipo":"arc","circulo":"2","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ECVfK3mxF3654Y8Y","name":"Ferver Sangue","type":"magia","sort":2300001,"flags":{"core":{"sourceId":"Item.nH9O86YqO06Gr5mm"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/ferver-sangue.webp","effects":[{"_id":"Bxba43zea5xHivv6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d6","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Compendium.tormenta20.magias.tVxVarpB0GaAoCp5","transfer":false,"tint":null},{"_id":"tLIrRjfeyDLLV8Q3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda alvo para criaturas escolhidas. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.tVxVarpB0GaAoCp5","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O sangue do alvo aquece rapidamente até entrar em ebulição. Quando a magia é lançada, e no início de cada um de seus turnos, o alvo sofre 3d6 pontos de dano de fogo (Fortitude reduz à metade). Se o alvo passar em dois testes de Fortitude seguidos, dissipa a magia. Se o alvo for reduzido a 0 PV pelo dano desta magia, seu corpo explode, matando-o e causando 6d6 pontos de dano de fogo em todas as criaturas a até 3m (Reflexos reduz à metade). Essa magia não afeta criaturas sem sangue, como construtos ou espíritos.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"3d6","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["3d6","",""]],"versatil":""}],"tipo":"arc","circulo":"3","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"8qmK57EpSjQR3Kar","name":"Servo Morto-Vivo","type":"magia","sort":2400001,"flags":{"core":{"sourceId":"Item.3Tpw8F0z40KpcNr4"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/servo-morto-vivo.webp","effects":[{"_id":"0MUgwJG22KJfRtDB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o componente material para pó de ônix negro (T$ 500). Em vez de um zumbi ou esqueleto, cria um carniçal. Ele pode funcionar como um aliado veterano, escolhido entre ajudante, atirador, combatente, fortão ou guardião. O resto segue normal.","origin":"Compendium.tormenta20.magias.CmdKoggK1dreuNpP","transfer":false,"tint":null},{"_id":"ukcKr4JgoW2Esv5l","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o componente material para pó de ônix negro (T$ 500). Em vez de um zumbi ou esqueleto, cria uma sombra. Ela pode funcionar como um aliado veterano, escolhido entre assassino, combatente ou perseguidor. O restante da magia segue normal.","origin":"Compendium.tormenta20.magias.CmdKoggK1dreuNpP","transfer":false,"tint":null},{"_id":"nhFAf9tFFCImUkhQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o componente material para ferramentas de embalsamar (T$ 1.000). Em vez de um zumbi ou esqueleto, cria uma múmia. Ela pode funcionar como um aliado mestre, escolhido entre ajudante, destruidor, guardião ou médico. O restante da magia segue normal. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.CmdKoggK1dreuNpP","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia transforma o cadáver de um humanoide, animal ou monstro em um esqueleto ou zumbi (conforme o estado de conservação do corpo). O morto-vivo então obedece a todos os seus comandos, mesmo suicidas. Se quiser que o morto-vivo o acompanhe, ele funciona como um aliado iniciante, de um tipo a sua escolha entre ajudante, atirador, combatente, fortão, guardião ou montaria.</p><p style=\"text-align:justify;\">Se não quiser usar o morto-vivo como aliado, pode ordenar que ele proteja um local específico, atacando invasores (nesse caso, use as estatísticas de criaturas vistas no Capítulo 7: Ameaças). O nível somado de mortos-vivos sob seu comando ao mesmo tempo não pode exceder o seu próprio nível +3, mas você só pode receber os benefícios de um deles como aliado por vez. Eles duram até serem destruídos (um morto-vivo destruído não pode ser reanimado).</p><p style=\"text-align:justify;\"><i>Componente material:</i> um ônix negro (T$ 100), inserido na boca ou olho do cadáver.</p>","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":6,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 cadáver","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"yjjVjKOg5ilUjdoH","name":"Assassino Fantasmagórico","type":"magia","sort":2500001,"flags":{"core":{"sourceId":"Item.0yvWEcVoCIAN4LSU"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/assassino-fantasmagorico.webp","effects":[{"_id":"ON5qEG9EzuUOxuQr","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":true}},"changes":[],"disabled":false,"duration":{"startTime":null,"rounds":999,"seconds":null,"combat":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/aura.svg","label":"Abalado","origin":"Item.WNJNcz01G1zoWXiW","tint":null,"transfer":false}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Usando os medos subconscientes do alvo, voc&ecirc; cria uma imagem daquilo que ele mais teme. Apenas a pr&oacute;pria v&iacute;tima pode ver o Assassino Fantasmag&oacute;rico com nitidez; outras criaturas presentes (incluindo o conjurador) enxergam apenas um espectro sombrio. O espectro surge adjacente a voc&ecirc; e flutua em dire&ccedil;&atilde;o &agrave; v&iacute;tima com deslocamento total de voo 18m por turno. Ele &eacute; incorp&oacute;reo e imune a magias. Se o espectro terminar seu turno em alcance curto da v&iacute;tima, ela deve fazer um teste de Vontade. Se falhar, ficar&aacute; abalada. Se o espectro terminar seu turno adjacente &agrave; v&iacute;tima, ela deve fazer um teste de Fortitude. Se passar, sofre 6d6 pontos de dano de trevas (este dano n&atilde;o pode reduzir o alvo a menos de 0 PV e n&atilde;o o deixa sangrando). Se falhar, sofre um colapso, ficando imediatamente com &ndash;1 PV e sangrando. O espectro persegue o alvo implacavelmente. Ele s&oacute; desaparece se deixar seu alvo inconsciente, se for dissipado ou ao t&eacute;rmino da cena.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"special","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"long","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":100001,"flags":{"editing":false,"torme
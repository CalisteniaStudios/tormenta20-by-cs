pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"pon":{"label":"Pontaria","value":0,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"ref":{"label":"Reflexos","value":5,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"rel":{"label":"Religião","value":0,"atributo":"sab","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"sob":{"label":"Sobrevivência","value":0,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"von":{"label":"Vontade","value":14,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0}},"periciasCustom":{"0":{"label":"Religião","nome":"pericia","value":14},"1":{"label":"Misticismo","nome":"pericia","value":10}},"resistencias":"","tamanho":"Médio","deslocamento":"6m (4q)","detalhes":{"biografia":"","dinheiro":{"tt":0,"to":0,"tp":0,"tc":0},"carga":0}},"sort":100001,"flags":{"theatre":{"settings":{"emote":"idea","textflyin":null,"textstanding":null,"textfont":null,"textsize":null,"textcolor":null}}},"img":"systems/tormenta20/icons/ameaças/Monstro.webp","token":{"flags":"","name":"Capelão de Guerra","displayName":0,"img":"systems/tormenta20/icons/ameaças/Monstro_token.webp","tint":"","width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":false,"dimSight":0,"brightSight":0,"dimLight":0,"brightLight":0,"sightAngle":360,"lightAngle":360,"lightColor":"","lightAlpha":1,"actorId":"2kweWiPEjdPB3zkv","actorLink":false,"actorData":{},"disposition":0,"displayBars":50,"bar1":{"attribute":"attributes.pv"},"bar2":{"attribute":"attributes.pm"},"randomImg":false},"items":[{"_id":"sK43u2LkoOdnFzxA","flags":{},"name":"Adaga de Guerra","type":"arma","img":"icons/svg/mystery-man.svg","data":{"description":"","pericia":"lut","dano":"1d8","atrDan":"0","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"atqBns":14,"danoBns":"11","peso":0,"qtd":1,"preco":0,"tipoUso":"simples"},"sort":100000},{"_id":"NDq4PKmEJBDSH1Pa","flags":{},"name":"Coragem Total","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"O capelão é imune a efeitos de medo.","roll":"","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":200000},{"_id":"F6rTLkCT4sX5C6ao","flags":{},"name":"Sangue De ferro","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"(Livre, 2 PM) O capelão recebe +2 em rolagens de dano e resistência a dano 5 até o fim da cena.","roll":"","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":300000},{"_id":"uikzh1m7QC3Vlc1J","flags":"","name":"Escudo da Fé","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"Um escudo místico se manifesta momentaneamente para bloquear um golpe. O alvo recebe +2 na Defesa.","tipo":"Divina","circulo":"1","custo":1,"preparada":false,"escola":"Abjuração","execucao":"Reação","alcance":"Curto","duracao":"1 turno","resistencia":"","alvo":"1 criatura","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda a execução para ação padrão, o alcance para toque e a duração para cena.","_id":"","id":"6b17ed22-d6df-4cd4-aec9-fe4e75c0102a","ativo":false},{"custo":"1","tipo":"Outros","formula":"","description":"também fornece ao alvo camuflagem contra ataques à distância.","_id":"","id":"7c613add-b793-43d5-9eef-0253fae351ad","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus na Defesa em +1.","_id":"","id":"9f08a19d-41be-437a-9057-ab0f3e593570","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a execução para ação padrão, o alcance para toque e a duração para cena. A magia cria uma conexão mística entre você e o alvo. Além do efeito normal, o alvo sofre apenas metade do dano por ataques e efeitos; a outra metade do dano é transferida a você. Se a qualquer momento o alvo sair de alcance curto de você, a magia é dissipada. Requer 2o círculo.","_id":"","id":"4981e7e1-44ea-4cf3-b54f-ad188103fa0d","ativo":false},{"custo":"3","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Requer 2o círculo.","_id":"","id":"46801a57-cc70-4b1d-9f8e-34d26b3f3693","ativo":false}]},"sort":1000000},{"_id":"LkcljnRMfnROvBOn","flags":"","name":"Arma Mágica","type":"magia","img":"systems/tormenta20/icons/magias/Trans.webp","data":{"description":"A arma fornece um bônus de +1 nos testes de ataque e rolagens de dano e é considerada mágica. Caso você esteja empunhando a arma, pode usar seu atributo-chave de magias em vez do atributo original nos testes de ataque.","tipo":"Universal","circulo":"1","custo":1,"preparada":false,"escola":"Transmutação","execucao":"Padrão","alcance":"Toque","duracao":"Cena","resistencia":"","alvo":"1 arma","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","_id":"","id":"d237dacd-e691-4a93-a6df-19f38c7a3582","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"a arma passa a causar +1d6 de dano de ácido, eletricidade, fogo ou frio, escolhido no momento em que a magia é lançada.","_id":"","id":"0913741d-c3bf-492f-8483-ddf9fb990477","ativo":false}]},"sort":1100000},{"_id":"QERCKNwctKuaSGok","flags":"","name":"Dissipar Magia","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"Você dissipa outras magias que estejam ativas, como se sua duração tivesse acabado. Note que efeitos de magias instantâneas não podem ser dissipados (não se pode dissipar uma Bola de Fogo ou Relâmpago depois que já causaram dano...). Se lançar essa magia em uma criatura ou área, faça um teste de Misticismo; você anula as magias com CD igual ou menor que o resultado do teste. Se lançada contra um item mágico, o transforma em um item mundano por 1d6 rodadas (sem teste de resistência).","tipo":"Universal","circulo":"2","custo":3,"preparada":false,"escola":"Abjuração","execucao":"Padrão","alcance":"Médio","duracao":"Instantânea","resistencia":"","alvo":"1 criatura ou 1 objeto mágico ou esfera com 3m de raio","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"12","tipo":"Muda","formula":"","description":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5o círculo.","_id":"","id":"5e8f8155-211c-45e8-adab-2f2f727384e7","ativo":false}]},"sort":1200000},{"_id":"IWZM3r188Eq9D1XM","flags":"","name":"Soco de Arsenal","type":"magia","img":"systems/tormenta20/icons/magias/Conv.webp","data":{"description":"Ninguém sabe se Mestre Arsenal foi realmente o criador desta magia — mas ele foi o primeiro a utilizá-la. Você fecha o punho e gesticula como se estivesse golpeando o alvo, causando 4d6 + mod. Força pontos de dano de impacto. A vítima é empurrada 3m na direção oposta à sua (ou 1,5m se passar na resistência). +1 PM: muda o alcance para pessoal, o alvo para você, a duração para cena e a resistência para nenhuma. Em vez do normal, seus ataques corpo a corpo passam a acertar inimigos distantes. Seu alcance natural aumenta em 3m; uma criatura Média pode atacar adversários a até 4,5m, por exemplo. +2 PM: aumenta o dano em +1d6. +4 PM: aumenta a distância do efeito de empurrar em +3m. +5 PM: muda o tipo do dano para essência.","tipo":"Divina","circulo":"2","custo":3,"preparada":false,"escola":"Convocação","execucao":"Padrão","alcance":"Médio","duracao":"Instantânea","resistencia":"Fortitude reduz à metade","alvo":"1 criatura","area":"","cd":0,"efeito":"4d6"},"sort":1300000},{"_id":"TA4z6ToKbNJr8Lx8","flags":"","name":"Oração","type":"magia","img":"systems/tormenta20/icons/magias/Encan.webp","data":{"description":"Todos os seus aliados no alcance recebem +2 em testes de perícia e rolagens de dano, e todos os seus inimigos no alcance sofrem –2 em testes de perícia e rolagens de dano. Esses bônus e penalidades são cumulativos com outras magias.","tipo":"Divina","circulo":"2","custo":3,"preparada":false,"escola":"Encantamento","execucao":"Padrão","alcance":"Curto","duracao":"Sustentada","resistencia":"","alvo":"todas as criaturas (veja texto)","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta os bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","_id":"","id":"f7a914f3-be20-45e6-b14a-074ce8f29557","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta as penalidades em –1, limitado pelo círculo máximo de magia que você pode lançar.","_id":"","id":"5ea8bceb-b542-4c95-a4ab-8bb3527d6931","ativo":false},{"custo":"7","tipo":"Muda","formula":"","description":"muda o alcance para médio. Requer 3o círculo.","_id":"","id":"8014f814-496c-4cde-bce8-5036192ac0a3","ativo":false},{"custo":"12","tipo":"Muda","formula":"","description":"muda a duração para cena. Requer 4o círculo","_id":"","id":"b946e3dd-b16b-4161-83af-8dd0e70401c4","ativo":false}]},"sort":1400000}]}

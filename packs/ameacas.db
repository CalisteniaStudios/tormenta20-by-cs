rma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"4d6","atqBns":"33","danoBns":"17","criticoM":17,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"natural","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"5ygtkUnbb9uCIHb5","name":"Garra","type":"arma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"3d6","atqBns":"33","danoBns":"17","criticoM":17,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"natural","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"s3kXlTUBntkPzlqv","name":"Aura Aterradora","type":"poder","data":{"description":"<p>A simples vis&atilde;o de um drag&atilde;o adulto ou mais velho amedronta o mais valente dos aventureiros. Uma criatura que comece seu turno em alcance longo do drag&atilde;o fica apavorada (se tiver 5 n&iacute;veis ou menos) ou abalada (se tiver 6 n&iacute;veis ou mais) at&eacute; o fim da cena (Vontade CD 26 evita). Uma&nbsp;criatura que passe no teste de resist&ecirc;ncia&nbsp;fica imune a esta habilidade por 24 horas.</p>\n<p>&nbsp;</p>\n<p>&nbsp;</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":"","chatFlavor":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"LGp6Jv3l84OiKh8C","name":"Magia Acelerada","type":"poder","data":{"description":"Quando lança uma magia com execução de ação completa ou menor, o dragão muda a execução dela para livre. Ele só pode usar este poder uma vez por rodada.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":"4","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"livre","subtipo":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"UkgT26OUbB2iWjoK","name":"Sopro","type":"poder","data":{"description":"<p>Cone m&eacute;dio. Criaturas na &aacute;rea sofrem [[/r 16d12]] pontos de dano de fogo e ficam em chamas (Ref CD 31 reduz o dano &agrave; metade e evita as chamas).</p>\n<p>O drag&atilde;o n&atilde;o pode usar esta habilidade duas rodadas seguidas.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"padrao","custo":3,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"16d12","tipo":"classe","subtipo":"","chatFlavor":""},"sort":500000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"Lt579bcLP2MRKv2A","name":"Trespassar","type":"poder","data":{"description":"Quando o dragão faz um ataque corpo a corpo e reduz os pontos de vida do alvo para 0 ou menos, pode gastar 1 PM para fazer um ataque adicional contra outra criatura dentro do seu alcance.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":"1","condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":600000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"pgXVvldOdfDd4zCE","name":"Armadura Arcana","type":"magia","data":{"description":"<p style=\"text-align: justify;\">Esta magia cria uma pel&iacute;cula protetora invis&iacute;vel, mas tang&iacute;vel, fornecendo +4 na Defesa. Esse b&ocirc;nus &eacute; cumulativo com outras magias, mas n&atilde;o com b&ocirc;nus fornecido por armaduras.</p>","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual.","_id":"","id":"074ea668-ba8c-463a-b59f-e18ba5b21be9","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus na Defesa em +1.","_id":"","id":"8bf9652c-e245-4392-990b-6e92cb6e4aaf","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Requer 2o círculo.","_id":"","id":"ad230447-7151-4fc0-9a91-b36c6d6e1e57","ativo":false}],"alcance":"Pessoal","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"Você","area":"","ativacao":{"execucao":"padrao","custo":1,"condicao":""},"duracao":{"valor":"","unidade":"cena"},"resistencia":"","atrRes":"int","cd":0,"tipo":"Arcana","circulo":"1","preparada":false,"escola":"Abjuração","efeito":""},"sort":700000,"flags":{"core":{"sourceId":"Item.tgkYUPq9MY1YItoL"}},"img":"systems/tormenta20/icons/magias/armadura-arcana.webp","effects":[{"_id":"W1WgvYbVsADr5MNL","flags":{"t20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"execucao","value":"reacao","mode":5},{"key":"data.defesa.temp","value":2,"mode":2},{"key":"duracao","value":"1 turno","mode":5}],"disabled":true,"duration":{"startTime":null,"seconds":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"ic
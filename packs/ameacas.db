{"_id":"ZjAV3NXuB0ZROCHs","name":"Aranha Gigante","type":"npc","img":"systems/tormenta20/icons/ameacas/aranha-gigante.png","items":[{"_id":"vSiBFyuzECuCuLzT","name":"Mordida","type":"arma","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"Aplica Veneno.","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"key":"dano0","name":"Dano","type":"dano","parts":[["1d8","",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"dup":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false,"lancinating":false},"chatFlavor":"","ativacao":{"custo":null,"condicao":"","execucao":"","qtd":"","special":""},"origin":"","tags":[],"chatGif":"","consume":{"amount":0,"mpMultiplier":false,"target":"","type":""},"upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"proficiencia":"natural","proposito":"corpo-a-corpo","empunhadura":"uma","size":"normal"},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"jg36Ay9GlBGIsWni","name":"Teia","type":"poder","sort":200000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"A aranha gigante dispara teia em uma área de 3m de lado em alcance curto. Criaturas na área ficam enredadas (Reflexos CD 17 evita). Uma criatura enredada pode se soltar com uma ação completa e um teste de Força ou Acrobacia (CD 20) ou cortando a teia (cada espaço de 1,5m de teia tem 5 PV e RD 5). Fogo queima a teia em duas rodadas (e liberta as criaturas), mas causa 1d6 pontos de dano de fogo por rodada a todas as criaturas nela. A aranha gigante também pode usar a teia para cobrir uma área quadrada com 6m de lado. Por sua semitransparência, a teia é difícil de ver (Percepção CD 20) até ser tarde demais. Uma criatura que entre na área fica enredada. A aranha pode andar na própria teia sem se enredar. Ela percebe automaticamente (como se tivesse percepção às cegas) qualquer criatura na teia.","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":2,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"","subtipo":"","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WHkxeD2MnBwO3ygV","name":"Veneno","type":"poder","sort":300000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Condi&ccedil;&atilde;o fraco (Fort CD 18 anula).</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>\n<p style=\"text-align:justify;\">&nbsp;</p>","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":
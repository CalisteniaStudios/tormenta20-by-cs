iço.</p>","peso":4,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"3d6","atqBns":"23","danoBns":"27","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"systems/tormenta20/icons/itens/tacape.webp","effects":[]},{"_id":"xmQhsSepoAWXZJED","name":"Mordida","type":"arma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"2d6","atqBns":"23","danoBns":"17","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"natural","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"hSKIn57d9KPTjeRh","name":"Golpe Avassalador","type":"poder","data":{"description":"<p>Quando acerta um ataque de tacape,o troll das cavernas arremessa a v&iacute;tima [[/r 1d6]] x 1,5m em uma dire&ccedil;&atilde;o &agrave; escolha dele. A v&iacute;tima fica ca&iacute;da e, se atingir algum obst&aacute;culo, sofre [[/r 1d6]] pontos de dano de impacto para cada 1,5m que foi arremessada. Um teste de Fortitude (CD 29) evita o arremesso.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"1d6","tipo":"classe","subtipo":"","chatFlavor":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"IJXJ36RTuniPdAql","name":"Varrer","type":"poder","data":{"description":"Uma vez por rodada, quando o troll das cavernas faz um ataque corpo a corpo e reduz os pontos de vida do alvo para 0 ou menos, pode realizar um ataque adicional contra outra criatura dentro do seu alcance. Esse ataque usa os mesmos bônus de ataque e dano, mas os dados devem ser rolados novamente.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]}],"effects":[]}

:{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"sempre que o alvo fizer o teste de Vontade e falhar, a marca causa 3d6 pontos de dano mental. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.6wASxSXLtFzQcy8V","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você toca uma criatura, gravando uma marca mística no corpo dela enquanto profere uma ordem, como “não ataque a mim ou meus aliados”, “siga-me” ou “não saia desta sala”. A criatura deve seguir essa ordem, gastando todas as ações de seu turno para isso. A ordem não pode ser genérica demais (como “ajude-me”, por exemplo), nem forçar o alvo a atos suicidas. A cada rodada, o alvo pode fazer um teste de Vontade. Se passar, a magia é dissipada.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"enc","aprimoramentos":[{"custo":"3","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Se não estiver em combate, a criatura só pode fazer o teste de Vontade a cada hora. Requer 3º círculo.","_id":"","id":"6d48162f-481f-4a13-a32d-a2802a5017cc","ativo":false},{"custo":"3","tipo":"Outros","formula":"","description":"sempre que o alvo fizer o teste de Vontade e falhar, a marca causa 3d6 pontos de dano
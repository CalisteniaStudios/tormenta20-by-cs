emplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"va
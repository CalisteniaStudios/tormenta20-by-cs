startRound":null,"startTurn":null},"icon":"icons/svg/aura.svg","label":"Apavorado","origin":"Item.dx8QPZrPlrOrzLQU","tint":null,"transfer":false}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo &eacute; envolvido por energias sombrias assustadoras. Se falhar na resist&ecirc;ncia, fica apavorado por 1d4 rodadas, depois abalado. Se passar, fica abalado por 1d4 rodadas.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 animal ou humanoide de ND 2 ou menor","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"nec","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"gSvF50hi89LktVk9","name":"Comando","type":"magia","sort":700000,"flags":{"core":{"sourceId":"Item.DClEXhRqbdmK0hPw"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/comando.webp","effects":[{"_id":"goAzE0oaWGOVE9Gm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false,"tint":null},{"_id":"UuprzsbsDv72xAxP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a quantidade de alvos em +1","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você dá uma ordem irresistível, que o alvo deve ser capaz de ouvir (mas não precisa entender). Se falhar na resistência, ele deve obedecer ao comando em seu próprio turno da melhor maneira possível. Escolha um dos efeitos.</p><p style=\"text-align:justify;\"><i>Fuja:</i> o alvo gasta seu turno se afastando de você (usando todas as suas ações).</p><p style=\"text-align:justify;\"><i>Largue:</i> o alvo solta quaisquer itens que esteja segurando e não pode pegá-los novamente até o início de seu próximo turno. Como esta é uma ação livre, ele ainda pode executar outras ações (exceto pegar aquilo que largou).</p><p style=\"text-align:justify;\"><i>Pare:</i> o alvo fica pasmo (não pode fazer ações, exceto reações).</p><p style=\"text-align:justify;\"><i>Senta:</i> com uma ação livre, o alvo senta no chão (se estava pendurado ou voando, desce até o chão). Ele pode fazer outras ações, mas não se levantar até o início de seu próximo turno. </p><p style=\"text-align:justify;\"><i>Venha:</i> o alvo gasta seu turno se aproximando de você (usando todas as suas ações).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"special","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"enc","origin":
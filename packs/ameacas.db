{"_id":"FF9PpLugg4L34Jh1","name":"Besouro Aberrante","type":"npc","img":"systems/tormenta20/icons/ameacas/besouro-aberrante.png","items":[{"_id":"06aeQPQVJUsINKVI","name":"Pancada","type":"arma","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"key":"dano0","name":"Dano","type":"dano","parts":[["4d6","",""],["@for","",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"dup":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false,"lancinating":false},"chatFlavor":"","ativacao":{"custo":null,"condicao":"","execucao":"","qtd":"","special":""},"origin":"","tags":[],"chatGif":"","consume":{"amount":0,"mpMultiplier":false,"target":"","type":""},"upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"proficiencia":"simples","proposito":"corpo-a-corpo","empunhadura":"uma","size":"normal"},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"a1THeP3wHEem0FXL","name":"Passar por Cima","type":"poder","sort":200000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O besouro aberrante percorre at&eacute; o dobro do seu deslocamento, passando por qualquer criatura Enorme ou menor. Uma criatura atropelada sofre [[/r 10d8+25]] pontos de dano (Ref CD 42 reduz &agrave; metade).</p>","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["10d8+25","",""]],"versatil":""}],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"cDogxmFfF4ig5X3R","name":"Carapaça","type":"poder","sort":300000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"A carapaça do besouro aberrante reduz todo dano de corte, impacto e perfuração que ele sofre pela metade e fornece resistência a magia +10. Se o besouro aberrante passar num teste de resistência contra magia, ela é revertida contra o conjurador. Apesar de resistente, a caparaça de um besouro aberrante possui pontos fracos, que podem ser encontrados com uma ação de movimento e um teste de Percepção (CD 25). Um personagem que encontre um ponto fraco pode atacar a criatura com –5 no teste de ataque, mas, se acertar, ignora as proteções da carapaça.","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resi
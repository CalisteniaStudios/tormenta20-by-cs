to":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, toda vez que uma cópia é destruída, emite um clarão de luz. A criatura que destruiu a cópia fica ofuscada por uma rodada. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.secWy6zyYamo3Xnx","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Três cópias ilusórias suas aparecem. As duplicatas ficam ao seu redor e imitam suas ações, tornando difícil para um inimigo saber quem atacar. Você recebe +6 na Defesa. Cada vez que um ataque contra você erra, uma das imagens desaparece e o bônus na Defesa diminui em 2. Um oponente deve ver as cópias para ser confundido. Se você estiver invisível, ou o atacante fechar os olhos, você não recebe o bônus (mas o atacante ainda sofre penalidades normais por não enxergar).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"ilu","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"SxIraDv5DaYWprMB","name":"Seta Infalível","type":"magia","sort":900001,"flags":{"core":{"sourceId":"Item.MXN6umhJ8krpE1QT"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/seta-infalivel.webp","effects":[{"_id":"LsqObMrldBr1Fcuf","flags"
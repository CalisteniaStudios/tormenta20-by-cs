,"outros":0,"notes":"","mod":0},"for":{"label":"Fortitude","value":16,"atributo":"con","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"fur":{"label":"Furtividade","value":0,"atributo":"des","st":false,"pda":true,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"gue":{"label":"Guerra","value":0,"atributo":"int","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"ini":{"label":"Iniciativa","value":16,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"int":{"label":"Intimidação","value":0,"atributo":"car","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"intu":{"label":"Intuição","value":0,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"inv":{"label":"Investigação","value":0,"atributo":"int","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"jog":{"label":"Jogatina","value":0,"atributo":"car","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"lad":{"label":"Ladinagem","value":0,"atributo":"des","st":true,"pda":true,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"lut":{"label":"Luta","value":0,"atributo":"for","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"mis":{"label":"Misticismo","value":0,"atributo":"int","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"nob":{"label":"Nobreza","value":0,"atributo":"int","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"ofi":{"label":"Oficios","value":0,"atributo":"int","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0,"mais":{}},"per":{"label":"Percepção","value":10,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"pil":{"label":"Pilotagem","value":0,"atributo":"des","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"pon":{"label":"Pontaria","value":0,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"ref":{"label":"Reflexos","value":16,"atributo":"des","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"rel":{"label":"Religião","value":0,"atributo":"sab","st":true,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"sob":{"label":"Sobrevivência","value":0,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0},"von":{"label":"Vontade","value":14,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0}},"periciasCustom":{"0":{"label":"Conhecimento","nome":"pericia","value":21},"1":{"label":"Intimidação","nome":"pericia","value":13},"2":{"label":"Misticismo","nome":"pericia","value":23}},"resistencias":"","tamanho":"Médio","deslocamento":"12m (8q)","detalhes":{"biografia":"","dinheiro":{"tt":0,"to":0,"tp":0,"tc":0},"carga":0}},"sort":100001,"flags":{},"img":"systems/tormenta20/icons/ameaças/Monstro.webp","token":{"flags":"","name":"Necromante Veterano","displayName":50,"img":"systems/tormenta20/icons/ameaças/Monstro_token.webp","tint":"","width":1,"height":1,"scale":1,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":false,"dimSight":0,"brightSight":0,"dimLight":0,"brightLight":0,"sightAngle":360,"lightAngle":360,"lightColor":"","lightAlpha":1,"actorId":"EN4wvAT5pzljgWch","actorLink":false,"actorData":{},"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.pv"},"bar2":{"attribute":"attributes.pm"},"randomImg":false},"items":[{"_id":"P1AK9QQ6wHfcG13t","flags":{},"name":"Adaga","type":"arma","img":"systems/tormenta20/icons/itens/adaga.webp","data":{"description":"<p>Esta faca afiada é usada por muitos habitantes adultos do Reinado, embora seja favorita de ladrões e assassinos, por ser facilmente escondida (fornece +2 em testes de Ladinagem para ocultá-la). Quando ataca com uma adaga, você pode usar seu modificador de Destreza em vez de Força nos testes de ataque. Uma adaga pode ser arremessada.</p>","pericia":"lut","dano":"1d4","atrDan":"for","criticoM":19,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"atqBns":17,"peso":0.5,"qtd":1,"preco":0,"tipoUso":"simples"},"sort":100000},{"_id":"wlmlHqmIb41lKjV1","flags":{},"name":"Mestre em Necromancia","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"A CD para resistir às magias de necromancia do necromante aumenta em +2 e o custo para lançá-las diminui em –1 PM (mínimo de 1 PM).","roll":"","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":200000},{"_id":"tpDBd8eTwe033bMB","flags":{},"name":"Guardas Esqueletos","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"O necromante está sempre acompanhado por dois esqueletos de elite (veja na página 283).","roll":"","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":1000000},{"_id":"yqg3z9RhZC6hhvnT","flags":{},"name":"Magia Acelerada","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Quando lança uma magia com execução de ação completa ou menor, o necromante veterano muda a execução dela para livre. Ele só pode usar este poder uma vez por rodada.","roll":"","tipo":"","ativacao":{"execucao":"livre","custo":"4"}},"sort":1100000},{"_id":"D0tPg3Cqb59k94Nm","flags":"","name":"Amedrontar","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"O alvo é envolvido por energias sombrias assustadoras. Se falhar na resistência, fica apavorado por 1d4 rodadas, depois abalado. Se passar, fica abalado por 1d4 rodadas.","tipo":"Arcana","circulo":"1","custo":1,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Curto","duracao":"Cena","resistencia":"Vontade parcial","alvo":"1 animal ou humanoide de ND 2 ou menor","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"muda o alvo para criatura de ND 2 ou menor.","_id":"","id":"af3efe8c-a41e-47e7-8e17-40502291f1b7","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"afeta alvos de ND 5 ou menor. Requer 2o círculo.","_id":"","id":"01e90d49-9743-4a39-b2ea-9b02a231040e","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta todos os alvos válidos a sua escolha dentro do alcance.","_id":"","id":"fa5a0a70-60a7-4e4e-96ee-4fde47afbfc5","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta alvos de ND 10 ou menor. Requer 3o círculo.","_id":"","id":"5f90a69e-3c2b-4755-b384-669023c7827e","ativo":false},{"custo":"9","tipo":"Outros","formula":"","description":"afeta alvos de ND 15 ou menor. Requer 4o círculo.","_id":"","id":"94b14247-c1f0-4b59-bff7-4d07870d7044","ativo":false},{"custo":"14","tipo":"Outros","formula":"","description":"afeta alvos de qualquer ND. Requer 5o círculo","_id":"","id":"3cade3b3-3556-4cf2-885a-396269da668a","ativo":false}]},"sort":1100000},{"_id":"3qWLVqx4ukAZZUIh","flags":"","name":"Raio do Enfraquecimento","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"Você dispara um raio púrpura que drena as forças do alvo. Se falhar na resistência, o alvo fica fatigado. Se passar, fica vulnerável.","tipo":"Arcana","circulo":"1","custo":1,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Curto","duracao":"Cena","resistencia":"Fortitude parcial","alvo":"1 criatura","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"muda o alcance para toque e a resistência para Fortitude anula. Em vez do normal, ao tocar o alvo, sua mão emana um brilho púrpura. O alvo fica fatigado. Note que, como efeitos de magia não acumulam, lançar este truque duas vezes contra o mesmo alvo não irá deixá-lo exausto.","_id":"","id":"2346e673-3628-46f1-a355-5c039107ea37","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"em vez do normal, se falhar na resistência o alvo fica exausto. Se passar, fica fatigado. Requer 2o círculo.","_id":"","id":"63fc47c2-b96e-4489-9812-02b4de7f298c","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"em vez do normal, se falhar na resistência o alvo fica inconsciente. Se passar, fica exausto. Requer 3o círculo.","_id":"","id":"4c86b2a6-e6fd-4c66-bd3f-daf041c726bc","ativo":false}]},"sort":1200000},{"_id":"0fBCVefrciFXfRK6","flags":"","name":"Vitalidade Fantasma","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"Você suga energia vital da terra, recebendo 2d8 pontos de vida temporários. Os PV temporários desaparecem ao final da cena.","tipo":"Arcana","circulo":"1","custo":1,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Pessoal","duracao":"Instantânea","resistencia":"","alvo":"você","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"1d8","description":"aumenta os PV temporários recebidos em +1d8.","_id":"","id":"67b48eab-94a1-4671-967a-dc20a965914a","ativo":false},{"custo":"5","tipo":"Muda","formula":"1d8","description":"muda o alvo para área: esfera com 6m de raio centrada em você e a resistência para Fortitude reduz à metade. Em vez do normal, você suga energia das criaturas vivas na área, causando 1d8 pontos de dano de trevas e recebendo PV temporários iguais ao dano total causado. Os PV temporários desaparecem ao final da cena. Requer 2o círculo.","_id":"","id":"3beb5444-7f07-4a06-8b9b-301208c2a7db","ativo":false}]},"sort":1300000},{"_id":"NSMbEveghRUBqeow","flags":"","name":"Armadura Arcana","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"Esta magia cria uma película protetora invisível, mas tangível, fornecendo +4 na Defesa. Esse bônus é cumulativo com outras magias, mas não com bônus fornecido por armaduras.","tipo":"Arcana","circulo":"1","custo":1,"preparada":false,"escola":"Abjuração","execucao":"Padrão","alcance":"Pessoal","duracao":"Cena","resistencia":"","alvo":"Você","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual.","_id":"","id":"074ea668-ba8c-463a-b59f-e18ba5b21be9","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus na Defesa em +1.","_id":"","id":"8bf9652c-e245-4392-990b-6e92cb6e4aaf","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Requer 2o círculo.","_id":"","id":"ad230447-7151-4fc0-9a91-b36c6d6e1e57","ativo":false}]},"sort":1400000},{"_id":"ktXeYFMdCFgsW0Dj","flags":"","name":"Conjurar Mortos-Vivos","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"Seis esqueletos de tamanho Médio feitos de energia negativa emergem do chão em espaços desocupados escolhidos por você dentro do alcance. Você pode usar uma ação de movimento para fazer os mortos-vivos andarem (eles têm deslocamento 9m) ou uma ação padrão para fazê-los causar dano a criaturas adjacentes (1d6+2 pontos de dano de trevas cada). Os esqueletos têm For 14, Des 14 e todos os outros atributos nulos; eles têm 1 PV, não têm valor de Defesa ou testes de resistência, falham automaticamente em qualquer teste oposto e são imunes a atordoamento, dano não letal, doença, encantamento, fadiga, frio, ilusão, paralisia, sono e veneno. Eles desaparecem quando são reduzidos a 0 PV ou no fim da cena. Os mortos-vivos não agem sem receber uma ordem. Usos criativos para criaturas invocadas fora de combate ficam a critério do mestre.","tipo":"Universal","circulo":"2","custo":3,"preparada":false,"escola":"Necromancia","execucao":"Completa","alcance":"Curto","duracao":"Sustentada","resistencia":"","alvo":"6 mortos-vivos","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o número de mortos-vivos conjurados em +1.","_id":"","id":"8a4bc6cc-1aba-4aca-bc1c-7376ed01e516","ativo":false},{"custo":"3","tipo":"Outros","formula":"","description":"em vez de esqueletos, conjura carniçais. Requer 3o círculo.","_id":"","id":"c464e0b3-e298-4aba-b9ac-111ade5d3bed","ativo":false},{"custo":"7","tipo":"Outros","formula":"","description":"em vez de esqueletos, conjura sombras. Requer 4o círculo. Carniçal: como o esqueleto, mas tem For 16, Des 16, 12 PV e causa 1d8+3 pontos de dano de trevas mais 1d8 pontos de dano de veneno. Além disso, criaturas atingidas por um carniçal devem passar num teste de Fortitude (CD igual à da magia) ou ficam paralisadas por 1 rodada. Uma criatura que passe no teste de resistência fica imune à paralisia dos carniçais por 24 horas. Sombra: como o esqueleto, mas tem a habilidade incorpóreo, Des 18, 30 PV e causa 1d10 pontos de dano de trevas mais 1d10 pontos de dano de frio. Além disso, criaturas vivas atingidas por uma sombra devem passar num teste de Fortitude (CD igual à da magia) ou perdem 1d4 PM. Sombras perdem a habilidade incorpóreo quando expostas à luz do sol.","_id":"","id":"4bba376f-2d03-433b-b917-c162ad811507","ativo":false}]},"sort":1500000},{"_id":"V0tA4riQZ0KcZfJv","flags":"","name":"Toque Vampírico","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"Sua mão brilha com energia sombria, causando 6d6 pontos de dano de trevas. Você recupera pontos de vida iguais à metade do dano causado (se causou algum dano).","tipo":"Arcana","circulo":"2","custo":3,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Toque","duracao":"Instantânea","resistencia":"Fortitude reduz à metade","alvo":"1 criatura","area":"","cd":0,"efeito":"6d6","aprimoramentos":[{"custo":"1","tipo":"Outros","formula":"","description":"como parte da execução da magia, você pode fazer um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia, e recupera pontos de vida iguais à metade do dano da magia.","_id":"","id":"8da7ae35-4b1c-4ac4-a7cb-7f991c586cba","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"2d6","description":"aumenta o dano em +2d6.","_id":"","id":"0de74972-d593-495f-a45d-e70a0d0f6f1d","ativo":false},{"custo":"2","tipo":"Muda","formula":"3d6","description":"muda o alcance para pessoal, o alvo para você e a duração para cena. Em vez do normal, a cada rodada você pode gastar uma ação padrão para tocar 1 criatura e causar 3d6 pontos de dano. Você recupera pontos de vida iguais à metade do dano causado. Requer 3o círculo.","_id":"","id":"b43be2d5-060d-414a-9425-b8af5eb6d013","ativo":false}]},"sort":1600000},{"_id":"PuIe5kfk6Gj4RF22","flags":"","name":"Ferver Sangue","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"O sangue do alvo aquece rapidamente até entrar em ebulição. Quando a magia é lançada, e no início de cada um de seus turnos, o alvo sofre 3d6 pontos de dano de fogo (Fortitude reduz à metade). Se o alvo passar em dois testes de Fortitude seguidos, dissipa a magia. Se o alvo for reduzido a 0 PV pelo dano desta magia, seu corpo explode, matando-o e causando 6d6 pontos de dano de fogo em todas as criaturas a até 3m (Reflexos reduz à metade). Essa magia não afeta criaturas sem sangue, como construtos ou espíritos.","tipo":"Arcana","circulo":"3","custo":6,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Curto","duracao":"Sustentada","resistencia":"Fortitude reduz à metade","alvo":"1 criatura","area":"","cd":0,"efeito":"3d6","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"1d6","description":"aumenta o dano em +1d6.","_id":"","id":"78a75bae-757a-4fd4-ad09-9006795e04d3","ativo":false},{"custo":"9","tipo":"Muda","formula":"","description":"muda alvo para criaturas escolhidas. Requer 5o círculo.","_id":"","id":"e86533b5-612a-4ba3-98fd-824672036fbf","ativo":false}]},"sort":1700000},{"_id":"kXnRqT01hMU1Va4H","flags":"","name":"Servo Morto-Vivo","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"Esta magia transforma o cadáver de um humanoide, animal ou monstro em um esqueleto ou zumbi (conforme o estado de conservação do corpo). O morto-vivo então obedece a todos os seus comandos, mesmo suicidas. Se quiser que o morto-vivo o acompanhe, ele funciona como um aliado iniciante, de um tipo a sua escolha entre ajudante, atirador, combatente, fortão, guardião ou montaria. Se não quiser usar o morto-vivo como aliado, pode ordenar que ele proteja um local específico, atacando invasores (nesse caso, use as estatísticas de criaturas vistas no Capítulo 7: Ameaças). O nível somado de mortos-vivos sob seu comando ao mesmo tempo não pode exceder o seu próprio nível +3, mas você só pode receber os benefícios de um deles como aliado por vez. Eles duram até serem destruídos (um morto-vivo destruído não pode ser reanimado). Componente material: um ônix negro (T$ 100), inserido na boca ou olho do cadáver.","tipo":"Universal","circulo":"3","custo":6,"preparada":false,"escola":"Necromancia","execucao":"Completa","alcance":"Toque","duracao":"Instantânea","resistencia":"","alvo":"1 cadáver","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"3","tipo":"Muda","formula":"","description":"muda o componente material para pó de ônix negro (T$ 500). Em vez de um zumbi ou esqueleto, cria um carniçal. Ele pode funcionar como um aliado veterano, escolhido entre ajudante, atirador, combatente, fortão ou guardião. O resto segue normal.","_id":"","id":"66149882-a3ad-44da-82fd-a5c69bca6ae5","ativo":false},{"custo":"3","tipo":"Muda","formula":"","description":"muda o componente material para pó de ônix negro (T$ 500). Em vez de um zumbi ou esqueleto, cria uma sombra. Ela pode funcionar como um aliado veterano, escolhido entre assassino, combatente ou perseguidor. O restante da magia segue normal.","_id":"","id":"1c40d08a-3493-4492-8427-f4e80f45870f","ativo":false},{"custo":"7","tipo":"Muda","formula":"","description":"muda o componente material para ferramentas de embalsamar (T$ 1.000). Em vez de um zumbi ou esqueleto, cria uma múmia. Ela pode funcionar como um aliado mestre, escolhido entre ajudante, destruidor, guardião ou médico. O restante da magia segue normal. Requer 4o círculo.","_id":"","id":"2f487e94-804c-4d36-a81e-df9394de3544","ativo":false}]},"sort":1800000},{"_id":"U6KFjWUnWlZqtpXs","flags":"","name":"Assassino Fantasmagórico","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"Usando os medos subconscientes do alvo, você cria uma imagem daquilo que ele mais teme. Apenas a própria vítima pode ver o Assassino Fantasmagórico com nitidez; outras criaturas presentes (incluindo o conjurador) enxergam apenas um espectro sombrio. O espectro surge adjacente a você e flutua em direção à vítima com deslocamento total de voo 18m por turno. Ele é incorpóreo e imune a magias. Se o espectro terminar seu turno em alcance curto da vítima, ela deve fazer um teste de Vontade. Se falhar, ficará abalada. Se o espectro terminar seu turno adjacente à vítima, ela deve fazer um teste de Fortitude. Se passar, sofre 6d6 pontos de dano de trevas (este dano não pode reduzir o alvo a menos de 0 PV e não o deixa sangrando). Se falhar, sofre um colapso, ficando imediatamente com –1 PV e sangrando. O espectro persegue o alvo implacavelmente. Ele só desaparece se deixar seu alvo inconsciente, se for dissipado ou ao término da cena.","tipo":"Arcana","circulo":"4","custo":10,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Longo","duracao":"Cena, até ser descarregada","resistencia":"Fortitude parcial","alvo":"1 criatura","area":"","cd":0,"efeito":"","aprimoramentos":[]},"sort":1900000}]}

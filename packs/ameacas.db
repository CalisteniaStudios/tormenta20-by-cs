,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"64LhGQcbLshnJU3y","name":"Goblins Consertadores","type":"poder","sort":200000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"Goblins especialmente pequenos rastejam por dentro dos dutos do colosso fazendo reparos, o que fornece ao construto cura acelerada 20. Por estarem dentro do construto, os goblins são imunes a dano, mas ainda podem ser afetados por efeitos mentais. Eles possuem Vontade +2 (mas recebem a resistência a magia do colosso) e, se forem afetados por qualquer condição, a cura acelerada deixa de funcionar.","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"","subtipo":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"nrWEwtD2npplXxdh","name":"Jato de Chamas","type":"poder","sort":400000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"icons/svg/mystery-man.svg","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O colosso dispara um jato de chamas que atinge um cone com alcance m&eacute;dio. Criaturas na &aacute;rea sofrem [[/r 8d8+10]] pontos de dano de fogo (Ref CD 35 reduz &agrave; metade).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","
s":[{"key":"resistencia","value":"Reflexos reduz à metade","mode":5,"priority":null},{"key":"dano","value":"3d12","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas maiores, como gatos, guaxinins, compsognatos ou kobolds. Ele causa 3d12 pontos de dano (a sua escolha entre corte, impacto ou perfuração). O resto da magia segue normal.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null},{"_id":"DHpBmH5U3daYrDVC","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de enxames em +1. Eles não podem ocupar o mesmo espaço. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null},{"_id":"ieUdi5tA1oF9QhoP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"resistencia","value":"Reflexos reduz à metade","mode":5,"priority":null},{"key":"dano","value":"5d12","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas elementais. Ele causa 5d12 pontos do dano (a sua escolha entre ácido, eletricidade, fogo ou frio). O resto da magia segue normal. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.0s9EEKvVnPbFwS1t","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você conjura um enxame de criaturas a sua escolha, como besouros, gafanhotos, mosquitos, ratos, morcegos ou serpentes, que surge em um ponto a sua escolha. O enxame pode passar pelo espaço de outras criaturas e não impede que outras criaturas entrem no espaço dele. No final de cada um de seus turnos, o enxame causa 2d12 pontos de dano de veneno a qualquer criatura em seu espaço (Fortitude reduz à metade). Você pode gastar uma ação de movimento para mover o enxame com deslocamento de 12m.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"1 enxame Médio (quadrado de 1,5m)","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"Convocação","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"1d12","description":"aumenta o dano em +1d12.","_id":"","id":"c8af3d80-fc7c-4551-a439-aa295a48887b","ativo":false},{"custo":"3","tipo":"Muda","formula":"3d12","description":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas maiores, como gatos, guaxinins, compsognatos ou kobolds. Ele causa 3d12 pontos de dano (a sua escolha entre corte, impacto ou perfuração). O resto da magia segue normal.","_id":"","id":"7de86cfa-37db-46fb-9660-c92b923f7c96","ativo":false},{"custo":"5","tipo":"Aumenta","formula":"","description":"aumenta o número de enxames em +1. Eles não podem ocupar o mesmo espaço. Requer 3º círculo.","_id":"","id":"188553c7-dbb2-4ab3-ab41-719ee669e406","ativo":false},{"custo":"7","tipo":"Muda","formula":"5d12","description":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas elementais. E
te de ataque. Se o ataque acertar e causar pelo menos 25 pontos de dano de corte, a cabeça é decepada e a hidra perde um ataque de mordida. Entretanto, 1d4 rodadas após a cabeça ser decepada, duas novas nascem em seu lugar (a hidra pode ter até dez cabeças). Para impedir o nascimento de novas cabeças é necessário cauterizar o pescoço. Isso exige causar 25 pontos de dano de ácido ou fogo na hidra. Se todas as cabeças da hidra forem decepadas e todos seus pescoços forem cauterizados, ela morre.","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[],"tipo":"classe","subtipo":"","chatFlavor":"","origin":"","tags":[],"chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":100001,"flags":{"exportSource":{"world":"andreverse-t20","system":"tormenta20","coreVersion":"0.6.6","systemVersion":"0.9.71"},"editing":false,"tormenta20":{"sheet":{},"lvlconfig":{"pv":{},"pm":{}},"version":"1.3.0.0"},"core":{"sourceId":"Compendium.tormenta20.ameacas.HZ42DL62joiPLBL5"}},"system":{"atributos":{"for":{"value":34,"bonus":0,"base":12,"racial":0},"des":{"value":11,"bonus":0,"base":0,"racial":0},"con":{"value":35,"bonus":0,"base":12,"racial":0},"int":{"value":2,"bonus":0,"base":-4,"racial":0},"sab":{"value":10,"bonus":0,"base":0,"racial":0},"car":{"value":9,"bonus":0,"base":-1,"racial":0}},"attributes":{"cd":19,"pv":{"value":396,"min":-500,"max":396,"temp":0},"pm":{"value":0,"min":0,"max":0,"temp":0},"movement":{"burrow":0,"climb":0,"fly":0,"swim":9,"walk":9,"unit":"m","hover":false},"
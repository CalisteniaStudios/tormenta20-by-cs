r arremessada.</p>","peso":1.5,"qtd":1,"preco":2,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d6","atqBns":"6","danoBns":"3","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"Perfuração","alcance":"Curto","custo":null,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":true,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.vaCe85lpdH10teLi"}},"img":"systems/tormenta20/icons/itens/lanca.webp","effects":[]},{"_id":"MnND9BKOqxO0BSnc","name":"Mordida","type":"arma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d6","atqBns":"6","danoBns":"3","criticoM":20,"criticoX":2,"lancinante":false,"tipo":"Perfuração","alcance":"","custo":0,"tipoUso":"natural","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"chatFlavor":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"ajilpUdsoqp9Z4im","name":"Arco curto","type":"arma","data":{"description":"<p>Uma arma antiga e comum, este arco é usado primariamente como ferramenta de caça, embora seja usado como arma de guerra por milícias, bandidos e exércitos menos equipados. Exige as duas mãos, mas pode ser usado montado.</p>","peso":1,"qtd":1,"preco":30,"atrAtq":"0","pericia":"pon","atrDan":"0","dano":"1d6","atqBns":"5","danoBns":"0","criticoM":20,"criticoX":3,"lancinante":false,"tipo":"Perfuração","alcance":"Médio","custo":null,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":true,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":fals
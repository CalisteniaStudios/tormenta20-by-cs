is veneno)","pericia":"lut","dano":"1d4","atrDan":"des","criticoM":19,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"atqBns":20,"peso":0.5,"qtd":1,"preco":0,"tipoUso":"simples"},"sort":100000},{"_id":"winOZp4g9sU6TzJV","flags":{},"name":"Ataque Furtivo","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Uma vez por rodada, a cultista de Sszzaas causa +5d6 pontos de dano com ataques corpo a corpo, ou à distância em alcance curto, contra alvos desprevenidos ou que ela esteja flanqueando.","roll":"5d6","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":200000},{"_id":"jgyeFCeJPx9sg89q","flags":{},"name":"Olhar Atordoante","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"A cultista força uma criatura em alcance curto a fazer um teste de Fortitude (CD 22). Se a criatura falhar, fica atordoada por 1 rodada. Se passar, fica imune a esta habilidade por um dia.","roll":"","tipo":"","ativacao":{"execucao":"movimento","custo":"1"}},"sort":300000},{"_id":"vRPbQJMY9x5NBgnv","flags":{},"name":"Veneno","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"2d12 pontos de dano por rodada durante 2d4 rodadas (Fort CD 23 reduz à metade).","roll":"2d12","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":400000},{"_id":"5Ugx1E2rG6uCe9ES","flags":"","name":"Arma Mágica","type":"magia","img":"systems/tormenta20/icons/magias/Trans.webp","data":{"description":"A arma fornece um bônus de +1 nos testes de ataque e rolagens de dano e é considerada mágica. Caso você esteja empunhando a arma, pode usar seu atributo-chave de magias em vez do atributo original nos testes de ataque.","tipo":"Universal","circulo":"1","custo":1,"preparada":false,"escola":"Transmutação","execucao":"Padrão","alcance":"Toque","duracao":"Cena","resistencia":"","alvo":"1 arma","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","_id":"","id":"d237dacd-e691-4a93-a6df-19f38c7a3582","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"a arma passa a causar +1d6 de dano de ácido, eletricidade, fogo ou frio, escolhido no momento em que a magia é lançada.","_id":"","id":"0913741d-c3bf-492f-8483-ddf9fb990477","ativo":false}]},"sort":1100000},{"_id":"07aXdvxQyEzUNKn2","flags":"","name":"Comando","type":"magia","img":"systems/tormenta20/icons/magias/Encan.webp","data":{"description":"Você dá uma ordem irresistível, que o alvo deve ser capaz de ouvir (mas não precisa entender). Se falhar na resistência, ele deve obedecer ao comando em seu próprio turno da melhor maneira possível. Escolha um dos efeitos. Fuja: o alvo gasta seu turno se afastando de você (usando todas as suas ações). Largue: o alvo solta quaisquer itens que esteja segurando e não pode pegá-los novamente até o início de seu próximo turno. Como esta é uma ação livre, ele ainda pode executar outras ações (exceto pegar aquilo que largou). Pare: o alvo fica pasmo (não pode fazer ações, exceto reações). Senta: com uma ação livre, o alvo senta no chão (se estava pendurado ou voando, desce até o chão). Ele pode fazer outras ações, mas não se levantar até o início de seu próximo turno. Venha: o alvo gasta seu turno se aproximando de você (usando todas as suas ações).","tipo":"Divina","circulo":"1","custo":1,"preparada":false,"escola":"Encantamento","execucao":"Padrão","alcance":"Curto","duracao":"1 rodada","resistencia":"Vontade anula","alvo":"1 humanóide","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura.","_id":"","id":"e525b111-4d4d-4bbc-86bb-7aabe0670f8b","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta a quantidade de alvos em +1","_id":"","id":"f7f61147-efcc-4acd-b19b-e70812260cfe","ativo":false}]},"sort":1200000},{"_id":"PMT0rC1iLJpeWMfI","flags":"","name":"Curar Ferimentos","type":"magia","img":"systems/tormenta20/icons/magias/Evoc.webp","data":{"description":"Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.","tipo":"Divina","circulo":"1","custo":1,"preparada":false,"escola":"Evocação","execucao":"Padrão","alcance":"Toque","duracao":"Instantânea","resistencia":"","alvo":"1 criatura","area":"","cd":0,"efeito":"2d8+2","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"em vez do normal, estabiliza uma criatura.","_id":"","id":"8ec8bbe2-b543-401a-a115-7f390f3c4ed3","ativo":false},{"custo":"0","tipo":"Truque","formula":"","description":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","_id":"","id":"b18deddf-a288-4e58-aad7-d26a1af32780","ativo":false},{"custo":"1","tipo":"Aumenta","formula":"1d8","description":"aumenta a cura em +1d8+1.","_id":"","id":"8f1b2389-8976-4575-8851-d726d7042fba","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"também remove uma condição de fadiga do alvo.","_id":"","id":"c526f528-0e2d-4058-b268-e0585516c228","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para curto.","_id":"","id":"d96838f2-e083-4a61-b7ef-e0de354fefc8","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para curto e o alvo para criaturas escolhidas.","_id":"","id":"7179b5d9-b224-4fa7-a2a3-35378434efbc","ativo":false}]},"sort":1300000},{"_id":"fE94PR4Y6YIXtJCi","flags":"","name":"Escuridão","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"O alvo emana sombras em uma área com 6m de raio. Criaturas dentro da área recebem camuflagem por escuridão. As sombras não podem ser iluminadas por nenhuma fonte de luz natural. O objeto pode ser guardado (em um bolso, por exemplo) para interromper a escuridão, que voltará a funcionar caso o objeto seja revelado. Se lançar a magia num objeto de uma criatura involuntária, ela tem direito a um teste de Vontade para anulá-la. Escuridão anula Luz.","tipo":"Universal","circulo":"1","custo":1,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Curto","duracao":"Cena","resistencia":"Vontade anula (veja texto)","alvo":"1 objeto","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"1","tipo":"Aumenta","formula":"","description":"aumenta a área da escuridão em +1,5m de raio.","_id":"","id":"6e91d427-3d2b-4d9f-a0ee-663dbaff1946","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o efeito para fornecer camuflagem total por escuridão.","_id":"","id":"7ecb20e2-3c7e-4ee0-99c9-ba946a75f94d","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia.","_id":"","id":"bc5c1c57-41d1-4324-b61a-0c2c8e086cb4","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alvo para 1 criatura e a resistência para Fortitude parcial. Você lança a magia nos olhos do alvo, que fica cego pela cena. Se passar na resistência, fica cego por 1 rodada. Requer 2o círculo.","_id":"","id":"f1f28cab-5c31-411c-ad5d-d2ce45f7caee","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para pessoal e o alvo para você. Em vez do normal, você é coberto por sombras, recebendo +10 em testes de Furtividade e camuflagem por escuridão. Requer 2o círculo.","_id":"","id":"a09ad58f-4421-4d1e-baab-7cddac66ff04","ativo":false}]},"sort":1400000},{"_id":"nApPOcCNnuqGEEmy","flags":"","name":"Enxame de Pestes","type":"magia","img":"systems/tormenta20/icons/magias/Conv.webp","data":{"description":"Você conjura um enxame de criaturas a sua escolha, como besouros, gafanhotos, mosquitos, ratos, morcegos ou serpentes, que surge em um ponto a sua escolha. O enxame pode passar pelo espaço de outras criaturas e não impede que outras criaturas entrem no espaço dele. No final de cada um de seus turnos, o enxame causa 2d12 pontos de dano de veneno a qualquer criatura em seu espaço (Fortitude reduz à metade). Você pode gastar uma ação de movimento para mover o enxame com deslocamento de 12m.","tipo":"Divina","circulo":"2","custo":3,"preparada":false,"escola":"Convocação","execucao":"Completa","alcance":"Médio","duracao":"Sustentada","resistencia":"Fortitude reduz à metade","alvo":"","area":"1 enxame Médio (quadrado de 1,5m)","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Aumenta","formula":"1d12","description":"aumenta o dano em +1d12.","_id":"","id":"c8af3d80-fc7c-4551-a439-aa295a48887b","ativo":false},{"custo":"3","tipo":"Muda","formula":"3d12","description":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas maiores, como gatos, guaxinins, compsognatos ou kobolds. Ele causa 3d12 pontos de dano (a sua escolha entre corte, impacto ou perfuração). O resto da magia segue normal.","_id":"","id":"7de86cfa-37db-46fb-9660-c92b923f7c96","ativo":false},{"custo":"5","tipo":"Aumenta","formula":"","description":"aumenta o número de enxames em +1. Eles não podem ocupar o mesmo espaço. Requer 3o círculo.","_id":"","id":"188553c7-dbb2-4ab3-ab41-719ee669e406","ativo":false},{"custo":"7","tipo":"Muda","formula":"5d12","description":"muda a resistência para Reflexos reduz à metade e o enxame para criaturas elementais. Ele causa 5d12 pontos do dano (a sua escolha entre ácido, eletricidade, fogo ou frio). O resto da magia segue normal. Requer 4o círculo.","_id":"","id":"2036b002-a1f7-4a2c-ab42-667b28daa384","ativo":false}]},"sort":1500000},{"_id":"6jsnIdzjhkNIOIxC","flags":"","name":"Miasma Mefítico","type":"magia","img":"systems/tormenta20/icons/magias/Necro.webp","data":{"description":"A área é coberta por emanações letais. Criaturas na área sofrem 5d6 pontos de dano de veneno e ficam enjoadas por 1 rodada. Se passarem na resistência, sofrem metade do dano e não ficam enjoadas.","tipo":"Divina","circulo":"2","custo":3,"preparada":false,"escola":"Necromancia","execucao":"Padrão","alcance":"Médio","duracao":"Instantânea","resistencia":"Fortitude (veja texto)","alvo":"","area":"nuvem com 6m de raio","cd":0,"efeito":"","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"muda o alcance para toque, a área para alvo (1 criatura com 0 PV ou menos), a duração para instantânea e a resistência para Fortitude anula. Em vez do normal, você canaliza o Miasma contra uma vítima. Se falhar na resistência, ela morre e você recebe +2 na CD de suas magias por 1 dia. Se passar, fica imune a este truque por um dia.","_id":"","id":"f3d543df-7c49-4893-9e08-f692a48af109","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"1d6","description":"aumenta o dano em +1d6.","_id":"","id":"c4f931bf-47b2-4c51-97a1-2f2eba06cd29","ativo":false},{"custo":"3","tipo":"Muda","formula":"","description":"muda o tipo do dano para trevas.","_id":"","id":"1f153d78-7022-46d3-830c-d1cc545232f7","ativo":false}]},"sort":1600000}]}

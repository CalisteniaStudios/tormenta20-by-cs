{"_id":"yDY9SyAksM37Lw0h","name":"Centauro Xamã","type":"npc","img":"https://i.imgur.com/UpvSMsw.png","items":[{"_id":"BeBV9ojO5WEPPvR0","name":"Cascos","type":"arma","sort":200000,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.NFepeG0ojjq3Xggs"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/itens/desarmado.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você pode atacar com um soco, chute ou qualquer outro golpe que use seu próprio corpo como se fosse uma arma corpo a corpo. Um ataque desarmado causa dano não letal.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20",""],["luta",""],[0,""]]},{"key":"dano0","name":"Dano","type":"dano","parts":[["1d8","impacto"],["@for",""]]}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"sim","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":true,"municao":false,"versatil":false,"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":true,"mun":false,"ver":false},"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d8","atqBns":"11","danoBns":"4","tipo":"Impacto","custo":null,"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":"","ativacao":{"custo":null}},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"BbUh3pikNCeWtIMv","name":"Medo de Altura","type":"poder","sort":400000,"flags":{"core":{"sourceId":"Compendium.tormenta20.poderes.xn9RfAp79NWrXSYI"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/racas/minotauro.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Se estiver adjacente a uma queda de 3m ou mais de altura (como um buraco ou penhasco), o centauro fica abalado.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[],"tipo":"racial","subtipo":"Minotauro","atrRes":"for","cd":0,"aprimoramentos":[],"roll":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"VvoXmCtMaM3NnPAC","name":"Bordão","type":"arma","sort":100000,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos.HyJBwTLK0vY5F1Vp"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/itens/bordao.webp","effects":[],"folder":null,"system":{"description":null,"source":"","equipado":false,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20",""],["luta",""],[0,""]]},{"key":"dano0","name":"Dano","type":"dano","parts":[["1d8","impacto"],["@for",""]]}],"criticoM":20,"criticoX":2,"lancinante":false,"alcance":"-","tipoUso":"sim","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":true,"leve":false,"municao":false,"versatil":false,"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":true,"lev":false,"mun":false,"ver":false},"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"1d8","atqBns":"11","danoBns":"4","tipo":"Impacto","custo":null,"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":"","ativacao":{"custo":null}},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"8ajzD9Rdm426cXDz","name":"Voz da Natureza","type":"poder","sort":500000,"flags":{"core":{"sourceId":"Compendium.tormenta20.poderes.Y9MfowI3KydAdgND"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/poderes/concedidos.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O centauro xam&atilde; est&aacute; sempre sob o efeito da magia <em>Voz Divina</em>, apenas para falar com animais.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":""},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[],"tipo":"concedido","subtipo":"Natureza","atrRes":"for","cd":0,"aprimoramentos":[],"roll":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WJNOuxS8DeP1UYXa","name":"Armamento da Natureza","type":"magia","sort":600000,"flags":{"core":{"sourceId":"Item.GMd2abkDfzsmHa6P"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/armamento-da-natureza.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você fortalece uma arma mundana primitiva (sem custo em T$, como bordão, clava, funda ou tacape), uma arma natural ou um ataque desarmado. O dano da arma aumenta em um passo e ela é considerada mágica para propósitos de resistência a dano. Ao lançar a magia, você pode mudar o tipo de dano da arma (escolhendo entre corte, impacto ou perfuração).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 arma (veja texto)","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","aprimoramentos":[{"custo":"1","tipo":"Outros","formula":"","description":"fornece +1 nos testes de ataque com a arma.","_id":"","id":"549ddcde-68b7-496d-9e37-b8a5772f9dad","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a execução para ação de movimento.","_id":"","id":"71ba9a2a-df76-4451-8edb-cecc3d2ba4ba","ativo":false},{"custo":"3","tipo":"Aumenta","formula":"","description":"aumenta o bônus nos testes de ataque em +1.","_id":"","id":"ca1193c0-84de-458b-9006-ba583bae1160","ativo":false},{"custo":"5","tipo":"Aumenta","formula":"","description":"aumenta o dano da arma em mais um passo.","_id":"","id":"3141616b-39de-4dc2-89ee-2dacb91ad066","ativo":false}],"atrRes":"sab","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WVTOqoNGCfRgQTXq","name":"Controlar Plantas","type":"magia","sort":700000,"flags":{"core":{"sourceId":"Item.oV66MsZrmtBHAQus"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/controlar-plantas.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia só pode ser lançada em uma área com vegetação. As plantas se enroscam nas criaturas da área. Aquelas que falharem na resistência ficam enredadas. Uma vítima pode se libertar com uma ação padrão e um teste de Acrobacia ou Atletismo. Além disso, a área é considerada terreno difícil. No início de seus turnos, a vegetação tenta enredar novamente qualquer criatura na área, exigindo um novo teste de Reflexos.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"quadrado com 9m de lado","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Reflexos anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"muda a área para alvo de 1 planta e a resistência para nenhuma. Em vez do normal, você pode fazer a planta se mover como se fosse animada. Ela não pode causar dano ou atrapalhar a concentração de um conjurador.","_id":"","id":"2b0e0ede-7a80-49c3-a9c0-974439e995cc","ativo":false},{"custo":"1","tipo":"Muda","formula":"","description":"muda a duração para instantânea. Em vez do normal, as plantas na área diminuem, como se tivessem sido podadas. Terreno difícil muda para terreno normal e não oferece camuflagem. Esse efeito dissipa o uso normal de Controlar Plantas.","_id":"","id":"98398082-cf54-4029-b14e-bc835d1d017f","ativo":false},{"custo":"1","tipo":"Outros","formula":"","description":"além do normal, criaturas que falhem na resistência também ficam imóveis.","_id":"","id":"22268a84-0bb5-47f0-8621-1b2b9e6b147b","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para pessoal, a área para alvo (você) e a resistência para nenhuma. Em vez do normal, você consegue se comunicar com plantas, que começam com atitude prestativa em relação a você. Além disso, você pode fazer testes de Diplomacia com plantas. Em geral, plantas têm uma percepção limitada de seus arredores e normalmente fornecem respostas simplórias.","_id":"","id":"1a24e74b-0962-4f9a-8e3b-6637462e6e0e","ativo":false}],"atrRes":"sab","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"0SeAYB9jmOSVN0uT","name":"Curar Ferimentos","type":"magia","sort":800000,"flags":{"core":{"sourceId":"Item.galK4UUS6FxYz22S"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/curar-ferimentos.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"2d8+2","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d8+2",""]]}],"tipo":"div","circulo":"1","preparada":false,"escola":"evo","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"em vez do normal, estabiliza uma criatura.","_id":"","id":"8ec8bbe2-b543-401a-a115-7f390f3c4ed3","ativo":false},{"custo":"0","tipo":"Truque","formula":"","description":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","_id":"","id":"b18deddf-a288-4e58-aad7-d26a1af32780","ativo":false},{"custo":"1","tipo":"Aumenta","formula":"1d8+1","description":"aumenta a cura em +1d8+1.","_id":"","id":"8f1b2389-8976-4575-8851-d726d7042fba","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"também remove uma condição de fadiga do alvo.","_id":"","id":"c526f528-0e2d-4058-b268-e0585516c228","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para curto.","_id":"","id":"d96838f2-e083-4a61-b7ef-e0de354fefc8","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para curto e o alvo para criaturas escolhidas.","_id":"","id":"7179b5d9-b224-4fa7-a2a3-35378434efbc","ativo":false}],"atrRes":"sab","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"PrqywwgkZoijCElM","name":"Enxame de Pestes","type":"magia","sort":1500001,"flags":{"core":{"sourceId":"Item.4e59kyZdikq2FgSd"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/enxame-de-pestes.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você conjura um enxame de criaturas a sua escolha, como besouros, gafanhotos, mosquitos, ratos, morcegos ou serpentes, que surge em um ponto a sua escolha. O enxame pode passar pelo espaço de outras criaturas e não impede que outras criaturas entrem no espaço dele. No final de cada um de seus turnos, o enxame causa 2d12 pontos de dano de veneno a qualquer criatura em seu espaço (Fortitude reduz à metade). Você pode gastar uma ação de movimento para mover o enxame com deslocamento de 12m.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":nul
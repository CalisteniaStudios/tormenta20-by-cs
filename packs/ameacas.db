:2,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0,"temp":0,"bonus":0,"penalidade":0}},"periciasCustom":{},"resistencias":"","tamanho":"Medio","detalhes":{"dinheiro":{"tl":0,"to":0,"tp":0,"tc":0,"tt":0},"carga":0,"biografia":"","altura":0,"peso":0,"aparencia":"","personalidade":"","cargaa":{"value":0,"medio":3,"max":10}},"biography":"","referencias":[],"modificadores":{"atributos":{"geral":0,"fisicos":0,"mentais":0,"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0,"bonus":0,"penalidade":0},"dano":{"geral":0,"cac":0,"ad":0,"mag":0},"custoPM":0,"pericias":{"geral":0,"semataque":0,"ataque":0,"resistencia":0,"atr":{"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0},"bonus":0,"penalidade":0},"ataques":{"bonus":0,"penalidade":0},"custosPM":{"bonus":0,"penalidade":0}},"sentidos":"visão no escuro","equipament":"","treasure":"Metade.","deslocamento":{"base":9,"bonus":0,"penalidade":0,"total":9,"cond":"nao","subst":0,"descricao":""}},"sort":100001,"flags":{"exportSource":{"world":"andreverse-t20","system":"tormenta20","coreVersion":"0.6.6","systemVersion":"0.9.71"},"editing":false},"img":"https://i.imgur.com/uZsvVuk.png","token":{"flags":{},"name":"Kobolds","displayName":50,"img":"https://i.imgur.com/uZsvVuk.png","tint":"","width":1,"height":1,"scale":1.5,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":true,"dimSight":0,"brightSight":30,"dimLight":0,"brightLight":0,"sightAngle":360,"lightAngle":360,"lightColor":"","lightAlpha":1,"lightAnimation":{"type":"","speed":5,"intensity":5},"actorId":"ZPxFnXhUZ2dbcedC","actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.pv"},"bar2":{"attribute":""},"randomImg":false},"items":[{"_id":"5ZFAWCLqhvtAQILR","name":"Caixa com Pregos","type":"poder","data":{"description":"<p><br />Os kobolds arremessam uma caixa com pregos (ou outra coisa perigosa, como insetos pe&ccedil;onhentos) em uma criatura em alcance curto. A v&iacute;tima sofre [[/r 2d6]] pontos de dano de perfura&ccedil;&atilde;o e fica atordoada por uma rodada (Ref CD 15 reduz o dano &agrave; metade e evita a condi&ccedil;&atilde;o atordoado).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"padrao","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"2d6","tipo":"classe","subtipo":"","chatFlavor":""},"sort":300000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"oIYSW9AXtm6tkWWC","name":"Enxame","type":"poder","data":{"description":"<p>Um enxame &eacute; uma aglomera&ccedil;&atilde;o de criaturas que agem em conjunto. Em termos de regras, pode entrar no espa&ccedil;o ocupado por um personagem. No fim de seu turno, o enxame causa [[/r 2d6]] pontos de dano de perfura&ccedil;&atilde;o a qualquer personagem em seu espa&ccedil;o, automaticamente.</p>\n<p>Um enxame &eacute; imune a manobras de combate e efeitos que afetam apenas uma criatura e n&atilde;o causam dano, e sofre apenas metade do dano de ataques com armas. Por&eacute;m, sofre 50% a mais de dano por efeitos de &aacute;rea.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"2d6","tipo":"classe","subtipo":"","chatFlavor":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"Vl2iEXyMBOAdGhTN","name":"Unidos Venceremos","type":"poder","data":{"description":"Periodicamente, novos kobolds se juntam ao enxame. No início de cada rodada, o enxame ganha +10 PV (até um limite máximo de 100 PV). O enxame recebe +1 em rolagens de dano para cada 10 PV que possui.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":500000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]}],"effects":[]}

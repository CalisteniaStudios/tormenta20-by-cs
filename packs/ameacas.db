{"_id":"G7CDTFhKKlvssbYh","name":"Goblin Engenhoqueiro","type":"npc","img":"systems/tormenta20/icons/ameacas/goblin-engenhoqueiro.png","items":[{"_id":"ZIdWDT6OeWwZFK4H","name":"Adaga","type":"arma","sort":100000,"flags":{"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/itens/adaga.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta faca afiada é usada por muitos habitantes adultos do Reinado, embora seja favorita de ladrões e assassinos, por ser facilmente escondida (fornece +2 em testes de Ladinagem para ocultá-la). Quando ataca com uma adaga, você pode usar seu modificador de Destreza em vez de Força nos testes de ataque. Uma adaga pode ser arremessada.</p>","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"key":"ataque0","name":"Ataque","type":"ataque","parts":[["1d20","",""],["luta","",""],["0","",""]],"versatil":""},{"key":"dano0","name":"Dano","type":"dano","parts":[["1d4","",""],["@for","",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"dup":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":true,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":true,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false,"lancinating":false},"chatFlavor":"","ativacao":{"custo":null,"condicao":"","execucao":"","qtd":"","special":""},"origin":"","tags":[],"chatGif":"","consume":{"amount":0,"mpMultiplier":false,"target":"","type":""},"upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"proficiencia":"simples","proposito":"arremesso","empunhadura":"leve","size":"normal"},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdT
sfera voar 9m em qualquer direção. Ela é imune a dano, mas pode ser apagada com água. Uma criatura só pode sofrer dano da esfera uma vez por rodada.","origin":"Compendium.tormenta20.magias.gcjCsjzpk2OtClSt","transfer":false,"tint":null},{"_id":"EOLJ5ChVkU6V1DAg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia ou até ser descarregada","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia ou até ser descarregada. Em vez do normal, você cria uma pequena pedra flamejante, que pode detonar como uma reação, descarregando a magia. A pedra pode ser usada como uma arma de arremesso com alcance curto. Uma vez detonada, causa o dano da magia numa área de esfera de 6m de raio.7","origin":"Compendium.tormenta20.magias.gcjCsjzpk2OtClSt","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta famosa magia de ataque cria uma poderosa explosão, causando 6d6 pontos de dano de fogo em todas as criaturas e objetos livres na área.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"6d6","alcance":"medium","alvo":"","area":"esfera com 6m de raio","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["6d6","",""]],"versatil":""}],"tipo":"arc","circulo":"2","preparada":false,"escola":"evo","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"G8UjbCZFmXhMEQuW","name":"Velocidade","type":"magia","sort":600000,"flags":{"core":{"sourceId":"Item.MtmFzJIsEiXnAzhU"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/velocidade.webp","effects":[{"_id":"lYxiSwCe3djsAOE6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas no alcance","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas no alcance. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false,"tint":null},{"_id":"wb7wmP9NbM1Q2Bxg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5,"priority":null},{"key":"alvo","value":"você","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para você. Você acelera sua mente, além de seu corpo. A ação adicional pode ser usada para lançar magias e ativar engenhocas. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O alvo pode realizar uma ação padrão ou de movimento adicional por turno. Esta ação não pode ser usada para lançar magias e ativar engenhocas.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ihYicIsn5q2ejFPt","name":"Lança Ígnea","type":"magia","sort":1500001,"flags":{"core":{"sourceId":"Item.sPQUNMjFQ0OG9v41"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/lanca-ignea.webp","effects":[{"_id":"pYnMbgG93GxeTt5q","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0,"priority":null},{"key":"condicao","value":"em chamas","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano inicial em +2d6 e o dano do efeito em chamas em +1d6.","origin":"Compendium.tormenta20.magias.RzK5XmyDjKEYWel5","transfer":false,"tint":null},{"_id":"q0RizI5ZTqZFUh4R","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"cena ou até ser descarregada","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para cena ou até ser descarregada. Em vez do efeito normal, a magia cria quatro dardos de lava que flutuam ao lado do conjurador. Uma vez por rodada, como uma ação livre, você pode disparar um dos dardos em uma criatura, causando o efeito normal da magia. Requer 4º Círculo.","origin":"Compendium.tormenta20.magias.RzK5XmyDjKEYWel5","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia foi desenvolvida por um mago imortal, entusiasta dos estudos vulcânicos. Ela dispara um projétil de magma superaquecido contra o alvo, que sofre 4d6 pontos de dano de fogo e 4d6 pontos de dano de perfuração e fica em chamas. As chamas causam 2d6 pontos de dano por rodada, em vez do dano normal. Se passar no teste de resistência, o alvo sofre metade do dano e não fica em chamas. Respingos de rocha incandescente se espalham com a explosão, atingindo todas as criaturas adjacentes ao alvo, que devem fazer um teste de Reflexos. Se falharem, ficam em chamas, como descrito acima.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"medium","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos parcial"},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"evo","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"c2ofHJj3lfvLk2cV","name":"Pele de Pedra","type":"magia","sort":1600001,"flags":{"core":{"sourceId":"Item.F5BAqRoj0aNAESXV"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/pele-de-pedra.webp","effects":[{"_id":"qwR1O4qpIh6U5OWW","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5,"priority":null},{"key":"alvo","value":"1 criatura","mode":5,"priority":null}],"disabled":true,"duration":{"startTime
:false},"items":[{"_id":"srEZAYVoiIfxgsuG","flags":{},"name":"Mordida","type":"arma","img":"icons/svg/mystery-man.svg","data":{"description":"","pericia":"lut","dano":"6d6","atrDan":"for","criticoM":16,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"atqBns":42,"peso":0,"qtd":1,"preco":0,"tipoUso":"natural"},"sort":100000},{"_id":"VzKPOw4g2wkq0Yif","flags":{},"name":"2 garras","type":"arma","img":"icons/svg/mystery-man.svg","data":{"description":"","pericia":"lut","dano":"4d6","atrDan":"for","criticoM":16,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"atqBns":40,"peso":0,"qtd":1,"preco":0,"tipoUso":"natural"},"sort":200000},{"_id":"kkzJOoMtnWAHWiJP","flags":{},"name":"Aura Aterradora","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Vontade CD 29 evita.","roll":"","tipo":"","ativacao":{"execucao":"","custo":0}},"sort":300000},{"_id":"kWmt3nheBXnZY4eQ","flags":{},"name":"Durão","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Quando sofre dano, o dragão ancião reduz esse dano à metade.","roll":"","tipo":"","ativacao":{"execucao":"reacao","custo":"2"}},"sort":400000},{"_id":"FKlqJZh2cGtsrSnw","flags":{},"name":"Magia Acelerada","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Quando lança uma magia com execução de ação completa ou menor, o dragão muda a execução dela para livre. Ele só pode usar este poder uma vez por rodada.","roll":"","tipo":"","ativacao":{"execucao":"livre","custo":"4"}},"sort":500000},{"_id":"Xmw6Cb7Nf54pvkaK","flags":{},"name":"Sopro","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Cone médio. Criaturas na área sofrem 20d12 pontos de dano de fogo e ficam em chamas (Ref CD 38 reduz o dano à metade e evita as chamas).","roll":"20d12","tipo":"","ativacao":{"execucao":"padrao","custo":"3"}},"sort":600000},{"_id":"dHQWhuyCpbnm2rpU","flags":{},"name":"Trespassar","type":"poder","img":"icons/svg/mystery-man.svg","data":{"description":"Quando o dragão faz um ataque corpo a corpo e reduz os pontos de vida do alvo para 0 ou menos, pode gastar 1 PM para fazer um ataque adicional contra outra criatura dentro do seu alcance.","roll":"","tipo":"","ativacao":{"execucao":"livre","custo":"1"}},"sort":700000},{"_id":"xuLtDlpwSmy2HFQh","flags":"","name":"Armadura Arcana","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"Esta magia cria uma película protetora invisível, mas tangível, fornecendo +4 na Defesa. Esse bônus é cumulativo com outras magias, mas não com bônus fornecido por armaduras.","tipo":"Arcana","circulo":"1","custo":1,"preparada":false,"escola":"Abjuração","execucao":"Padrão","alcance":"Pessoal","duracao":"Cena","resistencia":"","alvo":"Você","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual.","_id":"","id":"074ea668-ba8c-463a-b59f-e18ba5b21be9","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus na Defesa em +1.","_id":"","id":"8bf9652c-e245-4392-990b-6e92cb6e4aaf","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Requer 2o círculo.","_id":"","id":"ad230447-7151-4fc0-9a91-b36c6d6e1e57","ativo":false}]},"sort":1200000},{"_id":"z10OqEKdewi2wntn","flags":"","name":"Curar Ferimentos","type":"magia","img":"systems/tormenta20/icons/magias/Evoc.webp","data":{"description":"Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.","tipo":"Divina","circulo":"1","custo":1,"preparada":false,"escola":"Evocação","execucao":"Padrão","alcance":"Toque","duracao":"Instantânea","resistencia":"","alvo":"1 criatura","area":"","cd":0,"efeito":"2d8+2","aprimoramentos":[{"custo":"0","tipo":"Truque","formula":"","description":"em vez do normal, estabiliza uma criatura.","_id":"","id":"8ec8bbe2-b543-401a-a115-7f390f3c4ed3","ativo":false},{"custo":"0","tipo":"Truque","formula":"","description":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","_id":"","id":"b18deddf-a288-4e58-aad7-d26a1af32780","ativo":false},{"custo":"1","tipo":"Aumenta","formula":"1d8","description":"aumenta a cura em +1d8+1.","_id":"","id":"8f1b2389-8976-4575-8851-d726d7042fba","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"também remove uma condição de fadiga do alvo.","_id":"","id":"c526f528-0e2d-4058-b268-e0585516c228","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda o alcance para curto.","_id":"","id":"d96838f2-e083-4a61-b7ef-e0de354fefc8","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para curto e o alvo para criaturas escolhidas.","_id":"","id":"7179b5d9-b224-4fa7-a2a3-35378434efbc","ativo":false}]},"sort":1300000},{"_id":"Wo2qJjBPYjBbJApJ","flags":"","name":"Enfeitiçar","type":"magia","img":"systems/tormenta20/icons/magias/Encan.webp","data":{"description":"Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).","tipo":"Arcana","circulo":"1","custo":1,"preparada":false,"escola":"Encantamento","execucao":"Padrão","alcance":"Curto","duracao":"Cena","resistencia":"Vontade anula","alvo":"1 humanóide","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","_id":"","id":"07ab3013-a5c5-4805-ae1e-b87017f48c42","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alvo para 1 espírito ou monstro. Requer 3o círculo.","_id":"","id":"79758da9-d2f9-4b71-896e-763d309d8bb6","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta todos os alvos dentro do alcance.","_id":"","id":"16407353-737b-43b1-a0e1-f1373f8af7c2","ativo":false}]},"sort":1400000},{"_id":"VsYznLnpd4iBfE36","flags":"","name":"Dissipar Magia","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"Você dissipa outras magias que estejam ativas, como se sua duração tivesse acabado. Note que efeitos de magias instantâneas não podem ser dissipados (não se pode dissipar uma Bola de Fogo ou Relâmpago depois que já causaram dano...). Se lançar essa magia em uma criatura ou área, faça um teste de Misticismo; você anula as magias com CD igual ou menor que o resultado do teste. Se lançada contra um item mágico, o transforma em um item mundano por 1d6 rodadas (sem teste de resistência).","tipo":"Universal","circulo":"2","custo":3,"preparada":false,"escola":"Abjuração","execucao":"Padrão","alcance":"Médio","duracao":"Instantânea","resistencia":"","alvo":"1 criatura ou 1 objeto mágico ou esfera com 3m de raio","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"12","tipo":"Muda","formula":"","description":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5o círculo.","_id":"","id":"5e8f8155-211c-45e8-adab-2f2f727384e7","ativo":false}]},"sort":1500000},{"_id":"rCtb4Is9LnxZLeCY","flags":"","name":"Velocidade","type":"magia","img":"systems/tormenta20/icons/magias/Trans.webp","data":{"description":"O alvo pode realizar uma ação padrão ou de movimento adicional por turno. Esta ação não pode ser usada para lançar magias e ativar engenhocas.","tipo":"Arcana","circulo":"2","custo":3,"preparada":false,"escola":"Transmutação","execucao":"Padrão","alcance":"Curto","duracao":"Cena","resistencia":"","alvo":"1 criatura","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"7","tipo":"Muda","formula":"","description":"muda o alvo para criaturas escolhidas no alcance. Requer 4o círculo.","_id":"","id":"3e10b140-fc6f-4aa1-8465-27f8139f017b","ativo":false},{"custo":"7","tipo":"Muda","formula":"","description":"muda o alcance para pessoal e o alvo para você. Você acelera sua mente, além de seu corpo. A ação adicional pode ser usada para lançar magias e ativar engenhocas. Requer 4o círculo.","_id":"","id":"97d21fdc-a5c6-4d9b-b0ef-ff4640f3249b","ativo":false}]},"sort":1600000},{"_id":"sSCrWjrKGtPZH5cs","flags":"","name":"Globo de Invulnerabilidade","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"Você é envolto por uma esfera mágica brilhante com 3m de raio, que detém qualquer magia de 2o círculo ou menor. Nenhuma magia pode ser lançada contra um alvo dentro do globo e magias de área não o penetram. No entanto, magias ainda podem ser lançadas de dentro para fora. Dissipar Magia só dissipa o globo se for usada diretamente sobre você, não o afetando se usada em área. Efeitos mágicos não são dissipados quando entram na esfera, apenas suprimidos (voltam a funcionar fora do globo, caso sua duração não tenha acabado). O globo é imóvel e não tem efeito sobre criaturas ou objetos. Após lançá-lo, você pode entrar ou sair livremente.","tipo":"Arcana","circulo":"3","custo":6,"preparada":false,"escola":"Abjuração","execucao":"Padrão","alcance":"Pessoal","duracao":"Sustentada","resistencia":"","alvo":"Você","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"4","tipo":"Muda","formula":"","description":"muda o efeito para afetar magias de até 3o círculo. Requer 4o círculo.","_id":"","id":"da61770a-8fb9-4ee1-9807-3cc4673b7d32","ativo":false},{"custo":"9","tipo":"Muda","formula":"","description":"muda o efeito para afetar magias de até 4o círculo. Requer 5o círculo.","_id":"","id":"0a46ba17-b879-4faf-a3d7-95a4bf62a06c","ativo":false}]},"sort":1700000},{"_id":"Ho8Q8N8LeWQ7lfq3","flags":"","name":"Libertação","type":"magia","img":"systems/tormenta20/icons/magias/Abjur.webp","data":{"description":"O alvo fica imune a condições de paralisia e ignora qualquer efeito que impeça ou restrinja seu deslocamento. Por fim, pode usar habilidades que exigem liberdade de movimentos mesmo se estiver usando armadura ou escudo.","tipo":"Universal","circulo":"4","custo":10,"preparada":false,"escola":"Abjuração","execucao":"Padrão","alcance":"Curto","duracao":"Cena","resistencia":"","alvo":"1 criatura","area":"","cd":0,"efeito":"","aprimoramentos":[{"custo":"2","tipo":"Outros","formula":"","description":"além do normal, o alvo pode caminhar sobre a água ou outros líquidos com seu deslocamento normal. Entretanto, isso não protege contra qualquer efeito que o líquido possa causar (o alvo pode andar sobre lava, mas ainda vai sofrer dano).","_id":"","id":"46742907-e933-4f38-abb2-7b50ea6db94d","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"além do normal, o alvo pode escolher 20 em todos os testes de Atletismo.","_id":"","id":"34d3fab9-491a-434d-9463-e5c9ca15f04a","ativo":false},{"custo":"2","tipo":"Outros","formula":"","description":"além do normal, o alvo pode escolher 20 em todos os testes de Acrobacia e pode fazer todas as manobras desta perícia mesmo sem treinamento.","_id":"","id":"175434e1-1aad-41dc-afe2-67152f6a02b7","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alcance para curto e o alvo para até 5 criaturas.","_id":"","id":"e302b12e-0668-4fba-b9f8-dc86fa0c04b9","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"pode dissipar Aprisionamento.","_id":"","id":"7cea0a80-7fc0-4a11-9584-e715f2ae58ea","ativo":false}]},"sort":1800000},{"_id":"RetkwxiswMZZxzY6","flags":"","name":"Chuva de Meteoros","type":"magia","img":"systems/tormenta20/icons/magias/Conv.webp","data":{"description":"Esta magia faz com que um meteoro caia dos céus, devastando a área de impacto e seus arredores. Criaturas na área sofrem 20d6 pontos de dano (metade impacto, metade fogo).","tipo":"Arcana","circulo":"5","custo":15,"preparada":false,"escola":"Convocação","execucao":"Completa","alcance":"Longo","duracao":"Instantânea","resistencia":"Reflexos reduz à metade","alvo":"","area":"explosão com 9m de raio","cd":0,"efeito":"10d6 impacto 10d6 fogo","aprimoramentos":[{"custo":"2","tipo":"Outros","formula":"","description":"criaturas que falhem no teste de resistência ficam caídas e presas sob os escombros (agarradas). Uma criatura agarrada pode escapar gastando uma ação padrão e passando em um teste de Atletismo. Toda a área afetada fica coberta de escombros, sendo considerada terreno difícil.","_id":"","id":"bfeed0e3-da2c-4fa3-9018-1797afc5d512","ativo":false},{"custo":"10","tipo":"Aumenta","formula":"40d6","description":"aumenta o número de meteoros em +1. Os meteoros podem cair na mesma área, para acumular o dano (uma criatura atingida por dois meteoros, por exemplo, sofre 40d6 pontos de dano) ou em uma área diferente (mas ainda dentro do alcance) para afetar mais alvos","_id":"","id":"2e13ec74-d118-478e-afbb-d6225b2499cb","ativo":false}]},"sort":1900000}]}

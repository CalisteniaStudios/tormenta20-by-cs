lue":20,"atributo":"sab","st":false,"pda":false,"treinado":false,"treino":0,"outros":0,"notes":"","mod":0,"temp":0,"bonus":0,"penalidade":0}},"periciasCustom":[],"resistencias":"cura acelerada 20, resistência a magia +5, Imunidade  a  doenças,  fadiga,  sangramento,  sono  e  veneno;  não  precisa  respirar,  alimentar-se  e  dormir;  não  recupera  pontos  de  vida  por descanso e efeitos de cura;","tamanho":"Colossal","detalhes":{"biografia":"","dinheiro":{"tt":0,"to":0,"tp":0,"tc":0,"tl":0},"carga":0},"sentidos":"visão no escuro","equipament":"","deslocamento":{"base":9,"bonus":0,"penalidade":0,"total":9,"cond":"nao","subst":0,"descricao":""},"referencias":[],"modificadores":{"atributos":{"bonus":0,"penalidade":0,"geral":0,"fisicos":0,"mentais":0,"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0},"pericias":{"bonus":0,"penalidade":0,"geral":0,"semataque":0,"ataque":0,"resistencia":0,"atr":{"for":0,"des":0,"con":0,"int":0,"sab":0,"car":0}},"ataques":{"bonus":0,"penalidade":0},"custosPM":{"bonus":0,"penalidade":0},"dano":{"geral":0,"cac":0,"ad":0,"mag":0},"custoPM":0},"biography":"","treasure":""},"sort":100001,"flags":{"editing":false},"img":"https://i.imgur.com/JBxLYeE.png","token":{"flags":{},"name":"Colosso Supremo","displayName":0,"img":"https://i.imgur.com/JBxLYeE.png","tint":"","width":6,"height":6,"scale":1.5,"mirrorX":false,"mirrorY":false,"lockRotation":false,"rotation":0,"vision":true,"dimSight":0,"brightSight":30,"dimLight":0,"brightLight":0,"sightAngle":360,"lightAngle":360,"lightColor":"","lightAlpha":1,"lightAnimation":{"type":"","speed":5,"intensity":5},"actorId":"WMcZXuIIRzCPzr6a","actorLink":false,"disposition":-1,"displayBars":0,"bar1":{"attribute":"attributes.pv"},"bar2":{"attribute":"attributes.pm"},"randomImg":false},"items":[{"_id":"vSiBFyuzECuCuLzT","name":"Espada titânica","type":"arma","data":{"description":"","peso":0,"qtd":1,"preco":0,"atrAtq":"0","pericia":"lut","atrDan":"0","dano":"4d12","atqBns":"45","danoBns":"30","criticoM":19,"criticoX":2,"lancinante":false,"tipo":"","alcance":"","custo":0,"tipoUso":"simples","propriedades":{"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"chatFlavor":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"qsnU9NvGAhcLn8Oi","name":"Balistas","type":"poder","data":{"description":"<p>Um colosso supremo possui duas balistas, uma em cada ombro. Cada balista &eacute; tripulada por soldados que a carregam e a disparam em rodadas alternadas (b&ocirc;nus de ataque [[/r 1d20+13]], [[/r 6d8]] pontos de dano de perfura&ccedil;&atilde;o, cr&iacute;tico 19, alcance m&eacute;dio). &Eacute; poss&iacute;vel atacar as tripula&ccedil;&otilde;es para impedir os disparos. Cada tripula&ccedil;&atilde;o possui Defesa 26, 50 pontos de vida e usa os testes de resist&ecirc;ncia do colosso.</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"livre","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"","tipo":"classe","subtipo":"","chatFlavor":""},"sort":0,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"bTua2ujDZx5B698y","name":"Fumos Tóxicos","type":"poder","data":{"description":"<p>Uma criatura que comece seu turno em alcance curto do colosso sofre [[/r 4d6]] pontos de dano de veneno e fica enjoada (Fortitude CD 30 evita).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"4d6","tipo":"classe","subtipo":"","chatFlavor":""},"sort":100000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"64LhGQcbLshnJU3y","name":"Goblins Consertadores","type":"poder","data":{"description":"Goblins especialmente pequenos rastejam por dentro dos dutos do colosso fazendo reparos, o que fornece ao construto cura acelerada 20. Por estarem dentro do construto, os goblins são imunes a dano, mas ainda podem ser afetados por efeitos mentais. Eles possuem Vontade +2 (mas recebem a resistência a magia do colosso) e, se forem afetados por qualquer condição, a cura acelerada deixa de funcionar.","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"","cd":0,"aprimoramentos":[],"roll":"","tipo":"","subtipo":""},"sort":200000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"nrWEwtD2npplXxdh","name":"Jato de Chamas","type":"poder","data":{"description":"<p>O colosso dispara um jato de chamas que atinge um cone com alcance m&eacute;dio. Criaturas na &aacute;rea sofrem [[/r 8d8+10]] pontos de dano de fogo (Ref CD 35 reduz &agrave; metade).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"movimento","custo":0,"condicao":""},"duracao":{"valor":"","unidade":""},"resistencia":"","atrRes":"for","cd":0,"aprimoramentos":[],"roll":"8d8+10","tipo":"classe","subtipo":"","chatFlavor":""},"sort":400000,"flags":{},"img":"icons/svg/mystery-man.svg","effects":[]},{"_id":"vkFhQQj07PRcCPTs","name":"Passar por Cima","type":"poder","data":{"description":"<p>O colosso percorre at&eacute; o dobro do seu deslocamento, passando por qualquer criatura Grande ou menor. Uma criatura atropelada sofre [[/r 6d8+15]] pontos de dano de impacto (Reflexos CD 30 reduz &agrave; metade).</p>","alcance":"","target":{"value":null,"comprimento":null,"unidades":"","type":""},"alvo":"","area":"","ativacao":{"execucao":"completa","custo":0,"condicao":""},"duracao":{"valor":"","unidade":"
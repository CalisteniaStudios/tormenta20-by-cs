e,"dupla":true,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false,"lancinating":false},"chatFlavor":"","ativacao":{"custo":null,"condicao":"","execucao":"","qtd":"","special":""},"origin":"","tags":[],"chatGif":"","consume":{"amount":0,"mpMultiplier":false,"target":"","type":""},"upgrades":{"melhoria1":"","melhoria2":"","melhoria3":"","melhoria4":"","material":"","encanto1":"","encanto2":"","encanto3":""},"melhorias":{},"proficiencia":"simples","proposito":"corpo-a-corpo","empunhadura":"duas","size":"normal"},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"8ajzD9Rdm426cXDz","name":"Voz da Natureza","type":"poder","sort":500000,"flags":{"core":{"sourceId":"Compendium.tormenta20.poderes.Y9MfowI3KydAdgND"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/poderes/concedidos.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">O centauro xam&atilde; est&aacute; sempre sob o efeito da magia <em>Voz Divina</em>, apenas para falar com animais.</p>","unidentified":""},"source":"","ativacao":{"execucao":"","custo":0,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"","alvo":"","area":"","resistencia":{"pericia":"","atributo":"for","bonus":0,"txt":""},"rolls":[],"tipo":"concedido","subtipo":"Natureza","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WJNOuxS8DeP1UYXa","name":"Armamento da Natureza","type":"magia","sort":600000,"flags":{"core":{"sourceId":"Item.GMd2abkDfzsmHa6P"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/armamento-da-natureza.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você fortalece uma arma mundana primitiva (sem custo em T$, como bordão, clava, funda ou tacape), uma arma natural ou um ataque desarmado. O dano da arma aumenta em um passo e ela é considerada mágica para propósitos de resistência a dano. Ao lançar a magia, você pode mudar o tipo de dano da arma (escolhendo entre corte, impacto ou perfuração).</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"touch","alvo":"1 arma (veja texto)","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"WVTOqoNGCfRgQTXq","name":"Controlar Plantas","type":"magia","sort":700000,"flags":{"core":{"sourceId":"Item.oV66MsZrmtBHAQus"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/controlar-plantas.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia só pode ser lançada em uma área com vegetação. As plantas se enroscam nas criaturas da área. Aquelas que falharem na resistência ficam enredadas. Uma vítima pode se libertar com uma ação padrão e um teste de Acrobacia ou Atletismo. Além disso, a área é considerada terreno difícil. No início de seus turnos, a vegetação tenta enredar novamente qualquer criatura na área, exigindo um novo teste de Reflexos.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"scene","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"short","alvo":"","area":"quadrado com 9m de lado","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Reflexos anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"0SeAYB9jmOSVN0uT","name":"Curar Ferimentos","type":"magia","sort":800000,"flags":{"core":{"sourceId":"Item.galK4UUS6FxYz22S"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/curar-ferimentos.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.</p>","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"2d8+2","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["2d8+2","",""]],"versatil":""}],"tipo":"div","circulo":"1","preparada":false,"escola":"evo","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"PrqywwgkZoijCElM","name":"Enxame de Pestes","type":"magia","sort":1500001,"flags":{"core":{"sourceId":"Item.4e59kyZdikq2FgSd"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/enxame-de-pestes.webp","effects":[],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Você conjura um enxame de criaturas a sua escolha, como besouros, gafanhotos, mosquitos, ratos, morcegos ou serpentes, que surge em um ponto a sua escolha. O enxame pode passar pelo espaço de outras criaturas e não impede que outras criaturas entrem no espaço dele. No final de cada um de seus turnos, o enxame causa 2d12 pontos de dano de veneno a qualquer criatura em seu espaço (Fortitude reduz à metade). Você pode gastar uma ação de movimento para mover o enxame com deslocamento de 12m.</p>","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"0","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"","alcance":"medium","alvo":"","area":"1 enxame Médio (quadrado de 1,5m)","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"Convocação","origin":"","tags":[],"chatFlavor":"","chatGif":""},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}}],"effects":[],"folder":null,"sort":100001,"flags":{"editing":false,"tormenta20":{"sheet":{},"lvlconfig":{"pv":{},"pm":{}},"version":"1.3.0.0"},"core":{"sourceId":"Compendium.tormenta20.ameacas.yDY9SyAksM37Lw0h"}},"system":{"atributos":{"for":{"value":18,"bonus":0,"base":4,"racial":0},"de
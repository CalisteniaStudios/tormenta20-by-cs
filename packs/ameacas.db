mprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"abj","aprimoramentos":[{"custo":"1","tipo":"Muda","formula":"","description":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual.","_id":"","id":"074ea668-ba8c-463a-b59f-e18ba5b21be9","ativo":false},{"custo":"2","tipo":"Aumenta","formula":"","description":"aumenta o bônus na Defesa em +1.","_id":"","id":"8bf9652c-e245-4392-990b-6e92cb6e4aaf","ativo":false},{"custo":"2","tipo":"Muda","formula":"","description":"muda a duração para 1 dia. Requer 2o círculo.","_id":"","id":"ad230447-7151-4fc0-9a91-b36c6d6e1e57","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"ysxlb0cWlvge4hsp","name":"Enfeitiçar","type":"magia","sort":1300001,"flags":{"core":{"sourceId":"Item.ARP9yn6keaH9aNKt"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/enfeiticar.webp","effects":[{"_id":"wuyNqXeAYnTZxLx7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","aprimoramentos":[{"custo":"2","tipo":"Muda","formula":"","description":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","_id":"","id":"07ab3013-a5c5-4805-ae1e-b87017f48c42","ativo":false},{"custo":"5","tipo":"Muda","formula":"","description":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","_id":"","id":"79758da9-d2f9-4b71-896e-763d309d8bb6","ativo":false},{"custo":"5","tipo":"Outros","formula":"","description":"afeta todos os alvos dentro do alcance.","_id":"","id":"16407353-737b-43b1-a0e1-f1373f8af7c2","ativo":false}],"atrRes":"int","cd":0},"ownership":{"default":0},"_stats":{"systemId":null,"systemVersion":null,"coreVersion":null,"createdTime":null,"modifiedTime":null,"lastModifiedBy":null}},{"_id":"t3DSGzNsJ3n4VnQW","name":"Desespero Esmagador","type":"magia","sort":300001,"flags":{"core":{"sourceId":"Item.l9gxrlKYBkmJLnXZ"},"tormenta20":{"version":"1.3.0.0"}},"img":"systems/tormenta20/icons/magias/desespero-esmagador.webp","effects":[{"_id":"6fhmY20GSejtqLgU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"condicao","value":"debilitado","mode":0,"priority":null},{"key":"condicao","value":"esmorecido","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, as condições adquiridas são debilitado e esmorecido.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false,"tint":null},{"_id":"HsX3fBjwZwMTO2bb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, afeta qualquer tipo de criatura.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false,"tint":null},{"_id":"SFqxKl2kgQ69jfzA","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"condicao","value":"pasmo","mode":0,"priority":null}],"disabled":true,"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas que falhem na resistência ficam aos prantos (em termos de jogo, adquirem a condição pasmo) por 1 rodada. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false,"tint":null}],"folder":null,"system":{"description":{"value":"<p style=\"text-align:justify;\">Humanoides na área são acometidos de grande tristeza, adquirindo as condições fraco e frustrado. Se passarem na resistência, adquirem essas condições por uma rodada.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":
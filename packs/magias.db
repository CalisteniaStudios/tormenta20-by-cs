lse,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"2","durationScene":false}},"tint":null},{"_id":"PrA5nfh1uGd1u0VL","changes":[{"key":"data.tracos.resistencias.luz.value","mode":2,"value":"5"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a resistência a luz em +5","origin":"Item.OFMVErrtrMG2uF7U","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"2","durationScene":false}},"tint":null},{"_id":"HUhIYESVEm53yquZ","changes":[{"key":"data.tracos.resistencias.trevas.value","mode":2,"value":"5"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a resistência a trevas em +5","origin":"Item.OFMVErrtrMG2uF7U","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"2","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.AkTQawpuUEiray7n"},"cf":null}}
{"_id":"ELDmNrdpN7g8M3iJ","name":"Libertação","type":"magia","img":"systems/tormenta20/icons/magias/libertacao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">O alvo fica imune a condições de paralisia e ignora qualquer efeito que impeça ou restrinja seu deslocamento. Por fim, pode usar habilidades que exigem liberdade de movimentos mesmo se estiver usando armadura ou escudo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"4","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"BU5LpJQ6K0yU6b69","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo pode caminhar sobre a água ou outros líquidos com seu deslocamento normal. Entretanto, isso não protege contra qualquer efeito que o líquido possa causar (o alvo pode andar sobre lava, mas ainda vai sofrer dano).","origin":"Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ","transfer":false},{"_id":"u8bzRTaoDhpbpzhf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo pode escolher 20 em todos os testes de Atletismo.","origin":"Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ","transfer":false},{"_id":"7dRxwyy8vnjpqZQt","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo pode escolher 20 em todos os testes de Acrobacia e pode fazer todas as manobras desta perícia mesmo sem treinamento.","origin":"Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ","transfer":false},{"_id":"LIKqu6OYnyws76oU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"até 5 criaturas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para até 5 criaturas.","origin":"Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ","transfer":false},{"_id":"dOfwy9dacju0gnNw","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"pode dissipar Aprisionamento.","origin":"Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ","transfer":false},{"_id":"Yl8ldw9I3O8fnXxN","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/libertacao.webp","label":"Libertação","origin":"Item.iO6NoE2znh1fK5bD","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.IsMRX6mBUU29lKo7"}}}
{"_id":"Ebl1IOvc8Brfm4Qd","name":"Poeira da Podridão","type":"magia","img":"systems/tormenta20/icons/magias/poeira-da-podridao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você manifesta uma nuvem de poeira carregada de energia negativa, que apodrece lentamente as criaturas na área. Ao lançar a magia, e no início de seus turnos, criaturas na área sofrem 2d8+8 pontos de dano de trevas (Fortitude reduz à metade). Alvos que falharem no teste ficam imunes a magias de cura por uma rodada.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"2d8+8","alcance":"medium","alvo":"","area":"nuvem com 6m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude (veja texto)"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d8+8",""]]}],"tipo":"div","circulo":"3","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"F1UMAcyF4jBKmixk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em 1d8+4.","origin":"Compendium.tormenta20.magias.Ebl1IOvc8Brfm4Qd","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.EZMS37j7IUi4CllM"}}}
{"_id":"FW1NLpibuEisXYw4","name":"Mão Poderosa","type":"magia","img":"systems/tormenta20/icons/magias/mao-poderosa.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma mão flutuante de tamanho Grande que sempre se posiciona entre você e um oponente a sua escolha. A mão fornece cobertura (+5 na Defesa) contra esse oponente. Nada é capaz de enganar a mão — coisas como escuridão, invisibilidade, metamorfose e disfarces mundanos não a impedem de protegê-lo. A mão tem Defesa 20 e PV e resistências iguais aos seus. Com uma ação de movimento, você pode comandar a mão para que o proteja de outro oponente ou para que realize uma das ações a seguir.</p><p style=\"text-align:justify;\"><i>Agarrar:</i> a mão usa uma manobra agarrar contra o oponente, com bônus de +20. A mão mantém o oponente agarrado, mas não causa dano.</p><p style=\"text-align:justify;\"><i>Esmagar:</i> a mão esmaga um oponente já agarrado, causando 2d6+12 pontos de dano.</p><p style=\"text-align:justify;\"><i>Empurrar:</i> a mão afasta o oponente, usando uma manobra empurrar com bônus de +20. A mão sempre acompanha o oponente para empurrá-lo até a distância máxima que conseguir, dentro do alcance da magia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"mão gigante de energia","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"mIvHwDdM898hHwC8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus dos testes em +5 e o dano de impacto em +1d6+6.","origin":"Compendium.tormenta20.magias.FW1NLpibuEisXYw4","transfer":false},{"_id":"nmvFzB6CBJipqrVb","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/mao-poderosa.webp","label":"Mão Poderosa (Cobertura)","origin":"Item.h8ZfAbnNLMgdI8pq","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.xXhiZcJKC0WJA6af"}}}
{"_id":"FWtt8quRlKs3OTYF","name":"Refúgio","type":"magia","img":"systems/tormenta20/icons/magias/refugio.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria um domo imóvel e quase opaco por fora, mas transparente pelo lado de dentro. Ele protege contra calor, frio e forças pequenas, mas não contra qualquer coisa capaz de causar dano. Assim, o domo protege contra neve e vento comuns, mas não contra uma flecha ou Bola de Fogo. Porém, como o domo é quase opaco, qualquer criatura dentro dele tem camuflagem total contra ataques vindos de fora. Criaturas podem entrar e sair do domo livremente. Descansar dentro do Refúgio concede recuperação normal de PV e PM.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"domo com 6m de raio","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"w2MBiQsH7AZNMLlB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, os limites do domo são envoltos por uma fumaça escura e espessa, que impede criaturas do lado de fora de enxergar ou ouvir o que está dentro. Criaturas do lado de dentro enxergam e ouvem normalmente o que está do lado de fora. A fumaça também bloqueia magias de adivinhação.","origin":"Compendium.tormenta20.magias.FWtt8quRlKs3OTYF","transfer":false},{"_id":"W2NkcsKFPBbdARZ4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, cria uma cabana que comporta até 10 criaturas Médias. Descansar nesse espaço concede recuperação confortável (recupera PV e PM igual ao dobro do nível). Para todos os efeitos é uma cabana normal, com paredes de madeira, telhado, uma porta, duas janelas e alguma mobília (camas, uma mesa com bancos e uma lareira). A porta e as janelas têm 15 PV, RD 5 e são protegidas por um efeito idêntico à magia Tranca Arcana. As paredes têm 200 PV e RD 5.","origin":"Compendium.tormenta20.magias.FWtt8quRlKs3OTYF","transfer":false},{"_id":"ZDp7AIK0a7E2mUXD","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, cria um espaço extradimensional, similar a uma caverna vazia e escura, que comporta até 10 criaturas Médias. A entrada para o espaço precisa estar desenhada em um objeto fixo como uma grande pedra ou árvore. Qualquer criatura que atravesse a entrada consegue entrar no espaço. Nenhum efeito a partir do mundo real afeta o espaço e vice-versa, mas aqueles que estiverem dentro podem observar o mundo real como se uma janela de 1m estivesse centrada na entrada. Qualquer coisa que esteja no espaço extradimensional surge no mundo real na área vazia mais próxima da entrada quando a duração da magia acaba. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.FWtt8quRlKs3OTYF","transfer":false},{"_id":"Ic4EawK68vSntwCe","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, cria uma mansão extradimensional que comporta até 100 criaturas Médias, com quartos luxuosos, comida e bebida e dez servos fantasmagóricos (como na magia Servos Invisíveis). Descansar na mansão concede recuperação luxuosa (recupera PV e PM igual ao triplo do nível). A mansão tem uma única entrada, uma porta feita de luz. Você pode deixá-la visível ou invisível como uma ação livre e apenas criaturas escolhidas por você podem passar. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.FWtt8quRlKs3OTYF","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.deJp3nZmfU6vapJh"}}}
{"_id":"FYoig9D5AWpvNOHu","name":"Erupção Glacial","type":"magia","img":"systems/tormenta20/icons/magias/erupcao-glacial.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Estacas de gelo irrompem do chão. Criaturas na área sofrem 4d6 de dano de corte, 4d6 de dano de frio e ficam caídas. Passar no teste de Reflexos evita o dano de corte e a queda. As estacas duram pela cena, o que torna a área afetada terreno difícil, e concedem cobertura para criaturas dentro da área ou atrás dela. As estacas são destruídas caso sofram qualquer quantidade de dano por fogo mágico.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"quadrado de 6m de lado","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Relfexos parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["8d6",""]]}],"tipo":"arc","circulo":"3","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"lhm7KAuzog8jrlAp","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"4d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano de frio em +2d6 e o dano de corte em +2d6.","origin":"Compendium.tormenta20.magias.FYoig9D5AWpvNOHu","transfer":false,"tint":null},{"_id":"cv48VdIt4zSGiUiy","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"area","value":"cilindro com 6m de raio","mode":5},{"key":"duracao","value":"sustentada","mode":5},{"key":"dano","value":"3d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para cilindro com 6m de raio e 6m de altura e a duração para sustentada. Em vez do normal, a magia cria uma tempestade de granizo que causa 3d6 pontos de dano de impacto e 3d6 pontos de dano de frio em todas as criaturas na área (sem teste de resistência). A tempestade fornece camuflagem a todas as criaturas dentro dela e deixa o piso escorregadio. Piso escorregadio conta como terreno difícil e obriga criaturas na área a fazer testes de Acrobacia para equilíbrio (veja o Capítulo 2). Requer 4º círculo.","origin":"Compendium.tormenta20.magias.FYoig9D5AWpvNOHu","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.ypOyP3H2SUeL5aar"}}}
{"_id":"FxAlmaFR7sYRJD5z","name":"Salto Dimensional","type":"magia","img":"systems/tormenta20/icons/magias/salto-dimensional.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia transporta você para outro lugar dentro do alcance. Você não precisa perceber nem ter linha de efeito ao seu destino, podendo simplesmente imaginá-lo. Por exemplo, pode se transportar 3m adiante para ultrapassar uma porta fechada. Uma vez transportadas, criaturas não podem agir até a rodada seguinte. Esta magia não permite que você apareça dentro de um corpo sólido; se o ponto de chegada não tem espaço livre, você ressurge na área vazia mais próxima.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"SCNqyonvauqBmixL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"médio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para médio.","origin":"Compendium.tormenta20.magias.FxAlmaFR7sYRJD5z","transfer":false},{"_id":"Ntqu4ueHUMyU22PY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"você","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para você e uma criatura voluntária. Você pode escolher este aprimoramento mais vezes para aumentar o número de alvos adicionais em +1, mas deve estar tocando todos os alvos.","origin":"Compendium.tormenta20.magias.FxAlmaFR7sYRJD5z","transfer":false},{"_id":"clFR53t6qSbEJilN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"execucao","value":"reação","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para reação. Em vez do normal, você salta para um espaço adjacente (1,5m), recebendo +5 na Defesa e em testes de Reflexos contra um ataque ou efeito que esteja prestes a atingi-lo.","origin":"Compendium.tormenta20.magias.FxAlmaFR7sYRJD5z","transfer":false},{"_id":"HRQliZq16itaJoqD","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alcance","value":"longo","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para longo.","origin":"Compendium.tormenta20.magias.FxAlmaFR7sYRJD5z","transfer":false},{"_id":"uGWzWzlemJAPIqit","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"5"},{"key":"data.pericias.refl.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/salto-dimensional.webp","label":"Salto Dimensional","origin":"Item.2RbMZhAWI6aIaz4o","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.JblOvidFjUKalj80"}}}
{"_id":"G918QZzj9ln4mpMn","name":"Alterar Destino","type":"magia","img":"systems/tormenta20/icons/magias/alterar-destino.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Sua mente visualiza todas as possibilidades de um evento, permitindo a voc&ecirc; escolher o melhor curso de a&ccedil;&atilde;o. Voc&ecirc; automaticamente passa em um teste de resist&ecirc;ncia ou evita um ataque at&eacute; o in&iacute;cio de seu pr&oacute;ximo turno.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"reaction","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"abj","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.JOpGmxRAQQ9w9UJ5"}}}
{"_id":"GDlkTth7oEnb5d0Y","name":"Visão Mística","type":"magia","img":"systems/tormenta20/icons/magias/visao-mistica.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Seus olhos brilham com uma luz azul e passam a enxergar auras mágicas. Este efeito é similar ao uso de Misticismo para detectar magia, mas você detecta todas as auras mágicas em alcance médio e recebe todas as informações sobre elas sem gastar ações. Além disso, você pode gastar uma ação de movimento para descobrir se uma criatura que possa perceber em alcance médio é capaz de lançar magias e qual a aura gerada pelas magias de círculo mais alto que ela pode lançar.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"eCU8aGE8aijCkLQz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"recebe visão no escuro.","origin":"Compendium.tormenta20.magias.GDlkTth7oEnb5d0Y","transfer":false},{"_id":"H8kJ7pjbXZ5GHul1","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia.","origin":"Compendium.tormenta20.magias.GDlkTth7oEnb5d0Y","transfer":false},{"_id":"h2HgQs3BgaLA36Iq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também pode enxergar objetos e criaturas invisíveis. Eles aparecem como formas translúcidas.","origin":"Compendium.tormenta20.magias.GDlkTth7oEnb5d0Y","transfer":false},{"_id":"CbJYK47QeZh8jjXN","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/visao-mistica.webp","label":"Visão Mística","origin":"Item.PCaHH8sXU1qHJvSm","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.W5otW3BpG0GfKGF1"},"cf":null}}
{"_id":"GSFSVe8XGZbzQ2H6","name":"Controlar o Clima","type":"magia","img":"systems/tormenta20/icons/magias/controlar-clima.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; muda o clima da &aacute;rea onde se encontra, podendo criar qualquer condi&ccedil;&atilde;o clim&aacute;tica: chuva, neve, ventos, n&eacute;voas... Veja o Cap&iacute;tulo 6: O Mestre para os efeitos em jogo do clima.</p>\n<p style=\"text-align: justify;\">&nbsp;</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"4d12 horas","units":"special","special":"","valor":"4d12 horas","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"none","alvo":"Alcance 2 km","area":"esfera com 2km de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"4","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"2Z6OCBkc9N3riped","changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"(Apenas Druidas): muda o raio da área para 3km e duração para 1d4 dias.","origin":"Item.BBsCJvv06oQA3sV0","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"1","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.1v7kycXDOV1oENQb"}}}
{"_id":"Gj6RiMUjgLaYrWux","name":"Sopro da Salvação","type":"magia","img":"systems/tormenta20/icons/magias/sopro-da-salvacao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você enche seus pulmões de energia positiva e sopra um cone de poeira reluzente. O sopro afeta apenas seus aliados na área, curando 2d8+4 pontos de vida e removendo uma das seguintes condições de todos os alvos: abalado, atordoado, apavorado, alquebrado, cego, confuso, debilitado, enjoado, esmorecido, exausto, fascinado, fatigado, fraco, frustrado, lento, paralisado, pasmo e surdo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"cone","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Cura","key":"dano0","type":"dano","parts":[["2d8+4",""]]}],"tipo":"div","circulo":"3","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"J2p8XWtwE68zTyQ3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a quantidade de cura em 1d8+2.","origin":"Compendium.tormenta20.magias.Gj6RiMUjgLaYrWux","transfer":false},{"_id":"4AbPHIc75Tf1GXkQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, se um aliado estiver com PV negativos, seus PV são levados a 0 e então a cura é aplicada.","origin":"Compendium.tormenta20.magias.Gj6RiMUjgLaYrWux","transfer":false},{"_id":"lWcJ1YAte7SXpUl0","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"remove todas as condições listadas, em vez de apenas uma.","origin":"Compendium.tormenta20.magias.Gj6RiMUjgLaYrWux","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.3h1neY0e1kWcDJrD"}}}
{"_id":"GuHLeMskEm21WzFv","name":"Augúrio","type":"magia","img":"systems/tormenta20/icons/magias/augurio.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia diz se uma a&ccedil;&atilde;o que voc&ecirc; tomar&aacute; em breve &mdash; no m&aacute;ximo uma hora no futuro &mdash; trar&aacute; resultados bons ou ruins. O mestre rola 1d6 em segredo; com um resultado de 2 a 6, a magia funciona e voc&ecirc; recebe uma das seguintes respostas: &ldquo;felicidade&rdquo; (a a&ccedil;&atilde;o trar&aacute; bons resultados); &ldquo;mis&eacute;ria&rdquo; (a a&ccedil;&atilde;o trar&aacute; maus resultados); &ldquo;felicidade e mis&eacute;ria&rdquo; (para ambos) ou &ldquo;nada&rdquo; (para a&ccedil;&otilde;es que n&atilde;o trar&atilde;o resultados bons ou ruins).</p>\n<p style=\"text-align: justify;\">Com um resultado 1, a magia falha e oferece o resultado &ldquo;nada&rdquo;. N&atilde;o h&aacute; como saber se esse resultado foi dado porque a magia falhou ou n&atilde;o. Lan&ccedil;ar esta magia m&uacute;ltiplas vezes sobre o mesmo assunto gera sempre o primeiro resultado.</p>\n<p style=\"text-align: justify;\">Por exemplo, se o grupo est&aacute; prestes a entrar em uma c&acirc;mara, o aug&uacute;rio dir&aacute; &ldquo;felicidade&rdquo; se a c&acirc;mara cont&eacute;m um tesouro desprotegido, &ldquo;mis&eacute;ria&rdquo; se cont&eacute;m um monstro, &ldquo;felicidade e mis&eacute;ria&rdquo; se houver um tesouro e um monstro ou &ldquo;nada&rdquo; se a c&acirc;mara estiver vazia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"zWeTcVcSy9aA7BfP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"execucao","value":"1 minuto","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para 1 minuto. Em vez do normal, você pode consultar uma divindade, fazendo uma pergunta sobre um evento que acontecerá até um dia no futuro. O mestre rola a chance de falha; com um resultado de 2 a 6, você recebe uma resposta, desde uma simples frase até uma profecia ou enigma. Em geral, este uso sempre oferece pistas, indicando um caminho a tomar para descobrir a resposta que se procura. Numa falha você não recebe resposta alguma. Requer 3º círculo.","origin":"Item.sOyknQBB504tY5KB","tint":null,"transfer":false},{"_id":"ZYBWgmolM7f6aDUy","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","value":"1 minuto","mode":5},{"key":"execucao","value":"10 minutos","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para 10 minutos e a duração para 1 minuto. Em vez do normal, você consulta uma divindade, podendo fazer uma pergunta por rodada, desde que ela possa ser respondida com “sim”, “não” ou “não sei” (embora poderosos, os deuses não são oniscientes). O mestre rola a chance de falha para cada pergunta. Em caso de falha, a resposta também é “não sei”. Requer 4º círculo.","origin":"Item.sOyknQBB504tY5KB","tint":null,"transfer":false},{"_id":"JIcynrqdH9dZXBuS","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o mestre rola 1d12; a magia só falha em um resultado 1.","origin":"Item.sOyknQBB504tY5KB","tint":null,"transfer":false},{"_id":"dmQhkxNcK40fGl7U","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"12","durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o mestre rola 1d20; a magia só falha em um resultado 1.","origin":"Item.sOyknQBB504tY5KB","tint":null,"transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.axPB9npHqHAibRfY"}}}
{"_id":"H7tJCAL2UNJ8QLPN","name":"Detectar Ameaças","type":"magia","img":"systems/tormenta20/icons/magias/detectar-ameacas.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você percebe a presença e a localização de criaturas inamistosas ou hostis na área, mesmo através de barreiras físicas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"Esfera de 9m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"WJWA2GBoZcDlLn2e","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez de criaturas, você percebe a presença e localização de venenos.","origin":"Compendium.tormenta20.magias.H7tJCAL2UNJ8QLPN","transfer":false},{"_id":"t5yLRHYstZKEtMWI","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"execucao","value":"Completa","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação completa. Você descobre também a raça ou espécie e o poder das criaturas (determinado pela aura delas). Criaturas de 1º a 6o nível geram uma aura tênue, criaturas de 7o a 12º nível geram uma aura moderada e criaturas de 13º ao 20o nível geram uma aura poderosa. Criaturas acima do 20o nível geram uma aura avassaladora.","origin":"Compendium.tormenta20.magias.H7tJCAL2UNJ8QLPN","transfer":false},{"_id":"YlWmo9KUIn4n9sUx","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez de criaturas, você percebe a presença e localização de armadilhas.","origin":"Compendium.tormenta20.magias.H7tJCAL2UNJ8QLPN","transfer":false},{"_id":"p0ooV6BGcfpbIWI2","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"area","value":"esfera de 30m de raio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para esfera de 30m de raio. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.H7tJCAL2UNJ8QLPN","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.D8Qg7prEiBMKeBg5"}}}
{"_id":"I177NeKSwiAn8vz5","name":"Despedaçar","type":"magia","img":"systems/tormenta20/icons/magias/despedacar.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia emite um som alto e agudo. Se o alvo &eacute; uma criatura, sofre 1d8+2 pontos de dano de impacto e fica atordoado por uma rodada (Fortitude reduz o dano &agrave; metade, evita o atordoamento e n&atilde;o pode mais ser atordoada por esta magia&nbsp;at&eacute; o fim da cena). Construtos sofrem dano dobrado por essa magia. Se o alvo &eacute; um objeto, &eacute; destru&iacute;do (Reflexos anula).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura ou objeto mundano pequeno","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude parcial ou Reflexos anula"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["1d8+2",""]]}],"tipo":"div","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"LbEDlxeHOfexMbYO","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d8+2","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d8+2.","origin":"Compendium.tormenta20.magias.I177NeKSwiAn8vz5","transfer":false},{"_id":"HDHQCUh8nM4pANQf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alvo","value":"objeto mundano Médio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para objeto mundano Médio. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.I177NeKSwiAn8vz5","transfer":false},{"_id":"30IcETZW62RYh9Qk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"objeto mundano Grande","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para objeto mundano Grande. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.I177NeKSwiAn8vz5","transfer":false},{"_id":"es0fJdOaTlj0FRCz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"alvo","mode":5,"value":"objeto mun- dano Enorme"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para objeto mundano Enorme. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.I177NeKSwiAn8vz5","transfer":false,"tint":null},{"_id":"4RIX1aTMtm2znXIX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[{"key":"alvo","value":"objeto mundano Colossal","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para objeto mundano Colossal. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.I177NeKSwiAn8vz5","transfer":false},{"_id":"qRaVVXpL5EcAE9is","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"alcance","mode":5,"value":"pessoal"},{"key":"area","mode":5,"value":"explosão de 6m de raio"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e a área para esfera de 6m de raio. Todas as criaturas e objetos na área são afetados.","origin":"Compendium.tormenta20.magias.I177NeKSwiAn8vz5","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.07AHt1c9s0eKbfXB"}}}
{"_id":"I7if4gOoxqXhdjcK","name":"Chuva de Meteoros","type":"magia","img":"systems/tormenta20/icons/magias/chuva-de-meteoros.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia faz com que v&aacute;rios meteoros caiam&nbsp;dos c&eacute;us devastando a &aacute;rea de impacto. Criaturas na &aacute;rea sofrem 15d6 pontos de dano de&nbsp;impacto e 15d6 de dano de fogo (um teste de Reflexos reduz o dano total pela metade). Criaturas&nbsp;que falhem no teste de resist&ecirc;ncia ficam ca&iacute;das e presas sob os escombros (agarradas).</p>\n<p style=\"text-align: justify;\">Uma&nbsp;criatura presa pode escapar gastando uma a&ccedil;&atilde;o padr&atilde;o e passando em um teste de Atletismo&nbsp;(CD da magia). Toda a &aacute;rea afetada fica coberta de escombros, sendo considerada terreno dif&iacute;cil,&nbsp;e imersa numa nuvem de poeira densa (camuflagem parcial). Esta magia s&oacute; pode ser utilizada a&nbsp;c&eacute;u aberto.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"10d6 impacto + 10d6 fogo","alcance":"long","alvo":"","area":"quadrado com 18m de lado","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["30d6",""]]}],"tipo":"arc","circulo":"5","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"EiA6E64UonEUYa8o","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"4d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de meteoros que atingem a área, o que aumenta o dano em +2d6 de impacto e +2d6 de fogo.","origin":"Compendium.tormenta20.magias.I7if4gOoxqXhdjcK","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.s2LpPdDAp7PjShYl"}}}
{"_id":"IYB0YK1zLune1fs0","name":"Tentáculos de Trevas","type":"magia","img":"systems/tormenta20/icons/magias/tentaculos-de-trevas.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Uma esfera de energias sombrias se abre no ch&atilde;o, de onde surgem tent&aacute;culos feitos de treva viscosa. Ao lan&ccedil;ar a magia e no in&iacute;cio de cada um de seus turnos, voc&ecirc; faz um teste da manobra agarrar (usando seu b&ocirc;nus de Misticismo) contra cada criatura na &aacute;rea. Se voc&ecirc; passar, a criatura &eacute; agarrada; se a v&iacute;tima j&aacute; est&aacute; agarrada, &eacute; esmagada, sofrendo 4d6 pontos de dano de trevas. A &aacute;rea conta como terreno dif&iacute;cil. Os tent&aacute;culos s&atilde;o imunes a dano.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"esfera com 6m de raio","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[{"name":"Manobra Agarrar","key":"ataque0","type":"ataque","parts":[["1d20",""],["mist","int"],["",""]]},{"name":"Dano","key":"dano1","type":"dano","parts":[["4d6",""]]}],"tipo":"arc","circulo":"3","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"nQjQ8UmqV2tmL8Rr","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o raio da área em +3m.","origin":"Compendium.tormenta20.magias.IYB0YK1zLune1fs0","transfer":false},{"_id":"EoTSEUAxLwWL3ZCd","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"2d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano dos tentáculos em +2d6.","origin":"Compendium.tormenta20.magias.IYB0YK1zLune1fs0","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Wuk6bahrEEmrrMFH"}}}
{"_id":"Ih5qBTlgQyY2WhiS","name":"Anular a Luz","type":"magia","img":"systems/tormenta20/icons/magias/anular-luz.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia cria uma onda de escurid&atilde;o que causa diversos efeitos. Todas as magias de 3&ordm; c&iacute;rculo ou menor ativas na &aacute;rea s&atilde;o dissipadas se voc&ecirc; passar num teste de Religi&atilde;o contra a CD de cada magia. Seus aliados na &aacute;rea s&atilde;o protegidos por uma aura sombria e recebem +4 na Defesa at&eacute; o fim da cena. Inimigos na &aacute;rea ficam enjoados por 1d4 rodadas (apenas uma vez pela magia). Anular a Luz anula Dispersar as Trevas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"special","special":"Ver Texto","valor":"","unidade":"verTexto"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"esfera de 6m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"qo4G5dtFQfZJ3hpw","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus na Defesa em +1.","origin":"Item.Fviqk5ohbYlvRgvz","tint":null,"transfer":false},{"_id":"N2qZYyJIjFQ390ah","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o círculo máximo de magias dissipadas para 4º. Requer 4º Círculo.","origin":"Item.Fviqk5ohbYlvRgvz","tint":null,"transfer":false},{"_id":"Xnw2EPozN5CIB508","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o círculo máximo de magias dissipadas para 5º. Requer 5º Círculo.","origin":"Item.Fviqk5ohbYlvRgvz","tint":null,"transfer":false},{"_id":"oq21KrClIzX37uDs","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":true}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"4"}],"disabled":false,"duration":{"startTime":null,"rounds":999},"icon":"systems/tormenta20/icons/magias/anular-luz.webp","label":"Anular a Luz (Bônus)","origin":"Item.Fviqk5ohbYlvRgvz","tint":null,"transfer":false},{"_id":"lsVny2cN4ORKBpbf","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/anular-luz.webp","label":"Inimigos Afetados","origin":"Item.IfaGMjeO8p0YO1pz","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.axYSo81ouHtGA4WH"}}}
{"_id":"JS4oSL4XZDUusUaS","name":"Desejo","type":"magia","img":"systems/tormenta20/icons/magias/desejo.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta é a mais poderosa das magias arcanas, permitindo alterar a realidade a seu bel-prazer. Você pode:</p><ul><li>Dissipar os efeitos de qualquer magia de 4º círculo ou menor.</li><li>Transportar até 10 criaturas voluntárias em alcance longo para qualquer outro local, em qualquer plano.</li><li>Desfazer um acontecimento recente. A magia permite que um teste realizado por uma criatura em alcance longo na última rodada seja realizado novamente. Por exemplo, se um aliado morreu na última rodada devido ao ataque de um inimigo, você pode obrigar o inimigo a refazer esse ataque.</li></ul><p style=\"text-align:justify;\">Normalmente, Desejo não exige sacrifício de PM — mas você pode desejar por algo mais poderoso. Nesse caso, a magia requer o sacrifício de 2 PM e pode fazer coisas como:</p><ul><li>Criar um item mundano de até T$ 25.000.</li><li>Duplicar os efeitos de qualquer magia de até 4º círculo. Caso a magia precise de um componente material para ser lançada, ainda é necessário providenciar o componente.</li><li>Aumentar um atributo de uma criatura em +1. Um mesmo atributo pode ser aumentado em até +5 através do uso de Desejo.</li></ul><p style=\"text-align:justify;\">Desejo pode gerar efeitos ainda mais poderosos, mas tenha cuidado! Desejar a fortuna de um rei pode transportá-lo para a sala de tesouro real, onde você será preso ou morto; desejar ser imortal pode transformá-lo em morto-vivo, e assim por diante. Qualquer efeito que não encaixe na lista acima deve ser decidido pelo mestre.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"veja texto","units":"special","special":"","valor":"veja texto","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"spec","alvo":"veja texto","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"veja texto"},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"tra","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.OicPJbdbvUiS2e37"}}}
{"_id":"JctewV5T9iIwOD8b","name":"Conjurar Elemental","type":"magia","img":"systems/tormenta20/icons/magias/conjurar-elemental.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia transforma uma por&ccedil;&atilde;o de um elemento inerte em uma criatura elemental Grande do tipo do elemento alvo. Por exemplo, lan&ccedil;ar esta magia numa fogueira ou tocha cria um elemental do fogo. Voc&ecirc; pode criar elementais do ar, &aacute;gua, fogo e terra com essa magia. O elemental obedece a todos os seus comandos e pode funcionar como um aliado mestre do tipo destruidor (cuja habilidade custa apenas 2 PM para ser usada) e mais um tipo entre os indicados na lista abaixo. Somente voc&ecirc; pode ser auxiliado pelo elemental e ele n&atilde;o conta em seu limite de aliados.</p>\n<p style=\"text-align: justify;\"><em>Ar:</em> assassino, perseguidor ou vigilante. Dano de eletricidade.</p>\n<p style=\"text-align: justify;\"><em>&Aacute;gua:</em> ajudante, guardi&atilde;o ou m&eacute;dico. Dano de frio.</p>\n<p style=\"text-align: justify;\"><em>Fogo:</em> atirador, combatente ou fort&atilde;o. Dano de fogo.</p>\n<p style=\"text-align: justify;\"><em>Terra:</em> combatente, guardi&atilde;o ou montaria. Dano de impacto.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"aliado elemental","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"3Q6aRRLjOb8h5kFp","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o elemental muda para Enorme e recebe dois tipos de aliado indicados no seu elemento.","origin":"Compendium.tormenta20.magias.JctewV5T9iIwOD8b","transfer":false},{"_id":"DPXnyWDQQxzUOpi3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"você convoca um elemental de cada tipo. Você pode ordenar que cada elemental auxilie você ou seus aliados. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.JctewV5T9iIwOD8b","transfer":false},{"_id":"ZjjDD6sfPEyTebNW","changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"2d6"},{"key":"data.modificadores.dano.ad","mode":2,"value":"2d6"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental do Ar Assassino","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"xGV66nLa5dqIL1Jx","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental do Ar Perseguidor","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"YXLU6iLqqU2Gw0eC","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental do Ar Vigilante","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"2uitfX35jMNADQOa","changes":[{"key":"data.pericias.???.bonus","mode":2,"value":"4"},{"key":"data.pericias.???.bonus","mode":2,"value":"4"},{"key":"data.pericias.???.bonus","mode":2,"value":"4"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental da Água Ajudante","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"LL89OjzKMJLsTVqN","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"4"},{"key":"data.pericias.fort.bonus","mode":2,"value":"2"},{"key":"data.pericias.refl.bonus","mode":2,"value":"2"},{"key":"data.pericias.vont.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental da Água Guardião","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"Q45ubi3p8pdZnGt8","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental da Água Médico","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"bgrACGakK3NBNkcS","changes":[{"key":"data.modificadores.dano.ad","mode":2,"value":"2d8"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental do Fogo Atirador","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"rx4zmSmXq846kv9j","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"3"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"3"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental do Fogo Combatente","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"3JzHVxSdR96KTuOv","changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"3d6"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental do Fogo Fortão","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"KQFqSonMRC9Uxkk5","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"3"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"3"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental da Terra Combatente","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"5GBLKb6S8ymJnYYI","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"4"},{"key":"data.pericias.fort.bonus","mode":2,"value":"2"},{"key":"data.pericias.refl.bonus","mode":2,"value":"2"},{"key":"data.pericias.vont.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental da Terra guardião","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"AsD9TcYdabP4PUcp","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conjurar-elemental.webp","label":"Elemental da Terra Montaria","origin":"Item.bToFBkzXceKMrqBH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.jhLani6bivpW9vFn"}}}
{"_id":"K2VH0rr4Qw6OqQjA","name":"Enxame Rubro","type":"magia","img":"systems/tormenta20/icons/magias/enxame-rubro.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você conjura um enxame de pequenas criaturas da Tormenta, que surge em um ponto a sua escolha. O enxame pode passar pelo espaço de outras criaturas e não impede que outras criaturas entrem no espaço dele. No final de cada um de seus turnos, o enxame causa 4d12 pontos de dano de ácido a qualquer criatura em seu espaço (Reflexos reduz à metade). Você pode gastar uma ação de movimento para mover o enxame com deslocamento de 12m.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"1 enxame Grande (quadrado de 3m);","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["4d12",""]]}],"tipo":"arc","circulo":"3","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"qjUdUNOHZMHUZn7l","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, uma criatura que falhe no teste de Reflexos fica agarrada (o enxame escala e cobre o corpo dela). A criatura pode gastar uma ação padrão e fazer um teste de Acrobacia ou Atletismo para escapar. Se você mover o enxame, a criatura fica livre.","origin":"Compendium.tormenta20.magias.K2VH0rr4Qw6OqQjA","transfer":false},{"_id":"UFFFl7Mcw07E6mlZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"1d12"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d12.","origin":"Compendium.tormenta20.magias.K2VH0rr4Qw6OqQjA","transfer":false,"tint":null},{"_id":"XFjoMck9YYIaBTna","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o dano para trevas.","origin":"Compendium.tormenta20.magias.K2VH0rr4Qw6OqQjA","transfer":false},{"_id":"WqHRcdduicceDQE4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o enxame vira Enorme (quadrado de 6m de lado).","origin":"Compendium.tormenta20.magias.K2VH0rr4Qw6OqQjA","transfer":false},{"_id":"L5qKx8JhAMTpnzPG","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o enxame ganha deslocamento de voo 18m e passa a ocupar um cubo ao invés de um quadrado.","origin":"Compendium.tormenta20.magias.K2VH0rr4Qw6OqQjA","transfer":false},{"_id":"dsOs1Fs8OK7H6dVo","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o enxame inclui parasitas inchados que explodem e criam novos enxames. No início de cada um de seus turnos, role 1d6. Em um resultado 5 ou 6, um novo enxame surge adjacente a um já existente à sua escolha. Você pode mover todos os enxames com uma única ação de movimento, mas eles não podem ocupar o mesmo espaço. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.K2VH0rr4Qw6OqQjA","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.qziaONIC0EGsjCXs"}}}
{"_id":"KQTBh5aVCqDUSpvr","name":"Raio Polar","type":"magia","img":"systems/tormenta20/icons/magias/raio-polar.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; dispara um raio azul esbranqui&ccedil;ado de gelo e ar congelante. O alvo sofre 10d8 pontos de dano de frio e fica preso em um bloco de gelo (paralisado). Se passar no teste de resist&ecirc;ncia, sofre metade do dano e, em vez de paralisado, fica lento por uma rodada.</p>\n<p style=\"text-align: justify;\">&Eacute; poss&iacute;vel quebrar o gelo para libertar uma criatura presa: o bloco tem 20 PV, resist&ecirc;ncia a dano 10 e &eacute; vulner&aacute;vel a fogo. Uma criatura presa pode usar uma a&ccedil;&atilde;o completa para fazer um teste de Atletismo (com a mesma CD para resistir &agrave; magia) e tentar se libertar do gelo; cada vez que passar no teste causa 10 pontos de dano ao bloco, ignorando a RD.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["10d8",""]]}],"tipo":"arc","circulo":"4","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"87GfXamQvQPUX8zY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[{"key":"dano","value":"2d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d8.","origin":"Compendium.tormenta20.magias.KQTBh5aVCqDUSpvr","transfer":false},{"_id":"hjeZdKXLcWFQwHIj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"alvo","mode":5,"value":"área de explosão de 6m de raio"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para área de esfera de 6m de raio. Em vez de um raio, você dispara uma esfera de gelo que explode, causando o efeito da magia em todas as criaturas na área.","origin":"Compendium.tormenta20.magias.KQTBh5aVCqDUSpvr","transfer":false,"tint":null},{"_id":"Y06YINkVohOy4Gkb","changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/raio-polar.webp","label":"Raio Polar (RD)","origin":"Item.E5WJa9cUbROowNkr","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.xQBc8FBa1UCVRgLQ"}}}
{"_id":"KjCLKthxu8uKSOlh","name":"Fúria do Panteão","type":"magia","img":"systems/tormenta20/icons/magias/furia-do-panteao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você cria uma nuvem de tempestade, com trovões e relâmpagos. Enquanto você sustenta a magia, ela gera os seguintes efeitos, sempre no início do seu turno.</p><p style=\"text-align:justify;\"><i>1a rodada (quando você lança a magia):</i> trovões ribombam. Criaturas na área sofrem 6d6 pontos de dano de impacto e ficam surdas por uma rodada.</p><p style=\"text-align:justify;\"><i>2a rodada:</i> relâmpagos caem. Até seis criaturas a sua escolha na área sofrem 10d8 pontos de dano de eletricidade.</p><p style=\"text-align:justify;\"><i>3º rodada em diante:</i> chuva gélida e ventos causam 6d6 pontos de dano de frio por rodada. Além disso, reduzem a visibilidade (como a magia Névoa), transformam toda a área em terreno difícil e tornam ataques à distância impossíveis. Por fim, a área conta como condição terrível para conjuradores lançarem magias.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"Nuvem de tempestade com 90m de lado","alcance":"long","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"5","preparada":false,"escola":"evo","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.UsYXAeogVU64NVvV"}}}
{"_id":"KrorBYV7KV7jIC5c","name":"Localização","type":"magia","img":"systems/tormenta20/icons/magias/localizacao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia pode encontrar uma criatura ou objeto a sua escolha. Você pode pensar em termos gerais (“um elfo”, “algo de metal”) ou específicos (“Gwen, a elfa”, “uma espada longa”). A magia indica a direção e distância da criatura ou objeto mais próximo desse tipo, caso esteja ao alcance. Você pode movimentar-se para continuar procurando. Procurar algo muito específico (“a espada longa encantada do Barão Rulyn”) exige que você tenha em mente uma imagem precisa do objeto; caso a imagem não seja muito próxima da verdade, a magia falha, mas você gasta os PM mesmo assim. Esta magia pode ser bloqueada por uma fina camada de chumbo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"esfera com 90m de raio","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"bB48AzU3qOaJZex9","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"area","value":"alvo você","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para alvo você. Em vez do normal, você sabe onde fica o norte e recebe +5 em testes de Sobrevivência para se orientar.","origin":"Compendium.tormenta20.magias.KrorBYV7KV7jIC5c","transfer":false},{"_id":"LxA6sgrwQlDFFLjc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a área em um fator de 10 (90m para 900m, 900m para 9km e assim por diante).","origin":"Compendium.tormenta20.magias.KrorBYV7KV7jIC5c","transfer":false},{"_id":"KrU6EdqdsNQ6nJ78","changes":[{"key":"data.pericias.sobr.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/localizacao.webp","label":"Localização (Truque)","origin":"Item.qsft67JawC3F2BK5","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.IeXrwWLmVkWxn22W"}}}
{"_id":"L14jqsUhL7vvpmDM","name":"Mente Divina","type":"magia","img":"systems/tormenta20/icons/magias/mente-divina.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você traz inspiração divina à mente do alvo. Escolha entre Inteligência, Sabedoria ou Carisma. O alvo recebe +4 no atributo escolhido. Esse aumento não oferece PV, PM ou perícias adicionais.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"pYNzrQ7vGpSoXfeY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, o alvo recebe +4 nos três atributos mentais. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.L14jqsUhL7vvpmDM","transfer":false},{"_id":"jOX40cLUJtRwb0IP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.L14jqsUhL7vvpmDM","transfer":false},{"_id":"p9JaqAuh0rAPOLHw","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":true,"ability":false,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.atributos.int.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de inteligência em +2. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.L14jqsUhL7vvpmDM","transfer":false,"tint":null},{"_id":"LtHrEMsKKyIBARMw","changes":[{"key":"data.atributos.int.bonus","mode":2,"value":"0"},{"key":"data.atributos.sab.bonus","mode":2,"value":"0"},{"key":"data.atributos.car.bonus","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/mente-divina.webp","label":"Mente Divina","origin":"Item.P9xanVmQNokNpZKY","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"fyoPWOhR2pZUJQf4","changes":[{"key":"data.atributos.sab.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de sabedoria em +2. Requer 4º círculo.","origin":"Item.P9xanVmQNokNpZKY","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"7","durationScene":false}},"tint":null},{"_id":"K8i1KECd0UhhOKD4","changes":[{"key":"data.atributos.car.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de carisma em +2. Requer 4º círculo.","origin":"Item.P9xanVmQNokNpZKY","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"7","durationScene":false}},"tint":null},{"_id":"gvGWIMqoEX8nca8r","changes":[{"key":"data.atributos.int.bonus","mode":2,"value":"4"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"+4 Inteligência","origin":"Item.P9xanVmQNokNpZKY","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null},{"_id":"4Ovv73nGbtKp4TnX","changes":[{"key":"data.atributos.sab.bonus","mode":2,"value":"4"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"+4 Sabedoria","origin":"Item.P9xanVmQNokNpZKY","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null},{"_id":"EYuxCHv7zn3CVSNg","changes":[{"key":"data.atributos.car.bonus","mode":2,"value":"4"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"+4 Carisma","origin":"Item.P9xanVmQNokNpZKY","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.cW58wl3pNkGykmdi"},"cf":null}}
{"_id":"L3m9nPlKK8xe3u7a","name":"Muralha de Ossos","type":"magia","img":"systems/tormenta20/icons/magias/muralha-de-ossos.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Uma parede de ossos se eleva da terra. A parede tem 15m de comprimento, 3m de altura e 1,5m de espessura. Ela pode ter qualquer forma — não precisa ser uma linha reta —, mas sua base precisa estar no chão e ela não pode aparecer de modo que ocupe o espaço de uma criatura.</p><p style=\"text-align:justify;\">É possível escalar a parede. Isso exige um teste de Atletismo e causa 4d8 pontos de dano de corte. Também é possível destruir o muro para atravessá-lo ou libertar uma criatura agarrada. Cada trecho de 3m do muro tem Defesa 8, 40 PV e resistência a corte, frio e perfuração 5.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"muro de ossos","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"4","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"WRoIqLpQkO7xeByX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o comprimento em +15m e altura em +3m (máximo de 60m de comprimento e 9m de altura).","origin":"Compendium.tormenta20.magias.L3m9nPlKK8xe3u7a","transfer":false},{"_id":"wDTVFYVO1jT2baZZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"condicao","value":"agarrado","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o muro é feito de uma massa de esqueletos animados. Quando você lança a magia e no início de cada um de seus turnos, todos os inimigos adjacentes à muralha sofrem 4d8 pontos de dano de corte e devem fazer um teste de Reflexos. Se falharem, são agarrados pela muralha. Uma criatura agarrada pode gastar uma ação padrão para fazer um teste de Acrobacia ou Atletismo para se soltar.","origin":"Compendium.tormenta20.magias.L3m9nPlKK8xe3u7a","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Tg3DkEFX60uxDzFk"}}}
{"_id":"LCW7DDP9CfY22wna","name":"Projetar Consciência","type":"magia","img":"systems/tormenta20/icons/magias/projetar-consciencia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia faz com que sua consciência deixe seu corpo e se transporte instantaneamente para um local ou para perto de uma criatura alvo. Se escolher um local, ele precisa ser conhecido por você. Se escolher uma criatura, você transporta sua consciência até onde a criatura estiver, contanto que estejam no mesmo plano.</p><p style=\"text-align:justify;\">Você adquire uma forma fantasmagórica invisível, mas pode se mostrar usando uma ação de movimento. Pode se mover em qualquer direção com deslocamento de voo 18m e, por ser incorpóreo, é capaz de atravessar objetos sólidos, mas fica limitado a se mover dentro dos limites do local, ou dentro de alcance curto da criatura alvo. Você pode ver e ouvir como se estivesse presente no local e pode falar mentalmente com qualquer criatura que possa ver, contanto que tenham um idioma em comum.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"any","alvo":"local ou criatura conhecidos","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"5","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"g6K9JgHk876dMWV6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"10","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, sua projeção é capaz de lançar magias que não precisem de componentes materiais e tenham duração diferente de sustentada. Sua forma fantasmagórica funciona como na magia Forma Etérea, sendo afetada por magias de abjuração e essência, mas as magias que ela lança podem afetar criaturas corpóreas.","origin":"Compendium.tormenta20.magias.LCW7DDP9CfY22wna","transfer":false},{"_id":"uYkBdZYgfTImSzkG","changes":[{"key":"data.attributes.movement.fly","mode":2,"value":"18"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/projetar-consciencia.webp","label":"Projetar Consciência","origin":"Item.K86xNb1SrfDhetee","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.l8ykGibcLUXs1NEG"}}}
{"_id":"LFz30FCDJrLJwSrW","name":"Sopro das Uivantes","type":"magia","img":"systems/tormenta20/icons/magias/sopro-das-uivantes.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você sopra ar gélido que causa 4d6 pontos de dano de frio (Fortitude reduz à metade). Criaturas de tamanho Médio ou menor que falhem na resistência são empurradas 6m na direção oposta. Se houver uma parede ou outro objeto sólido (mas não uma criatura) no caminho, a criatura para de se mover, mas sofre 1d6 pontos de dano de impacto.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"cone (alcance 6m)","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["4d6",""]]}],"tipo":"arc","circulo":"2","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"oCaGz5C6enchAOFG","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano de frio em +2d6.","origin":"Compendium.tormenta20.magias.LFz30FCDJrLJwSrW","transfer":false},{"_id":"qEMIZqFCHkcq8TOV","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas que falhem no teste de Fortitude ficam caídas.","origin":"Compendium.tormenta20.magias.LFz30FCDJrLJwSrW","transfer":false},{"_id":"XASBNBVVLiS6cykc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o tamanho máximo das criaturas afetadas em uma categoria. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.LFz30FCDJrLJwSrW","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.F6m5mGtPokeg4XHM"}}}
{"_id":"LbRCMfcaEQr6BAyN","name":"Globo da Verdade","type":"magia","img":"systems/tormenta20/icons/magias/globo-da-verdade.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Cria um globo flutuante e intangível, com 50cm de diâmetro. O globo mostra uma cena vista até uma semana atrás por você ou por uma criatura que você toque ao lançar a magia (mediante uma pergunta; a criatura pode fazer um teste de Vontade para anular o efeito), permitindo que outras pessoas a vejam.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"1 globo","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"fKXok5ihS171EoRv","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o globo mostra uma cena vista até um mês atrás.","origin":"Compendium.tormenta20.magias.LbRCMfcaEQr6BAyN","transfer":false},{"_id":"wxmmZDSDMRKQyZkh","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"como acima, até um ano atrás.","origin":"Compendium.tormenta20.magias.LbRCMfcaEQr6BAyN","transfer":false},{"_id":"hUoz62gaoy91MJ1S","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"ao lançar a magia, você pode tocar um cadáver. O globo mostra a última cena vista por essa criatura.","origin":"Compendium.tormenta20.magias.LbRCMfcaEQr6BAyN","transfer":false},{"_id":"pDh5JjQwXjrhE1FI","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alcance","value":"longo","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para longo e o efeito para 10 globos. Todos mostram a mesma cena.","origin":"Compendium.tormenta20.magias.LbRCMfcaEQr6BAyN","transfer":false},{"_id":"AF0RsXeqGcWsyOJt","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/globo-da-verdade.webp","label":"Globo da Verdade","origin":"Item.o7EIJ3LdTLm8ct5P","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.aZf802WUk6cBfvzB"}}}
{"_id":"Lo49R4kuZV1bZHr4","name":"Esculpir Sons","type":"magia","img":"systems/tormenta20/icons/magias/esculpir-sons.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia altera os sons emitidos pelo alvo. Ela não é capaz de criar sons, mas pode omiti-los (como fazer uma carroça ficar silenciosa) ou transformá-los (como fazer uma pessoa ficar com voz de passarinho). Você não pode criar sons que não conhece (não pode fazer uma criatura falar num idioma que não conheça). Uma vez que escolha a alteração, ela não pode ser mudada. Um conjurador que tenha a voz modificada drasticamente não poderá lançar magias.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1 criatura ou objeto","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"PFybBH0Hj4GYkpE8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1. Todas as criaturas e objetos devem ser afetadas da mesma forma.","origin":"Compendium.tormenta20.magias.Lo49R4kuZV1bZHr4","transfer":false},{"_id":"DXFYimT4ePIOLuv0","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/esculpir-sons.webp","label":"Esculpir Sons","origin":"Item.uTTuZBUTRo5mE5AV","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.IzSJs3ttKE2KTSQJ"}}}
{"_id":"LqKnynFepm4ICynP","name":"Soco do Mestre","type":"magia","img":"systems/tormenta20/icons/magias/soco-do-mestre.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Ninguém sabe se o Mestre foi realmente o criador desta magia — mas ele foi o primeiro a utilizá-la. Você fecha o punho e gesticula como se estivesse golpeando o alvo, causando 4d6 + mod. Força pontos de dano de impacto. A vítima é empurrada 3m na direção oposta à sua (ou 1,5m se passar na resistência).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["4d6",""]]}],"tipo":"div","circulo":"2","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"3tmdiExOO5OE02li","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5},{"key":"duracao","value":"Cena","mode":5},{"key":"resistencia","value":"nenhuma","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal, o alvo para você, a duração para cena e a resistência para nenhuma. Em vez do normal, seus ataques corpo a corpo passam a acertar inimigos distantes. Seu alcance natural aumenta em 3m; uma criatura Média pode atacar adversários a até 4,5m, por exemplo.","origin":"Compendium.tormenta20.magias.LqKnynFepm4ICynP","transfer":false},{"_id":"v89Br8AqC4I9Opo6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Compendium.tormenta20.magias.LqKnynFepm4ICynP","transfer":false},{"_id":"g8SzVMTC1uT8yywO","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a distância do efeito de empurrar em +3m.","origin":"Compendium.tormenta20.magias.LqKnynFepm4ICynP","transfer":false},{"_id":"3slurquJ6XTcZEeJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o tipo do dano para essência.","origin":"Compendium.tormenta20.magias.LqKnynFepm4ICynP","transfer":false},{"_id":"RxpgTIWPpBfhgJyB","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/soco-do-mestre.webp","label":"Aprimoramento de Alcance","origin":"Item.3prAVM8QeRRSABlj","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.rjg708VUdECdYoZK"},"cf":null}}
{"_id":"MBX0tXnozRSrgnvx","name":"Vestimenta da Fé","type":"magia","img":"systems/tormenta20/icons/magias/vestimenta-da-fe.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você fortalece uma indumentária com o poder de sua fé. Isso aumenta o bônus de Defesa de uma armadura ou escudo em +2 (isso é uma melhoria no item, portanto é cumulativa com outras magias). No caso de um traje, ele passa a oferecer +2 na Defesa e continua contando como se você não estivesse usando armadura.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 traje, armadura ou escudo","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"tpC0UKqyNK3Zwrqm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o objeto também oferece o mesmo bônus em testes de resistência. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.MBX0tXnozRSrgnvx","transfer":false},{"_id":"9FAygRWiareMW6vf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"},{"key":"data.pericias.fort.bonus","mode":2,"value":"1"},{"key":"data.pericias.refl.bonus","mode":2,"value":"1"},{"key":"data.pericias.vont.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus em +1.","origin":"Compendium.tormenta20.magias.MBX0tXnozRSrgnvx","transfer":false,"tint":null},{"_id":"wgScJ6VgoqhLZMt6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"5"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o objeto também oferece resistência a dano 5. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.MBX0tXnozRSrgnvx","transfer":false,"tint":null},{"_id":"9MpQPRL0mLadehmJ","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"2"},{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/vestimenta-da-fe.webp","label":"Vestimenta da Fé","origin":"Item.4EElGSwclkjSNeER","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"SSOYnmmXKUZ0NRMt","changes":[{"key":"data.pericias.fort.bonus","mode":2,"value":"2"},{"key":"data.pericias.refl.bonus","mode":2,"value":"2"},{"key":"data.pericias.vont.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/vestimenta-da-fe.webp","label":"Bônus nas Resistências","origin":"Item.4EElGSwclkjSNeER","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.j1Kc5pXIA0SlLHMV"}}}
{"_id":"MbArAZo487Yb3hdl","name":"Potência Divina","type":"magia","img":"systems/tormenta20/icons/magias/potencia-divina.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você canaliza o poder de sua divindade. Você aumenta uma categoria de tamanho (seu equipamento muda de acordo). Além disso, você recebe Força +8 e resistência a dano 10. Você não pode lançar magias enquanto estiver sob efeito de Potência Divina.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"LZeLNUKYa4Wrj3uR","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.atributos.for.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de Força em +2.","origin":"Compendium.tormenta20.magias.MbArAZo487Yb3hdl","transfer":false,"tint":null},{"_id":"DrnQ3G5GdlguRFMR","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a resistência a dano em +2.","origin":"Compendium.tormenta20.magias.MbArAZo487Yb3hdl","transfer":false,"tint":null},{"_id":"gT58wfOEzw5hn1E3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para 1 criatura. A magia falha se o alvo não seguir a mesma divindade que você.","origin":"Compendium.tormenta20.magias.MbArAZo487Yb3hdl","transfer":false},{"_id":"CYW1kpakzd0nMIx8","changes":[{"key":"data.atributos.for.bonus","mode":2,"value":"8"},{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/potencia-divina.webp","label":"Potência Divina","origin":"Item.bgvsLIzf9M8zUfZa","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.DQi2UVtxtEC89ebZ"}}}
{"_id":"Mp0Mk82uyRUOBIPs","name":"Voo","type":"magia","img":"systems/tormenta20/icons/magias/voo.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você recebe deslocamento de voo 12m. Voar por meio desta magia é simples como andar — você pode atacar e lançar magias normalmente enquanto voa. Quando a magia termina, você desce lentamente até o chão, como se estivesse sob efeito de Queda Suave.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"uDJlecnsO28l1Dre","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.Mp0Mk82uyRUOBIPs","transfer":false},{"_id":"duUBwMb99gCuMuUL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.Mp0Mk82uyRUOBIPs","transfer":false},{"_id":"5jXCcJ1kznVsSCU5","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"até 10 criaturas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para até 10 criaturas. Requer 4° círculo.","origin":"Compendium.tormenta20.magias.Mp0Mk82uyRUOBIPs","transfer":false},{"_id":"CRX7wBp8q9Zkv9z2","changes":[{"key":"data.attributes.movement.fly","mode":2,"value":"12"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/voo.webp","label":"Voo","origin":"Item.TNU7KWJ843G0GKJN","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Vlk6hS0fo0iWKkKi"}}}
{"_id":"Mv8Lzi5PEklOW36c","name":"Metamorfose","type":"magia","img":"systems/tormenta20/icons/magias/metamorfose.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você muda sua aparência e forma — incluindo seu equipamento — para qualquer outra criatura, existente ou imaginada. Independentemente da forma escolhida, você recebe +20 em testes de Enganação para disfarce. Características não mencionadas não mudam.</p><p style=\"text-align:justify;\">Se mudar para uma forma humanoide, pode mudar o tipo de dano físico de suas armas (se usa uma maça e transformá-la em espada longa, ela pode causar dano de corte, por exemplo). Se quiser, pode assumir uma forma humanoide com uma categoria de tamanho acima ou abaixo da sua; nesse caso aplique os modificadores em Furtividade e testes de manobra.</p><p style=\"text-align:justify;\">Se mudar para outras formas, você pode escolher uma Forma Selvagem do druida (veja no Capítulo 1). Nesse caso você não pode atacar com suas armas, falar ou lançar magias até voltar ao normal, mas recebe uma ou mais armas naturais e os bônus da forma selvagem escolhida.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"R2D0YACPUmGjUoKi","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"a forma escolhida recebe uma habilidade de sentidos entre faro, visão na penumbra e visão no escuro.","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false},{"_id":"4Xuvb2qg7bL3h23G","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"a forma escolhida recebe percepção às cegas (alcance curto). Requer 3º círculo.","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false,"tint":null},{"_id":"l5lgIbyjG25pLI1A","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque, o alvo para 1 criatura e adiciona resistência (Vontade anula).","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false},{"_id":"9dQ4t2IyI5lkGx14","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alcance","value":"médio","mode":5},{"key":"alvo","value":"1 criatura","mode":5},{"key":"resistencia","value":"Vontade anula","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para médio, o alvo para 1 criatura e a resistência para Vontade anula. Em vez do normal, transforma o alvo em uma criatura ou objeto inofensivo (ovelha, sapo, galinha, pudim de ameixa etc.). A criatura não pode atacar, falar e lançar magias; seu deslocamento vira 3m e sua Defesa vira 10. Suas outras características não mudam. No início de seus turnos, o alvo pode fazer um teste de Vontade; se passar, retorna à sua forma normal e a magia termina. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false},{"_id":"UDsXmAKO93ZvNfda","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se mudar para formas não humanoides, pode escolher uma Forma Selvagem Aprimorada. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false},{"_id":"aWwVnVVlvjFdnyUT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se mudar para formas não humanoides, pode escolher uma Forma Selvagem Superior. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false},{"_id":"fwrXE703ArdqR4sX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, no início de seus turnos o alvo pode mudar de forma novamente, como uma ação livre, fazendo novas escolhas. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.Mv8Lzi5PEklOW36c","transfer":false},{"_id":"zJpKxizoHFPkqUgX","changes":[{"key":"data.pericias.enga.bonus","mode":2,"value":"20"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/metamorfose.webp","label":"Metamorfose","origin":"Item.uqwwUGqvxD2QdFRK","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.eEdcIzWYEuYkC6Og"}}}
{"_id":"N1xVfw9A8TiYeLae","name":"Hipnotismo","type":"magia","img":"systems/tormenta20/icons/magias/hipnotismo.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Suas palavras e movimentos ritmados deixam as criaturas fascinadas. Esta magia só afeta criaturas que possam perceber você. Se usar esta magia em combate, os alvos recebem +5 em seus testes de resistência.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1d4 rodadas","units":"special","special":"","valor":"1d4 rodadas","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"criaturas escolhidas de ND 2 ou menor","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"0qnDVKlJ4Y6vIqzN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5},{"key":"duracao","value":"1 rodada","mode":5},{"key":"condicao","value":"fascinado","mode":0},{"key":"condicao","value":"pasmo","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura e a duração para 1 rodada. Em vez de fascinado, o alvo fica pasmo. Uma criatura só pode ser afetada por este truque uma vez por cena.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"jN9vw5EXuCc5hmMq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"como o normal, mas se passarem na resistência os alvos não saberão que foram alvos de uma magia.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"n2XIwlHRUXWsyWoe","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para cena.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"yU9cKxRGtCBztsFj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"médio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para médio.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"fkKKvRKmx4fLgSzp","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 5 ou menor. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"9h8Bd2cCqHTlY8pk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 10 ou menor. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"3nAshgPzsnzLHb6y","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 15 ou menor. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"TcMcIJl3ParLiqKj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de qualquer ND. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.N1xVfw9A8TiYeLae","transfer":false},{"_id":"SeBpexrQ8zNDV7tm","changes":[{"key":"data.pericias.vont.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/hipnotismo.webp","label":"Alvo Hostil","origin":"Item.7QpJwWrO3AakONv7","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.JGfGGFDkpUiiIkvg"}}}
{"_id":"OTsBw84Ci2IKPStn","name":"Benção","type":"magia","img":"systems/tormenta20/icons/magias/bencao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Abençoa os alvos, que recebem +1 em testes de ataque e rolagens de dano. Bênção anula Perdição.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"Criaturas escolhidas","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"PGw8P6ddEbEYtIp8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 cadáver","mode":5},{"key":"duracao","value":"1 semana","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 cadáver e a duração para 1 semana. O cadáver não se decompõe nem pode ser transformado em morto-vivo pela duração da magia.","origin":"Compendium.tormenta20.magias.OTsBw84Ci2IKPStn","transfer":false},{"_id":"B1Gj4G6nXsXkiUw7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.pericias.ataque","mode":2,"value":"1"},{"key":"data.modificadores.dano.geral","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","origin":"Compendium.tormenta20.magias.OTsBw84Ci2IKPStn","transfer":false,"tint":null},{"_id":"br6Pl9ziSRDQXRYp","changes":[{"key":"data.modificadores.pericias.ataque","mode":2,"value":"1"},{"key":"data.modificadores.dano.geral","mode":2,"value":"1"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/bencao.webp","label":"Benção","origin":"Item.Z6YBQOJEKRQ5UbAM","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true},"t20":null},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.rTg1i3wFelcvUFte"},"tormenta20":{"version":"1.3.0.0"},"importid":"WUj6aoXSnA4diQ3A","cf":null}}
{"_id":"PS9AQUuhxRBnUeS4","name":"Legião","type":"magia","img":"systems/tormenta20/icons/magias/legiao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você domina a mente dos alvos. Os alvos obedecem cegamente a seus comandos, exceto ordens claramente suicidas. Um alvo tem direito a um teste no final de cada um de seus turnos para se livrar do efeito. Alvos que passarem no teste ficam abalados por 1 rodada enquanto recuperam a consciência.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"até 10 criaturas na área","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"AuPZAFB8KdmEmVoC","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.PS9AQUuhxRBnUeS4","transfer":false},{"_id":"c2dgWhqQu3iLb2tt","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/legiao.webp","label":"Alvos Controlados","origin":"Item.2jiIING3oBlNWZwf","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.jTZjIE4q4EKOolSB"}}}
{"_id":"PXR8dRhDk8Z0mtck","name":"Explosão de Chamas","type":"magia","img":"systems/tormenta20/icons/magias/explosao-de-chamas.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Um leque de chamas irrompe de suas mãos, causando 2d6 pontos de dano de fogo às criaturas na área.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"Cone (alcance 6m)","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d6",""]]}],"tipo":"arc","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"TXHO0XUKJkSZGDqf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"area","value":"alvo de 1 objeto","mode":5},{"key":"resistencia","value":"Reflexos anula","mode":5},{"key":"condicao","value":"em chamas","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto, a área para alvo de 1 objeto e a resistência para Reflexos anula. Você gera uma pequena explosão que não causa dano mas pode acender uma vela, tocha ou fogueira. Também pode fazer um objeto inflamável com RD 0 (como uma corda ou pergaminho) ficar em chamas. Uma criatura em posse de um objeto pode evitar esse efeito se passar no teste de resistência.","origin":"Compendium.tormenta20.magias.PXR8dRhDk8Z0mtck","transfer":false},{"_id":"vKShkoCm4FMcYevu","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Compendium.tormenta20.magias.PXR8dRhDk8Z0mtck","transfer":false},{"_id":"FTGTkuiyuKw6Bzyz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"resistencia","value":"Reflexos parcial","mode":5},{"key":"condicao","value":"em chamas","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a resistência para Reflexos parcial. Se passar, a criatura reduz o dano à metade; se falhar, fica em chamas (veja Condições, no Apêndice).","origin":"Compendium.tormenta20.magias.PXR8dRhDk8Z0mtck","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.dmZrFf0OW2mDIVUM"},"cf":null}}
{"_id":"PjNZfjmSHwQJJqZ9","name":"Tranca Arcana","type":"magia","img":"systems/tormenta20/icons/magias/tranca-arcana.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia tranca uma porta ou outro item que possa ser aberto ou fechado (como um baú, caixa etc.), aumentando a CD de testes de Força ou Ladinagem para abri-lo em +10. Você pode abrir livremente sua própria tranca sem problemas.</p><p style=\"text-align:justify;\"><i>Componente material:</i> chave de bronze no valor de T$ 25.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"permanente","units":"perm","special":"","valor":"permanente","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 objeto Grande ou menor","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"2gOGpe6CyRphUzDZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto. Em vez do normal, pode abrir ou fechar um objeto de tamanho Médio ou menor, como uma porta ou baú. Não afeta objetos trancados.","origin":"Compendium.tormenta20.magias.PjNZfjmSHwQJJqZ9","transfer":false},{"_id":"JkUbfLuaQ7VU4dLW","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"duracao","value":"instantânea","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e a duração para instantânea. Em vez do normal, a magia abre portas, baús e janelas trancadas, presas, barradas ou protegidas por Tranca Arcana (o efeito é dissipado) a sua escolha. Ela também afrouxa grilhões e solta correntes.","origin":"Compendium.tormenta20.magias.PjNZfjmSHwQJJqZ9","transfer":false},{"_id":"dEUjRL7piURGkjrG","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a CD para abrir o alvo em +5.","origin":"Compendium.tormenta20.magias.PjNZfjmSHwQJJqZ9","transfer":false},{"_id":"mzFVT7eFMk1FpxTi","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 objeto de qualquer tamanho","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 objeto de qualquer tamanho, podendo afetar até mesmo os portões de um castelo. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.PjNZfjmSHwQJJqZ9","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.KlVQiviCkOel37qk"}}}
{"_id":"Q2zkHtJ1h5o725IR","name":"Toque Chocante","type":"magia","img":"systems/tormenta20/icons/magias/toque-chocante.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Arcos elétricos envolvem sua mão, causando 2d8+2 pontos de dano de eletricidade. Se o alvo usa armadura de metal (ou carrega muito metal, a critério do mestre), sofre uma penalidade de –5 no teste de resistência.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d8+2",""]]}],"tipo":"arc","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"YyP4qNu40Ggkwz0a","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"1d8+1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em 1d8+1.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false,"tint":null},{"_id":"jKiy3mRU5EbSl9LA","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"como parte da execução da magia, você faz um ataque corpo a corpo contra o alvo. Se acertar, causa o dano do ataque e da magia.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false},{"_id":"oIteVo1ef18mDkof","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"alcance","mode":5,"value":"pessoal"},{"key":"alvo","mode":5,"value":"área: explosão com 6m de raio"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para área: esfera com 6m de raio. Você dispara raios pelas pontas dos dedos que afetam todas as criaturas na área.","origin":"Compendium.tormenta20.magias.Q2zkHtJ1h5o725IR","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.8bINHKgmg0uVS0QQ"},"cf":null}}
{"_id":"RLBhyAnxLXWj8thK","name":"Transformação de Guerra","type":"magia","img":"systems/tormenta20/icons/magias/transformacao-de-guerra.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você se torna uma máquina de combate, ficando mais forte, rápido e resistente. Você recebe +6 na Defesa, testes de ataque e rolagens de dano corpo a corpo, e 30 PV temporários. Durante a Transformação de Guerra você não pode lançar magias, mas se torna proficiente em todas as armas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"Irrry8mB5RZg5v99","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"1"},{"key":"data.modificadores.dano.cac","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os bônus na Defesa, testes de ataque e rolagens de dano corpo a corpo em +1, e os PV temporários em +10.","origin":"Compendium.tormenta20.magias.RLBhyAnxLXWj8thK","transfer":false,"tint":null},{"_id":"yzvoO2A6tQ24JfyC","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"10"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"adiciona componente material (uma barra de adamante no valor de T$ 100). Sua forma de combate ganha um aspecto metálico e sem expressões. Além do normal, você recebe resistência a dano 10 e imunidade a atordoamento, doenças, encantamento, fadiga, paralisia, necromancia, sangramento, sono e veneno, e não precisa respirar.","origin":"Compendium.tormenta20.magias.RLBhyAnxLXWj8thK","transfer":false,"tint":null},{"_id":"vbViJHkstWG6ZmKL","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"6"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"6"},{"key":"data.modificadores.dano.cac","mode":2,"value":"6"},{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/transformacao-de-guerra.webp","label":"Transformação de Guerra","origin":"Item.eO0IJZqC0ag6yR5e","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.nArk5DFEjUK51PFX"}}}
{"_id":"Rf5JM994mdEuYBMS","name":"Círculo da Justiça","type":"magia","img":"systems/tormenta20/icons/magias/circulo-da-justica.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Tamb&eacute;m conhecida como L&aacute;grimas do Deus da Trapa&ccedil;a, esta magia &eacute; usada em tribunais e para proteger &aacute;reas sens&iacute;veis. Criaturas na &aacute;rea sofrem &ndash;10 em testes de Acrobacia, Engana&ccedil;&atilde;o, Furtividade e Ladinagem e n&atilde;o podem mentir deliberadamente &mdash; mas podem tentar evitar perguntas que normalmente responderiam com uma mentira (sendo evasivas ou cometendo omiss&otilde;es, por exemplo). Uma criatura que passe na resist&ecirc;ncia tem as penalidades reduzidas para &ndash;5 e pode mentir.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 dia","units":"special","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"cubo com 9m de lado;","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"K7v6Zb57lbm1FYwo","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"execucao","value":"Padrão","mode":5},{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5},{"key":"duracao","value":"Cena","mode":5},{"key":"resistencia","value":"nenhuma","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação padrão, o alcance para pessoal, o alvo para você, a duração para cena e a resistência para nenhuma. Em vez do normal, qualquer criatura ou objeto invisível em alcance curto se torna visível. Isso não dissipa o efeito mágico; se sair do seu alcance, a criatura ou objeto voltam a ficar invisíveis.","origin":"Compendium.tormenta20.magias.Rf5JM994mdEuYBMS","transfer":false},{"_id":"upmsgufg5QeMPila","changes":[{"key":"data.pericias.acro.bonus","mode":2,"value":"-10"},{"key":"data.pericias.enga.bonus","mode":2,"value":"-10"},{"key":"data.pericias.furt.bonus","mode":2,"value":"-10"},{"key":"data.pericias.ladi.bonus","mode":2,"value":"-10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/circulo-da-justica.webp","label":"Círculo da Justiça (Penalidade)","origin":"Item.x7v8U3hByjtwgaVC","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"ebwqxg2dc1uXhHXc","changes":[{"key":"data.pericias.acro.bonus","mode":2,"value":"-5"},{"key":"data.pericias.enga.bonus","mode":2,"value":"-5"},{"key":"data.pericias.furt.bonus","mode":2,"value":"-5"},{"key":"data.pericias.ladi.bonus","mode":2,"value":"-5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/circulo-da-justica.webp","label":"Círculo da Justiça (Penalidade Parcial)","origin":"Item.x7v8U3hByjtwgaVC","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"nVcX9n0PDQn7Qk6z","changes":[{"key":"data.pericias.acro.bonus","mode":2,"value":"-10"},{"key":"data.pericias.enga.bonus","mode":2,"value":"-10"},{"key":"data.pericias.furt.bonus","mode":2,"value":"-10"},{"key":"data.pericias.ladi.bonus","mode":2,"value":"-10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/circulo-da-justica.webp","label":"Círculo da Justiça (Penalidade Parcial Aprimorada)","origin":"Item.x7v8U3hByjtwgaVC","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"AQGlJJFaH2TvCjtv","changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a penalidade nas perícias para –10 (se passar na resistência) e –20 (se falhar). Requer 4º círculo.","origin":"Item.x7v8U3hByjtwgaVC","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"3","durationScene":false}},"tint":null},{"_id":"eAS6FbcvG6ZdwJNl","changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para permanente e adiciona componente material (balança de prata no valor de T$ 5.000).","origin":"Item.x7v8U3hByjtwgaVC","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"7","durationScene":false}},"tint":null},{"_id":"d6FPubGl9QLSV5Uo","changes":[{"key":"data.pericias.acro.bonus","mode":2,"value":"-20"},{"key":"data.pericias.enga.bonus","mode":2,"value":"-20"},{"key":"data.pericias.furt.bonus","mode":2,"value":"-20"},{"key":"data.pericias.ladi.bonus","mode":2,"value":"-20"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/circulo-da-justica.webp","label":"Círculo da Justiça (Penalidade Aprimorada)","origin":"Item.x7v8U3hByjtwgaVC","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.DOo3let6a3YC5K5f"}}}
{"_id":"RsT4ntlPaT0TrGEW","name":"Guardião Divino","type":"magia","img":"systems/tormenta20/icons/magias/guardiao-divino.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">A magia invoca um elemental Pequeno, com a forma de um orbe feito de luz divina. A criatura é incorpórea, imune a dano e ilumina como uma tocha. O elemental tem 100 pontos de luz.</p><p style=\"text-align:justify;\">Uma vez por rodada, durante o seu turno, o elemental pode se movimentar (deslocamento de voo 18m) e gastar quantos pontos de luz quiser para curar dano ou condições de criaturas em alcance curto, à taxa de 1 PV por 1 ponto de luz ou uma condição por 3 pontos de luz (entre abalado, apavorado, alquebrado, atordoado, cego, confuso, debilitado, enjoado, esmorecido, exausto, fascinado, fatigado, fraco, frustrado, ofuscado, pasmo, sangrando, surdo ou vulnerável). A magia é encerrada quando o elemental fica sem pontos de luz.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"cena ou até ser descarregado","units":"scene","special":"","valor":"cena ou até ser descarregado","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"elemental de luz invocado","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"4","preparada":false,"escola":"con","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.wVmQKbHf025udZn1"}}}
{"_id":"RzK5XmyDjKEYWel5","name":"Lança Ígnea","type":"magia","img":"systems/tormenta20/icons/magias/lanca-ignea.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia foi desenvolvida por um mago imortal, entusiasta dos estudos vulc&acirc;nicos. Ela dispara um proj&eacute;til de magma superaquecido contra o alvo, que sofre 4d6 pontos de dano de fogo e 4d6 pontos de dano de perfura&ccedil;&atilde;o e fica em chamas. As chamas causam 2d6 pontos de dano por rodada, em vez do dano normal. Se passar no teste de resist&ecirc;ncia, o alvo sofre metade do dano e n&atilde;o fica em chamas.</p>\n<p style=\"text-align: justify;\">Respingos de rocha incandescente se espalham com a explos&atilde;o, atingindo todas as criaturas adjacentes ao alvo, que devem fazer um teste de Reflexos. Se falharem, ficam em chamas, como descrito acima.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["8d6",""]]}],"tipo":"arc","circulo":"3","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"pYnMbgG93GxeTt5q","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0},{"key":"condicao","value":"em chamas","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano inicial em +2d6 e o dano do efeito em chamas em +1d6.","origin":"Compendium.tormenta20.magias.RzK5XmyDjKEYWel5","transfer":false},{"_id":"q0RizI5ZTqZFUh4R","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"cena ou até ser descarregada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para cena ou até ser descarregada. Em vez do efeito normal, a magia cria quatro dardos de lava que flutuam ao lado do conjurador. Uma vez por rodada, como uma ação livre, você pode disparar um dos dardos em uma criatura, causando o efeito normal da magia. Requer 4º Círculo.","origin":"Compendium.tormenta20.magias.RzK5XmyDjKEYWel5","transfer":false},{"_id":"tk2TFX5v8C8zGeeW","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/lanca-ignea.webp","label":"Em chamas","origin":"Item.jqivb1xiblRAiN8o","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.sPQUNMjFQ0OG9v41"}}}
{"_id":"Sbf50YYcbKCXA3CI","name":"Runa de Proteção","type":"magia","img":"systems/tormenta20/icons/magias/runa-de-protecao.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; escreve uma runa pessoal em uma superf&iacute;cie fixa, como uma parede ou o ch&atilde;o, que protege&nbsp;uma pequena &aacute;rea ao redor. Quando uma criatura entra na &aacute;rea afetada a runa explode,&nbsp;causando 6d6 pontos de dano em todos os alvos a at&eacute; 6m. A criatura que ativa a runa n&atilde;o tem&nbsp;direito&nbsp;a teste de resist&ecirc;ncia; outras criaturas&nbsp;na &aacute;rea t&ecirc;m direito a um teste de Reflexos para&nbsp;reduzir o dano &agrave; metade. Quando lan&ccedil;a a magia, voc&ecirc; escolhe o tipo de dano, entre &aacute;cido,&nbsp;eletricidade, fogo, frio, luz ou trevas.</p>\n<p style=\"text-align: justify;\">Voc&ecirc; pode determinar que a runa se ative apenas em condi&ccedil;&otilde;es espec&iacute;ficas &mdash; por exemplo,&nbsp;apenas por goblins ou apenas por mortos-vivos. Voc&ecirc; tamb&eacute;m&nbsp;pode criar uma palavra m&aacute;gica que&nbsp;impe&ccedil;a a runa de se ativar.</p>\n<p style=\"text-align: justify;\">Um personagem pode encontrar a runa com um teste de Investiga&ccedil;&atilde;o e desarm&aacute;la com um teste&nbsp;de Ladinagem (CD da Magia).</p>\n<p style=\"text-align: justify;\"><em>Componente material:</em> p&oacute; de diamante no valor de T$ 200, com o qual o conjurador&nbsp;desenha a&nbsp;runa, que brilha por alguns&nbsp;instantes e depois se torna praticamente&nbsp;invis&iacute;vel.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"hour","custo":3,"qtd":"1 Hora","condicao":"","special":""},"duracao":{"value":"permanente até ser descarregada","units":"special","special":"permanente até ser descarregada","valor":"permanente até ser descarregada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"6d6","alcance":"touch","alvo":"uma área com 6m de raio","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"varia (veja o texto)"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["6d6",""]]}],"tipo":"uni","circulo":"2","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"A3kKxRbC8XZB32Mg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6.","origin":"Compendium.tormenta20.magias.Sbf50YYcbKCXA3CI","transfer":false},{"_id":"nC9JOVHMZZxs5pWc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para “você” e o alcance para “pessoal”. Ao invés do normal, escolha uma magia de 1º círculo que você conhece e pode lançar, com tempo de execução de uma ação padrão ou menor. Você escreve a runa em seu corpo e especifica uma condição de ativação como, por exemplo, “quando eu for alvo de um ataque” ou “quando for alvo de uma magia”. Quando a condição for cumprida, a runa é ativada e você pode lançar a magia escolhida como uma reação. Você só pode escrever uma runa em seu corpo ao mesmo tempo.","origin":"Compendium.tormenta20.magias.Sbf50YYcbKCXA3CI","transfer":false,"tint":null},{"_id":"xueONs898dqDBbTb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"como o aprimoramento anterior, mas você pode escolher magias de 2º  círculo. Requer 3º\ncírculo.","origin":"Compendium.tormenta20.magias.Sbf50YYcbKCXA3CI","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.mMtN5pdJ40yLxkFu"}}}
{"_id":"T1fJO9LOyBxtBBDN","name":"Transmutar Objetos","type":"magia","img":"systems/tormenta20/icons/magias/transmutar-objetos.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">A magia transforma mat&eacute;ria bruta para moldar um novo objeto. Voc&ecirc; pode usar mat&eacute;ria-prima mundana para criar um objeto de tamanho Pequeno ou menor e pre&ccedil;o m&aacute;ximo de T$ 25, como um balde ou uma espada. O objeto reverte &agrave; mat&eacute;ria-prima no final da cena, ou se for tocado por um objeto feito de chumbo. Esta magia n&atilde;o pode ser usada para criar objetos consum&iacute;veis, como alimentos, itens alqu&iacute;micos ou venenos, nem objetos com mecanismos complexos, como bestas ou armas de fogo. Transmutar Objetos anula Despeda&ccedil;ar.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"matéria-prima, como madeira, rochas, ossos","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"rELA1ZjG7sVZikL8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alvo","value":"1 objeto mundano","mode":5},{"key":"duracao","value":"instantânea","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 objeto mundano e a duração para instantânea. Em vez do normal, você pode alterar as propriedades físicas do objeto, como colorir, limpar ou sujar itens pequenos (incluindo peças de roupa), aquecer, esfriar e/ou temperar (mas não produzir) até 0,5kg de material inanimado (incluindo comida), ou curar 1 PV do objeto, consertando pequenas falhas como colar um frasco de cerâmica quebrado, unir os elos de uma corrente ou costurar uma roupa rasgada. Um objeto só pode ser afetado por este truque uma vez por dia.","origin":"Compendium.tormenta20.magias.T1fJO9LOyBxtBBDN","transfer":false},{"_id":"VL5A1KhUWApIJ2uv","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o limite de tamanho do objeto em uma categoria.","origin":"Compendium.tormenta20.magias.T1fJO9LOyBxtBBDN","transfer":false},{"_id":"OgdJNSqMmFwzc3dx","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o preço máximo do objeto criado em um fator de x10 (+3 PM por T$ 250 de preço, +6 PM por T$ 2.500 de preço, +9 PM por T$ 25.000 de preço e assim por diante).","origin":"Compendium.tormenta20.magias.T1fJO9LOyBxtBBDN","transfer":false,"tint":null},{"_id":"UORlQJJN1mYl1x3P","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 construto","mode":5},{"key":"duracao","value":"instantânea","mode":5},{"key":"dano","value":"2d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque, o alvo para 1 construto e a duração para instantânea. Em vez do normal, cura 2d8 PV do alvo. Você pode gastar 2 PM adicionais para aumentar a cura em +1d8.","origin":"Compendium.tormenta20.magias.T1fJO9LOyBxtBBDN","transfer":false},{"_id":"lDmZk5u7LoxzWW0S","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 objeto mundano","mode":5},{"key":"duracao","value":"instantânea","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 objeto mundano e a duração para instantânea. Em vez do normal, você cura todos os PV do alvo, restaurando o objeto totalmente. Este aprimoramento está sujeito aos limites de tamanho e preço do objeto conforme a magia original e não funciona se o objeto tiver sido completamente destruído (queimado até virar cinzas ou desintegrado, por exemplo). Requer 3º círculo.","origin":"Compendium.tormenta20.magias.T1fJO9LOyBxtBBDN","transfer":false},{"_id":"kOgRVcfCdYAyRlxR","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"como o aprimoramento anterior, mas passa a afetar itens mágicos.","origin":"Compendium.tormenta20.magias.T1fJO9LOyBxtBBDN","transfer":false},{"_id":"5yIIWf1kmySo4kXr","changes":[{"key":"dano","mode":2,"value":"1d8"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumentar a cura em +1d8.","origin":"Item.Tu2hvEaQT79eycTa","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"2","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Xxe4nFE3eEiypMUf"}}}
{"_id":"U2WEs5vlnx0kwSIb","name":"Campo Antimagia","type":"magia","img":"systems/tormenta20/icons/magias/campo-antimagia.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; &eacute; cercado por uma barreira invis&iacute;vel com 3m de raio que acompanha seus movimentos. Qualquer magia ou habilidade m&aacute;gica que entre na &aacute;rea da barreira &eacute; suprimida enquanto estiver l&aacute;.</p>\n<p style=\"text-align: justify;\">Criaturas convocadas que entrem em um Campo Antimagia desaparecem. Elas reaparecem na mesma posi&ccedil;&atilde;o quando a dura&ccedil;&atilde;o do Campo termina &mdash; supondo que a dura&ccedil;&atilde;o da magia que as convocou ainda n&atilde;o tenha terminado.</p>\n<p style=\"text-align: justify;\">Criaturas m&aacute;gicas, como elementais, ou construtos imbu&iacute;dos com magia durante sua cria&ccedil;&atilde;o, como golens, n&atilde;o s&atilde;o diretamente afetados pelo Campo Antimagia. Entretanto, como qualquer criatura, n&atilde;o poder&atilde;o usar magias ou habilidades m&aacute;gicas dentro dele.</p>\n<p style=\"text-align: justify;\">Magias que dissipam outras magias, como Dissipar Magia, n&atilde;o&nbsp;dissipam um Campo Antimagia, e dois Campos na mesma &aacute;rea n&atilde;o se neutralizam. Artefatos e deuses maiores n&atilde;o s&atilde;o afetados por um Campo Antimagia</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"HwAvcP5eRVbHdcBG","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/campo-antimagia.webp","label":"Campo Antimagia","origin":"Item.oRcerP7Sh6Gn5sV0","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.oCrCOF08U0dRe411"}}}
{"_id":"UIQajfvegC0ptC7O","name":"Dispersar as Trevas","type":"magia","img":"systems/tormenta20/icons/magias/dispersar-trevas.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia cria um forte brilho (multicolorido ou de uma cor que remeta a sua divindade) que causa diversos efeitos. Todas as magias de 3&ordm; c&iacute;rculo ou menor ativas na &aacute;rea s&atilde;o dissipadas se voc&ecirc; passar num teste de Religi&atilde;o contra a CD de cada magia. Seus aliados na &aacute;rea recebem +4 em testes de resist&ecirc;ncia e resist&ecirc;ncia a trevas 10 at&eacute; o fim da cena, protegidos por uma aura sutil da mesma cor. Inimigos na &aacute;rea ficam cegos por 1d4 rodadas (apenas uma vez pela magia). Dispersar as Trevas anula Anular a Luz.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"Esfera de 6m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"BAALs1pqe6qAvRCS","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.pericias.fort.bonus","mode":2,"value":"1"},{"key":"data.pericias.refl.bonus","mode":2,"value":"1"},{"key":"data.pericias.vont.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus nas resistências em +1.","origin":"Compendium.tormenta20.magias.UIQajfvegC0ptC7O","transfer":false,"tint":null},{"_id":"HVAXTTFcfJE6WkQu","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"area","value":"alvo 1 criatura","mode":5},{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto, a área para alvo 1 criatura e a duração para cena. O alvo fica imune a efeitos de necromancia e trevas.","origin":"Compendium.tormenta20.magias.UIQajfvegC0ptC7O","transfer":false},{"_id":"u2D4Npvi3ebOqo6I","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o círculo máximo de magias dissipadas para 4º. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.UIQajfvegC0ptC7O","transfer":false},{"_id":"dU6FV0gkSnFKJz79","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o círculo máximo de magias dissipadas para 5º. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.UIQajfvegC0ptC7O","transfer":false},{"_id":"Kp6MQS1nSURuLfaC","changes":[{"key":"data.tracos.resistencias.trevas.value","mode":2,"value":"10"},{"key":"data.pericias.fort.bonus","mode":2,"value":"4"},{"key":"data.pericias.refl.bonus","mode":2,"value":"4"},{"key":"data.pericias.vont.bonus","mode":2,"value":"4"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/dispersar-trevas.webp","label":"Dispersar as Trevas","origin":"Item.dgWCjcKWomv1B5NH","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.XijvwjCU2BVx9ddl"}}}
{"_id":"UhiM7pMNk3HfWNKP","name":"Telecinésia","type":"magia","img":"systems/tormenta20/icons/magias/telecinesia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você move objetos ou criaturas se concentrando. Ao lançar a magia, escolha uma das opções a seguir.</p><p style=\"text-align:justify;\"><i>Força Contínua:</i> você move uma criatura ou objeto com até 200kg, a até 6m por rodada. Uma criatura pode anular o efeito sobre ela, ou sobre um objeto que possua, passando num teste de Vontade. O peso pode ser movido em qualquer direção dentro do alcance. Ele cai no chão se sair do alcance ou a magia terminar. <b>Duração:</b> sustentada. </p><p style=\"text-align:justify;\"><i>Empurrão Violento:</i> nesta versão a energia mágica é expelida de uma única vez e arremessa até 10 objetos, ou um peso total de 200kg, o que for menor. Os objetos devem estar a até 3m uns dos outros.</p><p style=\"text-align:justify;\">Objetos arremessados podem atingir criaturas em seu caminho, causando de 1 ponto de dano de impacto por 10kg (objetos macios, sem pontas ou sem fio) até 1d6 pontos de dano por 10kg (objetos duros, pontudos ou afiados). Criaturas atingidas têm direito a um teste de Reflexos para reduzir o dano à metade.</p><p style=\"text-align:justify;\">Criaturas dentro da capacidade de peso da magia podem ser arremessadas, mas têm direito a um teste de Vontade para evitar o efeito (em si mesmas ou em objetos que estejam segurando). Uma criatura arremessada contra uma superfície sólida sofre 1d6 pontos de dano de impacto para cada 3m que “voou” no deslocamento (incluindo outras criaturas; nesse caso, ambas sofrem o dano). Duração: instantânea.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"sustentada ou instantânea (veja texto)","units":"special","special":"sustentada ou instantânea (veja texto)","valor":"sustentada ou instantânea (veja texto)","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"veja texto;","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"Dp5Pj6tZpuRzJ5ov","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o limite de peso em 100kg.","origin":"Compendium.tormenta20.magias.UhiM7pMNk3HfWNKP","transfer":false},{"_id":"k0Dc5bs8tYVYyK1x","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/telecinesia.webp","label":"Telecinésia","origin":"Item.vALWn0x2Qg3XL91R","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.xMIfHMU9ekmoWkpM"}}}
{"_id":"VqsjzRkQ9nA11XRD","name":"Muralha Elemental","type":"magia","img":"systems/tormenta20/icons/magias/muralha-elemental.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma muralha de um elemento a sua escolha. A muralha pode ter duas formas: uma barreira de até 30m de comprimento e 3m de altura (ou o contrário) ou uma cúpula de 3m de raio. Os efeitos variam conforme o tipo de elemento escolhido.</p><p style=\"text-align:justify;\"><i>Fogo.</i> Faz surgir uma violenta cortina de chamas. Um lado da muralha (a sua escolha) emite ondas de calor, que causam 2d6 pontos de dano de fogo em criaturas a até 6m. A muralha causa esse dano quando surge e no início de seus turnos. Atravessar a muralha causa 8d6 pontos de dano de fogo. Caso seja criada em uma área onde existem criaturas, elas sofrem dano como se estivessem atravessando a muralha, mas podem fazer um teste de Reflexos para reduzir o dano à metade (a criatura escolhe para qual lado quer escapar, mas se escapar para o lado quente sofrerá mais 2d6 pontos de dano).</p><p style=\"text-align:justify;\"><i>Gelo.</i> Evoca uma parede grossa de gelo denso com 15cm de espessura. Na forma de cúpula, pode prender uma ou mais criaturas, mas elas têm direito a um teste de Reflexos para escapar antes que a cúpula se forme. Cada trecho de 3m da muralha tem Defesa 8, 40 PV e RD 5. Um trecho da muralha que atinja 0 PV será rompido. Qualquer efeito de fogo causa dano dobrado à muralha. Uma criatura que atravesse um trecho rompido da muralha sofre 4d6 pontos de dano de frio.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"muralha de energia","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"veja texto"},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"BnJuNG5XwFbAYZDc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o comprimento em +15m e altura em +3m, até 60m de comprimento e 9m de altura.","origin":"Compendium.tormenta20.magias.VqsjzRkQ9nA11XRD","transfer":false},{"_id":"O8ODPwbDDbAk3bJj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"sustentada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para sustentada e adiciona uma nova escolha, Essência. A muralha é invisível e indestrutível — imune a qualquer forma de dano e não afetada por nenhuma magia. Ela não pode ser atravessada nem mesmo por criaturas incorpóreas. No entanto, magias que teletransportam criaturas, como Salto Dimensional, podem atravessá-la. Magias e efeitos de dano, como Bola de Fogo e o sopro de um dragão, não vencem a muralha, mas magias lançadas diretamente sobre uma criatura ou área, como Sono, podem ser lançadas contra alvos que estejam no outro lado como se tivessem linha de efeito. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.VqsjzRkQ9nA11XRD","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Ud2Eyw6UWUKTsMVv"}}}
{"_id":"VtD27Z068vl78qH3","name":"Oração","type":"magia","img":"systems/tormenta20/icons/magias/oracao.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; e&nbsp;todos os seus aliados no alcance&nbsp;recebem +2 em testes de per&iacute;cia e rolagens de dano, e todos os seus inimigos no alcance sofrem &ndash;2 em testes de per&iacute;cia e rolagens de dano. Esses b&ocirc;nus e penalidades s&atilde;o cumulativos com outras magias.</p>\n<p style=\"text-align: justify;\">Componente Material: T$ 25&nbsp;por PM gastos em incensos ou outras oferendas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"todas as criaturas (veja texto)","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"kn9WNxJzJkpiKMCl","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"1"},{"key":"data.modificadores.dano.geral","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","origin":"Compendium.tormenta20.magias.VtD27Z068vl78qH3","transfer":false,"tint":null},{"_id":"OMyyngbguabh6qhg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"-1"},{"key":"data.modificadores.dano.geral","mode":2,"value":"-1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta as penalidades em –1, limitado pelo círculo máximo de magia que você pode lançar.","origin":"Compendium.tormenta20.magias.VtD27Z068vl78qH3","transfer":false,"tint":null},{"_id":"nZkAxUimWlwGK2kG","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"médio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para médio. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.VtD27Z068vl78qH3","transfer":false},{"_id":"FL0aIDsjW6ThkHfK","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para cena. Requer 4º círculo","origin":"Compendium.tormenta20.magias.VtD27Z068vl78qH3","transfer":false},{"_id":"9cGeU1ke2VZp64op","changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"2"},{"key":"data.modificadores.dano.geral","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/oracao.webp","label":"Oração (Bônus)","origin":"Item.bNHmwK5MeV25SVkn","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"oYI6xE8QZVl0jSvt","changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"-2"},{"key":"data.modificadores.dano.geral","mode":2,"value":"-2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/oracao.webp","label":"Oração (Penalidade)","origin":"Item.bNHmwK5MeV25SVkn","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.03ZJcX1qy0WS8Ea2"}}}
{"_id":"W3wssZ36rMtbMPaA","name":"Seta Infalível","type":"magia","img":"systems/tormenta20/icons/magias/seta-infalivel.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Favorita entre arcanistas iniciantes, esta magia lan&ccedil;a duas setas de energia que causam 1d4+1 pontos de dano de ess&ecirc;ncia cada. Voc&ecirc; pode lan&ccedil;ar as setas em alvos diferentes ou concentr&aacute;-las num mesmo alvo. Caso voc&ecirc; possua um b&ocirc;nus no dano de magias, como pelo poder Arcano de Batalha, ele &eacute; aplicado em apenas uma seta (o b&ocirc;nus vale para a magia, n&atilde;o cada alvo).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"até 2 criaturas","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[{"name":"dano","key":"dano0","type":"dano","parts":[["2d4+2",""]]}],"tipo":"arc","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"LsqObMrldBr1Fcuf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"d8"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda as setas para lanças de energia que surgem e caem do céu. Cada lança causa 1d8+1 pontos de dano de essência. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.W3wssZ36rMtbMPaA","transfer":false,"tint":null},{"_id":"FNDcKMDqbeI2fS1z","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":5,"value":"3d4+3"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o número de setas/lanças para três.","origin":"Compendium.tormenta20.magias.W3wssZ36rMtbMPaA","transfer":false,"tint":null},{"_id":"ueestmdj5uAD6cQe","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":5,"value":"5d4+5"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o número de setas/lanças para cinco. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.W3wssZ36rMtbMPaA","transfer":false,"tint":null},{"_id":"4yIBeldeGDY1thXx","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":5,"value":"10d4+10"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o número de setas/lanças para dez. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.W3wssZ36rMtbMPaA","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.MXN6umhJ8krpE1QT"},"cf":null}}
{"_id":"WrXV3FSwTkh5Hgtc","name":"Buraco Negro","type":"magia","img":"systems/tormenta20/icons/magias/buraco-negro.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia cria um v&aacute;cuo capaz de sugar tudo nas proximidades. Escolha um espa&ccedil;o desocupado para o buraco negro. No in&iacute;cio de cada um de seus tr&ecirc;s turnos seguintes, todas as criaturas em alcance longo do buraco negro, incluindo voc&ecirc;, devem fazer um teste de Fortitude. Em caso de falha, ficam ca&iacute;das e s&atilde;o puxadas 30m na dire&ccedil;&atilde;o do buraco. Objetos soltos tamb&eacute;m s&atilde;o puxados. Criaturas podem gastar uma a&ccedil;&atilde;o de movimento para se segurar em algum objeto fixo, recebendo +2 em seus testes de resist&ecirc;ncia. Criaturas e objetos que toquem o buraco negro s&atilde;o sugadas, desaparecendo para sempre.</p>\n<p style=\"text-align: justify;\">N&atilde;o se conhece o destino das coisas sugadas pelo buraco negro, uma vez que jamais retornam. Alguns estudiosos sugerem que podem ser enviadas para outros mundos. Muitos cl&eacute;rigos das Trevas acreditam que esta magia abre um portal para Sombria, o lar de sua deusa, e sonham um dia poder realizar essa jornada.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"3 rodadas","units":"special","special":"","valor":"3 rodadas","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"","area":"Buraco negro","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude parcial"},"rolls":[],"tipo":"uni","circulo":"5","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"IZkYfoMdeEGdbnWl","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para que criaturas escolhidas dentro do alcance não sejam afetadas.","origin":"Compendium.tormenta20.magias.WrXV3FSwTkh5Hgtc","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.zNbKsEwKPq8mTiN6"}}}
{"_id":"X89YrsleSF5Ulsa1","name":"Conjurar Monstro","type":"magia","img":"systems/tormenta20/icons/magias/conjurar-monstro.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia conjura um monstro Pequeno que ataca seus inimigos. Voc&ecirc; escolhe a apar&ecirc;ncia do monstro e o tipo de dano que ele pode causar, entre corte, impacto e perfura&ccedil;&atilde;o. No entanto, ele n&atilde;o &eacute; uma criatura real, e sim um construto feito de energia. Se for destru&iacute;do, ou quando a magia acaba, desaparece com um brilho, sem deixar nada para tr&aacute;s. Voc&ecirc; s&oacute; pode ter um monstro conjurado por esta magia por vez. O monstro surge em um ponto escolhido por voc&ecirc; dentro do alcance e pode agir no come&ccedil;o do seu pr&oacute;ximo turno, sempre na sua Iniciativa. O monstro tem deslocamento 9m e pode fazer uma a&ccedil;&atilde;o de movimento por rodada. Voc&ecirc; pode usar uma a&ccedil;&atilde;o padr&atilde;o para dar uma das seguintes ordens a ele.</p>\n<p style=\"text-align: justify;\"><em>Mover:</em> o monstro se movimenta o dobro do deslocamento nessa rodada.</p>\n<p style=\"text-align: justify;\"><em>Atacar:</em> o monstro ataca um alvo em alcance corpo a corpo. O ataque acerta automaticamente e causa 2d4+2 pontos de dano.</p>\n<p style=\"text-align: justify;\"><em>Lan&ccedil;ar Magia:</em> o monstro pode servir como ponto de origem para uma magia lan&ccedil;ada por voc&ecirc; com execu&ccedil;&atilde;o de uma a&ccedil;&atilde;o padr&atilde;o ou menor. Ele pode descarregar um Toque Chocante em um inimigo distante, ou mesmo &ldquo;cuspir&rdquo; uma Bola de Fogo! Voc&ecirc; gasta PM normalmente para lan&ccedil;ar a magia.</p>\n<p style=\"text-align: justify;\">Outros usos criativos para monstros conjurados ficam a crit&eacute;rio do mestre.</p>\n<p style=\"text-align: justify;\">O monstro n&atilde;o age sem receber uma ordem.</p>\n<p style=\"text-align: justify;\">Para efeitos de jogo, o monstro conjurado tem For 14, Des 17 e todos os outros atributos nulos. Ele tem 20 pontos de vida, n&atilde;o tem um valor de Defesa (ataques feitos contra ele acertam automaticamente) e usa o seu b&ocirc;nus para teste de Reflexos. Ele &eacute; imune a efeitos que pedem um teste de Fortitude ou Vontade.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura conjurada","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"c9TlOJN3jYxPi4gz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o monstro ganha deslocamento de escalada ou natação igual ao seu deslocamento terrestre.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"ZxWdWMajzEJJbS3Z","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o deslocamento do monstro em +3m.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"Dw7Hi67Kc6ElagOk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o tipo de dano do ataque do monstro para ácido, fogo, frio ou eletricidade.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"e1nNqjFxfeG6sBHl","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o monstro ganha percepção às cegas (alcance curto).","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false,"tint":null},{"_id":"zAVRe2HtZLt7i3Dv","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os PV do monstro em +10 para cada categoria de tamanho a partir de Pequeno (+10 PV para Pequeno, +20 PV para Médio etc.).","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false,"tint":null},{"_id":"EsKCHpUXf96ip0I5","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o tamanho do monstro para Médio. Ele tem For 18, Des 16, 45 PV, deslocamento 12m e seu ataque causa 2d6+4 pontos de dano.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"4aCmcFMty29RiUgp","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o monstro ganha resistência 5 contra dois tipos de dano (por exemplo, corte e frio).","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"xQSUi8smYjA0zcJc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o monstro ganha uma nova ordem: Arma de Sopro. O monstro causa o dobro de seu dano de ataque em um cone de 6m a partir de si (Reflexos reduz à metade).","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"n7Xw9WgOy3UaOGpH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o tamanho do monstro para Grande. Ele tem For 24, Des 14, 75 PV, deslocamento 12m e seu ataque causa 3d6+7 pontos de dano com 3m de alcance. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"cDyoYnw2Zg17k2Cv","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o monstro ganha deslocamento de voo igual ao dobro do deslocamento.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"cUV8VBanY0RP8mW9","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"o monstro ganha imunidade contra dois tipos de dano.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"UV34LsxA03TFxALd","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":true}},"changes":[{"key":"dano","value":"4d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o tamanho do monstro para Enorme. Ele tem For 32, Des 12, 110 PV, deslocamento 15m e seu ataque causa 4d6+11 pontos de dano com 4,5m de alcance. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false},{"_id":"q7leN2w2QXj3nAd0","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14","aumenta":true}},"changes":[{"key":"dano","value":"6d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o tamanho do monstro para Colossal. Ele tem For 41, Des 10, 180 PV, deslocamento 15m e seu ataque causa 6d6+15 de dano com 9m de alcance. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.X89YrsleSF5Ulsa1","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.rDxYObrDvg5kQnpI"}}}
{"_id":"XJoWTcH8zVtHc2xa","name":"Escudo da Fé","type":"magia","img":"systems/tormenta20/icons/magias/escudo-da-fe.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Um escudo místico se manifesta momentaneamente para bloquear um golpe. O alvo recebe +2 na Defesa.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"reaction","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"turn","special":"","valor":"1 turno","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"elfboK1tOLQA5COJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"execucao","value":"Padrão","mode":5},{"key":"alcance","value":"toque","mode":5},{"key":"duracao","value":"cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação padrão, o alcance para toque e a duração para cena.","origin":"Compendium.tormenta20.magias.i6LtB6c3u8fLQOXp","tint":null,"transfer":false},{"_id":"dWw5EaKzbTWoRNZw","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também fornece ao alvo camuflagem contra ataques à distância.","origin":"Compendium.tormenta20.magias.i6LtB6c3u8fLQOXp","transfer":false},{"_id":"qOH6ej4ccboq16RJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus na Defesa em +1.","origin":"Compendium.tormenta20.magias.i6LtB6c3u8fLQOXp","tint":null,"transfer":false},{"_id":"Lg6PDnTETj0kcL6F","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"execucao","value":"ação padrão","mode":5},{"key":"alcance","value":"toque","mode":5},{"key":"duracao","value":"cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação padrão, o alcance para toque e a duração para cena. A magia cria uma conexão mística entre você e o alvo. Além do efeito normal, o alvo sofre apenas metade do dano por ataques e efeitos; a outra metade do dano é transferida a você. Se a qualquer momento o alvo sair de alcance curto de você, a magia é dissipada. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.i6LtB6c3u8fLQOXp","transfer":false},{"_id":"iyuhAEsEq67Q8aWK","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.i6LtB6c3u8fLQOXp","transfer":false},{"_id":"sjxS6CGlVJSg38co","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/escudo-da-fe.webp","label":"Escudo da Fé (Cena)","origin":"Item.eTMQ5GAOTIEXKSv0","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":null,"sort":0,"permission":{"default":0,"b9Q3OXh7jXHQRm5r":3},"flags":{"core":{"sourceId":"Item.QYhatl1WC0qggYKe"},"importid":"0nLtxzy8N6fUDERs","cf":null}}
{"_id":"XWEJNZMs6Wb9uUHF","name":"Velocidade","type":"magia","img":"systems/tormenta20/icons/magias/velocidade.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">O alvo pode realizar uma a&ccedil;&atilde;o demovimento adicional por turno.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"lYxiSwCe3djsAOE6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas no alcance","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas no alcance. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false},{"_id":"wb7wmP9NbM1Q2Bxg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para você. Você acelera sua mente, além de seu corpo. A ação adicional pode ser usada para lançar magias e ativar engenhocas. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF","transfer":false},{"_id":"1GMNISQtXMIgnH78","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/velocidade.webp","label":"Velocidade","origin":"Item.bcI6qQ9HH1A8YCcu","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"H1gsE0MDcKksovuP","changes":[{"key":"duracao","mode":5,"value":"sustentada"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para sustentada. Em vez de ação de movimento, o alvo pode realizar uma ação padrão adicional por\nturno. \nEsta ação não pode ser usada para lançar magias e ativar engenhocas.","origin":"Item.Lr2HLRTDMGrZB7eL","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.MtmFzJIsEiXnAzhU"},"cf":null}}
{"_id":"YDxLaaDhfXOkSfnF","name":"Arma Mágica","type":"magia","img":"systems/tormenta20/icons/magias/arma-magica.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">A arma fornece um b&ocirc;nus de +1 nos testes de ataque e rolagens de dano e &eacute; considerada m&aacute;gica. Caso voc&ecirc; esteja empunhando a arma, pode usar seu atributo-chave de magias em vez do atributo original nos testes de ataque.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 arma","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"CsxccmtGU6cmoFwn","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"1"},{"key":"data.modificadores.dano.ad","mode":2,"value":"1"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"1"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus em +1, limitado pelo círculo máximo de magia que você pode lançar.","origin":"Item.N0VolSuZqafQ4qdh","tint":null,"transfer":false},{"_id":"2B720KAGoTazOT5e","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"a arma passa a causar +1d6 de dano de ácido, eletricidade, fogo ou frio, escolhido no momento em que a magia é lançada.","origin":"Item.N0VolSuZqafQ4qdh","tint":null,"transfer":false},{"_id":"C1dFmv83ttXKFkCc","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"1"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"1"},{"key":"data.modificadores.dano.cac","mode":2,"value":"1"},{"key":"data.modificadores.dano.ad","mode":2,"value":"1"}],"disabled":false,"duration":{"rounds":999,"startTime":null},"icon":"modules/modulot20automatizado/assets/modules/moduloguilda/assets/systems/tormenta20/icons/magias/arma-magica.webp","label":"Arma Mágica","origin":"Item.OpEZYZDFAt8y1r4m","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"WLFFoDvUgh8beJuC","changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"1d6"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"1d6"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/arma-magica.webp","label":"Arma Mágica (Dano Elemental)","origin":"Item.0q6g830lMR2q3yT2","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.GHPogramaHOYtMYH"},"cf":null}}
{"_id":"YkWiMqxvNrmHi1Hv","name":"Reanimação Impura","type":"magia","img":"systems/tormenta20/icons/magias/reanimacao-impura.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você reanima uma criatura morta recentemente (dentro da mesma cena), trazendo sua alma de volta ao corpo de forma forçada. O tipo da criatura muda para morto-vivo, mas ela retém suas memórias e habilidades de quando estava viva, podendo inclusive lançar magias. A criatura pode pensar e falar livremente, mas obedece cegamente a seus comandos. Quando a cena termina, a criatura volta a ficar morta, mas muitos clérigos malignos usam meios para guardar e preservar o corpo de criaturas poderosas para serem reanimadas dessa forma quando necessário. Se for destruída, a criatura não pode ser reanimada novamente com esta magia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"5","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"DpDTFRvfXagUqH08","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/reanimacao-impura.webp","label":"Reanimação Impura","origin":"Item.nlVUnkGHOGkSO5XT","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.n346cbbQHkqRKb9l"}}}
{"_id":"Yzvo9SdSZX94PPNl","name":"Aparência Perfeita","type":"magia","img":"systems/tormenta20/icons/magias/aparencia-perfeita.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia lhe concede um rosto idealizado, porte f&iacute;sico garboso, voz melodiosa e olhar sedutor, deixando-o mais atraente e confi&aacute;vel. Enquanto a magia estiver ativa, seu Carisma torna-se 20 (ou recebe um b&ocirc;nus de +4, caso seja 20 ou maior) e voc&ecirc; recebe +5 nos testes de Diplomacia e Engana&ccedil;&atilde;o. Quando a magia acaba, quaisquer observadores percebem a mudan&ccedil;a e tendem a suspeitar de voc&ecirc;. Da mesma maneira, pessoas que o viram sob o efeito da magia sentir&atilde;o que &ldquo;algo est&aacute; errado&rdquo; ao v&ecirc;-lo em condi&ccedil;&otilde;es normais. Quando a cena acabar, voc&ecirc; pode gastar os PM da magia novamente como uma a&ccedil;&atilde;o livre para mant&ecirc;-la ativa. Este efeito n&atilde;o fornece PV ou PM adicionais.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"eZYZ5KPkIH2a6fjO","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 humanoide","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para 1 humanoide","origin":"Item.CRLvBrcWaySC2yYi","tint":null,"transfer":false},{"_id":"AOxASZv1uaoyhTyD","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":true}},"changes":[{"key":"data.atributos.car.value","mode":5,"value":"20"},{"key":"data.pericias.dipl.bonus","mode":2,"value":"5"},{"key":"data.pericias.enga.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"startTime":null,"rounds":999},"icon":"systems/tormenta20/icons/magias/aparencia-perfeita.webp","label":"Aparência Perfeita (Car 20)","origin":"Item.CRLvBrcWaySC2yYi","tint":"","transfer":false},{"_id":"eRKzguN7fqoNtNS1","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":true}},"changes":[{"key":"data.atributos.car.value","mode":2,"value":"4"},{"key":"data.pericias.dipl.bonus","mode":2,"value":"5"},{"key":"data.pericias.enga.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"startTime":null,"rounds":999},"icon":"systems/tormenta20/icons/magias/aparencia-perfeita.webp","label":"Aparência Perfeita (Car +4)","origin":"Item.CRLvBrcWaySC2yYi","tint":"","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.GwWIB8ls4Gy6YQHj"}}}
{"_id":"ZUQneRqpDjJKRO5n","name":"Teletransporte","type":"magia","img":"systems/tormenta20/icons/magias/teletransporte.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia transporta os alvos para um lugar a sua escolha a até 1.000km. Você precisa fazer um teste de Misticismo, com dificuldade que depende de seu conhecimento sobre o local de destino.</p><p style=\"text-align:justify;\">CD 20. Um lugar familiar, que você visita com frequência.</p><p style=\"text-align:justify;\">CD 30. Um lugar conhecido, que você já visitou pelo menos uma vez.</p><p style=\"text-align:justify;\">CD 40. Um lugar desconhecido, que você nunca visitou e só conhece a partir da descrição de outra pessoa que esteve lá.</p><p style=\"text-align:justify;\">Você não pode se teletransportar para um lugar que nunca visitou sem a descrição de alguém. Ou seja, não pode se transportar para a “sala de tesouro do rei” se nunca esteve nela nem falou com alguém que esteve.</p><p style=\"text-align:justify;\">Se passar no teste, os alvos chegam ao lugar desejado. Se falhar, os alvos surgem 1d10 x 10km afastados em qualquer direção (se o destino é uma cidade costeira, você pode surgir em alto-mar). Se falhar por 5 ou mais, você chega em um lugar parecido, mas errado. E se você rolar 1 natural no teste a magia falha, mas você gasta PM normalmente e fica atordoado por 1d4 rodadas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"até 5 criaturas voluntárias","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"NFLLVMBUfN5gexid","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +5.","origin":"Compendium.tormenta20.magias.ZUQneRqpDjJKRO5n","transfer":false},{"_id":"aQKgLT90Ts8sNMGg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, a magia teletransporta os alvos para seu santuário — um local familiar e previamente preparado. A magia pode ser usada sem limite de distância ou necessidade de testes, mas apenas dentro do mesmo plano. Preparar um local como seu santuário exige um ritual de um dia e o gasto de T$ 1.000. Você só pode ter um santuário por vez.","origin":"Compendium.tormenta20.magias.ZUQneRqpDjJKRO5n","transfer":false},{"_id":"OZP9mnniQOQrxkIL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"execucao","value":"Completa","mode":5},{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação completa, a duração para cena e adiciona sacrifício de 1 PM. Em vez do normal, você cria um círculo de 1,5m de diâmetro no chão, que transporta qualquer criatura que pisar nele. O destino é escolhido quando a magia é lançada e pode ser qualquer lugar, em qualquer mundo, sem a necessidade de testes, desde que seja conhecido por você. O círculo é tênue e praticamente invisível. Você pode marcá-lo de alguma forma (por exemplo, lançando-o sobre uma plataforma elevada). Se não fizer isso, alguém pode pisar nele por acidente. Junte isso a um destino hostil e você terá uma armadilha bastante eficaz! Requer 5º círculo.","origin":"Compendium.tormenta20.magias.ZUQneRqpDjJKRO5n","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.qGGSbADpRE22w35f"}}}
{"_id":"Zi46sKpwydfQdIJt","name":"Controlar Terra","type":"magia","img":"systems/tormenta20/icons/magias/controlar-terra.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você manipula a densidade e a forma de toda terra, pedra, lama, argila ou areia na área. Ao lançar a magia, escolha.</p><p style=\"text-align:justify;\"><i>Amolecer:</i> se afetar o teto, uma coluna ou suporte, provoca um desabamento que causa 10d6 pontos de dano de impacto às criaturas na área (Reflexos reduz à metade). Se afetar um piso de terra ou pedra, cria terreno difícil de areia ou argila, respectivamente.</p><p style=\"text-align:justify;\"><i>Modelar:</i> pode usar pedra ou argila para criar um ou mais objetos simples de tamanho Enorme ou menor (sem mecanismos ou partes móveis). Por exemplo, pode transformar um tijolo em uma maça, criar uma passagem onde antes havia apenas uma parede ou levantar uma ou mais paredes que oferecem cobertura total (RD 8 e 50 PV para cada 3m).</p><p style=\"text-align:justify;\"><i>Solidificar:</i> transforma lama ou areia em terra ou pedra. Criaturas com os pés na superfície ficam agarradas. Elas podem se soltar com uma ação padrão e um teste de Acrobacia ou Atletismo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"instantanea","units":"special","special":"","valor":"instantanea","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"","area":"9 cubos com 1,5m de lado","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Veja texto"},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"KzvZou1jQoqIoay1","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de cubos de 1,5m em +2.","origin":"Compendium.tormenta20.magias.Zi46sKpwydfQdIJt","transfer":false},{"_id":"xvwIs3X94QHqNBVJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5},{"key":"duracao","value":"1 dia","mode":5},{"key":"dano","value":"10d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal, o alvo para você e a duração para 1 dia. Você e seu equipamento fundem-se a uma superfície ou objeto adjacente feito de pedra, terra, argila ou areia que possa acomodá-lo. Você pode voltar ao espaço adjacente como uma ação livre, dissipando a magia. Enquanto mesclado, você não pode falar ou fazer ações físicas, mas consegue perceber seus arredores normalmente. Pequenos danos não o afetam, mas se o objeto (ou o trecho onde você está imerso) for destruído, a magia é dissipada, você volta a um espaço livre adjacente e sofre 10d6 pontos de dano de impacto.","origin":"Compendium.tormenta20.magias.Zi46sKpwydfQdIJt","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.aHuGc9VrXbojCPBr"}}}
{"_id":"ZwM3J3oEjFz8cCt0","name":"Conceder Milagre","type":"magia","img":"systems/tormenta20/icons/magias/conceder-milagre.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você transfere um pouco de seu poder divino a outra criatura. Escolha uma magia de até 2º círculo que você conheça; o alvo pode lançar essa magia uma vez, sem pagar o custo base dela em PM (aprimoramentos podem ser usados, mas o alvo deve gastar seus próprios PM). Você sofre uma penalidade de –3 PM até que o alvo lance a magia que ganhou.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"permanente até ser descarregada","units":"special","special":"","valor":"permanente até ser descarregada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"4","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"huOA1zSiiJL2Ffjv","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o círculo da magia concedida para 3º e a penalidade de PM para –6.","origin":"Compendium.tormenta20.magias.ZwM3J3oEjFz8cCt0","transfer":false},{"_id":"JLj04JvTNJmckzGh","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/conceder-milagre.webp","label":"Conceder Milagre","origin":"Item.xoO82iq18dQtgham","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Lg9tzYZmrTxFO0q6"}}}
{"_id":"ZzDo9khqHDty1iDV","name":"Abençoar Alimentos","type":"magia","img":"systems/tormenta20/icons/magias/abencoar-alimentos.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; purifica e aben&ccedil;oa uma por&ccedil;&atilde;o de comida ou dose de bebida. Isso torna um alimento sujo, estragado ou envenenado pr&oacute;prio para consumo. Al&eacute;m disso, se for consumido at&eacute; o final da dura&ccedil;&atilde;o, o alimento oferece 5 PV tempor&aacute;rios ou 1 PM tempor&aacute;rio (al&eacute;m de quaisquer b&ocirc;nus que j&aacute; oferecesse). B&ocirc;nus de alimenta&ccedil;&atilde;o duram um dia e cada personagem s&oacute; pode receber um b&ocirc;nus de alimenta&ccedil;&atilde;o por dia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"Alimento para 1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"stE1aQS78iamg8A5","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"","durationScene":false,"onuse":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"o alimento é purificado (não causa nenhum efeito nocivo se estava estragado ou envenenado), mas não oferece bônus ao ser consumido.","origin":"Item.ooljhEHVC95FFYy2","tint":null,"transfer":false},{"_id":"8tPnJoXVcIhXbVkw","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"1","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"1","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"aumenta o número de alvos em +1.","origin":"Item.ooljhEHVC95FFYy2","tint":null,"transfer":false},{"_id":"S9PfJej9nKnyc6sE","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"1","durationScene":false,"onuse":true}},"changes":[{"key":"duracao","value":"permanente","mode":5},{"key":"alvo","value":"1 frasco com água","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda a duração para permanente, o alvo para 1 frasco com água e adiciona componente material (pó de prata no valor de T$ 5). Em vez do normal, cria  @Compendium[tormenta20.equipamentos.labWwyXiXHl7JvE0]{Água benta}","origin":"Item.ooljhEHVC95FFYy2","tint":null,"transfer":false},{"_id":"rkGfGUa8tjaJl82y","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/abencoar-alimentos.webp","label":"Sob Efeito do Fruto","origin":"Item.Fd7SJsp1MNFbSCCd","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.u6AnCM0wCR5c1Mn0"}}}
{"_id":"ZzibqJnR2Cd0efWX","name":"Convocação Instantânea","type":"magia","img":"systems/tormenta20/icons/magias/convocacao-instantanea.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você invoca um objeto de qualquer lugar para sua mão. O item deve ter sido previamente preparado com uma runa ou marca pessoal sua (ao custo de T$ 5). A magia não funciona se o objeto estiver com outra criatura, mas você saberá onde ele está e quem o está carregando (ou sua descrição física, caso não conheça a criatura).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"any","alvo":"1 objeto de até 5kg","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"QQoGixlukm4d28Xs","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, até 1 hora após ter lançado a magia, você pode gastar uma ação de movimento para enviar o objeto de volta para o local em que ele estava antes.","origin":"Compendium.tormenta20.magias.ZzibqJnR2Cd0efWX","transfer":false},{"_id":"NcDNYaGsMh9A71TX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"um baú Médio","mode":5},{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para um baú Médio, a duração para permanente e adiciona sacrifício de 1 PM. Em vez do normal, você esconde o baú alvo no Etéreo, com até 250kg de equipamento. A magia faz com que qualquer objeto caiba no baú, independentemente do seu tamanho. Uma vez escondido, você pode convocar o baú para um espaço livre adjacente, ou de volta para o Etéreo, como uma ação padrão. Componente material: baú construído com matéria-prima da melhor qualidade (T$ 1.000). Você deve ter em mãos uma miniatura do baú, no valor de T$ 100, para invocar o baú verdadeiro.","origin":"Compendium.tormenta20.magias.ZzibqJnR2Cd0efWX","transfer":false},{"_id":"9nWgAXltywJKiZ2I","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.ZzibqJnR2Cd0efWX","transfer":false},{"_id":"v9QZtJ7jjE7Vl6ik","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o peso limite do alvo em um fator de 10, até 500 kg. Um objeto muito grande ou pesado para aparecer em suas mãos é teletransportado para um espaço adjacente a sua escolha.","origin":"Compendium.tormenta20.magias.ZzibqJnR2Cd0efWX","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.CP6zrXJTTjbH9NIh"}}}
{"_id":"ahIU6trHt6MuMTS7","name":"Voz Divina","type":"magia","img":"systems/tormenta20/icons/magias/voz-divina.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você pode conversar com criaturas de qualquer raça e tipo: animal, construto, espírito, humanoide, monstro ou morto-vivo. Pode fazer perguntas e entende suas respostas, mesmo sem um idioma em comum ou se a criatura não for capaz de falar, mas respeitando os limites da Inteligência dela. A atitude dessas criaturas não é alterada, mas você pode usar a perícia Diplomacia para tentar mudar sua atitude.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"1XNyP8IzeH87FX4m","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"você concede um pouco de vida a um cadáver, suficiente para que ele responda a suas perguntas. O conhecimento do corpo é limitado ao que ele tinha enquanto vivo e suas respostas são curtas e enigmáticas. Um corpo só pode ser alvo desta magia uma vez. Ela também não funciona em um corpo cuja cabeça tenha sido destruída.","origin":"Compendium.tormenta20.magias.ahIU6trHt6MuMTS7","transfer":false},{"_id":"qBjpCbWkUIHrFgzQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"você pode falar com plantas (normais ou monstruosas) e rochas. Plantas e rochas têm percepção limitada de seus arredores e normalmente fornecem respostas simplórias.","origin":"Compendium.tormenta20.magias.ahIU6trHt6MuMTS7","transfer":false},{"_id":"dzJ8kkudhuafWeWK","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/voz-divina.webp","label":"Voz Divina","origin":"Item.keNUZdSKmZcOUEuz","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.9RTzq32hE0Of2RAG"}}}
{"_id":"atEVWEfDYu76wyCO","name":"Névoa","type":"magia","img":"systems/tormenta20/icons/magias/nevoa.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Uma névoa espessa eleva-se de um ponto a sua escolha, obscurecendo toda a visão — criaturas a até 1,5m têm camuflagem e criaturas a partir de 3m têm camuflagem total. Um vento forte dispersa a névoa em 4 rodadas e um vendaval a dispersa em 1 rodada. Esta magia não funciona sob a água.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"nuvem com 6m de raio e 6m de altura","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"klkObcd5CG66Sshf","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"a magia também funciona sob a água, criando uma nuvem de tinta.","origin":"Compendium.tormenta20.magias.atEVWEfDYu76wyCO","transfer":false},{"_id":"ftkwbiVy2pQf3klg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"você pode escolher criaturas no alcance ao lançar a magia; elas enxergam através do efeito. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.atEVWEfDYu76wyCO","transfer":false},{"_id":"Bu3xxk5TAhtWYoYu","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, a nuvem tem um cheiro horrível. No início de seus turnos, qualquer criatura dentro dela, ou qualquer criatura com faro em alcance curto da nuvem, deve fazer um teste de Fortitude. Se falhar, fica enjoada por uma rodada.","origin":"Compendium.tormenta20.magias.atEVWEfDYu76wyCO","tint":null,"transfer":false},{"_id":"AdteyDMTn54EcUP3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","value":"2d4","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, a nuvem tem um tom esverdeado e se torna cáustica. No início de seus turnos, criaturas dentro dela sofrem 2d4 pontos de dano de ácido.","origin":"Compendium.tormenta20.magias.atEVWEfDYu76wyCO","tint":null,"transfer":false},{"_id":"rFg3jSdwQCKJBXeB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","value":"2d4","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano de ácido em +2d4.","origin":"Compendium.tormenta20.magias.atEVWEfDYu76wyCO","tint":null,"transfer":false},{"_id":"DZlkMCHT475MLItN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.movement.walk","value":"3","mode":2},{"key":"data.modificadores.pericias.ataque","value":"-2","mode":2},{"key":"data.modificadores.dano.geral","value":"-2","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, a nuvem fica espessa, quase sólida. Qualquer criatura dentro dela tem seu deslocamento reduzido para 3m (independentemente de seu deslocamento normal) e sofre –2 em testes de ataque e rolagens de dano.","origin":"Compendium.tormenta20.magias.atEVWEfDYu76wyCO","tint":null,"transfer":false},{"_id":"xw3nw36GxpEkyTXZ","changes":[{"key":"data.modificadores.dano.geral","mode":2,"value":"-2"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"-2"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"-2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/nevoa.webp","label":"Névoa Sólida","origin":"Item.gmAnhGn92yyGzAd2","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.DjKTHezkBUqcKCqO"}}}
{"_id":"bTYmLsNGfcg4pFzu","name":"Terremoto","type":"magia","img":"systems/tormenta20/icons/magias/terremoto.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia cria um tremor de terra que rasga o solo. O terremoto dura uma rodada, durante a qual criaturas sobre o solo n&atilde;o podem se mover, atacar ou lan&ccedil;ar magias.&nbsp;<span style=\"font-family: var(--font-primary); font-size: var(--font-size-14);\">Barreiras f&iacute;sicas n&atilde;o&nbsp;</span><span style=\"font-family: var(--font-primary); font-size: var(--font-size-14);\">interrompem a &aacute;rea de Terremoto.</span></p>\n<p style=\"text-align: justify;\">O efeito exato depende do terreno.&nbsp;</p>\n<p style=\"text-align: justify;\"><em>Caverna ou subterr&acirc;neo:</em> a magia derruba o teto, causando 12d6 pontos de dano de impacto e agarrando todas as criaturas na &aacute;rea. Um teste de Reflexos reduz o dano &agrave; metade e evita ficar agarrado.</p>\n<p style=\"text-align: justify;\"><em>Constru&ccedil;&atilde;o:</em> todas as estruturas na &aacute;rea sofrem 200 pontos de dano de impacto, o suficiente para derrubar constru&ccedil;&otilde;es de madeira ou alvenaria simples, mas n&atilde;o de alvenaria refor&ccedil;ada. Criaturas em uma constru&ccedil;&atilde;o que desmorone sofrem o mesmo efeito de criaturas em uma caverna (veja acima).</p>\n<p style=\"text-align: justify;\"><em>Espa&ccedil;o aberto:</em> fendas se abrem no ch&atilde;o; cada criatura tem 25% de chance (1 em 1d4) de cair em uma delas. A v&iacute;tima tem direito a um teste de Reflexos para se agarrar na borda e escapar. No in&iacute;cio do seu pr&oacute;ximo turno as fendas se fecham, matando todos que estejam dentro delas.</p>\n<p style=\"text-align: justify;\"><em>Penhascos:</em> o penhasco racha, criando um desmoronamento que percorre uma dist&acirc;ncia horizontal igual &agrave; dist&acirc;ncia vertical da queda. Por exemplo, um penhasco com 30m de altura desmorona em uma &aacute;rea de 30m de comprimento al&eacute;m da base. Qualquer criatura no caminho sofre 8d6 pontos de dano de impacto e fica agarrada. Um teste de Reflexos reduz o dano &agrave; metade e evita ficar agarrado.</p>\n<p style=\"text-align: justify;\"><em>Rio, lago ou p&acirc;ntano:</em> fissuras se abrem sob a &aacute;gua, drenando-a e formando um lama&ccedil;al. Criaturas na &aacute;rea precisam fazer um teste de Reflexos para n&atilde;o afundarem na lama e ficarem agarradas. No in&iacute;cio do seu pr&oacute;ximo turno as fissuras se fecham, possivelmente afogando as criaturas que ficaram agarradas. Escapar exige uma a&ccedil;&atilde;o completa e um teste de Atletismo.</p>\n<p style=\"text-align: justify;\">Criaturas agarradas (efeito poss&iacute;vel de caverna, constru&ccedil;&atilde;o, penhasco e rio, lago ou p&acirc;ntano) sofrem 1d6 pontos de dano por rodada at&eacute; serem libertadas, o que exige uma a&ccedil;&atilde;o completa e um teste de Atletismo (por parte da pr&oacute;pria criatura ou de um aliado adjacente).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 rodada","units":"special","special":"","valor":"1 rodada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"","area":"esfera com 30m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"veja texto"},"rolls":[],"tipo":"div","circulo":"4","preparada":false,"escola":"evo","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.0mji3tOeK02ZLGTt"}}}
{"_id":"bjjhaGHKPoTOKtyT","name":"Réquiem","type":"magia","img":"systems/tormenta20/icons/magias/requiem.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma ilusão particular para cada uma das criaturas que atingir. Enquanto a magia durar, no início de cada um de seus turnos, cada criatura afetada deve fazer um teste de Vontade; se falhar, acha que não tomou as ações que realmente fez no turno anterior e é obrigada a repetir as mesmas ações neste turno, com uma penalidade cumulativa de –5 em todos os testes para cada vez que se repetir (a penalidade não se aplica ao teste de Vontade contra esta magia). Por exemplo, se a criatura se aproximou de um alvo e o atacou, precisa se aproximar desse mesmo alvo e atacar novamente. A ação repetida consome PM e recursos normalmente e, caso exija um teste de resistência, qualquer alvo faz esse teste com um bônus igual ao da penalidade desta magia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"criaturas escolhidas","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"iNvGcLd8arHs5jUJ","changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"-5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/requiem.webp","label":"Réquiem (Penalidade)","origin":"Item.hIyrBaEfpVKQiI5i","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"r4Pq9uiKMywbw21B","changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/requiem.webp","label":"Réquiem (Bônus)","origin":"Item.hIyrBaEfpVKQiI5i","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.OYuwHKSao0qaEXyI"}}}
{"_id":"bs3SycPD7ENusrfH","name":"Miasma Mefítico","type":"magia","img":"systems/tormenta20/icons/magias/miasma-mefitico.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">A área é coberta por emanações letais. Criaturas na área sofrem 5d6 pontos de dano de veneno e ficam enjoadas por 1 rodada. Se passarem na resistência, sofrem metade do dano e não ficam enjoadas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"nuvem com 6m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude (veja texto)"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["5d6",""]]}],"tipo":"div","circulo":"2","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"fyrWEjDhKy6MU5of","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"area","value":"alvo (1 criatura com 0 PV ou menos)","mode":5},{"key":"duracao","value":"instantânea","mode":5},{"key":"resistencia","value":"Fortitude anula","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque, a área para alvo (1 criatura com 0 PV ou menos), a duração para instantânea e a resistência para Fortitude anula. Em vez do normal, você canaliza o Miasma contra uma vítima. Se falhar na resistência, ela morre e você recebe +2 na CD de suas magias por 1 dia. Se passar, fica imune a este truque por um dia.","origin":"Compendium.tormenta20.magias.bs3SycPD7ENusrfH","transfer":false},{"_id":"1VEcwX3EAmPtckY8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"1d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Compendium.tormenta20.magias.bs3SycPD7ENusrfH","transfer":false,"tint":null},{"_id":"0jY8pxm5JZUViwRp","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o tipo do dano para trevas.","origin":"Compendium.tormenta20.magias.bs3SycPD7ENusrfH","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.54dzN92Dt0iAl0tl"}}}
{"_id":"cgJPXzVbOQLjyXfe","name":"Físico Divino","type":"magia","img":"systems/tormenta20/icons/magias/fisico-divino.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">O alvo se torna uma versão mais poderosa de si mesmo. O alvo recebe +4 em Força, Destreza ou Constituição, a sua escolha. Esse aumento não oferece PV ou PM adicionais.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"Iw1Su6f48hP42yjc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, o alvo recebe +4 nos três atributos físicos. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.cgJPXzVbOQLjyXfe","transfer":false},{"_id":"aSIzUL1KZZbcLibV","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.cgJPXzVbOQLjyXfe","transfer":false},{"_id":"scy3EyDVbAGydVTq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":true,"ability":false,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.atributos.for.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de força em +2. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.cgJPXzVbOQLjyXfe","transfer":false,"tint":null},{"_id":"APuBh1yBMnCE4zBH","changes":[{"key":"data.atributos.for.bonus","mode":2,"value":"0"},{"key":"data.atributos.des.bonus","mode":2,"value":"0"},{"key":"data.atributos.con.bonus","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/fisico-divino.webp","label":"Físico Divino","origin":"Item.4zu34o2w2P5bC2Xb","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"2FucHqVShYvx9rYq","changes":[{"key":"data.atributos.des.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de destreza em +2. Requer 4º círculo.","origin":"Item.4zu34o2w2P5bC2Xb","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"7","durationScene":false}},"tint":null},{"_id":"GarfwwQ94a8zMSak","changes":[{"key":"data.atributos.con.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus de constituição em +2. Requer 4º círculo.","origin":"Item.4zu34o2w2P5bC2Xb","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"7","durationScene":false}},"tint":null},{"_id":"TXbZz91XvGCAtmTP","changes":[{"key":"data.atributos.for.bonus","mode":2,"value":"4"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"+4 em Força","origin":"Item.4zu34o2w2P5bC2Xb","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null},{"_id":"bBshs5Hf8uEhDIAv","changes":[{"key":"data.atributos.des.bonus","mode":2,"value":"4"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"+4 em Destreza","origin":"Item.4zu34o2w2P5bC2Xb","transfer":false,"flags":{"tormenta20":{"onuse":true,"ability":false,"self":true,"attack":false,"skill":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null},{"_id":"wqOXTqAQYZRk92CG","changes":[{"key":"data.atributos.con.bonus","mode":2,"value":"4"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"+4 em Constituição","origin":"Item.4zu34o2w2P5bC2Xb","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"0","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.3uSMwDV1wkKi1h6B"},"cf":null}}
{"_id":"dYUHQDlIZVNclE02","name":"Intervenção Divina","type":"magia","img":"systems/tormenta20/icons/magias/intervencao-divina.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; pede a sua divindade para interceder diretamente. Voc&ecirc; pode:</p>\n<ul>\n<li>Curar todos os PV e condi&ccedil;&otilde;es de at&eacute; 10 criaturas em alcance longo.</li>\n<li>Dissipar os efeitos de qualquer magia de 4&ordm; c&iacute;rculo ou menor.</li>\n</ul>\n<p style=\"text-align: justify;\">Normalmente, Interven&ccedil;&atilde;o Divina n&atilde;o exige sacrif&iacute;cio de PM &mdash; mas voc&ecirc; pode implorar por algo mais poderoso. Nesse caso, a magia requer o sacrif&iacute;cio de 2 PM e pode fazer coisas como:</p>\n<ul>\n<li>Criar um item mundano de at&eacute; T$ 25.000.</li>\n<li>Duplicar os efeitos de qualquer magia de at&eacute; 4&ordm; c&iacute;rculo. Caso a magia precise de um componente material para ser lan&ccedil;ada, ainda &eacute; necess&aacute;rio providenciar o componente.</li>\n<li>Proteger uma cidade de um desastre, como uma erup&ccedil;&atilde;o vulc&acirc;nica, enchente ou terremoto.</li>\n<li>Ressuscitar uma criatura em alcance longo que tenha morrido h&aacute; at&eacute; uma rodada. A criatura acorda com 1 PV.</li>\n<li>Qualquer outra coisa que o mestre autorize, conforme os desejos e objetivos da divindade do conjurador.</li>\n</ul>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"veja texto","units":"special","special":"","valor":"veja texto","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"spec","alvo":"veja texto","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"veja texto"},"rolls":[],"tipo":"div","circulo":"5","preparada":false,"escola":"con","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.j8EXP5BQEsqXwvHv"}}}
{"_id":"dlRCSddITrSwAdtc","name":"Controlar o Tempo","type":"magia","img":"systems/tormenta20/icons/magias/controlar-tempo.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Aquele que controla o tempo controla o mundo. Escolha um dos efeitos a seguir.</p><p style=\"text-align:justify;\"><i>Congelar o tempo:</i> você entra em um estado atemporal que faz todas as criaturas e efeitos parecerem congelados. Você pode agir livremente por 3 rodadas de tempo aparente. Durante essas rodadas, efeitos contínuos não o afetam, mas criaturas e objetos em posse de criaturas ficam imunes a seus ataques e magias. Magias de área e com duração maior que este efeito vão agir normalmente quando o congelamento acabar. Este efeito costuma ser usado para fortalecer suas defesas e invocar criaturas.</p><p style=\"text-align:justify;\"><i>Saltar no tempo:</i> você e até 5 criaturas voluntárias são transportadas de 1 a 24 horas para o futuro, desaparecendo com um brilho. Vocês ressurgem no mesmo lugar, com a mesma velocidade e orientação; do seu ponto de vista, nenhum tempo se passou. Se um objeto sólido agora ocupa o espaço de uma criatura, ela ressurge na área vazia mais próxima.</p><p style=\"text-align:justify;\"><i>Voltar no tempo:</i> você revive os últimos segundos. Todas as ações da rodada anterior são desfeitas (incluindo perda de PV e PM). Tudo retorna à posição em que estava no início do seu turno na última rodada e você é o único que sabe o que acontecerá. Todos os outros personagens envolvidos na cena devem repetir as mesmas ações — exceto se você fizer algo a respeito (como avisar seus aliados sobre o que vai acontecer).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"veja texto","units":"special","special":"","valor":"veja texto","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"veja texto","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"zmLjUlz4Ilhttv1G","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/controlar-tempo.webp","label":"Controlar o Tempo","origin":"Item.rVviaQ1tiMr65FuJ","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.rpfs1Gxeh3pdftiy"}}}
{"_id":"dvq8aLolbWGm7E2Z","name":"Orientação","type":"magia","img":"systems/tormenta20/icons/magias/orientacao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você oferece ajuda. Escolha um atributo — até o final da cena, sempre que o alvo fizer um teste de perícia baseada no atributo escolhido, pode rolar dois dados e ficar com o melhor resultado. Esse benefício não se aplica a testes de ataque ou resistência.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"f7BI2N4cbZGEtFSW","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"execucao","value":"Padrão","mode":5},{"key":"duracao","value":"1 rodada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação padrão e a duração para 1 rodada. O bônus vale para um único teste. Uma criatura só pode ser afetada por esse truque uma vez por dia.","origin":"Compendium.tormenta20.magias.dvq8aLolbWGm7E2Z","transfer":false},{"_id":"fFCKnCEF44r0NORX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez de um atributo, escolha entre atributos físicos (Força, Destreza e Constituição) ou mentais (Inteligência, Sabedoria e Carisma). Requer 3º círculo.","origin":"Compendium.tormenta20.magias.dvq8aLolbWGm7E2Z","transfer":false},{"_id":"DAcOJvxciLakcLhq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.dvq8aLolbWGm7E2Z","transfer":false},{"_id":"oFqJPOaDazitsMs4","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/orientacao.webp","label":"Orientação","origin":"Item.xajp2MVYpXTSDoek","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.WxNnSgQt0WxHeP0J"},"cf":null}}
{"_id":"eB2JWvyIseIiSfR2","name":"Palavra Primordial","type":"magia","img":"systems/tormenta20/icons/magias/palavra-primordial.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; pronuncia uma palavra do idioma primordial da Cria&ccedil;&atilde;o, que causa um dos efeitos abaixo, a sua escolha.</p>\n<p style=\"text-align: justify;\"><em>Atordoar:</em> a criatura fica atordoada por 2d4 rodadas. Se passar no teste de resist&ecirc;ncia, fica desprevenida por 1d4 rodadas e n&atilde;o pode mais ser atordoada por esta magia at&eacute; o final da cena.</p>\n<p style=\"text-align: justify;\"><em>Cegar:</em> a criatura fica cega. Se passar no teste de resist&ecirc;ncia, fica ofuscada por 1d4 rodadas.</p>\n<p style=\"text-align: justify;\"><em>Matar:</em> a criatura morre. Al&eacute;m do teste de Vontade, a criatura tem direito a um teste de Fortitude. Se passar em qualquer um deles, em vez de morrer sofre 10d8 pontos de dano de trevas e fica sangrando.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura com menos níveis que você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["10d8",""]]}],"tipo":"uni","circulo":"5","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"VaWZMPwg38tEE3WI","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/palavra-primordial.webp","label":"Palavra Primordial","origin":"Item.LsXNnIjmOUAakYvc","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.im1XyxghVkmJkTvG"}}}
{"_id":"eJcIYwz9CthoWZs4","name":"Luz","type":"magia","img":"systems/tormenta20/icons/magias/luz.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">O alvo emite luz (mas não produz calor) em uma área com 6m de raio. O objeto pode ser guardado (em um bolso, por exemplo) para interromper a luz, que voltará a funcionar caso o objeto seja revelado. Se lançar a magia num objeto de uma criatura involuntária, ela tem direito a um teste de Vontade para anulá-la. Luz anula Escuridão.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 objeto","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula (veja texto)"},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"nIsSvxFoRrmtfp6z","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a área iluminada em +3m de raio.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false},{"_id":"KRvojx6noeqkJxJk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false},{"_id":"7KDug58inXFQQMT1","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","mode":5,"value":"permanente"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para permanente e adiciona componente material (pó de rubi no valor de T$ 50). Não pode ser usado em conjunto com outros aprimoramentos. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false,"tint":null},{"_id":"oslZtVKDDldJmscs","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"0","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"alvo","mode":5,"value":"1 criatura"},{"key":"condicao","mode":0,"value":"ofuscado"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"(Apenas Arcanos): muda o alvo para 1 criatura. Você lança a magia nos olhos do alvo, que fica ofuscado pela cena. Não afeta criaturas cegas.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false,"tint":null},{"_id":"dkpWcFdFcEIDPSno","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"longo","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"(Apenas Arcanos): muda o alcance para longo e o efeito para 4 esferas brilhantes. Cria esferas flutuantes de pura luz com 10cm de diâmetro, que você pode posicionar onde quiser dentro do alcance. Você pode enviar uma esfera à frente, outra para trás, outra para cima e manter uma perto de você, por exemplo. Uma vez por rodada, você pode mover as esferas com uma ação livre. Cada esfera ilumina como uma tocha, mas não produz calor. Se uma esfera ocupar o espaço de uma criatura, ela fica ofuscada e sua silhueta pode ser vista claramente (ela não recebe camuflagem por escuridão ou invisibilidade). Requer 2º círculo.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false},{"_id":"VxwlL97aX68Or39x","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"condicao","value":"sangrando","mode":0},{"key":"condicao","value":"ofuscado","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"(Apenas Divinos): a luz é cálida como a do sol. Criaturas que sofrem penalidades e dano pela luz solar sofrem seus efeitos como se estivessem expostos à luz solar real. Dentro da área seus aliados estabilizam automaticamente e ficam imunes à condição sangrando, e seus inimigos ficam ofuscados. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false},{"_id":"tQHnpvyJS0vl2uFM","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"(Apenas Divinos): muda o alcance para toque e o alvo para 1 criatura. Em vez do normal, o alvo é envolto por um halo de luz, recebendo +10 em testes de Diplomacia e resistência a trevas 10. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.eJcIYwz9CthoWZs4","transfer":false},{"_id":"eyY7FuUylx3DS7xm","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/luz.webp","label":"Luz","origin":"Item.qLssdCORvk0ecwDY","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"HxIVQteBUkZKv4FE","changes":[{"key":"data.pericias.dipl.bonus","mode":2,"value":"10"},{"key":"data.tracos.resistencias.trevas.value","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/luz.webp","label":"Luz (Aprimoramento +5 PM)","origin":"Item.qLssdCORvk0ecwDY","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.QEj7zsYRk2YJhEC7"}}}
{"_id":"eXSBd4j6jFuwbKIc","name":"Compreensão","type":"magia","img":"systems/tormenta20/icons/magias/compreensao.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Essa magia lhe confere compreens&atilde;o sobrenatural. Voc&ecirc; pode tocar um texto e entender as palavras mesmo que n&atilde;o conhe&ccedil;a o idioma. Se tocar numa criatura inteligente, pode se comunicar com ela mesmo que n&atilde;o tenham um idioma em comum. Se tocar uma criatura n&atilde;o inteligente, como um animal, pode perceber seus sentimentos.</p>\n<p style=\"text-align: justify;\">Voc&ecirc; tamb&eacute;m pode gastar uma a&ccedil;&atilde;o de movimento para ouvir os pensamentos de uma criatura tocada (voc&ecirc; &ldquo;ouve&rdquo; o que o alvo est&aacute; pensando), mas um alvo involunt&aacute;rio tem direito a um teste de Vontade para proteger seus pensamentos e evitar este efeito.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura ou texto","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula (veja descrição)"},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"2zsNjoDTTGB97S1p","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto.","origin":"Compendium.tormenta20.magias.eXSBd4j6jFuwbKIc","transfer":false},{"_id":"wbLOZj8sTbPSh6nm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas. Você pode entender todas as criaturas afetadas, mas só pode ouvir os pensamentos de uma por vez.","origin":"Compendium.tormenta20.magias.eXSBd4j6jFuwbKIc","transfer":false},{"_id":"WtC8qOvCluWhx5AI","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura. Em vez do normal, pode vasculhar os pensamentos do alvo para extrair informações. O alvo tem direito a um teste de Vontade para anular este efeito. O mestre decide se a criatura sabe ou não a informação que você procura. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.eXSBd4j6jFuwbKIc","transfer":false},{"_id":"uWVD2weIEPNZX6Nc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal e o alvo para você. Em vez do normal, você pode falar, entender e escrever qualquer idioma. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.eXSBd4j6jFuwbKIc","transfer":false},{"_id":"iuCXDUnY10pFsaW6","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/compreensao.webp","label":"Compreensão","origin":"Item.3srl2yMG0BgfmdnO","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.haLYHZ0Je0Bsh9iS"},"cf":null}}
{"_id":"esdCmrww2lzzzFlh","name":"Cólera do Deus-Sol","type":"magia","img":"systems/tormenta20/icons/magias/colera-do-deus-sol.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; cria uma explos&atilde;o de luz dourada e intensa. Criaturas na &aacute;rea ficam cegas por 1d4 rodadas, pegam fogo e sofrem 10d6 pontos de dano de fogo (mortos-vivos sofrem 10d8 pontos de dano). Uma criatura que passe no teste de resist&ecirc;ncia n&atilde;o fica cega, n&atilde;o pega fogo e sofre metade do dano.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"5","units":"inst","special":"5 rodadas","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"esfera com 6m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Reflexos Parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["10d6",""]]}],"tipo":"div","circulo":"4","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"UglztrTC1qB5IpkP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"2d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6 (+2d8 contra mortos-vivos).","origin":"Compendium.tormenta20.magias.esdCmrww2lzzzFlh","transfer":false,"tint":null},{"_id":"eGij8finUlD6XyBy","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a área em +6m de raio.","origin":"Compendium.tormenta20.magias.esdCmrww2lzzzFlh","transfer":false},{"_id":"e3iSuuFS42kjJ3Cb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"a luz purificadora do Deus-Sol dissipa todas as magias de necromancia ativas na área. Requer 5º círculo","origin":"Compendium.tormenta20.magias.esdCmrww2lzzzFlh","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.fV9U9iuEgCBRv2lI"}}}
{"_id":"f5swL7i71uhFJ8UE","name":"Suporte Ambiental","type":"magia","img":"systems/tormenta20/icons/magias/suporte-ambiental.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia garante a sobrevivência em ambientes hostis. O alvo fica imune aos efeitos de calor e frio extremos, pode respirar na água se respirar ar (ou vice-versa) e não sufoca em fumaça densa.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"02eRj9Zr9055gT01","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.f5swL7i71uhFJ8UE","transfer":false},{"_id":"QPJqACutyPpbXUho","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/suporte-ambiental.webp","label":"Suporte Ambiental","origin":"Item.25kLeEX233C6MjvL","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.uiBJzcQuUeLqN0Qq"},"cf":null}}
{"_id":"fOtHLMKZGMFEgSsT","name":"Ligação Telepática","type":"magia","img":"systems/tormenta20/icons/magias/ligacao-telepatica.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você cria um elo mental entre duas criaturas com Inteligência 3 ou maior (você pode ser uma delas). As criaturas podem se comunicar independente de idioma ou distância, mas não em mundos diferentes.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"2 criaturas voluntárias","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"b4u7QIBaHFQ2BZBZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.fOtHLMKZGMFEgSsT","transfer":false},{"_id":"OCtwpi8UMs93xwSt","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura. Em vez do normal, você cria um elo mental que permite que você veja e ouça pelos sentidos da criatura, se gastar uma ação de movimento. Uma criatura involuntária pode fazer um teste de Vontade para suprimir a magia por uma hora. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.fOtHLMKZGMFEgSsT","transfer":false},{"_id":"2uezfZ2hiCwgaNgN","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/ligacao-telepatica.webp","label":"Ligação Telepática","origin":"Item.Ba97gKikgZPILIju","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.H5pPo6oVQkupWarO"}}}
{"_id":"fQ3D9t4VPsVjLbz1","name":"Camuflagem Ilusória","type":"magia","img":"systems/tormenta20/icons/magias/camuflagem-ilusoria.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">O alvo fica com sua imagem nublada, como se vista através de um líquido, recebendo os efeitos de camuflagem.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"car","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"KLQsMwsmxz7baXdx","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"a imagem do alvo fica mais distorcida, oferecendo camuflagem total.","origin":"Compendium.tormenta20.magias.fQ3D9t4VPsVjLbz1","transfer":false},{"_id":"pKglQPDURDrJqLE4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.fQ3D9t4VPsVjLbz1","transfer":false},{"_id":"f1LcNebKj8pv5Ljc","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/camuflagem-ilusoria.webp","label":"Camuflagem Ilusória","origin":"Item.pZNwli327h2aW39A","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.qF2MlZAfalfNVmEs"},"cf":null}}
{"_id":"fmGirvluTr0RMZvE","name":"Rogar Maldição","type":"magia","img":"systems/tormenta20/icons/magias/rogar-maldicao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você entoa cânticos maléficos que amaldiçoam uma vítima, criando efeitos variados. Ao lançar a magia, escolha entre os seguintes.</p><p style=\"text-align:justify;\"><i>Debilidade:</i> o alvo fica esmorecido e não pode se comunicar ou lançar magias. Ainda reconhece seus aliados e pode segui-los e ajudá-los, mas sempre de maneira simplória.</p><p style=\"text-align:justify;\"><i>Doença:</i> muda a duração para instantânea. O alvo contrai uma doença a sua escolha, que o afeta imediatamente (sem período de incubação).</p><p style=\"text-align:justify;\"><i>Fraqueza:</i> o alvo fica debilitado e lento.</p><p style=\"text-align:justify;\"><i>Isolamento:</i> o alvo perde o uso de um de seus cinco sentidos a sua escolha. Se perder a visão, fica cego. Se perder a audição, fica surdo. Se perder o olfato ou paladar, não pode usar a habilidade faro. Se perder o tato, fica caído e não pode se levantar.</p><p style=\"text-align:justify;\">Você também pode inventar sua própria maldição, usando esses exemplos como sugestões, mas o mestre tem a palavra final sobre o efeito.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude anula"},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"zovWBmCLN6OBfU6r","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de efeitos que você pode escolher em +1. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.fmGirvluTr0RMZvE","transfer":false},{"_id":"pytnNK29OELS0vL8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"duracao","value":"permanente","mode":5},{"key":"resistencia","value":"Fortitude parcial","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para permanente e resistência para Fortitude parcial. Se passar, a criatura ainda sofre os efeitos da maldição, mas por 1 rodada. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.fmGirvluTr0RMZvE","transfer":false},{"_id":"VXbH5U30whHzR915","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/rogar-maldicao.webp","label":"Rogar Maldição","origin":"Item.wBOSJGFrFzX79Lxz","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.AymOW8jXPkeflXUi"}}}
{"_id":"g48EeeYhek5Wh5Ll","name":"Leque Cromático","type":"magia","img":"systems/tormenta20/icons/magias/leque-cromatico.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Um cone de luzes brilhantes surge a partir das suas m&atilde;os, deixando as criaturas na &aacute;rea atordoadas por 1 rodada e ofuscadas pela cena. Caso passem na resist&ecirc;ncia, n&atilde;o ficam atordoadas e n&atilde;o podem mais ser atordoadas por esta magia at&eacute; o fim&nbsp;da cena. Esta magia afeta apenas criaturas de ND 2 ou menor e n&atilde;o afeta criaturas cegas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"cone de  4,5 metros","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"uePHR4uObPuqI2va","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a duração do efeito em +1 rodada.","origin":"Compendium.tormenta20.magias.g48EeeYhek5Wh5Ll","transfer":false},{"_id":"jQmTpSkGboy8hYWX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 5 ou menor. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.g48EeeYhek5Wh5Ll","transfer":false},{"_id":"EzD4s83A7fyffuFS","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 10 ou menor. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.g48EeeYhek5Wh5Ll","transfer":false},{"_id":"km15FEP8zvdOITwE","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 15 ou menor. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.g48EeeYhek5Wh5Ll","transfer":false},{"_id":"XGutsmC6Tm8brUAt","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de qualquer ND. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.g48EeeYhek5Wh5Ll","transfer":false},{"_id":"Htr7D9DLeTYoJMah","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/leque-cromatico.webp","label":"Leque Cromático","origin":"Item.aUvSqSllFALQh4kY","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.HDEibR9EGszmWbQ2"}}}
{"_id":"gUp6Pm0Bf4WTUcSA","name":"Controlar Madeira","type":"magia","img":"systems/tormenta20/icons/magias/controlar-madeira.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você molda, retorce, altera ou repele madeira. Ao lançar a magia, escolha.</p><p style=\"text-align:justify;\"><i>Fortalecer:</i> deixa o alvo mais resistente. Armas têm seu dano aumentado em um passo. Escudos têm seu bônus de Defesa aumentado em +2. Além disso, esses e outros itens de madeira recebem +5 na RD e dobram seus PV.</p><p style=\"text-align:justify;\"><i>Modelar:</i> muda a forma do alvo. Pode transformar um galho em espada, criar uma porta onde antes havia apenas uma parede, transformar um tronco em uma caixa... Mas não pode criar mecanismos complexos (como uma besta) ou itens consumíveis.</p><p style=\"text-align:justify;\"><i>Repelir:</i> o alvo é repelido por você. Se for uma arma, ataques feitos com ela contra você falham automaticamente. Se for uma porta ou outro objeto que possa ser aberto, ele vai se abrir quando você se aproximar, mesmo que esteja trancado. Uma carroça ou outro objeto que vá atingi-lo, como um tronco caindo ou barril, vai desviar ou simplesmente parar adjacente a você, sem lhe causar dano. Os efeitos de regras em outros objetos de madeira ficam a cargo do mestre.</p><p style=\"text-align:justify;\"><i>Retorcer:</i> torna o alvo imprestável. Uma porta emperra (exigindo um teste de Força contra CD 25 para ser aberta). Armas e itens retorcidos impõem uma penalidade de –2 em testes de perícia. Escudos retorcidos deixam de oferecer qualquer bônus (mas ainda impõem penalidades). Um barco retorcido começa a afundar e naufraga ao final da cena. Os efeitos de regras em outros objetos de madeira ficam a cargo do mestre.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1objeto de madeira grande ou menor","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"u7sTLX49eZCIU8JA","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5},{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal, o alvo para você e a duração para 1 dia. Você e seu equipamento se transformam em uma árvore de tamanho Grande. Nessa forma, você não pode falar ou fazer ações físicas, mas consegue perceber seus arredores normalmente. Se for atacado nessa forma, a magia é dissipada. Um teste de Sobrevivência (CD 30) revela que você não é uma árvore verdadeira.","origin":"Compendium.tormenta20.magias.gUp6Pm0Bf4WTUcSA","transfer":false},{"_id":"fwMTgwpZsj9p70EF","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"área de quadrado com 9m de lado","mode":5},{"key":"duracao","value":"Cena","mode":5},{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para área de quadrado com 9m de lado e a duração para cena. Em vez do normal, qualquer vegetação na área fica rígida e afiada. A área é considerada terreno difícil e criaturas que andem nela sofrem 1d6 pontos de dano de corte para cada 1,5m que avancem.","origin":"Compendium.tormenta20.magias.gUp6Pm0Bf4WTUcSA","transfer":false},{"_id":"z0mX6DxMh5Tqk7QT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[{"key":"alvo","value":"objeto de madeira Enorme ou menor","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para objeto de madeira Enorme ou menor. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.gUp6Pm0Bf4WTUcSA","transfer":false},{"_id":"N0YtJafRzUYattiZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"alvo","value":"objeto de madeira Colossal ou menor","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para objeto de madeira Colossal ou menor. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.gUp6Pm0Bf4WTUcSA","transfer":false},{"_id":"pg3ytn3Qnn1d18L6","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/controlar-madeira.webp","label":"Fortalecer (Escudo)","origin":"Item.GeWD5R8BQOslV31K","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"dC4PhTM0FoTZIXqq","changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"-2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/controlar-madeira.webp","label":"Retorcer (Penalidade)","origin":"Item.GeWD5R8BQOslV31K","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Rp0pQaJ0DrJeAeTl"}}}
{"_id":"gcjCsjzpk2OtClSt","name":"Bola de Fogo","type":"magia","img":"systems/tormenta20/icons/magias/bola-de-fogo.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta famosa magia de ataque cria uma poderosa explosão, causando 6d6 pontos de dano de fogo em todas as criaturas e objetos livres na área.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"6d6","alcance":"medium","alvo":"","area":"esfera com 6m de raio","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["6d6",""]]}],"tipo":"arc","circulo":"2","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"UWydlNbe3IFFWSmJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"2d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +2d6.","origin":"Compendium.tormenta20.magias.gcjCsjzpk2OtClSt","transfer":false},{"_id":"54Cbq85qzDbWg4SB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"area","value":"efeito de esfera flamejante com tamanho Médio","mode":5},{"key":"duracao","value":"Cena","mode":5},{"key":"dano","value":"3d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para efeito de esfera flamejante com tamanho Médio e a duração para cena. Em vez do normal, cria uma esfera flamejante com 1,5m de diâmetro que causa 3d6 pontos de dano a qualquer criatura no mesmo espaço. Você pode gastar uma ação de movimento para fazer a esfera voar 9m em qualquer direção. Ela é imune a dano, mas pode ser apagada com água. Uma criatura só pode sofrer dano da esfera uma vez por rodada.","origin":"Compendium.tormenta20.magias.gcjCsjzpk2OtClSt","transfer":false},{"_id":"EOLJ5ChVkU6V1DAg","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","mode":5,"value":"1 dia ou até ser descarregada"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia ou até ser descarregada. Em vez do normal, você cria uma pequena pedra flamejante, que pode detonar como uma reação, descarregando a magia. A pedra pode ser usada como uma arma de arremesso com alcance curto. Uma vez detonada, causa o dano da magia numa área de esfera de 6m de raio.","origin":"Compendium.tormenta20.magias.gcjCsjzpk2OtClSt","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.LSj3INZ0KooRr5bs"}}}
{"_id":"h98JyQAldmgexmzR","name":"Visão da Verdade","type":"magia","img":"systems/tormenta20/icons/magias/visao-da-verdade.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você enxerga a forma real das coisas. Você pode ver através de camuflagem (normal e total), escuridão (normal e mágica) e efeitos de ilusão e transmutação (enxergando a verdade como formas translúcidas ou sobrepostas).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"4","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"BWFXuE9D8h1DWj67","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.h98JyQAldmgexmzR","transfer":false},{"_id":"l3aogOkppbIgUFgD","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.pericias.perc.bonus","mode":2,"value":"10"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo fica com sentidos apurados; ele recebe +10 em todos os testes de Percepção.","origin":"Compendium.tormenta20.magias.h98JyQAldmgexmzR","transfer":false,"tint":null},{"_id":"W0nnBmflVSGSVySF","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.pericias.intu.bonus","mode":2,"value":"10"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo escuta falsidades; ele recebe +10 em todos os testes de Intuição.","origin":"Compendium.tormenta20.magias.h98JyQAldmgexmzR","transfer":false,"tint":null},{"_id":"FQkmvLSsOHYIA1Lu","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo enxerga através de paredes e barreiras com 30cm de espessura ou menos (as paredes e barreiras parecem translúcidas).","origin":"Compendium.tormenta20.magias.h98JyQAldmgexmzR","transfer":false},{"_id":"kcliNEvn1MIfvLBt","changes":[{"key":"data.pericias.perc.bonus","mode":2,"value":"0"},{"key":"data.pericias.intu.bonus","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/visao-da-verdade.webp","label":"Visão da Verdade","origin":"Item.5GWVq233XBgX05To","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.JFk9tvOtPkiZzYh2"}}}
{"_id":"hJ7eYMyWFf0i1jBn","name":"Ligaçao Sombria","type":"magia","img":"systems/tormenta20/icons/magias/ligacao-sombria.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Cria uma conexão entre seu corpo e o da criatura alvo, deixando uma marca idêntica na pele de ambos. Enquanto a magia durar, sempre que você sofrer qualquer dano ou condição, o alvo desta magia deve fazer um teste de Fortitude; se falhar, sofre o mesmo dano que você ou adquire a mesma condição. A magia termina se o alvo chegar a 0 pontos de vida.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 dia","units":"special","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude anula"},"rolls":[],"tipo":"div","circulo":"4","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"1CIyRJBmaEBhQQZl","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo também pode morrer por perda de PV ou se você morrer (um teste de Fortitude anula a morte).","origin":"Compendium.tormenta20.magias.hJ7eYMyWFf0i1jBn","transfer":false},{"_id":"eutYN40NmTDMBA76","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/ligacao-sombria.webp","label":"Ligaçao Sombria","origin":"Item.MaQpWm7kCs0Ns5jo","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.7tg5XIwHI0SN8NCz"}}}
{"_id":"hikpz9g3jwJoTcRZ","name":"Raio do Enfraquecimento","type":"magia","img":"systems/tormenta20/icons/magias/raio-do-enfraquecimento.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você dispara um raio púrpura que drena as forças do alvo. Se falhar na resistência, o alvo fica fatigado. Se passar, fica vulnerável.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"h9YSgDixO3JIQakZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"resistencia","value":"Fortitude anula","mode":5},{"key":"condicao","value":"fatigado","mode":0},{"key":"condicao","value":"exausto","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e a resistência para Fortitude anula. Em vez do normal, ao tocar o alvo, sua mão emana um brilho púrpura. O alvo fica fatigado. Note que, como efeitos de magia não acumulam, lançar este truque duas vezes contra o mesmo alvo não irá deixá-lo exausto.","origin":"Compendium.tormenta20.magias.hikpz9g3jwJoTcRZ","transfer":false},{"_id":"Mxv1Ddofr1ILIZ7n","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"condicao","value":"exausto","mode":0},{"key":"condicao","value":"fatigado","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, se falhar na resistência o alvo fica exausto. Se passar, fica fatigado. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.hikpz9g3jwJoTcRZ","transfer":false},{"_id":"k2YDfSRA8tF21vZB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"condicao","value":"inconsciente","mode":0},{"key":"condicao","value":"exausto","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, se falhar na resistência o alvo fica inconsciente. Se passar, fica exausto. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.hikpz9g3jwJoTcRZ","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.JfNM4D7BR0mPG1zh"}}}
{"_id":"hyrMxy1zmRDWJbmB","name":"Manto do Cruzado","type":"magia","img":"systems/tormenta20/icons/magias/manto-do-cruzado.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você invoca a energia sagrada de sua divindade na forma de um manto de energia sólida que reveste seu corpo. Esta magia tem duas versões. Você escolhe qual versão pode lançar quando aprende esta magia. Ela não pode ser mudada.</p><p style=\"text-align:justify;\"><i>Manto de Luz:</i> um manto dourado e luminoso. No início de cada um de seus turnos, você e todos os seus aliados em alcance curto recuperam 2d8 PV. Você fica imune a dano de trevas e seus ataques corpo a corpo causam +2d8 pontos de dano de luz.</p><p style=\"text-align:justify;\"><i>Manto de Trevas:</i> um manto negro como a noite. No início de cada um de seus turnos, todos os inimigos em alcance curto sofrem 2d8 pontos de dano de trevas. Você cura metade de todo o dano causado pela magia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"vocẽ","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"4","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"tpVQeMpu7R1uub2U","changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"2d8"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/manto-do-cruzado.webp","label":"Manto de Luz","origin":"Item.rayAzLYgDBfc2cvv","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"GIvosxSBsp5Xd9Be","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/manto-do-cruzado.webp","label":"Manto de Trevas","origin":"Item.rayAzLYgDBfc2cvv","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.c1OvRgidkUKf383j"}}}
{"_id":"iHOlYjBeNhqDVYbQ","name":"Manto de Sombras","type":"magia","img":"systems/tormenta20/icons/magias/manto-de-sombras.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você fica coberto por um manto de energia sombria. Nesta forma, torna-se incorpóreo (inclui seu equipamento): só pode ser afetado por armas mágicas, magias ou outras criaturas incorpóreas e pode atravessar objetos sólidos, mas não manipulá-los. Contudo, se torna vulnerável à luz direta: se exposto a uma fonte de luz, sofre 1 ponto de dano por rodada.</p><p style=\"text-align:justify;\">Você pode gastar uma ação de movimento e 1 PM para “entrar” em uma sombra do seu tamanho ou maior e se teletransportar para outra sombra, também do seu tamanho ou maior, em alcance médio.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"TRhjtRauX2pys3Dz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para 1 criatura. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.iHOlYjBeNhqDVYbQ","transfer":false},{"_id":"uzz47NJXJQyyN3n1","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/manto-de-sombras.webp","label":"Manto de Sombras","origin":"Item.17Vdl7dStTWnjAZY","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.ah80wZBkSqnDO35i"}}}
{"_id":"iHW9iWhl7DYu3ggt","name":"Servo Divino","type":"magia","img":"systems/tormenta20/icons/magias/servo-divino.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você pede a sua divindade que envie um espírito para ajudá-lo. Esse espírito realiza uma tarefa a sua escolha que possa ser cumprida em até uma hora — desde algo simples como “use suas asas para nos levar até o topo da montanha” até algo complexo como “escolte esses camponeses até o castelo”. A magia é descarregada quando a criatura cumpre a tarefa, retornando a seu plano natal. O tipo de criatura é escolhido pelo mestre, de acordo com as necessidades da tarefa.</p><p style=\"text-align:justify;\"><i>Componente material:</i> um pagamento de T$ 100 ao espírito. A forma de pagamento varia — doações a um templo, um item mágico ou mesmo dinheiro.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"cena ou até ser descarregada","units":"special","special":"Cena ou até ser descarregada","valor":"cena ou até ser descarregada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"criatura conjurada","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"vqD2IOqb07ojo0el","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia ou até ser descarregada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia ou até ser descarregada. O espírito realiza uma tarefa a sua escolha que exija até um dia. O custo do pagamento aumenta para T$ 500. O resto segue normal.","origin":"Compendium.tormenta20.magias.iHW9iWhl7DYu3ggt","transfer":false},{"_id":"FQ43qgzKHiNWmojm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"duracao","value":"1 semana ou até ser descarregada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 semana ou até ser descarregada. O espírito realiza uma tarefa que exija até uma semana. O custo do pagamento aumenta para T$ 1.000. O resto segue normal.","origin":"Compendium.tormenta20.magias.iHW9iWhl7DYu3ggt","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.rBZanV8JUOj8yQOc"}}}
{"_id":"irVr5pJiREIGsiUe","name":"Heroísmo","type":"magia","img":"systems/tormenta20/icons/magias/heroismo.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia imbui uma criatura com coragem e valentia. O alvo fica imune a medo e recebe +4 em testes de ataque e rolagens de dano contra inimigos com ND maior que seu nível.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"M1s8bLjkyjxCetDN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"2"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"2"},{"key":"data.modificadores.dano.geral","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o bônus para +6.","origin":"Compendium.tormenta20.magias.irVr5pJiREIGsiUe","transfer":false,"tint":null},{"_id":"ShTxB5z4GbrqS05H","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"4"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"4"},{"key":"data.modificadores.dano.geral","mode":2,"value":"4"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/heroismo.webp","label":"Heroísmo","origin":"Item.O8DXn4NTdhicWYho","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.3bUHZjJXt0G1rRo4"}}}
{"_id":"ji7Bn9t7lk8zyNN1","name":"Pele de Pedra","type":"magia","img":"systems/tormenta20/icons/magias/pele-de-pedra.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Sua pele ganha aspecto e dureza de rocha. Você recebe resistência a dano 5.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"qwR1O4qpIh6U5OWW","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.ji7Bn9t7lk8zyNN1","transfer":false},{"_id":"DXgPVubZdLV3aTN3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia.","origin":"Compendium.tormenta20.magias.ji7Bn9t7lk8zyNN1","transfer":false},{"_id":"VwRKNwnkPMpXybdU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"5"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"sua pele ganha aspecto e dureza de aço. Você recebe resistência a dano 10. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.ji7Bn9t7lk8zyNN1","transfer":false,"tint":null},{"_id":"mf74wJb7svFGeyZ9","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5},{"key":"duracao","value":"1d4 rodadas","mode":5},{"key":"dano","value":"1d4","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque, o alvo para 1 criatura, a duração para 1d4 rodadas e adiciona Resistência: Fortitude anula. Em vez do efeito normal, a magia transforma o alvo e seu equipamento em uma estátua inerte e sem consciência. A estátua possui os mesmos PV da criatura e resistência a dano 8; se for quebrada, a criatura morrerá. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.ji7Bn9t7lk8zyNN1","transfer":false},{"_id":"I7FQWn0XQH6kK16v","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"como acima, mas com duração permanente. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.ji7Bn9t7lk8zyNN1","transfer":false},{"_id":"cinVV4iNTLHUtqi2","changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/pele-de-pedra.webp","label":"Pele de Pedra","origin":"Item.jxKpBUL3sbIg9gT1","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"meLMHVbPN4Rbicll","changes":[{"key":"data.tracos.resistencias.dano.value","mode":2,"value":"8"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/pele-de-pedra.webp","label":"Estátua","origin":"Item.jxKpBUL3sbIg9gT1","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.F5BAqRoj0aNAESXV"}}}
{"_id":"k8E2gbV1NwkI0ehs","name":"Primor Atlético","type":"magia","img":"systems/tormenta20/icons/magias/primor-atletico.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você modifica os limites físicos do alvo, que recebe deslocamento +9m e +10 em testes de Atletismo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"LEvqHCa0eJeVujQF","flags":{"t20":null,"tormenta20":{"onuse":true,"self":false,"custo":"1","aumenta":false,"skill":true,"attack":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"roll","mode":2,"value":"20"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo recebe um bônus adicional de +20 em testes de Atletismo para saltar (para um bônus total de +30).","origin":"Compendium.tormenta20.magias.k8E2gbV1NwkI0ehs","transfer":true,"tint":null},{"_id":"7RahEjc2OLqC74lr","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"condicao","value":"desprevenido","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, o alvo pode escalar paredes e tetos sem precisar fazer testes de Atletismo. Para isso, precisa estar com as mãos livres, mas pode usar uma única mão se ficar parado no lugar. O alvo não fica desprevenido enquanto escala.","origin":"Compendium.tormenta20.magias.k8E2gbV1NwkI0ehs","transfer":false},{"_id":"v3rAhsAcv5vyGxuA","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"execucao","value":"Movimento","mode":5},{"key":"alcance","value":"pessoal","mode":5},{"key":"alvo","value":"você","mode":5},{"key":"duracao","value":"instantânea","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação de movimento, o alcance para pessoal, o alvo para você e a duração para instantânea. Você salta muito alto e pousa em alcance corpo a corpo de uma criatura em alcance curto. Se fizer um ataque corpo a corpo contra essa criatura nesta rodada, recebe os benefícios e penalidades de uma investida e sua arma tem o dano aumentado em um dado do mesmo tipo durante este ataque.","origin":"Compendium.tormenta20.magias.k8E2gbV1NwkI0ehs","transfer":false},{"_id":"xl42D6i5Tb1fGlXb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, ao fazer testes de perícias baseadas em Força, Destreza ou Constituição, o alvo pode rolar dois dados e escolher o melhor. Não afeta testes de ataque ou resistência. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.k8E2gbV1NwkI0ehs","transfer":false},{"_id":"sx6R5Ibto2BmCPYe","changes":[{"key":"data.attributes.movement.walk","mode":2,"value":"9"},{"key":"data.pericias.atle.bonus","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/primor-atletico.webp","label":"Primor Atlético","origin":"Item.Nmw9vLzCvl0bHvZE","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.29Lo3dTU8EKzqreW"},"cf":null}}
{"_id":"kTzPm7Dy3UqZNli8","name":"Aviso","type":"magia","img":"systems/tormenta20/icons/magias/aviso.webp","data":{"description":{"value":"<p>Envia um aviso telep&aacute;tico para uma criatura, mesmo que n&atilde;o possa v&ecirc;-la nem tenha linha de efeito.</p>\n<p>Escolha um:</p>\n<p>Alerta: o alvo recebe +5 em seu pr&oacute;ximo teste de Iniciativa e de Percep&ccedil;&atilde;o dentro da cena.</p>\n<p>Mensagem: o alvo recebe uma mensagem sua de at&eacute; 25 palavras. Voc&ecirc;s devem ter um idioma em comum para o alvo poder entend&ecirc;-lo.</p>\n<p>Localiza&ccedil;&atilde;o: o alvo sabe onde voc&ecirc; est&aacute; naquele momento. Se voc&ecirc; mudar de posi&ccedil;&atilde;o, ele n&atilde;o saber&aacute;.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"move","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"instantâneo","units":"special","special":"","valor":"instantâneo","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"1","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"Yhot21vYrR3vKU8d","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o alcance em um fator de 10 (90m para 900m, 900m para 9km e assim por diante).","origin":"Item.NAiIhVt6LzQAd6JB","tint":null,"transfer":false},{"_id":"Fa13IV0BmrO2Rpcn","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se escolher mensagem, o alvo pode enviar uma resposta de até 25 palavras para você até o fim de seu próximo turno.","origin":"Item.NAiIhVt6LzQAd6JB","transfer":false},{"_id":"ocrf6jCRuVl2F5Uc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se escolher localização, muda a duração para cena. O alvo sabe onde você está mesmo que você mude de posição.","origin":"Item.NAiIhVt6LzQAd6JB","tint":null,"transfer":false},{"_id":"3yk8ibptmBzFMghM","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Item.NAiIhVt6LzQAd6JB","tint":null,"transfer":false},{"_id":"zrrOQECVSy8RNTlj","changes":[{"key":"data.pericias.perc.bonus","mode":2,"value":"5"},{"key":"data.pericias.inic.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":999,"startTime":null},"icon":"modules/modulot20automatizado/assets/modules/moduloguilda/assets/systems/tormenta20/icons/magias/aviso.webp","label":"Aviso (Alerta)","origin":"Item.lH4bKSnFbZQ7hJ2J","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.IR4HtftvUdp76xAc"},"cf":null}}
{"_id":"kgD9swQEhzwDC1tb","name":"Alarme","type":"magia","img":"systems/tormenta20/icons/magias/alarme.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; cria uma barreira protetora invis&iacute;vel que detecta qualquer criatura que tocar ou entrar na &aacute;rea protegida. Ao lan&ccedil;ar a magia, voc&ecirc; pode escolher quais criaturas podem entrar na &aacute;rea sem ativar seus efeitos. Alarme pode emitir um aviso telep&aacute;tico ou sonoro, decidido quando a magia &eacute; lan&ccedil;ada. Um aviso telep&aacute;tico alerta apenas voc&ecirc;, inclusive acordando-o se estiver dormindo, mas apenas se estiver a at&eacute; 1km da &aacute;rea protegida. Um aviso sonoro alerta todas as criaturas em alcance longo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 dia","units":"special","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"Esfera de 9m de raio","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"OYOQjSwW2hUP5Z3n","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"2","durationScene":false,"onuse":true}},"changes":[{"key":"alcance","value":"pessoal","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alcance para pessoal. A área é emanada a partir de você.","origin":"Item.6HxDuhAq9n3tmqTe","tint":null,"transfer":false},{"_id":"bfMpC2zKMn2fxsqt","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"5","durationScene":false,"onuse":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"além do normal, você também percebe qualquer efeito de adivinhação que seja usado dentro da área ou atravesse a área. Você pode fazer um teste oposto de Misticismo contra quem usou o efeito; se passar, tem um vislumbre de seu rosto e uma ideia aproximada de sua localização (“três dias de viagem ao norte”, por exemplo).","origin":"Item.6HxDuhAq9n3tmqTe","tint":null,"transfer":false},{"_id":"Z5HPTpIRymv7xenI","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"9","durationScene":false,"onuse":true}},"changes":[{"key":"duracao","mode":5,"value":"1 dia ou até ser descarregada"},{"key":"resistência","mode":5,"value":"Vontade anula"},{"key":"condicao","mode":0,"value":"Paralisado"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda a duração para 1 dia ou até ser descarregada e a resistência para Vontade anula. Quando um intruso entra na área, você pode descarregar a magia como uma reação. Se o intruso falhar na resistência, ficará paralisado por 1d4 rodadas. Além disso, pelas próximas 24 horas você e as criaturas escolhidas ganham +10 em testes de Sobrevivência para rastrear o intruso.","origin":"Item.6HxDuhAq9n3tmqTe","tint":null,"transfer":false},{"_id":"NXCJVw3Mkl7WfdsC","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/alarme.webp","label":"Alarme","origin":"Item.MqQCNZCfQCg7WIlh","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"aGkwkxy35YEqTAgL","changes":[{"key":"data.pericias.sobr.bonus","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/alarme.webp","label":"Alarme (+10 para rastrear)","origin":"Item.MqQCNZCfQCg7WIlh","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.X1EZvFTsMUrqQ4eJ"}}}
{"_id":"lAsj1NrA2J6GbvDi","name":"Concentração de Combate","type":"magia","img":"systems/tormenta20/icons/magias/concentracao-de-combate.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; amplia sua percep&ccedil;&atilde;o, antecipando movimentos dos inimigos e achando brechas em sua defesa. Quando faz&nbsp;um teste de ataque, voc&ecirc; rola dois dados e usa o melhor resultado</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"free","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 rodada","units":"special","special":"","valor":"1 rodada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"LvHT31M1UBY6eqIL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"execucao","value":"padrão","mode":5},{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para padrão e a duração para cena. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"2XHxvPBjrqijXw9I","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, ao atacar você, um inimigo deve rolar dois dados e usar o pior resultado. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"NrEAsxaqpXAWVZ5d","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"execucao","value":"padrão","mode":5},{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5},{"key":"duracao","value":"Cena","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para padrão, o alcance para curto, o alvo para criaturas escolhidas e a duração para cena. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"Q9xwXkqN6t3iEhBD","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[{"key":"execucao","value":"padrão","mode":5},{"key":"duracao","value":"1 dia","mode":5},{"key":"condicao","value":"surpreendido","mode":0},{"key":"condicao","value":"desprevenido","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para padrão e a duração para 1 dia. Além do normal, você recebe um sexto sentido que o avisa de qualquer perigo ou ameaça. Você fica imune às condições surpreendido e desprevenido e recebe +10 em Defesa e Reflexos. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.lAsj1NrA2J6GbvDi","transfer":false},{"_id":"WxhX0zABmEAJkQ13","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/concentracao-de-combate.webp","label":"Concentração de Combate (Cena)","origin":"Item.jZYdLUCwQx3e9Odi","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"5QruiDpfvtxwupil","changes":[{"key":"data.pericias.refl.bonus","mode":2,"value":"10"},{"key":"data.attributes.defesa.bonus","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/concentracao-de-combate.webp","label":"Concentração de Combate (Aprimoramento +14 PM)","origin":"Item.JbY4RCfiRXJEG8JU","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.1UBi6j1FJdnCdLH1"},"cf":null}}
{"_id":"lGxJ1sVeGzOrEBjP","name":"Segunda Chance","type":"magia","img":"systems/tormenta20/icons/magias/segunda-chance.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Um brilho alaranjado, na forma de asas de fênix, emana do alvo. Ele recupera 200 pontos de vida e se cura de qualquer das seguintes condições: abalado, apavorado, alquebrado, atordoado, cego, confuso, debilitado, enjoado, envenenado, esmorecido, exausto, fascinado, fatigado, fraco, frustrado, lento, ofuscado, paralisado, pasmo ou surdo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Cura","key":"dano0","type":"dano","parts":[["200",""]]}],"tipo":"div","circulo":"5","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"I3oHcP1DmIn6LHYi","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":2,"value":"20"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a cura em +20 PV.","origin":"Compendium.tormenta20.magias.lGxJ1sVeGzOrEBjP","transfer":false,"tint":null},{"_id":"1BVxrSXyv3h9o9X5","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"até 5 criaturas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para até 5 criaturas.","origin":"Compendium.tormenta20.magias.lGxJ1sVeGzOrEBjP","transfer":false},{"_id":"Kg9fAT3uWVkFysDS","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"uma criatura que tenha morrido há até uma rodada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para uma criatura que tenha morrido há até uma rodada. Esta magia pode curá-la","origin":"Compendium.tormenta20.magias.lGxJ1sVeGzOrEBjP","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.J1XLOgbG0Su5ACKN"}}}
{"_id":"lJYJQFhk5oai46Ty","name":"Enfeitiçar","type":"magia","img":"systems/tormenta20/icons/magias/enfeiticar.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia torna o alvo prestativo (veja a página 118). Ele não fica sob seu controle, mas percebe suas palavras e ações da maneira mais favorável possível. Você recebe um bônus de +10 em testes de Diplomacia com a vítima. Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resistência. Se você ou seus aliados tomarem qualquer ação hostil contra o alvo, a magia é dissipada e o alvo retorna à atitude que tinha antes (ou piorada, de acordo com o mestre).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"wuyNqXeAYnTZxLx7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, você sugere uma ação para o alvo e ele obedece. A sugestão deve ser feita de modo que pareça aceitável, a critério do mestre. Pedir ao alvo que pule de um precipício, por exemplo, dissipa a magia. Já sugerir a um guarda que descanse um pouco, de modo que você e seus aliados passem por ele, é aceitável. Quando o alvo executa a ação, a magia termina. Você pode determinar uma condição específica para a sugestão: por exemplo, que um rico mercador doe suas moedas para o primeiro mendigo que encontrar.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"f2WlVQN7BVQNLFG4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito ou monstro","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito ou monstro. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"wFiXySUySfFHMQJQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos dentro do alcance.","origin":"Compendium.tormenta20.magias.lJYJQFhk5oai46Ty","transfer":false},{"_id":"RpeV8bkz5C0z80ze","changes":[{"key":"data.pericias.dipl.bonus","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/enfeiticar.webp","label":"Bônus em Diplomacia","origin":"Item.ahAito9xDqRm0W8H","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"l8esy2GPcIETfxbi","changes":[{"key":"data.pericias.vont.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/enfeiticar.webp","label":"Alvo Hostil","origin":"Item.ahAito9xDqRm0W8H","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.ARP9yn6keaH9aNKt"}}}
{"_id":"m14TgW19d1JTBz8U","name":"Amedrontar","type":"magia","img":"systems/tormenta20/icons/magias/amedrontar.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">O alvo &eacute; envolvido por energias sombrias assustadoras. Se falhar na resist&ecirc;ncia, fica apavorado por 1d4 rodadas, depois abalado. Se passar, fica abalado por 1d4 rodadas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 animal ou humanoide de ND 2 ou menor","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"OciQRYsZfkxrckgc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criatura de ND 2 ou menor.","origin":"Item.dx8QPZrPlrOrzLQU","tint":null,"transfer":false},{"_id":"iywixWPGn64reD5Q","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 5 ou menor. Requer 2o círculo.","origin":"Item.dx8QPZrPlrOrzLQU","tint":null,"transfer":false},{"_id":"8UpVbn31ZXEq8328","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta todos os alvos válidos a sua escolha dentro do alcance.","origin":"Item.dx8QPZrPlrOrzLQU","transfer":false},{"_id":"5S5ALCJBe5NMcrKw","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 10 ou menor. Requer 3o círculo.","origin":"Item.dx8QPZrPlrOrzLQU","transfer":false},{"_id":"5nWntl7vY0fVdm05","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 15 ou menor. Requer 4o círculo.","origin":"Item.dx8QPZrPlrOrzLQU","transfer":false},{"_id":"3b0LC7Mr4KZxkHM4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de qualquer ND. Requer 5o círculo","origin":"Item.dx8QPZrPlrOrzLQU","transfer":false},{"_id":"f4qLZKk0usOOS9yV","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/amedrontar.webp","label":"Amedrontado","origin":"Item.p238CZtFsOfXHxuZ","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.FFmQzSgam5bmfIub"}}}
{"_id":"m93YbVqNnWphT8cp","name":"Selo de Mana","type":"magia","img":"systems/tormenta20/icons/magias/selo-de-mana.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Seu toque manifesta um selo mágico na pele do alvo, que atrapalha o fluxo de mana. Pela duração da magia, sempre que o alvo realizar qualquer ação que gaste PM, deve fazer um teste de Vontade; se passar, faz a ação normalmente. Se falhar, a ação não tem efeito (mas os PM são gastos mesmo assim).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade Parcial"},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"Aq0COlqZ74DfQuAv","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas dentro do alcance","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas dentro do alcance. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.m93YbVqNnWphT8cp","transfer":false},{"_id":"hvYlMwqQIuhvhq2Y","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/selo-de-mana.webp","label":"Selo de Mana","origin":"Item.QLAHX5o9izSriYVU","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.5gepKgj0P01IG4oo"}}}
{"_id":"m9jubp5PK3j2nCFC","name":"Purificação","type":"magia","img":"systems/tormenta20/icons/magias/purificacao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Seu toque purifica a criatura tocada.\nEsta magia remove uma das seguintes condições: abalado, apavorado, alquebrado, atordoado, cego, confuso, debilitado, enjoado, envenenado, esmorecido, exausto, fascinado, fatigado, fraco, frustrado, lento, ofuscado, paralisado, pasmo ou surdo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"ATklm5lmUhDHjZyL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também cura todo o dano causado por venenos.","origin":"Compendium.tormenta20.magias.m9jubp5PK3j2nCFC","transfer":false},{"_id":"a5IZ3BLkdKVTVjXH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez de uma, remove todas as condições listadas.","origin":"Compendium.tormenta20.magias.m9jubp5PK3j2nCFC","transfer":false},{"_id":"eQlPzFnZjH7uIOeY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também permite que o alvo solte qualquer item amaldiçoado que esteja segurando (mas não remove a maldição do item em si).","origin":"Compendium.tormenta20.magias.m9jubp5PK3j2nCFC","transfer":false},{"_id":"dnwZJ5JwixjC5mwT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também dissipa magias e efeitos prejudiciais de encantamento, necromancia e transmutação afetando o alvo. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.m9jubp5PK3j2nCFC","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.GJhchbcAKEWXWHVi"},"cf":null}}
{"_id":"mG617USsDrhcj6Tk","name":"Armamento da Natureza","type":"magia","img":"systems/tormenta20/icons/magias/armamento-da-natureza.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; fortalece uma arma mundana primitiva (sem custo em T$, como bord&atilde;o, clava, funda ou tacape), uma arma natural ou um ataque desarmado. O dano da arma aumenta em um passo e ela &eacute; considerada m&aacute;gica. Ao lan&ccedil;ar a magia, voc&ecirc; pode mudar o tipo de dano da arma (escolhendo entre corte, impacto ou perfura&ccedil;&atilde;o).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 arma (veja texto)","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"bpitZzQKZ4vqJiXI","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"1"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"fornece +1 nos testes de ataque com a arma.","origin":"Item.j12hZf69LhObcibS","transfer":false,"tint":null},{"_id":"Psilqc9kzkJDsroj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"execucao","mode":5,"value":""}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para ação de movimento.","origin":"Item.j12hZf69LhObcibS","transfer":false},{"_id":"oiuYjM78cegM2I18","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"1"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus nos testes de ataque em +1.","origin":"Item.j12hZf69LhObcibS","transfer":false,"tint":null},{"_id":"fNdlwClqGCE484dL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano da arma em mais um passo.","origin":"Item.j12hZf69LhObcibS","transfer":false},{"_id":"5PLkfZAb7QnlPYh1","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"0"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/armamento-da-natureza.webp","label":"Armamento da Natureza (Bônus de Ataque)","origin":"Item.qOXSaAjO4yVPYpiT","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.GMd2abkDfzsmHa6P"}}}
{"_id":"mQeWRsFwBWENaVeD","name":"Acalmar Animal","type":"magia","img":"systems/tormenta20/icons/magias/acalmar-animal.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">O animal fica prestativo em rela&ccedil;&atilde;o a voc&ecirc;. Ele n&atilde;o fica sob seu controle, mas percebe suas palavras e a&ccedil;&otilde;es da maneira mais favor&aacute;vel poss&iacute;vel. Voc&ecirc; recebe +10 nos testes de Adestramento e Diplomacia que fizer contra o animal.</p>\n<p style=\"text-align: justify;\">Um alvo hostil ou que esteja envolvido em um combate recebe +5 em seu teste de resist&ecirc;ncia. Se voc&ecirc; ou seus aliados tomarem qualquer a&ccedil;&atilde;o hostil contra o alvo, a magia &eacute; dissipada e ele retorna &agrave; atitude que tinha antes (ou piorada, de acordo com o mestre). Se tratar bem o alvo, a atitude pode permanecer mesmo ap&oacute;s o t&eacute;rmino da magia.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 animal","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"IFsWkZiplumHPzOu","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"1","durationScene":false,"onuse":true}},"changes":[{"key":"alcance","value":"médio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alcance para médio.","origin":"Item.uQOZKckUmRrVHgIS","tint":null,"transfer":false},{"_id":"UhozPblJ0Hv6mhCA","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"1","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"1 monstro ou espírito com Inteligência 1 ou 2.","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alvo para 1 monstro ou espírito com Inteligência 1 ou 2.","origin":"Item.uQOZKckUmRrVHgIS","tint":null,"transfer":false},{"_id":"8TDoOR0QqftWHvjK","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"2","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"1","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"aumenta o número de alvos em +1.","origin":"Item.uQOZKckUmRrVHgIS","tint":null,"transfer":false},{"_id":"9bY0f5WMRIYhgsiY","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"5","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"1 monstro ou espírito.","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alvo para 1 monstro ou espírito. Requer 3o círculo.","origin":"Item.uQOZKckUmRrVHgIS","tint":null,"transfer":false},{"_id":"rruGYEasKqs9DiE9","changes":[{"key":"data.pericias.ades.bonus","mode":2,"value":"10"}],"disabled":false,"duration":{"rounds":99,"startTime":null},"icon":"systems/tormenta20/icons/magias/acalmar-animal.webp","label":"Acalmar Animal (Bônus de +10)","origin":"Item.p3Ytw7UhxzS0NWKX","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.SLFkHSHeOfTdtfrF"},"cf":null}}
{"_id":"mp25mjirts0eMdlQ","name":"Aura Divina","type":"magia","img":"systems/tormenta20/icons/magias/aura-divina.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; se torna um condutor direto da energia de sua divindade, emanando uma aura brilhante da cor que escolher. Seus aliados na &aacute;rea recebem +5 na Defesa e em testes de resist&ecirc;ncia (voc&ecirc; e aliados devotos da mesma divindade que voc&ecirc; recebem +10) e ficam imunes a encantamento. Al&eacute;m disso, inimigos que entrem na &aacute;rea afetada devem fazer um teste de Vontade; em caso de falha, recebem uma condi&ccedil;&atilde;o a sua escolha entre esmorecido, debilitado ou lento at&eacute; o fim da cena. O teste deve ser refeito cada vez que a criatura entrar novamente na &aacute;rea.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"","area":"esfera de 9m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"div","circulo":"5","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"6wLWvHT1aEd3fpoW","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"},{"key":"data.pericias.refl.bonus","mode":2,"value":"1"},{"key":"data.pericias.fort.bonus","mode":2,"value":"1"},{"key":"data.pericias.vont.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os bônus na Defesa e em testes de resistência em +1.","origin":"Item.OROKwtjkajwKhNST","transfer":false,"tint":null},{"_id":"230TjFlqsBvcCJxJ","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"5"},{"key":"data.pericias.refl.bonus","mode":2,"value":"5"},{"key":"data.pericias.fort.bonus","mode":2,"value":"5"},{"key":"data.pericias.vont.bonus","mode":2,"value":"5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aura-divina.webp","label":"Aura Divina","origin":"Item.BRR2wEhjX8MoYqzF","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.VrmVbEOckxo2zxKe"}}}
{"_id":"nJsZgECVcjg9jwCz","name":"Área Escorregadia","type":"magia","img":"systems/tormenta20/icons/magias/area-escorregadia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia recobre uma superf&iacute;cie com uma subst&acirc;ncia gordurosa e escorregadia. Criaturas na &aacute;rea devem passar na resist&ecirc;ncia para n&atilde;o cair. Nas rodadas seguintes, criaturas que tentem movimentar-se pela &aacute;rea devem fazer testes de Acrobacia para equil&iacute;brio (CD 10). &Aacute;rea Escorregadia pode tornar um item escorregadio. Uma criatura segurando um objeto afetado deve passar na resist&ecirc;ncia para n&atilde;o deixar o item cair cada vez que us&aacute;-lo.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":0,"condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"Quadrado de 3m ou 1 objeto","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos (veja texto)"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"Convocação"},"effects":[{"_id":"BZlhiAeHxvOEQedE","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"durationScene":false}},"changes":[{"key":"area","value":"1,5m","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a área em +1 quadrado de 1,5m.","origin":"Item.DDU9iwWVX0WUHyfO","tint":null,"transfer":false},{"_id":"rxYgpqs7ve0xZ9J5","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a CD dos testes de Acrobacia para 15.","origin":"Item.DDU9iwWVX0WUHyfO","transfer":false},{"_id":"F8u49l0sz9ZpG7Lz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a CD dos testes de Acrobacia para 20.","origin":"Item.DDU9iwWVX0WUHyfO","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.1INkZJEYMajwh5bm"}}}
{"_id":"nTGtbkxrFRRY7fXc","name":"Relâmpago Flamejante","type":"magia","img":"systems/tormenta20/icons/magias/relampago-flamejante.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta &eacute; uma magia poderosa, mas lenta, desenvolvida por um met&oacute;dico e impass&iacute;vel arquimago. Na primeira rodada de execu&ccedil;&atilde;o, voc&ecirc; invoca as energias elementais do fogo e uma de suas m&atilde;os fica em chamas. Na segunda rodada, invoca as energias elementais dos rel&acirc;mpagos, ficando com a outra m&atilde;o eletrificada.</p>\n<p style=\"text-align: justify;\">Ent&atilde;o, pela dura&ccedil;&atilde;o da magia, pode usar uma a&ccedil;&atilde;o de movimento para disparar bolas de fogo (6d6 pontos de dano de fogo numa esfera de 3m de raio) ou rel&acirc;mpagos (6d6 pontos de dano de eletricidade numa linha). Voc&ecirc; tamb&eacute;m pode, como uma a&ccedil;&atilde;o padr&atilde;o, usar as duas m&atilde;os num ataque de energia mista (12d12 pontos de dano, metade de fogo e metade de eletricidade, numa esfera de 6m de raio). Voc&ecirc; precisa estar com as duas m&atilde;os livres para invocar o efeito misto e isso consome toda a energia da magia, terminando-a imediatamente.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"special","custo":10,"qtd":"","condicao":"","special":"Duas Rodadas"},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"bolas de fogo e relâmpagos","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"lXssXpcmsW7fnX1J","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":true}},"changes":[{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano das rajadas em +1d6 e o dano da rajada mista em +2d12.","origin":"Compendium.tormenta20.magias.nTGtbkxrFRRY7fXc","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Nxri8V6bc06JZkQf"}}}
{"_id":"niuOSuCZnUd6sR8p","name":"Viagem Arbórea","type":"magia","img":"systems/tormenta20/icons/magias/viagem-arborea.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Como parte da execução, você entra em uma árvore adjacente que seja maior do que você. Você pode permanecer dentro da árvore, percebendo os arredores de forma normal (mas sem poder fazer ações). Você pode gastar uma ação de movimento para sair da mesma árvore, ou de qualquer outra dentro de 1km. Se estiver dentro de uma árvore que seja destruída, a magia termina e você sofre 10d6 pontos de dano de impacto. Enquanto a magia durar você pode gastar ações de movimento para entrar em outras árvores.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"AB5Wt8Lak1O5Regb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"até cinco criaturas","mode":5},{"key":"duracao","value":"instantânea","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque, o alvo para até cinco criaturas e a duração para instantânea. Os alvos entram em uma planta (de tamanho Médio ou maior) e saem em outra planta do mesmo tamanho a até 100km de distância, especificada em direção e distância aproximadas (como “50km ao norte”).","origin":"Compendium.tormenta20.magias.niuOSuCZnUd6sR8p","transfer":false},{"_id":"y0umPu4smMdovHEY","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/viagem-arborea.webp","label":"Viagem Arbórea","origin":"Item.UMXJrtRLa0HVey6y","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.w2iCg14rkyixjOsh"}}}
{"_id":"oFPOvZqHlPTyj4XD","name":"Desintegrar","type":"magia","img":"systems/tormenta20/icons/magias/desintegrar.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; dispara um raio fino e esverdeado que causa 10d12 pontos de dano de ess&ecirc;ncia. Se o alvo passar no teste de resist&ecirc;ncia, em vez disso sofre 2d12 pontos de dano.</p>\n<p style=\"text-align: justify;\">Independentemente do resultado do teste de Fortitude, se os PV do alvo forem reduzidos a 0 ou menos, ele ser&aacute; completamente desintegrado, restando apenas p&oacute;.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1 criatura ou objeto","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["10d12",""]]}],"tipo":"arc","circulo":"4","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"qeqZ9ZhouJ48lEj9","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"2d12"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano total em +2d12 e o dano mínimo em +1d12.","origin":"Compendium.tormenta20.magias.oFPOvZqHlPTyj4XD","transfer":false,"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.cMRNoSnkc0i085Wx"}}}
{"_id":"oMhqpjjWQzvHdIlc","name":"Preparação de Batalha","type":"magia","img":"systems/tormenta20/icons/magias/preparacao-de-batalha.webp","data":{"description":{"value":"<p style=\"text-align: justify;\"><strong>Custo Adicional:</strong> penalidade de 1 PM</p>\n<p style=\"text-align: justify;\">Essa magia &eacute; muito utilizada por cl&eacute;rigos e bardos que n&atilde;o precisam (ou n&atilde;o podem) estar sempre com suas armas ou armaduras. A magia &eacute; lan&ccedil;ada sobre at&eacute; dois itens que voc&ecirc; possua. A partir da&iacute;, em qualquer momento, voc&ecirc; pode usar uma a&ccedil;&atilde;o completa para convocar os itens, que aparecem sobre seu corpo e em suas m&atilde;os. O efeito &eacute; espalhafatoso, sendo praticamente imposs&iacute;vel utiliz&aacute;-lo sem chamar aten&ccedil;&atilde;o. A magia funciona independentemente da dist&acirc;ncia dos itens, contanto que estejam no mesmo plano, mas termina se voc&ecirc; perder a posse deles.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"Custo Adicional: penalidade de 1 PM","special":""},"duracao":{"value":"permanente até ser descarregada","units":"special","special":"","valor":"permanente até ser descarregada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"até dois itens que você possua, entre armas, armaduras e escudos","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"abj","chatFlavor":"Custo adicional de 1 PM"},"effects":[{"_id":"Stlr7Ll69XLIQaVi","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"Aumenta o número de alvos em dois e o custo adicional em 1 PM.","origin":"Compendium.tormenta20.magias.oMhqpjjWQzvHdIlc","transfer":false}],"folder":null,"sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Compendium.tormenta20.magias.oMhqpjjWQzvHdIlc"},"cf":null}}
{"_id":"oyIcPlsAaASUEJpT","name":"Arma Espiritual","type":"magia","img":"systems/tormenta20/icons/magias/arma-espiritual.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; invoca a arma preferida de sua divindade (se tiver uma), que surge flutuando a seu lado. Uma vez por rodada, quando voc&ecirc; sofre um ataque corpo a corpo, pode usar uma rea&ccedil;&atilde;o para que a arma cause automaticamente [[/r 2d6]] pontos de dano do tipo da arma &mdash; por exemplo, uma espada longa causa dano de corte &mdash; no oponente que fez o ataque. Esta magia se dissipa se voc&ecirc; morrer.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d6",""]]}],"tipo":"div","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"NE7A9gt5vGem326j","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, a arma também o protege, oferecendo +1 na Defesa.","origin":"Item.TRX7bQoCQlkBofMm","tint":null,"transfer":false},{"_id":"YOyqYFFJIde7GpRt","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus na Defesa em +1.","origin":"Item.TRX7bQoCQlkBofMm","tint":null,"transfer":false},{"_id":"13m69ZFjBms7pxGq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"durationScene":false}},"changes":[{"key":"duracao","value":"sustentada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para sustentada. Além do normal, uma vez por rodada, você pode gastar uma ação livre para fazer a arma acertar automaticamente um alvo em alcance curto. Se a arma atacar, não poderá contra-atacar até seu próximo turno. Requer 2o círculo.","origin":"Item.TRX7bQoCQlkBofMm","tint":null,"transfer":false},{"_id":"5GTi8H6gTNQECJ2r","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o tipo do dano para essência. Requer 2o círculo.","origin":"Item.TRX7bQoCQlkBofMm","transfer":false},{"_id":"y4ZDPyYeLnGbVG0d","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5"}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"invoca duas armas, permitindo que você contra-ataque (ou ataque, se usar o aprimoramento acima) duas vezes por rodada. Requer 3o círculo.","origin":"Item.TRX7bQoCQlkBofMm","transfer":false},{"_id":"nPQrQvRyaiL8xq7M","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/arma-espiritual.webp","label":"Arma Espiritual","origin":"Item.2E85Xv836bjrcoLj","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.eS7C2MlLC6iCAG5o"},"cf":null}}
{"_id":"p6sWgQAgMD5Kp6EF","name":"Contato Extraplanar","type":"magia","img":"systems/tormenta20/icons/magias/contato-extraplanar.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Sua mente viaja até outro plano de existência, onde entra em contato com seres extraplanares como gênios, demônios ou elementais. Você firma um contrato com uma dessas entidades para que o auxilie durante o dia, em troca de se alimentar de seu mana. Quando a magia é lançada, você recebe 6d6 dados de auxílio. Enquanto a magia durar, sempre que for realizar um teste de perícia, você pode gastar qualquer quantidade desses d6 e adicionar o resultado rolado como bônus no teste. No entanto, esse auxílio tem um preço: sempre que rolar um “6” num desses d6, a entidade “suga” 1 PM de você. A magia termina quando você ficar sem dados para rolar, sem PM ou no fim do dia (o que acontecer primeiro).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"3","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"RDj6YcZ4urDG8acJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de dados de auxílio em +1.","origin":"Compendium.tormenta20.magias.p6sWgQAgMD5Kp6EF","transfer":false},{"_id":"44JzTDSZZyNuJDQH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"8","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"Muda os dados de auxílio para d12. Sempre que rolar um resultado 12 num desses d12, a entidade “suga” 2 PM de você. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.p6sWgQAgMD5Kp6EF","transfer":false},{"_id":"vQ3KCTv7rnUwKOtV","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/contato-extraplanar.webp","label":"Contato Extraplanar","origin":"Item.XD2xtNzDW8c7QK5n","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.e2QOZPn8AYTIyXgi"}}}
{"_id":"q6jHyHSI2hWrZGE9","name":"Criar Ilusão","type":"magia","img":"systems/tormenta20/icons/magias/criar-ilusao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma ilusão visual (uma criatura, uma parede...) ou sonora (um grito de socorro, um uivo assustador...). A magia cria apenas imagens ou sons simples, com volume equivalente ao tom de voz normal para cada cubo de 1,5m no efeito. Não é possível criar cheiros, texturas ou temperaturas, nem sons complexos, como uma música ou diálogo. Criaturas e objetos atravessam uma ilusão sem sofrer dano, mas a magia pode, por exemplo, esconder uma armadilha ou inimigo. A magia é dissipada se você sair do alcance.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"ilusão que se estende a até 4 cubos de 1,5m","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade desacredita"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"n6Z0C6i7zRdMXJCI","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"duracao","value":"sustentada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para sustentada. A cada rodada você pode usar uma ação livre para mover a imagem ou alterar levemente o som, como aumentar o volume ou fazer com que pareça se afastar ou se aproximar, ainda dentro dos limites do efeito. Você pode, por exemplo, criar a ilusão de um fantasma que anda pela sala, controlando seus movimentos. Quando você para de sustentar a magia, a imagem ou som persistem por mais uma rodada antes de a magia se dissipar.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"gXUeZ4lyPCG5kfnY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o efeito da ilusão em +1 cubo de 1,5m.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"8CGYdVwtdBDIgijP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também pode criar ilusões de imagem e sons combinados.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"4SwLXxXiKyLA6GOB","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também pode criar sons complexos com volume máximo equivalente ao que cinco pessoas podem produzir para cada cubo de 1,5m no efeito. Com uma ação livre, você pode alterar o volume do som ou fazê-lo se aproximar ou se afastar dentro do alcance.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"AnqwHcCEzCpLaLE2","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também pode criar odores e sensações térmicas, que são percebidos a uma distância igual ao dobro do tamanho máximo do efeito. Por exemplo, uma miragem de uma fogueira com 4 cubos de 1,5m poderia emanar calor e cheiro de queimado a até 12m.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"iVGfbDJ0mD47pTJl","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"longo","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para longo e o efeito para esfera de 30m de raio. Em vez do normal, você cria um som muito alto, equivalente a uma multidão. Criaturas na área lançam magias como se estivessem em uma condição ruim e a CD de testes de Percepção para ouvir aumenta em +10. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"kKU9wZjz6XhykthM","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também pode criar sensações táteis, como texturas; objetos ainda atravessam a ilusão, mas criaturas não conseguem atravessá-la sem passar em um teste de Vontade. A ilusão ainda é incapaz de causar ou sofrer dano. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false},{"_id":"3ea4dd14qL7c9Fmy","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"duracao","value":"sustentada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para sustentada. Além do normal, você pode gastar uma ação livre para modificar livremente a ilusão (mas não pode acrescentar novos aprimoramentos após lançá-la). Requer 3º círculo.","origin":"Compendium.tormenta20.magias.q6jHyHSI2hWrZGE9","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.YGoq4tkfGEGyBy9S"}}}
{"_id":"rQ44Cz2gJdt86jFL","name":"Toque da Morte","type":"magia","img":"systems/tormenta20/icons/magias/toque-da-morte.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Sua mão exala energias letais. Se a criatura tocada falhar no teste de Fortitude, seus PV são reduzidos a –10; se passar, sofre 10d8 pontos de dano de trevas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Fortitude parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["10d8",""]]}],"tipo":"uni","circulo":"5","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"3Ivodo4341tW7cj8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto. Em vez de tocar no alvo, você dispara um raio púrpura da ponta de seu dedo indicador.","origin":"Compendium.tormenta20.magias.rQ44Cz2gJdt86jFL","transfer":false},{"_id":"IDwvmjisl8U6TBXN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"10","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"inimigos no alcance","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para inimigos no alcance. Em vez de tocar no alvo, você dispara raios púrpuras da ponta de seus dedos.","origin":"Compendium.tormenta20.magias.rQ44Cz2gJdt86jFL","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.qvu2YUpgSU6ex75r"}}}
{"_id":"rfTGYwrXLjcIAIP5","name":"Dissipar Magia","type":"magia","img":"systems/tormenta20/icons/magias/dissipar-magia.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; dissipa outras magias que estejam ativas, como se sua dura&ccedil;&atilde;o tivesse acabado. Note que efeitos de magias instant&acirc;neas n&atilde;o podem ser dissipados (n&atilde;o se pode dissipar uma Bola de Fogo ou Rel&acirc;mpago depois que j&aacute; causaram dano...). Se lan&ccedil;ar essa magia em uma criatura ou &aacute;rea, fa&ccedil;a um teste de Misticismo; voc&ecirc; dissipa as magias com CD igual ou menor que o resultado do teste. Se lan&ccedil;ada contra um item m&aacute;gico, o transforma em um item mundano por 1d6 rodadas (sem teste de resist&ecirc;ncia). Dissipar Magia n&atilde;o dissipa habilidades m&aacute;gicas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"1 criatura ou 1 objeto mágico","area":"ou esfera com 3m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"2","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"kKZ6L0mhMN53y13e","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"area","value":"esfera com 9m de raio","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para esfera com 9m de raio. Em vez do normal, cria um efeito de disjunção. Todas as magias na área são automaticamente dissipadas e todos os itens mágicos na área, exceto aqueles que você estiver carregando, viram itens mundanos (com direito a um teste de resistência para evitar esse efeito). Requer 5º círculo.","origin":"Compendium.tormenta20.magias.rfTGYwrXLjcIAIP5","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.LnZpwedvAkmScrZG"}}}
{"_id":"rjB5WyNkH0eInOGW","name":"Comando","type":"magia","img":"systems/tormenta20/icons/magias/comando.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; d&aacute; uma ordem irresist&iacute;vel, que o alvo deve ser capaz de ouvir (mas n&atilde;o precisa entender). Se falhar na resist&ecirc;ncia, ele deve obedecer ao comando em seu pr&oacute;prio turno da melhor maneira poss&iacute;vel. Escolha um dos efeitos.</p>\n<p style=\"text-align: justify;\"><em>Fuja:</em> o alvo gasta seu turno se afastando de voc&ecirc; (usando todas as suas a&ccedil;&otilde;es).</p>\n<p style=\"text-align: justify;\"><em>Largue:</em> o alvo solta quaisquer itens que esteja segurando e n&atilde;o pode peg&aacute;-los novamente at&eacute; o in&iacute;cio de seu pr&oacute;ximo turno. Como esta &eacute; uma a&ccedil;&atilde;o livre, ele ainda pode executar outras a&ccedil;&otilde;es (exceto pegar aquilo que largou).</p>\n<p style=\"text-align: justify;\"><em>Pare:</em> o alvo fica pasmo (n&atilde;o pode fazer a&ccedil;&otilde;es, exceto rea&ccedil;&otilde;es). Se passar no teste&nbsp;de resist&ecirc;ncia, o alvo n&atilde;o pode mais ficar pasmo por esta magia at&eacute; o fim da cena.</p>\n<p style=\"text-align: justify;\"><em>Senta:</em> com uma a&ccedil;&atilde;o livre, o alvo senta no ch&atilde;o (se estava pendurado ou voando, desce at&eacute; o ch&atilde;o). Ele pode fazer outras a&ccedil;&otilde;es, mas n&atilde;o se levantar at&eacute; o in&iacute;cio de seu pr&oacute;ximo turno.</p>\n<p style=\"text-align: justify;\"><em>Venha:</em> o alvo gasta seu turno se aproximando de voc&ecirc; (usando todas as suas a&ccedil;&otilde;es).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 rodada","units":"special","special":"","valor":"1 rodada","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 humanóide","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"goAzE0oaWGOVE9Gm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false},{"_id":"UuprzsbsDv72xAxP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a quantidade de alvos em +1","origin":"Compendium.tormenta20.magias.rjB5WyNkH0eInOGW","transfer":false},{"_id":"18JDpeaGFnz9KNKz","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/comando.webp","label":"Comando (Alvo Afetado)","origin":"Item.XeTC7eLTsBnZ57CL","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.DClEXhRqbdmK0hPw"}}}
{"_id":"rttQq9tufgLj1I8j","name":"Mapear","type":"magia","img":"systems/tormenta20/icons/magias/mapear.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Uma fagulha percorre a superfície afetada, queimando-a enquanto esboça um mapa da região onde o conjurador está. Se você conhece o lugar, o mapa será completo. Caso contrário, apresentará apenas um esboço geral, além de um ponto de referência (para possibilitar localização) e um lugar de interesse, ambos definidos pelo mestre. A região representada no mapa tem tamanho máximo de um quadrado de 10km de lado. Caso você esteja dentro de uma construção, o mapa mostrará o andar no qual você se encontra.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"superfície ou objeto plano, como uma mesa ou pergaminho","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"dseg81UgYcAVPUkk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5},{"key":"duracao","value":"1 hora","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura e a duração para 1 hora. Em vez do normal, a criatura tocada descobre o caminho mais direto para entrar ou sair de um lugar. Assim, a magia pode ser usada para descobrir a rota até o relicário de uma catedral ou a saída mais próxima de uma masmorra (mas não para encontrar a localização de uma criatura ou objeto; a magia funciona apenas em relação a lugares). Caso a criatura demore mais de uma hora para percorrer o caminho, o conhecimento se perde.","origin":"Compendium.tormenta20.magias.rttQq9tufgLj1I8j","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.N1nJpTemQkOIZj44"}}}
{"_id":"s6QK5uGb7SBlVXMp","name":"Barragem Elemental","type":"magia","img":"systems/tormenta20/icons/magias/barragem-elemental.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Criada por um arquimago, esta magia produz quatro esferas elementais (&aacute;cido, eletricidade, fogo e frio) que voam at&eacute; um ponto a sua escolha. Quando atingem o ponto escolhido, explodem causando 6d6 pontos de dano (cada uma do seu tipo) numa esfera com 12m de raio. Um teste de Reflexos reduz o dano &agrave; metade. Voc&ecirc; pode mirar cada esfera em uma criatura ou ponto diferente. Uma criatura ao alcance da explos&atilde;o de mais de uma esfera deve fazer um teste de resist&ecirc;ncia para cada uma. Al&eacute;m disso, as esferas causam os seguintes efeitos em criaturas que falharem em seus respectivos testes de resist&ecirc;ncia:</p>\n<p style=\"text-align: justify;\">&bull; Esfera de &aacute;cido: vulner&aacute;vel at&eacute; o fim da cena.</p>\n<p style=\"text-align: justify;\">&bull; Esfera el&eacute;trica: atordoado por uma rodada. Se passar no teste de resist&ecirc;ncia, a criatura n&atilde;o pode mais ser&nbsp;atordoada por esta magia at&eacute; o fim da cena.</p>\n<p style=\"text-align: justify;\">&bull; Esfera de fogo: em chamas.</p>\n<p style=\"text-align: justify;\">&bull; Esfera de frio: lento at&eacute; o fim da cena.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"4 esferas elementais","alcance":"long","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["24d6",""]]}],"tipo":"arc","circulo":"5","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"fymYz7rNSFuVXYmd","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"8d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano de cada esfera em +2d6.","origin":"Compendium.tormenta20.magias.s6QK5uGb7SBlVXMp","transfer":false,"tint":null},{"_id":"MzegepIlmQDbaq82","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o tipo de dano de todas as esferas para essência (mas elas ainda causam os outros efeitos como se seu tipo de dano não mudasse).","origin":"Compendium.tormenta20.magias.s6QK5uGb7SBlVXMp","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.BautUansTRJLLIo1"}}}
{"_id":"s9z7z8KtujpICCZw","name":"Sussurros Insanos","type":"magia","img":"systems/tormenta20/icons/magias/sussurros-insanos.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você murmura palavras desconexas que afetam a mente do alvo. O alvo fica confuso.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 humanoide","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"a91Qq4uJWCt9BaHJ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.s9z7z8KtujpICCZw","transfer":false},{"_id":"n4P4UlD5bQRhtzIh","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.s9z7z8KtujpICCZw","transfer":false},{"_id":"Yiwe30aN5lDHb5mk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"12","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.s9z7z8KtujpICCZw","transfer":false},{"_id":"LIjMpDqxc7ekPkTw","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/sussurros-insanos.webp","label":"Sussurros Insanos","origin":"Item.cP0uK2cOx8pVxsIX","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.j3ykT4OMk0qP8PSg"}}}
{"_id":"sG4l65MMEA2JtHLq","name":"Aliado Animal","type":"magia","img":"systems/tormenta20/icons/magias/aliado-animal.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; cria um v&iacute;nculo mental com um animal prestativo em rela&ccedil;&atilde;o a voc&ecirc;. O Aliado Animal obedece a voc&ecirc; no melhor de suas capacidades, mesmo que isso arrisque a vida dele. Ele funciona como um aliado veterano, de um tipo a sua escolha entre ajudante, combatente, fort&atilde;o, guardi&atilde;o, montaria ou perseguidor.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 dia","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 animal prestativo","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"2","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"vT20hZe7eWNDVnkJ","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"1","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"1 animal Minúsculo","mode":5},{"key":"duracao","value":"1 semana","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alvo para 1 animal Minúsculo e a duração para 1 semana. Em vez do normal, o animal se desloca no melhor de suas capacidades até um local designado por você — em geral, para levar um item, carta ou similar. Quando o animal chega ao destino, fica esperando até o fim da magia, permitindo apenas que uma ou mais criaturas escolhidas por você se aproximem e peguem o que ele estiver carregando.","origin":"Item.k2OoCtbCZQQuy1Ew","tint":null,"transfer":false},{"_id":"QrQnnDytbwLzxW0A","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"7","durationScene":false,"onuse":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o aliado para mestre. Requer 3o círculo.","origin":"Item.k2OoCtbCZQQuy1Ew","tint":null,"transfer":false},{"_id":"zFFKqt4nUv52aqdW","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"12","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"2 animais prestativos.","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alvo para 2 animais prestativos. Cada animal funciona como um aliado de um tipo diferente, e você pode receber a ajuda de ambos (mas ainda precisa seguir o limite de aliados de acordo com o seu nível de personagem). Requer 4o círculo","origin":"Item.k2OoCtbCZQQuy1Ew","tint":null,"transfer":false},{"_id":"ZNNjKCBvRulvNuWa","changes":[{"key":"data.pericias.???.bonus","mode":2,"value":"2"},{"key":"data.pericias.???.bonus","mode":2,"value":"2"},{"key":"data.pericias.???.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aliado-animal.webp","label":"Aliado Ajudante","origin":"Item.cgBgjYtWdzBHc55T","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"R13faf8DERa8x7pa","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"2"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aliado-animal.webp","label":"Aliado Combatente","origin":"Item.cgBgjYtWdzBHc55T","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"ZXH89ub6e0RN2yOn","changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"1d12"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aliado-animal.webp","label":"Aliado Fortão","origin":"Item.cgBgjYtWdzBHc55T","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"iU6m2KjvsxZ5bVwC","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"3"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aliado-animal.webp","label":"Aliado Guardião","origin":"Item.cgBgjYtWdzBHc55T","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"Oifd02yZgDo8Vv5g","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aliado-animal.webp","label":"Aliado Montaria","origin":"Item.cgBgjYtWdzBHc55T","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"rbyi2QmKfn7ZqgZz","changes":[{"key":"data.pericias.perc.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/aliado-animal.webp","label":"Aliado Perseguidor","origin":"Item.cgBgjYtWdzBHc55T","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.vg3jzyGuVolBpvbZ"}}}
{"_id":"sSUOYxFZVrthYvfn","name":"Controlar Plantas","type":"magia","img":"systems/tormenta20/icons/magias/controlar-plantas.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia só pode ser lançada em uma área com vegetação. As plantas se enroscam nas criaturas da área. Aquelas que falharem na resistência ficam enredadas. Uma vítima pode se libertar com uma ação padrão e um teste de Acrobacia ou Atletismo. Além disso, a área é considerada terreno difícil. No início de seus turnos, a vegetação tenta enredar novamente qualquer criatura na área, exigindo um novo teste de Reflexos.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"quadrado com 9m de lado","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Reflexos anula"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"rZdJYsUgC0ebL7Sc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"area","value":"alvo de 1 planta","mode":5},{"key":"resistencia","value":"nenhuma","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para alvo de 1 planta e a resistência para nenhuma. Em vez do normal, você pode fazer a planta se mover como se fosse animada. Ela não pode causar dano ou atrapalhar a concentração de um conjurador.","origin":"Compendium.tormenta20.magias.sSUOYxFZVrthYvfn","transfer":false},{"_id":"8XOjU7dESDfzOclq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"duracao","value":"instantânea","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para instantânea. Em vez do normal, as plantas na área diminuem, como se tivessem sido podadas. Terreno difícil muda para terreno normal e não oferece camuflagem. Esse efeito dissipa o uso normal de Controlar Plantas.","origin":"Compendium.tormenta20.magias.sSUOYxFZVrthYvfn","transfer":false},{"_id":"fvTTXL2IlhpHs4nu","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas que falhem na resistência também ficam imóveis.","origin":"Compendium.tormenta20.magias.sSUOYxFZVrthYvfn","transfer":false},{"_id":"OnXUprtI8dDsyccX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"pessoal","mode":5},{"key":"area","value":"alvo (você)","mode":5},{"key":"resistencia","value":"nenhuma","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para pessoal, a área para alvo (você) e a resistência para nenhuma. Em vez do normal, você consegue se comunicar com plantas, que começam com atitude prestativa em relação a você. Além disso, você pode fazer testes de Diplomacia com plantas. Em geral, plantas têm uma percepção limitada de seus arredores e normalmente fornecem respostas simplórias.","origin":"Compendium.tormenta20.magias.sSUOYxFZVrthYvfn","transfer":false},{"_id":"xKnSC30V3Kzq8qjt","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/controlar-plantas.webp","label":"Controlar Plantas (Aprimoramento de +2 PM)","origin":"Item.QS9vHEwxKu3OtdSL","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.oV66MsZrmtBHAQus"}}}
{"_id":"secWy6zyYamo3Xnx","name":"Imagem Espelhada","type":"magia","img":"systems/tormenta20/icons/magias/imagem-espelhada.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Três cópias ilusórias suas aparecem. As duplicatas ficam ao seu redor e imitam suas ações, tornando difícil para um inimigo saber quem atacar. Você recebe +6 na Defesa. Cada vez que um ataque contra você erra, uma das imagens desaparece e o bônus na Defesa diminui em 2. Um oponente deve ver as cópias para ser confundido. Se você estiver invisível, ou o atacante fechar os olhos, você não recebe o bônus (mas o atacante ainda sofre penalidades normais por não enxergar).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"Ie29TxOU55m47buZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de cópias em +1 (e o bônus na Defesa em +2).","origin":"Compendium.tormenta20.magias.secWy6zyYamo3Xnx","transfer":false,"tint":null},{"_id":"vGmIE4QLA0WTxIt9","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, toda vez que uma cópia é destruída, emite um clarão de luz. A criatura que destruiu a cópia fica ofuscada por uma rodada. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.secWy6zyYamo3Xnx","transfer":false},{"_id":"caDtz2AyMaR6qYkX","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"6"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/imagem-espelhada.webp","label":"Imagem Espelhada","origin":"Item.zJjM1i69MWx3xcBT","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.w2JCxtC9wEAu6FQk"},"cf":null}}
{"_id":"soVAGPRWQmKxOrPm","name":"Curar Ferimentos","type":"magia","img":"systems/tormenta20/icons/magias/curar-ferimentos.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você canaliza energia positiva que recupera 2d8+2 pontos de vida na criatura tocada. Como mortos-vivos usam energia negativa, esta magia causa dano de luz a eles (Vontade reduz à metade). Curar Ferimentos anula Infligir Ferimentos.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Cura","key":"dano0","type":"dano","parts":[["2d8+2",""]]}],"tipo":"div","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"iwzkb3ErKCkqeI1D","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, estabiliza uma criatura.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"E5Ynb8D45IFPkqGc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"alvo","value":"1 morto-vivo","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 morto-vivo. Em vez do normal, causa 1d8 pontos de dano de luz (Vontade reduz à metade).","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"T7W1dpep8KKLNdPQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"dano","value":"1d8+1","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a cura em +1d8+1.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"xncd3c6sRimZD4nY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também remove uma condição de fadiga do alvo.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"8NiPKz2Ks17aIGcT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false},{"_id":"lcjBzJa7QT1xtM5I","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"curto","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para curto e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.soVAGPRWQmKxOrPm","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.galK4UUS6FxYz22S"}}}
{"_id":"sw6TTkiY2ycfZefD","name":"Despertar Consciência","type":"magia","img":"systems/tormenta20/icons/magias/despertar-consciencia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você desperta a consciência de um animal ou planta, que passa a ajudá-lo. O alvo se torna um aliado veterano de um tipo a sua escolha entre ajudante, combatente, fortão, guardião, médico ou perseguidor. Se usar esta magia em um aliado que já possua, seu nível de poder aumenta em um passo (iniciante para veterano, veterano para mestre). Se já for um aliado mestre, fornece um bônus adicional de outro tipo de aliado iniciante (entre as escolhas acima). O alvo ganha Inteligência 3d6, +1d4 de Carisma e pode falar os idiomas que você conhece.</p><p style=\"text-align:justify;\">Se não quiser ter o alvo como aliado, você pode pedir que ele proteja um local específico, atacando invasores (nesse caso, use as estatísticas apropriadas à criatura; plantas usam as estatísticas de entes).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 animal ou planta","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"3","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"sF7igOGJWfq5j3Zb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"alvo","value":"1 escultura mundana inanimada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 escultura mundana inanimada. Além do normal, o alvo tem as mesmas características de um construto.","origin":"Compendium.tormenta20.magias.sw6TTkiY2ycfZefD","transfer":false},{"_id":"f958aTtmx3LyPrPi","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para permanente e adiciona sacrifício de 1 PM.","origin":"Compendium.tormenta20.magias.sw6TTkiY2ycfZefD","transfer":false},{"_id":"ozcfs2WPz3dMyodO","changes":[{"key":"data.pericias.???.bonus","mode":2,"value":"2"},{"key":"data.pericias.???.bonus","mode":2,"value":"2"},{"key":"data.pericias.???.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/despertar-consciencia.webp","label":"Ajudante Veterano","origin":"Item.iMYHSkwwQgHw6ATG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"6QUG0pmFj02rJr0k","changes":[{"key":"data.modificadores.ataque.cac","mode":2,"value":"2"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/despertar-consciencia.webp","label":"Combatente Veterano","origin":"Item.iMYHSkwwQgHw6ATG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"XemA5c23ohyWgyUD","changes":[{"key":"data.modificadores.dano.cac","mode":2,"value":"1d12"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/despertar-consciencia.webp","label":"Fortão Veterano","origin":"Item.iMYHSkwwQgHw6ATG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"ZDFoX3BWkquJPvrp","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"3"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/despertar-consciencia.webp","label":"Guardião Veterano","origin":"Item.iMYHSkwwQgHw6ATG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"KrRB9W1GEmmLSCbY","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/despertar-consciencia.webp","label":"Médico Veterano","origin":"Item.iMYHSkwwQgHw6ATG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"JqxkK37O59MqeC4N","changes":[{"key":"data.pericias.perc.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/despertar-consciencia.webp","label":"Perseguidor Veterano","origin":"Item.iMYHSkwwQgHw6ATG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.Jhn0wCQGoUm5aAWG"}}}
{"_id":"t7gd203PbRh3HfgS","name":"Alterar Memória","type":"magia","img":"systems/tormenta20/icons/magias/alterar-memoria.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Voc&ecirc; invade a mente do alvo e altera ou apaga suas mem&oacute;rias da &uacute;ltima hora.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"43Xr7frcuZwDiOmD","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"2","durationScene":false,"onuse":true}},"changes":[{"key":"alcance","value":"4,5m","mode":5},{"key":"alvo","value":"criaturas na área","mode":5},{"key":"area","value":"cone de 4,5m","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alcance para cone de 4,5m e o alvo para criaturas na área.","origin":"Item.x0FfeLySj5HBFbQ2","tint":null,"transfer":false},{"_id":"hfNuICnLPw71APCO","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"5","durationScene":false,"onuse":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"você pode alterar ou apagar as memórias das últimas 24 horas.","origin":"Item.x0FfeLySj5HBFbQ2","tint":null,"transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.l5nCVIKKdhuUAbz5"}}}
{"_id":"tJI1ESr2Mcxtx95L","name":"Profanar","type":"magia","img":"systems/tormenta20/icons/magias/profanar.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia enche a &aacute;rea com energia negativa. Efeitos que causam dano de trevas ou canalizam energia negativa t&ecirc;m seus efeitos&nbsp;maximizados&nbsp;dentro da &aacute;rea. Esta magia n&atilde;o pode ser lan&ccedil;ada em uma &aacute;rea contendo um s&iacute;mbolo vis&iacute;vel dedicado a uma divindade que n&atilde;o a sua. Profanar anula Consagrar.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"","area":"esfera com 9m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"fk8a19vw8q3BTczW","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"2"},{"key":"data.modificadores.pericias.geral","mode":2,"value":"2"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, mortos-vivos na área recebem +2 na Defesa e +2 em todos os testes.","origin":"Compendium.tormenta20.magias.tJI1ESr2Mcxtx95L","transfer":false,"tint":null},{"_id":"NZbTgUfqLcqk3DUb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"},{"key":"data.modificadores.pericias.geral","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta os bônus para mortos-vivos em +1.","origin":"Compendium.tormenta20.magias.tJI1ESr2Mcxtx95L","transfer":false,"tint":null},{"_id":"wD5kuxIAboyvZySZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"execucao","value":"1 hora","mode":5},{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para 1 hora, a duração para permanente e adiciona componente material (incenso e óleos no valor de T$ 1.000). Requer 4º círculo.","origin":"Compendium.tormenta20.magias.tJI1ESr2Mcxtx95L","transfer":false},{"_id":"jTaLFbtbvhjyJCNt","changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"0"},{"key":"data.modificadores.pericias.geral","mode":2,"value":"0"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/profanar.webp","label":"Bônus para Mortos-Vivos","origin":"Item.KsjzxeFvX5IWGefM","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.PLmnuK64Q0a11htq"}}}
{"_id":"tMZhHyjssqzaEe1L","name":"Teia","type":"magia","img":"systems/tormenta20/icons/magias/teia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Teia cria várias camadas de fibras entrelaçadas e pegajosas na área. Qualquer criatura na área que falhar na resistência fica enredada. Uma vítima pode se libertar com uma ação padrão e um teste de Acrobacia ou Atletismo. A área ocupada por Teia é terreno difícil.</p><p style=\"text-align:justify;\">A Teia é inflamável. Qualquer ataque que cause dano de fogo destrói as teias por onde passar, libertando as criaturas enredadas mas deixando-as em chamas (veja Condições, no Apêndice).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"cubo com 6m de lado","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos anula"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"a0waZ2BosDxhayOq","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas que falhem na resistência também ficam imóveis.","origin":"Compendium.tormenta20.magias.tMZhHyjssqzaEe1L","transfer":false},{"_id":"SotOlvQ7cLawscaR","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, no início de seus turnos a magia afeta novamente qualquer criatura na área, exigindo um novo teste de Reflexos. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.tMZhHyjssqzaEe1L","transfer":false},{"_id":"g5ncZPJA0OvT4dx2","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a área em +1 cubo de 1,5m.","origin":"Compendium.tormenta20.magias.tMZhHyjssqzaEe1L","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.9NxasCwrWEimctkw"},"cf":null}}
{"_id":"tQAIfnReI9DV014V","name":"Lendas e Histórias","type":"magia","img":"systems/tormenta20/icons/magias/lendas-historias.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você descobre informações sobre uma criatura, objeto ou local que esteja tocando. O que exatamente você descobre depende do mestre: talvez você não descubra tudo que há para saber, mas ganhe pistas para continuar a investigação. A cada rodada que mantiver a magia, você descobre:</p><ul><li>Todas as informações sobre o alvo, como se tivesse passado em todos os testes de Conhecimento para tal.</li><li>Todas as habilidades do alvo. Se for uma criatura, você sabe suas estatísticas de jogo como raça, classe, nível, atributos, magias, resistências e fraquezas. Se for um item mágico, aprende seu efeito e funcionamento.</li><li>Se o alvo está sob influência de alguma magia e todas as informações sobre as magias ativas, se houver alguma.</li></ul></p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 craitura, objeto ou local","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"38qQpPaoMbUr1US2","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"4","aumenta":false}},"changes":[{"key":"execucao","value":"1 dia","mode":5},{"key":"alcance","value":"ilimitado","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para 1 dia, o alcance para ilimitado e adiciona componente material (cuba de ouro cheia d’água e ingredientes mágicos, no valor de T$ 1.000). Você ainda precisa ter alguma informação sobre o alvo, como um nome, descrição ou localização.","origin":"Compendium.tormenta20.magias.tQAIfnReI9DV014V","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.HYUbDs8EipA6TE8g"}}}
{"_id":"tVxVarpB0GaAoCp5","name":"Ferver Sangue","type":"magia","img":"systems/tormenta20/icons/magias/ferver-sangue.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">O sangue do alvo aquece rapidamente at&eacute; entrar em ebuli&ccedil;&atilde;o. Quando a magia &eacute; lan&ccedil;ada, e no in&iacute;cio de cada um de seus turnos, o alvo sofre 3d6 pontos de dano de fogo (Fortitude reduz &agrave; metade). Se o alvo passar em dois testes de Fortitude seguidos, dissipa a magia. Se o alvo for reduzido a 0 PV pelo dano desta magia, seu corpo explode, matando-o e causando 6d6 pontos de dano de fogo em todas as criaturas a at&eacute; 3m (Reflexos reduz &agrave; metade). Essa magia n&atilde;o&nbsp;afeta criaturas sem sangue, como construtos ou mortos-vivos.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["3d6",""]]}],"tipo":"arc","circulo":"3","preparada":false,"escola":"nec","chatFlavor":""},"effects":[{"_id":"Bxba43zea5xHivv6","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Compendium.tormenta20.magias.tVxVarpB0GaAoCp5","transfer":false},{"_id":"tLIrRjfeyDLLV8Q3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda alvo para criaturas escolhidas. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.tVxVarpB0GaAoCp5","transfer":false},{"_id":"DEij8bV7eUeqE3fE","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/ferver-sangue.webp","label":"Criaturas Escolhidas","origin":"Item.tj3iMUCTzv8AKjnh","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.nH9O86YqO06Gr5mm"}}}
{"_id":"u2Yo7BCg7xOrQJyF","name":"Desespero Esmagador","type":"magia","img":"systems/tormenta20/icons/magias/desespero-esmagador.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Humanoides na área são acometidos de grande tristeza, adquirindo as condições fraco e frustrado. Se passarem na resistência, adquirem essas condições por uma rodada.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"Cone de 6 metros","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"6fhmY20GSejtqLgU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"condicao","value":"debilitado","mode":0},{"key":"condicao","value":"esmorecido","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, as condições adquiridas são debilitado e esmorecido.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false},{"_id":"HsX3fBjwZwMTO2bb","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, afeta qualquer tipo de criatura.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false},{"_id":"SFqxKl2kgQ69jfzA","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"condicao","mode":0,"value":"pasmo"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas que falhem na resistência ficam aos prantos (em termos de jogo, adquirem a condição pasmo) por 1 rodada. Criaturas que passarem no teste de resistência não podem mais ficar pasmas por esta\nmagia até o fim da cena. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.u2Yo7BCg7xOrQJyF","transfer":false,"tint":null},{"_id":"SKAFxmVCXlbjW5aR","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/desespero-esmagador.webp","label":"Desespero Esmagador","origin":"Item.z7QzFtHupsPxkLvT","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.l9gxrlKYBkmJLnXZ"}}}
{"_id":"u8Drz7nb84o5LIKG","name":"Sonho","type":"magia","img":"systems/tormenta20/icons/magias/sonho.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você entra nos sonhos de uma criatura. Uma vez lá, pode conversar com ela até que ela acorde. Se o alvo não estiver dormindo quando você lançar a magia, você pode permanecer em transe até que ele adormeça. Durante o transe, você fica indefeso e sem consciência dos arredores. Você pode sair do transe quando quiser, mas a magia termina.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"minute","custo":10,"qtd":"10 Minutos","condicao":"","special":""},"duracao":{"value":"veja texto","units":"special","special":"Veja Texto","valor":"veja texto","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"any","alvo":"1 criatura viva","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"adv","chatFlavor":""},"effects":[{"_id":"Td04D1iUcjNXOkWF","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"transforma o sonho do alvo em um pesadelo. A vítima deve fazer um teste de Vontade. Se falhar, não recupera PV ou PM pela noite, sofre 1d10 pontos de dano de trevas e acorda fatigada. A vítima recebe bônus ou penalidades em seu teste de resistência, dependendo do conhecimento que você tiver dela. Use os mesmos modificadores da magia Vidência.","origin":"Compendium.tormenta20.magias.u8Drz7nb84o5LIKG","transfer":false},{"_id":"JjXia570MMqdi6X9","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1. Todos os alvos compartilham um mesmo sonho (ou pesadelo) entre si e com você.","origin":"Compendium.tormenta20.magias.u8Drz7nb84o5LIKG","transfer":false},{"_id":"cORkOS9TjEL0BhLr","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/sonho.webp","label":"Sonho","origin":"Item.WnFojSk50613opVj","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.6cMiYbbqr0uFph3U"}}}
{"_id":"uAomjSrbq2JpCcz0","name":"Consagrar","type":"magia","img":"systems/tormenta20/icons/magias/consagrar.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia enche a &aacute;rea com energia positiva. Efeitos de luz que curam pontos de vida ou canalizam energia positiva t&ecirc;m seus efeitos maximizados.</p>\n<p style=\"text-align: justify;\">Por exemplo, Curar Ferimentos cura automaticamente 18 PV em alvos dentro da &aacute;rea. Esta magia n&atilde;o pode ser lan&ccedil;ada em uma &aacute;rea contendo um s&iacute;mbolo vis&iacute;vel dedicado a uma divindade que n&atilde;o a sua. Consagrar anula Profanar.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 dia","units":"special","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"","area":"esfera com 9m de raio","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"zjkaNWLGzSmvwWLX","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, mortos-vivos na área sofrem –2 em testes e Defesa.","origin":"Compendium.tormenta20.magias.uAomjSrbq2JpCcz0","transfer":false},{"_id":"TQzuS6ucn9K3jaZO","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"-1"},{"key":"data.attributes.defesa.bonus","mode":2,"value":"-1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta as penalidades para mortos-vivos em –1.","origin":"Compendium.tormenta20.magias.uAomjSrbq2JpCcz0","transfer":false,"tint":null},{"_id":"6wnjMrwszCAfHMwN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[{"key":"execucao","value":"1 hora","mode":5},{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para 1 hora, a duração para permanente e adiciona componente material (incenso e óleos no valor de T$ 1.000). Requer 4º círculo.","origin":"Compendium.tormenta20.magias.uAomjSrbq2JpCcz0","transfer":false},{"_id":"m53luwH5h5g7ihnZ","changes":[{"key":"data.modificadores.pericias.geral","mode":2,"value":"-2"},{"key":"data.attributes.defesa.bonus","mode":2,"value":"-2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/consagrar.webp","label":"Penalidade em Mortos-Vivos (Aprimoramento)","origin":"Item.2AmeIlEpP4vtCqyF","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.gfQM43TBWF5K1Pui"},"cf":null}}
{"_id":"uQKtqFd7ciS8zTRD","name":"Aprisionamento","type":"magia","img":"systems/tormenta20/icons/magias/aprisionamento.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; cria uma pris&atilde;o m&aacute;gica para aprisionar uma criatura. Se falhar no teste de resist&ecirc;ncia, o alvo sofre o efeito da magia; se passar, fica imune a esta magia por uma semana. Enquanto estiver aprisionada, a criatura n&atilde;o precisa respirar e alimentar-se, e n&atilde;o envelhece. Magias de adivinha&ccedil;&atilde;o n&atilde;o conseguem localizar ou perceber o alvo. Ao lan&ccedil;ar a magia, voc&ecirc; escolhe uma das seguintes formas de pris&atilde;o. O componente material varia, mas todos custam T$ 1.000.</p>\n<p style=\"text-align: justify;\">Acorrentamento: o alvo &eacute; preso por correntes firmemente enraizadas no ch&atilde;o, que o mant&eacute;m no lugar. O alvo fica paralisado e n&atilde;o pode se mover ou ser movido por qualquer meio. Componente Material: uma fina corrente de mitral.</p>\n<p style=\"text-align: justify;\">Conten&ccedil;&atilde;o M&iacute;nima: o alvo diminui para uma altura de 2 cent&iacute;metros e &eacute; preso dentro de uma pedra preciosa ou objeto semelhante. A luz pode passar atrav&eacute;s da pedra preciosa normalmente (permitindo que o alvo veja o lado de fora e outras criaturas o vejam), mas nada mais pode passar, nem por meio de teletransporte ou viagem planar. A pedra n&atilde;o pode ser quebrada enquanto o alvo estiver dentro. Componente Material: uma pedra preciosa, como um diamante ou rubi.</p>\n<p style=\"text-align: justify;\">Pris&atilde;o Dimensional: o alvo &eacute; transportado para um pequeno semiplano protegido contra teletransporte e viagens planares. O semiplano pode ser um labirinto, uma gaiola, uma torre ou qualquer estrutura ou &aacute;rea confinada similar de sua escolha. Componente Material: uma representa&ccedil;&atilde;o em miniatura da pris&atilde;o, feita de jade.</p>\n<p style=\"text-align: justify;\">Sepultamento: o alvo &eacute; sepultado bem fundo abaixo da terra, dentro de uma esfera de for&ccedil;a m&aacute;gica. Nada pode destruir ou atravessar a esfera, nem mesmo teletransporte ou viagens planares. Componente Material: um pequeno orbe de adamante.</p>\n<p style=\"text-align: justify;\">Sono Eterno: o alvo adormece e n&atilde;o pode ser acordado. Componente Material: fruta preparada com ervas son&iacute;feras raras.</p>\n<p style=\"text-align: justify;\">Quando a magia &eacute; lan&ccedil;ada, voc&ecirc; deve especificar uma condi&ccedil;&atilde;o que far&aacute; com que ela termine e solte o alvo. A condi&ccedil;&atilde;o pode ser t&atilde;o espec&iacute;fica ou elaborada quanto voc&ecirc; quiser, mas deve ser poss&iacute;vel de acontecer. As condi&ccedil;&otilde;es podem se basear no nome, identidade ou divindade padroeira de uma criatura, ou em a&ccedil;&otilde;es ou qualidades observ&aacute;veis, mas nunca em estat&iacute;sticas intang&iacute;veis, como n&iacute;vel, classe ou pontos de vida. O mestre tem a palavra final sobre se uma condi&ccedil;&atilde;o &eacute; v&aacute;lida ou n&atilde;o.</p>\n<p style=\"text-align: justify;\">Dissipar Magia pode dissipar o efeito, mas deve ser conjurada com o aprimoramento de 5o c&iacute;rculo e alvo na pris&atilde;o (poss&iacute;vel neste caso).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"permanente","units":"special","special":"","valor":"permanente","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"abj","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.safc9z4VKE919fhv"}}}
{"_id":"vAC1umkrWgM6aRPI","name":"Controlar a Gravidade","type":"magia","img":"systems/tormenta20/icons/magias/controlar-gravidade.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; controla os efeitos da gravidade dentro da &aacute;rea. Ao lan&ccedil;ar a magia, escolha um dos efeitos abaixo. Enquanto a magia durar, voc&ecirc; pode usar uma a&ccedil;&atilde;o padr&atilde;o para mudar o efeito.</p>\n<p style=\"text-align: justify;\"><em>Aumentar:</em> a gravidade fica mais forte. No in&iacute;cio de seus turnos, cada criatura na &aacute;rea deve fazer um teste de Atletismo. Se passar, fica fatigada. Se falhar, fica fatigada e ca&iacute;da.</p>\n<p style=\"text-align: justify;\"><em>Inverter:</em> inverte a gravidade da &aacute;rea, fazendo com que criaturas e objetos &ldquo;caiam&rdquo; para cima, atingindo o topo (12m) em uma rodada. Se um obst&aacute;culo (como um teto) impedir o movimento das criaturas, elas sofrem 1d6 pontos de dano de impacto para cada 1,5m de &ldquo;queda&rdquo;. Elas podem ent&atilde;o se levantar e caminhar no obst&aacute;culo, de cabe&ccedil;a para baixo. Se n&atilde;o houver obst&aacute;culo, as criaturas e objetos ficam flutuando no topo da &aacute;rea afetada, sem poder sair do lugar. Criaturas voadoras podem se movimentar normalmente. Algu&eacute;m adjacente a algo que possa agarrar tem direito a um teste de Reflexos para evitar a &ldquo;queda&rdquo;. A criatura deve permanecer presa pela dura&ccedil;&atilde;o da magia; caso contr&aacute;rio &ldquo;cair&aacute;&rdquo;.</p>\n<p style=\"text-align: justify;\"><em>Reduzir:</em> a gravidade fica mais leve. Criaturas ou objetos livres com at&eacute; 100kg flutuam para cima e para baixo conforme sua vontade, com deslocamento de voo 6m. Criaturas na &aacute;rea recebem +20 de b&ocirc;nus em testes de Atletismo para escalar e saltar. Uma criatura levitando fica inst&aacute;vel, sofrendo &ndash;2 de penalidade em testes de ataque.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"cubo de 12m de lado","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"8YYT033FJ5HbfJ8H","changes":[{"key":"data.pericias.atle.bonus","mode":2,"value":"20"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"-2"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"-2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/controlar-gravidade.webp","label":"Controlar a Gravidade (Reduzir)","origin":"Item.9n6KciVkvT7bf420","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.zeO5x4XW1sLKAcIu"}}}
{"_id":"vTVcrCjSdnOmcIyi","name":"Sono","type":"magia","img":"systems/tormenta20/icons/magias/sono.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Um sono místico recai sobre o alvo. Se passar na resistência, fica fatigado por uma rodada. Se falhar, fica inconsciente e caído.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura de ND 2 ou menor","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"2RSritpp09rILvcN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"alvo","value":"área de quadrado com 3m de lado","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para área de quadrado com 3m de lado. Todas as criaturas na área dentro do limite de ND são afetadas.","origin":"Compendium.tormenta20.magias.vTVcrCjSdnOmcIyi","transfer":false},{"_id":"NiU1L1ieGobYHI7J","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 5 ou menor. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.vTVcrCjSdnOmcIyi","transfer":false},{"_id":"jLalw0NTSbItIema","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 10 ou menor. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.vTVcrCjSdnOmcIyi","transfer":false},{"_id":"EPHBBEqIiZxPG0lj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para criaturas escolhidas. Todas as criaturas no alcance dentro do limite de ND são afetadas.","origin":"Compendium.tormenta20.magias.vTVcrCjSdnOmcIyi","transfer":false},{"_id":"Cz7be1ijtyd8K8yc","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"9","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de ND 15 ou menor. Requer 4º círculo.","origin":"Compendium.tormenta20.magias.vTVcrCjSdnOmcIyi","transfer":false},{"_id":"78AtWeMtkZBwX5d8","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"14","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"afeta alvos de qualquer ND. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.vTVcrCjSdnOmcIyi","transfer":false},{"_id":"FgYS2NNPgDpPqjpi","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/sono.webp","label":"Sono","origin":"Item.pBwmRLeF2gyonfGU","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.LZXii8FfFUq1f471"}}}
{"_id":"vUsntyToyQl1TuFZ","name":"Armadura Arcana","type":"magia","img":"systems/tormenta20/icons/magias/armadura-arcana.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma pel&iacute;cula protetora invis&iacute;vel, mas tang&iacute;vel, fornecendo +4 na Defesa. Esse b&ocirc;nus &eacute; cumulativo com outras magias, mas n&atilde;o com b&ocirc;nus fornecido por armaduras.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"W1WgvYbVsADr5MNL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"execucao","mode":5,"value":"reacao"},{"key":"data.attributes.defesa.bonus","mode":2,"value":"2"},{"key":"duracao","mode":5,"value":"1 turno"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para reação. Em vez do normal, você cria um escudo mágico que fornece +6 na Defesa contra o próximo ataque que sofrer até o fim do turno atual (cumulativo com o bônus fornecido pelo efeito básico desta magia e armaduras).","origin":"Item.6tacmHJDvuMoxe8v","tint":null,"transfer":false},{"_id":"cOarntwGdXunJRyH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus na Defesa em +1.","origin":"Item.6tacmHJDvuMoxe8v","tint":null,"transfer":false},{"_id":"CRwrKNwVnkcuyYGR","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Requer 2º círculo.","origin":"Item.6tacmHJDvuMoxe8v","tint":null,"transfer":false},{"_id":"DXFHELXQkzrakHqN","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":true}},"changes":[{"key":"data.attributes.defesa.bonus","mode":2,"value":"4"}],"disabled":false,"duration":{"startTime":null,"rounds":999},"icon":"systems/tormenta20/icons/magias/armadura-arcana.webp","label":"Armadura Arcana","origin":"Item.6tacmHJDvuMoxe8v","tint":null,"transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.tgkYUPq9MY1YItoL"}}}
{"_id":"veCfW87hsFWhz59h","name":"Tempestade Divina","type":"magia","img":"systems/tormenta20/icons/magias/tempestade-divina.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia só pode ser usada em ambientes abertos. A área fica sujeita a um vendaval — ataques à distância sofrem penalidade de –5, chamas são apagadas e névoas e fumaças são dissipadas em 1 rodada. Você também pode causar chuva (–5 em testes de Percepção), neve (como chuva, mais a área se torna terreno difícil) ou granizo (como chuva, mais 1 ponto de dano de impacto por rodada, no início de seus turnos). Criaturas na área recebem uma penalidade de –15m no deslocamento de voo (mínimo 1,5m).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"long","alvo":"","area":"cilindro com 9m de raio e 9m de altura","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["",""]]}],"tipo":"div","circulo":"2","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"WfuyoM5JdO5bcFjN","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"duracao","value":"sustentada","mode":5},{"key":"dano","value":"3d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para sustentada. Além do normal, uma vez por rodada, como uma ação padrão, você pode fazer um relâmpago cair sobre um alvo na área, causando 3d8 pontos de dano de eletricidade (Reflexos reduz à metade).","origin":"Compendium.tormenta20.magias.veCfW87hsFWhz59h","transfer":false},{"_id":"JUP95qhc6V5uLkb3","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se escolheu causar granizo, muda o dano para 1d6.","origin":"Compendium.tormenta20.magias.veCfW87hsFWhz59h","transfer":false},{"_id":"IICNqbp9bQErGEtT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","mode":0,"value":"1d6"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1 dado do mesmo tipo (d6).","origin":"Compendium.tormenta20.magias.veCfW87hsFWhz59h","transfer":false,"tint":null},{"_id":"Jfvb7y8tMe0oRwfx","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se escolheu causar chuva, ela revela criaturas e objetos invisíveis na área.","origin":"Compendium.tormenta20.magias.veCfW87hsFWhz59h","transfer":false},{"_id":"oxXDU2xXfiOQX5Xm","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"7","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se escolheu causar neve, criaturas na área sofrem 2d6 pontos de dano de frio no início de seus turnos.","origin":"Compendium.tormenta20.magias.veCfW87hsFWhz59h","transfer":false},{"_id":"i7wCy0z0SYhs7wZ5","changes":[{"key":"data.attributes.movement.fly","mode":2,"value":"-15"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"-5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/tempestade-divina.webp","label":"Tempestade Divina (Vendaval)","origin":"Item.SK6l5OMgnKXTm1EA","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"SAhyyMWO1buILcqt","changes":[{"key":"data.pericias.perc.bonus","mode":2,"value":"-5"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/tempestade-divina.webp","label":"Tempestade Divina (Chuva)","origin":"Item.SK6l5OMgnKXTm1EA","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null},{"_id":"5BPPxoO16pHevI33","changes":[{"key":"dano","mode":0,"value":"1d8"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1 dado do mesmo tipo (d8).","origin":"Item.SK6l5OMgnKXTm1EA","transfer":false,"flags":{"tormenta20":{"onuse":true,"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"2","durationScene":false}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.DAkw7RgNE6zE9A2a"}}}
{"_id":"vvVVqYlYER6WpqhM","name":"Criar Elementos","type":"magia","img":"systems/tormenta20/icons/magias/criar-elementos.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você cria uma pequena porção de um elemento, a sua escolha. Os elementos criados são reais, não mágicos. Elementos físicos devem surgir em uma superfície. Em vez de um cubo, pode-se criar objetos simples (sem partes móveis) feitos de gelo, terra ou pedra.</p><p style=\"text-align:justify;\"><i>Água:</i> enche um recipiente de tamanho Minúsculo (como um odre) com água potável ou cria um cubo de gelo de tamanho Minúsculo.</p><p style=\"text-align:justify;\"><i>Ar:</i> cria um vento fraco em um quadrado de 1,5m. Isso purifica a área de qualquer gás ou fumaça, ou remove névoa por uma rodada.</p><p style=\"text-align:justify;\"><i>Fogo:</i> cria uma chama que ilumina como uma tocha. Você pode segurá-la na palma de sua mão sem se queimar, ou fazê-la surgir em um quadrado de 1,5m. Se uma criatura ou objeto estiver no quadrado, sofre 1d6 pontos de dano de fogo; se falhar num teste de Reflexos, pega fogo.</p><p style=\"text-align:justify;\"><i>Terra:</i> cria um cubo de tamanho Minúsculo feito de terra, argila ou pedra.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"elemento escolhido","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"Hp8Z2nPlbYVhB8eU","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a quantidade do elemento em um passo (uma categoria de tamanho para água ou terra, +1 quadrado de 1,5m para ar e fogo).","origin":"Compendium.tormenta20.magias.vvVVqYlYER6WpqhM","transfer":false},{"_id":"wK72592kCWxLLTLL","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"resistencia","value":"Reflexos reduz à metade","mode":5},{"key":"dano","value":"2d4","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o efeito para alvo 1 criatura ou objeto e a resistência para Reflexos reduz à metade. Se escolher água ou terra, você arremessa o cubo ou objeto criado no alvo, causando 2d4 pontos de dano de impacto. Para cada categoria de tamanho acima de Minúsculo, o dano aumenta em um passo. O cubo se desfaz em seguida.","origin":"Compendium.tormenta20.magias.vvVVqYlYER6WpqhM","transfer":false},{"_id":"Mz8829iyEZ0ENP6T","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"se escolheu fogo, aumenta o dano inicial de cada chama em +1d6.","origin":"Compendium.tormenta20.magias.vvVVqYlYER6WpqhM","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.G85JKn5ALpAJbMIr"}}}
{"_id":"vwpjRRdyR0iHI1TH","name":"Imobilizar","type":"magia","img":"systems/tormenta20/icons/magias/imobilizar.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">O alvo fica paralisado; se passar na resistência, em vez disso fica lento. A cada rodada, pode gastar uma ação completa para fazer um novo teste de Vontade. Se passar, se liberta do efeito.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 humanóide ou animal","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"fSTTlBXholQ6WJhC","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 espírito","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 espírito.","origin":"Compendium.tormenta20.magias.vwpjRRdyR0iHI1TH","transfer":false},{"_id":"czmZboVVWzbVD2om","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.vwpjRRdyR0iHI1TH","transfer":false},{"_id":"50yF4EBxvj43Q4M7","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura. Requer 4º círculo","origin":"Compendium.tormenta20.magias.vwpjRRdyR0iHI1TH","transfer":false},{"_id":"sjZWBk2nqII7nUdK","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/imobilizar.webp","label":"Imobilizar","origin":"Item.7wYcaxfLVXEccXBy","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.PpdYrxI9UwSNot2P"}}}
{"_id":"vyc0fQ9bSefwjZ0H","name":"Mata-Dragão","type":"magia","img":"systems/tormenta20/icons/magias/mata-dragao.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta é uma das mais poderosas magias de destruição existentes. Após entoar longos cânticos, o conjurador dispara uma carga de energia que varre uma enorme área à sua frente, causando 20d12 pontos de dano de essência em todas as criaturas, construções e objetos livres atingidos. Apesar de seu poder destrutivo, esta magia é lenta, tornando seu uso difícil em combate. Além disso, pode causar tantos danos colaterais que poucos conjuradores se arriscam a utilizá-la.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"special","custo":15,"qtd":"","condicao":"","special":"2 Rodadas"},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"cone","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Reflexos reduz à metade"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["20d12",""]]}],"tipo":"arc","circulo":"5","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"urJP9nlZMdgYd00A","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[{"key":"dano","value":"1d12","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em 1d12.","origin":"Compendium.tormenta20.magias.vyc0fQ9bSefwjZ0H","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.T1PiqtZfJU2FoLAr"}}}
{"_id":"wXiJf2x05HqH5B6P","name":"Alterar Tamanho","type":"magia","img":"systems/tormenta20/icons/magias/alterar-tamanho.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia aumenta ou diminui o tamanho de um item mundano em at&eacute; tr&ecirc;s categorias (um objeto Enorme vira Pequeno, por exemplo). Voc&ecirc; tamb&eacute;m pode mudar a consist&ecirc;ncia do item, deixando-o r&iacute;gido como pedra ou flex&iacute;vel como seda (isso n&atilde;o altera sua RD ou PV, apenas suas propriedades f&iacute;sicas).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 dia","units":"special","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 objeto","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"HVWDInqh2swfM9NB","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":true,"custo":"1","durationScene":false,"onuse":true}},"changes":[{"key":"alvo","value":"1","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"aumenta o número de alvos em +1.","origin":"Item.UjPqDyQosaR9StGX","tint":null,"transfer":false},{"_id":"Os1QpQXkllq68WBr","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"2","durationScene":false,"onuse":true}},"changes":[{"key":"alcance","mode":5,"value":"Toque"},{"key":"alvo","mode":5,"value":"1 criatura"},{"key":"reistencia","mode":5,"value":"Fortitude anula"},{"key":"efeito","mode":2,"value":"Tamanho Aumentado"},{"key":"data.tracos.tamanho","mode":0,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alcance para toque e o alvo para 1 criatura. Em vez do normal, o alvo e seu equipamento aumentam de tamanho em uma categoria. O alvo também recebe Força +4. Um alvo involuntário pode fazer um teste de Fortitude para negar o efeito.","origin":"Item.UjPqDyQosaR9StGX","tint":null,"transfer":false},{"_id":"oP2xU4GWsFT7QZAa","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"3","durationScene":false,"onuse":true}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5},{"key":"efeito","value":"Fortitude anula","mode":5},{"key":"data.tracos.tamanho","value":"-1","mode":0},{"key":"efeito","value":"Tamanho Reduzido","mode":2}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alcance para toque e o alvo para 1 criatura. Em vez do normal, o alvo e seu equipamento diminuem de tamanho em uma categoria. O alvo também recebe Destreza +4. Um alvo involuntário pode fazer um teste de Fortitude para negar o efeito. Requer 3o círculo.","origin":"Item.UjPqDyQosaR9StGX","tint":null,"transfer":false},{"_id":"uurtgE1BFd5Jt342","flags":{"onuse":true,"t20":null,"tormenta20":{"self":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"aumenta":false,"custo":"7","durationScene":false,"onuse":true}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"1 criatura","mode":5},{"key":"reistencia","value":"Fortitude Anula","mode":5},{"key":"efeito","value":"Tamanho Minúsculo","mode":0},{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/aura.svg","label":"muda o alcance para toque, o alvo para 1 criatura, a duração para permanente e a resistência para Fortitude anula. Em vez do normal, se falhar na resistência o alvo e seu equipamento têm seu tamanho mudado para Minúsculo. O alvo também tem seu valor de Força reduzido a 1 e suas formas de deslocamento reduzidas a 3m. Requer 4o círculo.","origin":"Item.UjPqDyQosaR9StGX","tint":null,"transfer":false},{"_id":"JOgtB6qBRsJDTWGr","flags":{"onuse":false,"t20":null,"tormenta20":{"durationScene":false}},"changes":[{"key":"data.atributos.for.bonus","mode":2,"value":"4"}],"disabled":false,"duration":{"startTime":null,"seconds":86400},"icon":"systems/tormenta20/icons/magias/alterar-tamanho.webp","label":"Tamanho Aumentado (Criatura)","origin":"Item.UjPqDyQosaR9StGX","tint":null,"transfer":false},{"_id":"HLrhcQDKmFvW5e0k","flags":{"onuse":false,"t20":null,"tormenta20":{"durationScene":false,"onuse":false}},"changes":[{"key":"data.atributos.des.bonus","mode":2,"value":"4"}],"disabled":false,"duration":{"startTime":null,"seconds":86400},"icon":"systems/tormenta20/icons/magias/alterar-tamanho.webp","label":"Tamanho Reduzido (Criatura)","origin":"Item.UjPqDyQosaR9StGX","tint":null,"transfer":false},{"_id":"nEUrBHlV305ewLqE","changes":[{"key":"data.atributos.for.value","mode":5,"value":"1"},{"key":"data.attributes.movement.walk","mode":5,"value":"3"},{"key":"data.attributes.movement.burrow","mode":5,"value":"3"},{"key":"data.attributes.movement.climb","mode":5,"value":"3"},{"key":"data.attributes.movement.fly","mode":5,"value":"3"},{"key":"data.attributes.movement.swim","mode":5,"value":"3"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/alterar-tamanho.webp","label":"Alterar Tamanho (Minúsculo)","origin":"Item.Mx354sk6VPfY9hK8","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.FZfG5x5I8z7cUc2A"}}}
{"_id":"wbPt3fdyHUpdZoLF","name":"Forma Etérea","type":"magia","img":"systems/tormenta20/icons/magias/forma-eterea.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você e todo o equipamento que está com você são transportados para o plano etéreo, que existe paralelamente ao plano material (o mundo físico). Na prática, é como ser transformado em um fantasma (mas você ainda é considerado uma criatura viva). Uma criatura etérea é invisível (pode alterar entre visível e invisível como ação livre), incorpórea e capaz de se mover em qualquer direção, inclusive para cima e para baixo. Ela enxerga o plano material, mas tudo parece cinza e insubstancial, reduzindo o alcance da visão e audição para 18m. Magias de abjuração e essência afetam criaturas etéreas, mas outras magias, não. Da mesma forma, uma criatura etérea não pode atacar nem lançar magias contra criaturas no plano material. Duas criaturas etéreas podem se afetar normalmente. Uma criatura afetada pode se materializar como uma ação de movimento, encerrando a magia. Uma criatura etérea que se materialize em um espaço ocupado é jogada para o espaço não ocupado mais próximo e sofre 1d6 pontos de dano de impacto para cada 1,5m de deslocamento.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"self","alvo":"Você","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"tra","chatFlavor":""},"effects":[{"_id":"pCpnSAcgeRCehbS0","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"Toque","mode":5},{"key":"alvo","value":"até 5 criaturas voluntárias que estejam de mãos dadas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para toque e o alvo para até 5 criaturas voluntárias que estejam de mãos dadas. Depois que a magia é lançada, as criaturas podem soltar as mãos. Requer 5º círculo.","origin":"Compendium.tormenta20.magias.wbPt3fdyHUpdZoLF","transfer":false},{"_id":"YY9Aok6sOuZPDfA5","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/forma-eterea.webp","label":"Forma Etérea","origin":"Item.zOGUwXhKmLh6cM7W","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.hlRhKX0YXEeZfWhX"}}}
{"_id":"wuqyoslFlYe2zgCp","name":"Tranquilidade","type":"magia","img":"systems/tormenta20/icons/magias/tranquilidade.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você emana ondas de serenidade. Se falhar na resistência, o alvo tem sua atitude mudada para indiferente (veja Diplomacia no Capítulo 2) e não pode atacar ou realizar qualquer ação agressiva. Se passar, sofre –2 em testes de ataque. Qualquer ação hostil contra o alvo ou seus aliados dissipa a magia e faz ele retornar à atitude que tinha antes (ou pior, de acordo com o mestre).</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 animal ou humanóide","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"NVI6QjnLauWHcDLx","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[{"key":"alvo","value":"1 criatura","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para 1 criatura.","origin":"Compendium.tormenta20.magias.wuqyoslFlYe2zgCp","transfer":false},{"_id":"HvFXSGLtaUOURcBd","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de alvos em +1.","origin":"Compendium.tormenta20.magias.wuqyoslFlYe2zgCp","transfer":false},{"_id":"aNhfPENXwE7CaFoj","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.modificadores.pericias.ataque","mode":2,"value":"-1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta a penalidade em –1.","origin":"Compendium.tormenta20.magias.wuqyoslFlYe2zgCp","transfer":false,"tint":null},{"_id":"M3sGod8S4s0hvu8A","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"alcance","value":"médio","mode":5},{"key":"alvo","value":"criaturas escolhidas","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alcance para médio e o alvo para criaturas escolhidas. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.wuqyoslFlYe2zgCp","transfer":false},{"_id":"Kb2Ft0450viFIuQr","changes":[{"key":"data.modificadores.pericias.ataque","mode":2,"value":"-2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/tranquilidade.webp","label":"Tranquilidade","origin":"Item.h1DFW7RU5rbIA0oM","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.cr97efu5mEuVAS9e"},"cf":null}}
{"_id":"wwMqDi0m8o2Jnhw5","name":"Servos Invisíveis","type":"magia","img":"systems/tormenta20/icons/magias/servos-invisiveis.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você cria até três servos invisíveis e silenciosos, capazes de realizar tarefas simples como apanhar lenha, colher frutos, varrer o chão ou alimentar um cavalo. Os servos podem ser usados para manter arrumada e organizada uma mansão ou pequena torre ou para preparar um acampamento nos ermos para você e seus aliados (veja a perícia Sobrevivência, na página 123).</p><p style=\"text-align:justify;\">Eles também podem ajudá-lo em tarefas mais complexas, como fazer uma pesquisa ou preparar uma poção, mas isso consome sua energia mágica. Você pode “gastar” um servo para receber um bônus não cumulativo de +2 em um teste de perícia (exceto testes de ataque e resistência). Os servos não são criaturas reais; não podem lutar, nem resistir a qualquer dano ou efeito que exija um teste de resistência ou teste oposto — falharão automaticamente no teste e serão destruídos.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1 cena","units":"scene","special":"","valor":"1 cena","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"criaturas conjuradas","alcance":"long","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"K1me4oYjZtNejwvZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o número de servos conjurados em 1.","origin":"Compendium.tormenta20.magias.wwMqDi0m8o2Jnhw5","transfer":false},{"_id":"ve8JZ5XOoHV96cNY","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"você pode comandar os servos para realizar uma única tarefa no seu lugar. Em termos de jogo, eles passam automaticamente em um teste de perícia com CD máxima igual ao seu nível, +2 para cada servo conjurado. O tempo necessário para realizar a tarefa é o tempo do uso da perícia em questão. Requer 3º círculo","origin":"Compendium.tormenta20.magias.wwMqDi0m8o2Jnhw5","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.jOLdWWSfYkCFx8HQ"}}}
{"_id":"wzEx37udhiSSTeFD","name":"Raio Solar","type":"magia","img":"systems/tormenta20/icons/magias/raio-solar.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você canaliza uma poderosa rajada de energia positiva que ilumina o campo de batalha. Criaturas na área sofrem 4d8 pontos de dano de luz (ou 4d12, se forem mortos-vivos) e ficam ofuscadas por uma rodada. Se passarem na resistência, sofrem metade do dano e não ficam ofuscadas.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"medium","alvo":"","area":"linha","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Reflexos (veja texto)"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["4d8",""]]}],"tipo":"div","circulo":"2","preparada":false,"escola":"evo","chatFlavor":""},"effects":[{"_id":"02fF0HaEnzjjxWCk","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"","aumenta":false}},"changes":[{"key":"duracao","value":"Cena","mode":5},{"key":"resistencia","value":"nenhuma","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para cena e a resistência para nenhuma. Em vez do normal, cria um facho de luz que ilumina a área da magia. Uma vez por rodada, você pode mudar a direção do facho como uma ação livre.","origin":"Compendium.tormenta20.magias.wzEx37udhiSSTeFD","transfer":false},{"_id":"0scxuZfMACRm0MaF","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true}},"changes":[{"key":"dano","value":"1d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano ou cura em +1d8 (ou +1d12 em mortos-vivos).","origin":"Compendium.tormenta20.magias.wzEx37udhiSSTeFD","transfer":false},{"_id":"OfviaR1sdHH8ZLYT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"dano","value":"4d8","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"em vez do normal, criaturas vivas a sua escolha na área curam 4d8 pontos de vida; o restante sofre o dano normalmente.","origin":"Compendium.tormenta20.magias.wzEx37udhiSSTeFD","transfer":false},{"_id":"VNfMJgm411DpDTdQ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"criaturas que falhem na resistência ficam cegas por 1d4 rodadas.","origin":"Compendium.tormenta20.magias.wzEx37udhiSSTeFD","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.qmi4Qv4060eZHSr9"}}}
{"_id":"xFlTNVAkliPUlDta","name":"Semiplano","type":"magia","img":"systems/tormenta20/icons/magias/semiplano.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você cria um semiplano — uma dimensão particular. Você pode entrar no semiplano gastando uma ação padrão e 1 PM, desaparecendo do plano material como se tivesse se teletransportado. Você pode levar criaturas voluntárias que esteja tocando, ao custo de 1 PM por criatura extra. Você também pode levar objetos que esteja tocando, ao custo de 1 PM por 200kg. Uma vez no semiplano, você pode gastar uma ação completa para voltar ao plano material, no mesmo local onde estava. Caso conheça a magia Viagem Planar, pode lançá-la para voltar ao plano material em outro local.</p><p style=\"text-align:justify;\">Você escolhe a forma e a aparência do semiplano — uma caverna, um asteroide que singra o éter, um palacete de cristal etc. Ele contém ar, luz e calor, mas além disso é vazio. Entretanto, você pode levar itens (mobília, ferramentas etc.) a cada viagem.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"semiplano com 30m de lado","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"5","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"A6olwAs12FJ8PebT","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"adiciona alvo (1 criatura). Você cria uma semiplano labiríntico e expulsa o alvo para ele. A cada rodada, a\nvítima tem direito a um teste de Investigação ou Sobrevivência (CD da magia) para escapar do labirinto, com bônus cumulativo de +2 para cada teste já realizado. Quando o alvo escapa, a magia termina e o alvo reaparece no plano material no mesmo local onde estava quando a magia foi lançada. Magias como Salto Dimensional e Teletransporte não ajudam a escapar do labirinto, mas Viagem Planar, sim.","origin":"Compendium.tormenta20.magias.xFlTNVAkliPUlDta","transfer":false,"tint":null},{"_id":"7eSeMG1wnGoC1S55","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para permanente e adiciona componente material (diorama do semiplano feito de materiais preciosos no valor de T$ 5.000). Você pode lançar a magia diversas vezes para aumentar as dimensões do semiplano em +30m de lado a cada vez.","origin":"Compendium.tormenta20.magias.xFlTNVAkliPUlDta","transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.imZ1aL8vUSDg6jYT"}}}
{"_id":"xfYTGGsdd81Pa0AN","name":"Adaga Mental","type":"magia","img":"systems/tormenta20/icons/magias/adaga-mental.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Voc&ecirc; manifesta e dispara uma adaga imaterial contra a mente do alvo, que sofre 2d6 pontos de dano mental e fica pasmo por uma rodada. Se passar no teste de resist&ecirc;ncia, sofre apenas metade do dano, n&atilde;o fica pasmo e n&atilde;o pode mais ficar pasmo por esta magia at&eacute; o final da cena.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":"","comprimento":null,"unidades":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Vontade parcial"},"rolls":[{"name":"Dano","key":"dano0","type":"dano","parts":[["2d6",""]]}],"tipo":"arc","circulo":"1","preparada":false,"escola":"enc","chatFlavor":""},"effects":[{"_id":"fORHsYOz2U1D8N5k","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"você lança a magia sem gesticular ou\npronunciar palavras (o que permite lançar essa magia de armadura) e a adaga se torna invisível. Se o alvo falhar no teste de resistência, não percebe que você lançou uma magia\ncontra ele.","origin":"Item.IQrZTuimhJHEW9at","transfer":false,"tint":null},{"_id":"EkX61NpwVj1yC0Mo","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"duracao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para 1 dia. Além do normal, você “finca” a adaga na mente do alvo. Enquanto a magia durar, você sabe a direção e localização do alvo, desde que ele esteja no mesmo mundo.","origin":"Item.IQrZTuimhJHEW9at","tint":null,"transfer":false},{"_id":"MeJCcH3OCS1Y12zZ","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"dano","value":"1d6","mode":0}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o dano em +1d6.","origin":"Item.IQrZTuimhJHEW9at","tint":null,"transfer":false},{"_id":"Qb05w1R82YFgBoIB","flags":{"t20":null,"tormenta20":{"onuse":false,"durationScene":false}},"changes":[],"disabled":false,"duration":{"startTime":null,"rounds":1},"icon":"icons/svg/aura.svg","label":"Pasmo","origin":"Item.IQrZTuimhJHEW9at","tint":null,"transfer":false}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.E9UitKPfwJPDlA04"}}}
{"_id":"xujhDNzdQOOdWoTo","name":"Explosão Caleidoscópica","type":"magia","img":"systems/tormenta20/icons/magias/explosao-caleidoscopica.webp","data":{"description":{"value":"<p style=\"text-align: justify;\">Esta magia cria uma forte explos&atilde;o de luzes estrobosc&oacute;picas e sons cacof&ocirc;nicos que desorientam as criaturas atingidas. O efeito que cada criatura sofre depende do ND dela.</p>\n<p style=\"text-align: justify;\"><em>ND 4 ou menor:</em> se falhar no teste de resist&ecirc;ncia, fica inconsciente. Se passar, fica atordoada por 1d4 rodadas e enjoada pelo resto da cena.</p>\n<p style=\"text-align: justify;\"><em>ND entre 5 e 9:</em> se falhar no teste de resist&ecirc;ncia, fica atordoada por 1d4 rodadas e enjoada pelo resto da cena. Se passar, fica atordoada por 1 rodada e enjoada por 1d4 rodadas.</p>\n<p style=\"text-align: justify;\"><em>ND 10 ou maior:</em> se falhar no teste de resist&ecirc;ncia, fica atordoada por 1 rodada e enjoada por 1d4 rodadas. Se passar, fica desprevenida e enjoada por 1 rodada.</p>\n<p style=\"text-align: justify;\">Criaturas que passem em seus testes de resist&ecirc;ncia n&atilde;o poder&atilde;o mais ser atordoadas&nbsp;por esta magia at&eacute; o fim da cena.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"","area":"esfera de 6m de raio","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":"Fortitude parcial"},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.JhLWmuAPq0CcEwyz"}}}
{"_id":"y0AkIvcwBstmPcpX","name":"Vidência","type":"magia","img":"systems/tormenta20/icons/magias/videncia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Através de uma superfície reflexiva (bacia de água benta para clérigos, lago para druidas, bola de cristal para magos, espelho para feiticeiros etc.) você pode ver e ouvir uma criatura escolhida e seus arredores (cerca de 6m em qualquer direção), mesmo que ela se mova. O alvo pode estar a qualquer distância, mas se passar em um teste de Vontade, a magia falha. A vítima recebe bônus ou penalidades em seu teste de resistência, dependendo do conhecimento que você tiver dela.</p><ul><li>Não conhece o alvo: +10.</li><li>Ouviu falar do alvo: +5.</li><li>O alvo está em outro plano ou mundo: +5.</li><li>Já encontrou o alvo pessoalmente: +0.</li><li>Tem uma pintura, escultura ou outra representação do alvo: –2.</li><li>Conhece bem o alvo: –5.</li><li>Tem um pertence pessoal ou peça de roupa do alvo: –5.</li><li>Tem uma parte do corpo do alvo (unhas, cabelos...): –10.</li></ul></p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"full","custo":6,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"sust","special":"","valor":"","unidade":"sustentada"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"none","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade anula"},"rolls":[],"tipo":"uni","circulo":"3","preparada":false,"escola":"adv","chatFlavor":""},"effects":[],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.ywVzwB6WnEOGBTlX"}}}
{"_id":"yw8aypIy198lFNCE","name":"Lágrimas da Deusa da Magia","type":"magia","img":"systems/tormenta20/icons/magias/lagrimas-da-deusa-da-magia.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Se falhar no teste de resistência, o alvo perde a habilidade de lançar magias arcanas até o fim da cena. Se passar, perde a habilidade por uma rodada.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":15,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"inst","special":"","valor":"","unidade":"instant"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"short","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":"Vontade parcial"},"rolls":[],"tipo":"div","circulo":"5","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"nYdSOq8aCeFORZSI","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"area","mode":5,"value":"círculo de 6m de raio"},{"key":"alvo","mode":5,"value":"criaturas escolhidas"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a área para esfera de 6m de raio e o alvo para criaturas escolhidas.","origin":"Compendium.tormenta20.magias.yw8aypIy198lFNCE","transfer":false,"tint":null},{"_id":"6PGbiz0Yp8Y1Dm86","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[{"key":"execucao","value":"1 dia","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para 1 dia e adiciona custo adicional (sacrifício de 1 PM). O alvo da magia precisa ser mantido em alcance curto do conjurador durante toda a execução. Ao término, faz um teste de Vontade. Se falhar, perde a habilidade de lançar magias arcanas permanentemente. Se passar, resiste, mas ainda pode ser alvo da magia no dia seguinte. Nenhum poder mortal é capaz de reverter essa perda. Os clérigos da deusa da Magia dizem que a deusa chora cada vez que este ritual é realizado.","origin":"Compendium.tormenta20.magias.yw8aypIy198lFNCE","transfer":false},{"_id":"21kB3mrglIlYUWAC","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/lagrimas-da-deusa-da-magia.webp","label":"Lágrimas da Deusa da Magia","origin":"Item.NUpTGosxznyLdSPV","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.pUXq40GNKki8ij1m"}}}
{"_id":"z9cFTeixJ1wt1HyE","name":"Montaria Arcana","type":"magia","img":"systems/tormenta20/icons/magias/montaria-arcana.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia convoca um cavalo de batalha que serve como um aliado montaria veterano. Sua aparência é de um animal negro com crina e cauda cinzentas e cascos feitos de fumaça, mas você pode mudá-la se quiser. Além dos benefícios normais, a Montaria Arcana pode atravessar terreno difícil sem redução em seu deslocamento.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":3,"qtd":"","condicao":"","special":""},"duracao":{"value":"1","units":"day","special":"","valor":"1 dia","unidade":"outra"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"criatura conjurada","alcance":"short","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"2","preparada":false,"escola":"con","chatFlavor":""},"effects":[{"_id":"yxJYcH0QAWQDJCTy","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"1","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"além do normal, criaturas do tipo animal em alcance curto da montaria devem fazer um teste de Vontade. Se passarem, ficam abaladas pela cena; se falharem, ficam apavoradas por 1d4 rodadas, depois abaladas pela cena.","origin":"Compendium.tormenta20.magias.z9cFTeixJ1wt1HyE","transfer":false},{"_id":"p8mUjnwHq97nbSZH","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[{"key":"duracao","value":"permanente","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a duração para permanente e adiciona sacrifício de 1 PM.","origin":"Compendium.tormenta20.magias.z9cFTeixJ1wt1HyE","transfer":false},{"_id":"yxZf87cOWDgpxGCz","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":true}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o tamanho da montaria em uma categoria. Isso também aumenta o número de criaturas que ela pode carregar — duas para uma criatura Enorme, seis para Colossal. Uma única criatura controla a montaria; as outras apenas são deslocadas.","origin":"Compendium.tormenta20.magias.z9cFTeixJ1wt1HyE","transfer":false},{"_id":"nb5IXMwsn8UPR1k4","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o nível do aliado para mestre. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.z9cFTeixJ1wt1HyE","transfer":false,"tint":null},{"_id":"ucTdFCjgr0EtdyfQ","changes":[{"key":"data.attributes.movement.walk","mode":5,"value":"15"},{"key":"data.modificadores.ataque.cac","mode":2,"value":"2"},{"key":"data.modificadores.ataque.ad","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/montaria-arcana.webp","label":"Montaria (Cavalo) Veterana","origin":"Item.IJ0YANfQNNhEKHC3","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.W7BzpbM3XkGnn48e"}}}
{"_id":"zfFIZLWoyI32pMfl","name":"Proteção Divina","type":"magia","img":"systems/tormenta20/icons/magias/protecao-divina.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Esta magia cria uma barreira mística invisível que fornece ao alvo +2 em testes de resistência.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":1,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"","alcance":"touch","alvo":"1 criatura","area":"","resistencia":{"pericia":"","atributo":"sab","bonus":0,"txt":""},"rolls":[],"tipo":"div","circulo":"1","preparada":false,"escola":"abj","chatFlavor":""},"effects":[{"_id":"7FKquN1OyrnomRVC","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":true,"skill":false,"attack":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"data.pericias.fort.bonus","mode":2,"value":"1"},{"key":"data.pericias.refl.bonus","mode":2,"value":"1"},{"key":"data.pericias.vont.bonus","mode":2,"value":"1"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"aumenta o bônus concedido em +1.","origin":"Compendium.tormenta20.magias.zfFIZLWoyI32pMfl","transfer":false,"tint":null},{"_id":"s2Co8Gxq7NXHauUM","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false}},"changes":[{"key":"execucao","value":"reação","mode":5},{"key":"alcance","value":"curto","mode":5},{"key":"duracao","value":"1 rodada","mode":5}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda a execução para reação, o alcance para curto e a duração para 1 rodada","origin":"Compendium.tormenta20.magias.zfFIZLWoyI32pMfl","transfer":false},{"_id":"GWawsOeKpln3gxxn","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"2","aumenta":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":false,"consumable":false,"durationScene":false}},"changes":[{"key":"alvo","mode":5,"value":"área de círculo com 3m de raio"}],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"muda o alvo para área de esfera com 3m de raio. Todos os aliados dentro da esfera recebem o bônus da magia. Requer 2º círculo.","origin":"Compendium.tormenta20.magias.zfFIZLWoyI32pMfl","transfer":false,"tint":null},{"_id":"ixLPCV65hpLSuxc1","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"5","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"também torna o alvo imune a efeitos de encantamento. Requer 3º círculo.","origin":"Compendium.tormenta20.magias.zfFIZLWoyI32pMfl","transfer":false},{"_id":"imwY3XLCzTPuADV7","changes":[{"key":"data.pericias.fort.bonus","mode":2,"value":"2"},{"key":"data.pericias.refl.bonus","mode":2,"value":"2"},{"key":"data.pericias.vont.bonus","mode":2,"value":"2"}],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/protecao-divina.webp","label":"Proteção Divina","origin":"Item.dEcKsALEP8soUECG","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.1zPVUNczk6X1gjSt"},"cf":null}}
{"_id":"zlHOKjfs1K3L6xGI","name":"Duplicata Ilusória","type":"magia","img":"systems/tormenta20/icons/magias/duplicata-ilusoria.webp","data":{"description":{"value":"<p style=\"text-align:justify;\">Você cria uma cópia ilusória semirreal de... você mesmo! Ela é idêntica em aparência, som e cheiro, mas é intangível. A cada turno, você escolhe se verá e ouvirá através da duplicata ou de seu corpo original. A cópia reproduz todas as suas ações, incluindo fala. Qualquer magia com alcance de toque ou maior que você lançar pode se originar da duplicata, em vez do seu corpo original. As magias afetam outros alvos normalmente, com a única diferença de se originarem da cópia, em vez de você. Se quiser que a duplicata faça algo diferente de você, você deve gastar uma ação de movimento. Qualquer criatura que interagir com a cópia tem direito a um teste de Vontade para perceber que é uma ilusão. As magias que se originam dela, no entanto, são reais. A cópia desaparece se sair do alcance.</p>","chat":"","unidentified":""},"source":"","ativacao":{"execucao":"action","custo":10,"qtd":"","condicao":"","special":""},"duracao":{"value":"","units":"scene","special":"","valor":"","unidade":"cena"},"target":{"value":null,"width":null,"units":"","type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":null,"amount":null},"efeito":"cópia ilusória","alcance":"medium","alvo":"","area":"","resistencia":{"pericia":"","atributo":"int","bonus":0,"txt":""},"rolls":[],"tipo":"arc","circulo":"4","preparada":false,"escola":"ilu","chatFlavor":""},"effects":[{"_id":"W6hp2Ht89NjwBphP","flags":{"t20":null,"tormenta20":{"onuse":true,"self":true,"custo":"3","aumenta":false}},"changes":[],"disabled":true,"duration":{"startTime":null},"icon":"icons/svg/upgrade.svg","label":"cria uma cópia adicional.","origin":"Compendium.tormenta20.magias.zlHOKjfs1K3L6xGI","transfer":false},{"_id":"RItlzTJ28IdM0zoO","changes":[],"disabled":false,"duration":{"rounds":1,"startTime":null},"icon":"systems/tormenta20/icons/magias/duplicata-ilusoria.webp","label":"Duplicata Ilusória","origin":"Item.jpSbAq1ko8aO6jr9","transfer":false,"flags":{"tormenta20":{"onuse":false,"durationScene":true}},"tint":null}],"folder":"FbPjEgczM7veRyer","sort":0,"permission":{"default":0},"flags":{"core":{"sourceId":"Item.H2VWnpXlkCImmClL"}}}

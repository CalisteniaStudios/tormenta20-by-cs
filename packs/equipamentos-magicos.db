{"_id":"01uzk8l2pN2tDIfq","name":"Lanterna da Revelação","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/lanterna-da-revelacao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.01uzk8l2pN2tDIfq"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este item funciona como um lampião normal, mas sua luz revela todas as criaturas e objetos invisíveis em alcance curto.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000084,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"02lvsZmWSfVanJi0","name":"Cajado da Destruição","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/cajado-da-destruicao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.02lvsZmWSfVanJi0"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este bordão formidável escuro e reforçado com ponteiras de metal é procurado por conjuradores de batalha. Quando você lança uma magia de dano, ela causa +1 ponto de dano por dado.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","impacto",""],["@for","",""],["+2","impacto",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"-","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000085,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"0gjHApA2kZhUpeBc","name":"Azagaia dos Relâmpagos","type":"consumivel","img":"systems/tormenta20/icons/itens/itens-magicos/azagaia-do-relampago.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.0gjHApA2kZhUpeBc"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Quando arremessada, esta azagaia se transforma em um <i>Relâmpago</i> (6d6 de dano de eletricidade numa linha com alcance médio). Quando atinge o fim do alcance ela volta a ser uma azagaia e cai no chão.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":1,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"ativacao":{"execucao":"","custo":0,"qtd":"","condicao":"","special":""},"duracao":{"value":0,"units":"inst","special":""},"target":{"value":null,"width":null,"type":""},"range":{"value":null,"units":""},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"efeito":"6d6","alcance":"medium","alvo":"","area":"Linha","resistencia":{"pericia":"","atributo":"sab","bonus":20,"txt":"Reflexos reduz à metade"},"rolls":[{"type":"dano","key":"dano0","name":"Dano","parts":[["6d6","",""]],"versatil":""}],"tipo":"ammo","uses":{"autoDestroy":false},"chatFlavor":"","origin":"","tags":[],"subtipo":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000085,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"1ZXiPXFQmdWUr51u","name":"Punhal Traiçoeiro","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/punhal-traicoeiro.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.1ZXiPXFQmdWUr51u"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>adaga assassina formidável venenosa</strong> tem l&acirc;mina negra e ondulada. Você pode gastar uma ação padrão e 2 PM para transformar o punhal traiçoeiro em um objeto inofensivo de tamanho similar, como uma colher ou pena. Nenhuma magia é capaz de detectar essa transformação. Transformar o punhal em arma é uma ação livre.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":0.5,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d4","perfuracao",""],["@for","",""],["+2","perfuracao",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":true,"dst":false,"dms":false,"dup":false,"lev":true,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":true,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":true,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000086,"modifiedTime":1666662796833,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"2ulfzRqI448ZZ04i","name":"Gema da Luminosidade","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/gema-da-luminosidade.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.2ulfzRqI448ZZ04i"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este cristal tem a aparência de um longo prisma. Com um comando, emite luz equivalente a uma tocha ou então um raio brilhante, que força uma criatura em alcance curto a passar em um teste de Fortitude ou ficar cega por [[/r 1d4]] rodadas.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000086,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"34ZGhD61vaoBYaZD","name":"Escudo do Conjurador","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/escudo-do-conjurador.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.34ZGhD61vaoBYaZD"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>escudo leve defensor</strong> tem uma pequena tira de couro na parte interna, sobre a qual um conjurador pode lançar uma magia. A magia não surte efeito na hora; em vez disso, fica inscrita na tira. A tira pode então ser lida como um pergaminho. Uma vez que a magia seja lançada, outra pode ser inscrita.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":3,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"escudo","armadura":{"value":3,"penalidade":-1,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000086,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"402QJlcWzp7gaZYo","name":"Cinto do Campeão","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/cinto-do-campeao.webp","effects":[{"label":"Cinto do Campeão","icon":"systems/tormenta20/icons/itens/itens-magicos/cinto-do-campeao.webp","origin":"Item.402QJlcWzp7gaZYo","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"2F2h8pqnK77FT9eA","changes":[{"key":"system.atributos.for.value","mode":2,"value":"1","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.402QJlcWzp7gaZYo"}},"system":{"description":{"value":"<p>Este cintur&atilde;o de ouro &eacute; cravejado de joias e possui gravuras de gladiadores e pugilistas minotauros. Voc&ecirc; recebe +1 em For&ccedil;a e a habilidade @UUID[Compendium.tormenta20.poderes.1gvsbH8ljOuhBdKM]{Briga} (veja a p&aacute;gina 76). Caso j&aacute; a possua, seu dano desarmado ser&aacute; calculado como se voc&ecirc; possu&iacute;sse quatro n&iacute;veis de lutador a mais (m&aacute;ximo 2d12). Por fim, caso possua o poder Torcida, o b&ocirc;nus que voc&ecirc; recebe por ele aumenta para +3. Em tempos antigos, estes cintos eram dados aos vencedores dos jogos gladiatoriais do Imp&eacute;rio de Tauron. A cada ano, diversos combatentes de toda Arton viajavam a Tiberus para competir e ter uma chance de ganhar um destes itens.</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":51000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000087,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"56TGgR3gpMyWTVq2","name":"Botas Aladas","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/botas-aladas.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.56TGgR3gpMyWTVq2"}},"system":{"description":{"value":"Você pode gastar 2 PM para fazer asas brotarem dos calcanhares destas botas e receber deslocamento de voo 12m por uma rodada. Você pode gastar 1 PM no início de cada um de seus turnos para manter esse efeito.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":15000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"ativacao":{"custo":2},"origin":"","tags":[],"chatFlavor":"","melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000087,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"5L8PBHcigod9Qav1","name":"Brincos da Sagacidade","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/brincos.webp","effects":[{"label":"Brincos da Sagacidade","icon":"systems/tormenta20/icons/itens/itens-magicos/brincos.webp","origin":"Item.5L8PBHcigod9Qav1","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"z5qXS98E4zZASqU9","changes":[{"key":"system.atributos.int.value","mode":2,"value":"2","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.5L8PBHcigod9Qav1"}},"system":{"description":{"value":"Este par de brincos de safira aguça o raciocínio. Você recebe +2 em Inteligência (mas não recebe perícias treinadas extras).","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":4500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000088,"modifiedTime":1666662783383,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"7ZSpOEZBMbT3aVsO","name":"Lâmina da Luz","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/lamina-da-luz.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.7ZSpOEZBMbT3aVsO"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">De l&acirc;mina prateada e reluzente, esta <strong>espada bastarda formidável</strong> é concedida a cavaleiros da Luz de honra e virtude comprovadas. Você pode gastar uma ação de movimento e 2 PM para erguer a l&acirc;mina da luz acima de sua cabeça. Se fizer isso, ela irradia luz brilhante em alcance médio até o fim da cena. Todos os inimigos dentro da luz ficam ofuscados.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":3,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d10","corte",""],["@for","",""],["+2","corte",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"-","tipoUso":"exo","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000088,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"8BBFvJdLe3sCiX8f","name":"Vingadora Sagrada","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/vingadora-sagrada.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.8BBFvJdLe3sCiX8f"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>espada longa formidável </strong>revela todo o seu poder apenas quando empunhada por um paladino. Nessa situação, ela fornece +5 em testes de ataque e rolagens de dano, +5 nos testes de resistência contra magia ao paladino e aliados em alcance curto, e reduz o custo de Golpe Divino em &ndash;1 PM.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["7","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","impacto",""],["@for","",""],["+7","impacto",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000088,"modifiedTime":1666662796833,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"8tAO6PDX7s5DJOiN","name":"Machado Silvestre","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/machado-silvestre.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.8tAO6PDX7s5DJOiN"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">O cabo e a l&acirc;mina deste <strong>machado de batalha formidável</strong> são cobertos de gravuras representando plantas e animais selvagens. Quando você usa o machado silvestre em um ambiente ermo e ao ar livre, causa +[[/r 1d8]] de dano e recebe o poder Trespassar. Caso já possua este poder, pode utilizá-lo sem pagar pontos de mana.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":3,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","corte",""],["@for","",""],["+2","corte",""]],"versatil":""}],"criticoM":20,"criticoX":3,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000090,"modifiedTime":1666662796833,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"AJEwZYS6iJvqdQlr","name":"Colar Guardião","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/colar-guardiao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.AJEwZYS6iJvqdQlr"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este diamante lapidado preso em uma corrente de platina deflete ataques contra seu usuário. Você recebe +5 em Defesa.</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":51000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":5,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000090,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"AUDPOjclJNiX4Xlm","name":"Baluarte Anão","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/baluarte-anao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.AUDPOjclJNiX4Xlm"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>armadura completa reforçada defensora de adamante</strong> fornece proteção sem igual. Se você não se deslocar em seu turno, a RD que ela fornece aumenta para 10 até seu próximo turno.</p>\n<p style=\"text-align:justify;\"><strong>Reforçada.</strong>&nbsp;Placas adicionais, uma camada extra de cota de malha ou acolchoamento, proteção dobrada nas juntas e áreas vulneráveis... O bônus na Defesa e a penalidade de armadura de uma armadura ou escudo com esta modificação aumentam em +1. Uma armadura não pode ser reforçada e delicada.</p>\n<p style=\"text-align:justify;\"><strong>Defensora.</strong> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>\n<p style=\"text-align:justify;\"><strong>Adamante.</strong> Encontrado apenas em meteoritos (e por isso também chamado de \"ferro-meteórico\"), o adamante é um metal escuro, fosco e mais denso que o aço. Armaduras e escudos fornecem resistência a dano, de acordo com seu tipo: armaduras leves e escudos, RD 2; armaduras pesadas, RD 5.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":25,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":13,"penalidade":-6,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000090,"modifiedTime":1666662790247,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"BPnw00NblhjMIwm0","name":"Anel da Vitalidade","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.BPnw00NblhjMIwm0"}},"system":{"description":{"value":"Você recebe +10 PV. Os efeitos do anel só se ativam após um dia de uso.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":21000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000091,"modifiedTime":1666662783381,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"BfZoAqLXeM2mBUfi","name":"Manto da Noite","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manto-da-noite.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.BfZoAqLXeM2mBUfi"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>couro batido ajustado defensor sombrio</strong> é negro com partes metálicas foscas. Quando usa esta armadura, você não sofre penalidade em testes de Furtividade por se mover em seu deslocamento normal e a penalidade que você sofre em testes de Furtividade por atacar diminui para –10.</p><p style=\"text-align:justify;\"><b>Ajustada</b> Feito com extremo cuidado e peças medidas com precisão, o item tem a sua penalidade de armadura diminuída em 1.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2.</p><p style=\"text-align:justify;\"><b>Sombrio</b> Você recebe +5 em Furtividade e ignora a penalidade de armadura do item para testes dessa perícia. Um item sombrio é escuro, fosco e bem lubrificado, para não fazer barulho.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":10,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"leve","armadura":{"value":5,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000091,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"ClsAwXF91HUeKnPb","name":"Gema Elemental","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/gema-elemental.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.ClsAwXF91HUeKnPb"}},"system":{"description":{"value":"Você pode lançar <i>Conjurar Elemental</i> sem pagar seu custo em PM.","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000091,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"ES395oS9Gazb7wJA","name":"Luvas da Delicadeza","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/luvas-da-delicadeza.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.ES395oS9Gazb7wJA"}},"system":{"description":{"value":"Estas luvas de tecido fino permitem manipulação delicada. Você recebe +2 em Destreza.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000092,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"Fbdu5n9CAaiknpAS","name":"Brincos da Paz","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/brincos.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.Fbdu5n9CAaiknpAS"}},"system":{"description":{"value":"<p>Este par de brincos brancos &eacute; aben&ccedil;oado pela Deusa da Paz. A primeira criatura que o atacar em uma cena deve fazer um teste de Vontade (CD Car). Se falhar, perder&aacute; a a&ccedil;&atilde;o. Se voc&ecirc; atacar uma criatura, o efeito dos brincos &eacute; cancelado por um dia. Se voc&ecirc; possuir Apar&ecirc;ncia Inofensiva (ou um poder similar) os efeitos acumulam, afetando as duas primeiras criaturas que o atacarem em uma cena</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":21000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000092,"modifiedTime":1666662783383,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"GIW26oN36GYT1UNX","name":"Couro de Monstro","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/couro-de-monstro.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.GIW26oN36GYT1UNX"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Usado por chefes bárbaros das Montanhas Sanguinárias, este <strong>gibão de peles defensor</strong> é feito do couro de monstros, como basiliscos e wyverns. Se você usar o poder Ataque Poderoso ou fizer uma investida, recebe um bônus de +2d6 nas rolagens de dano.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":12,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"leve","armadura":{"value":6,"penalidade":-3,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000093,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"HvaItUlAcCtEUUPc","name":"Anel de Telecinesia","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[{"label":"Anel de Telecinesia","icon":"icons/svg/upgrade.svg","origin":"Item.HvaItUlAcCtEUUPc","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":false,"skill":false,"ability":false,"power":false,"spell":true,"consumable":false,"items":"","aumenta":false,"custo":"-1"}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"doonvoDKEU6bPv44","changes":[],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.HvaItUlAcCtEUUPc"}},"system":{"description":{"value":"<p>Voc&ecirc; pode lan&ccedil;ar @UUID[Compendium.tormenta20.magias.UhiM7pMNk3HfWNKP]{Telecin&eacute;sia}. Caso j&aacute; conhe&ccedil;a a magia, o custo para lan&ccedil;&aacute;-la diminui em &ndash;1 PM.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":10500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000093,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"IvIBlYuZS6Sn5cE6","name":"Robe do Arquimago","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/robe-do-arquimago.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.IvIBlYuZS6Sn5cE6"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este traje pesado alinha-se com as energias arcanas emitidas por seu usuário para gerar um campo protetor. Se você for um conjurador arcano, recebe um bônus na Defesa igual a 5 + o círculo de magia mais alto que puder lançar e um bônus em testes de resistência igual à metade do bônus na Defesa. Assim, um arcanista de 9º nível (capaz de lançar magias de 3º círculo) recebe +8 em Defesa e +4 em testes de resistência.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":5,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000093,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"JWcrwkfQSIVnD9SR","name":"Avalanche","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/avalanche.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.JWcrwkfQSIVnD9SR"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este machado de guerra de gelo eterno congelante formidável fornece resistência a fogo 10. Você pode gastar uma ação padrão e 6 PM para brandi-lo acima de sua cabeça e invocar uma tempestade de gelo que afeta alcance curto ao seu redor. Criaturas na área recebem camuflagem e sofrem [[/r 3d6]] pontos de dano de impacto e [[/r 3d6]] pontos de frio por rodada. Você não sofre os efeitos nocivos da tempestade (o dano e a chance de falha pela camuflagem) e pode gastar 1 PM no início de cada um de seus turnos para mantê-la.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":6,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d12","corte",""],["@for","",""],["+2+2","corte",""]],"versatil":""}],"criticoM":20,"criticoX":3,"alcance":"-","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":true,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":true,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":6},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000094,"modifiedTime":1666662796831,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"JqiWjXlU9pdOZTeb","name":"Faixas do Pugilista","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/faixas-do-pugilista.webp","effects":[{"label":"Faixas do Pugilista","icon":"systems/tormenta20/icons/itens/itens-magicos/faixas-do-pugilista.webp","origin":"Item.JqiWjXlU9pdOZTeb","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"LNHXtqNgtxR2jAPs","changes":[{"key":"system.modificadores.ataque.cac","mode":2,"value":"2","priority":null},{"key":"system.modificadores.dano.cac","mode":2,"value":"2","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.JqiWjXlU9pdOZTeb"}},"system":{"description":{"value":"Estas faixas de pano surrado são amarradas nos punhos, nos braços ou na testa. Você recebe +2 em testes de ataque e rolagens de dano com ataques desarmados.","chat":"","unidentified":""},"source":"T20, pg. 344 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":21000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000095,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"KcDQ91RPuDgistWJ","name":"Espelho do Aprisionamento","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/espelho-do-aprisonamento.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.KcDQ91RPuDgistWJ"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este item de cristal, com 1,5m de altura e moldura de metal, pode ser fixado em qualquer superfície e ativado (ou desativado) com um comando. Qualquer criatura que se aproxime a alcance curto do espelho do aprisionamentoe enxergue seu próprio reflexo deve passar em um teste de Reflexos ou será transportada magicamente para um espaço extradimensional dentro do espe-lho, ficando presa ali. O tamanho da criatura não importa — mas construtos, mortos-vivos e objetos não podem ser transportados. Com um comando, é possível conversar com uma criatura presa no espe-lho ou libertá-la. Se o espelho for quebrado, todas as criaturas dentro dele são libertadas.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000096,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"Ki19ctJh88ucznGW","name":"Loriga do Centurião","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/loriga-do-centuriao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.Ki19ctJh88ucznGW"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>loriga segmentada defensora</strong> é dourada com detalhes em vermelho e possui o símbolo de Tauron, antigo Deus da Força, gravado no peitoral. Se estiver liderando uma ou mais criaturas (em termos de jogo, se estiver usando o poder Comandar ou similar), seus ataques corpo a corpo causam +2d6 de fogo.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":17,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":9,"penalidade":-3,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000096,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"LN0jEKvCz1Rb3bOo","name":"Estatueta Animista","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/estatueta-animista.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.LN0jEKvCz1Rb3bOo"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta estatueta de pedra é esculpida na forma de um animal e tem cerca de 10cm de altura. Quando é atirada no chão e a palavra de comando é proferida, transforma-se no animal correspondente. O animal fornece os benefícios de um aliado veterano até o fim da cena, quando então volta à sua forma de estatueta. O tipo de aliado é definido pelo animal: raposa (aliado ajudante), onça (assassino), águia (atirador), lobo (combatente), leão (fortão) ou urso (guardião).</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000096,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"LtG3azBFsLf4OkV1","name":"Cajado do Poder","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/cajado-do-poder.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.LtG3azBFsLf4OkV1"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este bordão magnífico tem cabo reto e liso, com uma joia cintilante na ponta. O custo de suas magias arcanas diminui em –1 PM e a CD para resistir a elas aumenta em +2.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","impacto",""],["@for","",""],["+2","impacto",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"-","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000097,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"M4E3uPL5jOZn9xjy","name":"Anel Refletor","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel-refletor.webp","effects":[{"label":"Anel Refletor","icon":"icons/svg/upgrade.svg","origin":"Item.M4E3uPL5jOZn9xjy","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":true,"skill":true,"ability":true,"power":false,"spell":false,"consumable":false,"items":"","aumenta":true,"custo":"1"}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"tpKMe7dEC1J2axm0","changes":[],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.M4E3uPL5jOZn9xjy"}},"system":{"description":{"value":"Este aro de platina é poderoso contra conjuradores. Uma vez por rodada, quando você é alvo de uma magia, pode gastar PM igual ao custo dela para refletila de volta ao seu conjurador. As características da magia (efeitos, CD...) se mantêm, mas você toma qualquer decisão exigida por ela.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":51000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000098,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"MGQyoR2Jm9Db6sP2","name":"Couraça do Comando","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/couraca-do-comando.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.MGQyoR2Jm9Db6sP2"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>couraça banhada a ouro sob medida defensora</strong> irradia uma aura de autoridade. Você recebe +2 em Carisma. Se usar o poder Comandar, o bônus fornecido aumenta para +2.</p><p style=\"text-align:justify;\"><b>Banhada a ouro</b> Uma modificação favorita de nobres pomposos ou aventureiros que acabaram de enriquecer. Um item banhado a ouro concede um bônus de +2 em testes de Diplomacia. O mestre pode mudar o bônus para uma penalidade de –2, caso você esteja interagindo com pessoas que desprezam tal ostentação. Além disso, pode atrair a cobiça de ladrões.</p><p style=\"text-align:justify;\"><b>Sob medida</b> Embora muitas armaduras sejam feitas especificamente para um usuário, esta passou por um período extenso de ajustes e refinamento, adequando-se com perfeição ao seu corpo. Reduz a penalidade por armadura em 2, mas apenas para o usuário específico (para outros, comporta-se como um item ajustado). Pré-requisito: Ajustada.</p><p style=\"text-align:justify;\"><b>Defensora</b> A arma se movimenta para aparar ataques contra você. Você recebe +2 na Defesa.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":15,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"leve","armadura":{"value":7,"penalidade":-2,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000098,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"MSPF3mDfZ4Od4eDh","name":"Manual dos Movimentos Precisos","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/manual-dos-movimentos-precisos.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.MSPF3mDfZ4Od4eDh"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este tomo volumoso descreve exercícios de coordenação e equilíbrio, mas mesclado às palavras há um poderoso efeito mágico. Funciona como um Manual do Bom Exercício, mas fornece +1 de Destreza.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000098,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"Mba9KnxNivmpuJhy","name":"Chapéu do Disfarce","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/chapeu-do-disfarse.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.Mba9KnxNivmpuJhy"}},"system":{"description":{"value":"<p>Voc&ecirc; pode lan&ccedil;ar @UUID[Compendium.tormenta20.magias.19donXyns0pliwj9]{Disfarce Ilus&oacute;rio}&nbsp;(CD Car), com o aprimoramento que inclui odores e sensa&ccedil;&otilde;es e muda o b&ocirc;nus em Engana&ccedil;&atilde;o para disfarces para +20, sem pagar seu custo em PM. Voc&ecirc; n&atilde;o pode usar outros aprimoramentos. Como parte do disfarce, o chap&eacute;u pode mudar para um elmo, faixa, tiara, gorro, touca e assim por diante.</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":6000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000099,"modifiedTime":1666662783383,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"NGJkBqxukaxF9jza","name":"Florete Fugaz","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/florete-fugaz.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.NGJkBqxukaxF9jza"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>florete formidável</strong> tem o cabo e a guarda trabalhados com prata e pedrarias. Quando usa a ação atacar, você pode gastar 1 PM. Se fizer isso e acertar um crítico no turno, pode fazer um ataque adicional contra a mesma criatura.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":1,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","perfuracao",""],["@for","",""],["+2","perfuracao",""]],"versatil":""}],"criticoM":18,"criticoX":2,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":true,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":true,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000099,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"NQhYZu63b2iFZfv4","name":"Bola de Cristal","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bola-de-cristal.webp","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>Esta pequena esfera revela pessoas e lugares distantes. Olhar atrav&eacute;s dela &eacute; uma a&ccedil;&atilde;o completa e gera a magia @UUID[Compendium.tormenta20.magias.y0AkIvcwBstmPcpX]{Vid&ecirc;ncia}(CD Sab).</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":10500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[],"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666197429146,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"NvLnwQwZQlImALJq","name":"Manto Élfico","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manto-elfico.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.NvLnwQwZQlImALJq"}},"system":{"description":{"value":"Indistinguível de um manto cinza comum. Entretanto, quando usado com o capuz cobrindo o rosto, fornece +5 em Furtividade.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000099,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"OAOvHNSqcpDL6UA5","name":"Bainha Mágica","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bainha-magica.webp","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>Esta bainha de couro curtido e prata muda de tamanho para acomodar qualquer arma corpo a corpo. Voc&ecirc; pode lan&ccedil;ar @UUID[Compendium.tormenta20.magias.YDxLaaDhfXOkSfnF]{Arma M&aacute;gica} em qualquer arma na bainha sem pagar seu custo em PM.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":3000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[],"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666197179765,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"OtW7whLVNzm2utSb","name":"Gema da Telepatia","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/gema-da-telepatia.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.OtW7whLVNzm2utSb"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Você pode lançar <i>Compreensão</i> e <i>Enfeitiçar</i> sem pagar seu custo em PM.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000100,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"PBfThK5WWVbIY0iP","name":"Cinto da Força do Gigante","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/cinto-da-forca-do-gigante.webp","effects":[{"label":"Cinto da Força do Gigante","icon":"systems/tormenta20/icons/itens/itens-magicos/cinto-da-forca-do-gigante.webp","origin":"Item.PBfThK5WWVbIY0iP","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"nOdcNBP9QgrrN2Xk","changes":[{"key":"system.atributos.for.value","mode":2,"value":"2","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.PBfThK5WWVbIY0iP"}},"system":{"description":{"value":"<p>Este cinto largo&nbsp; &eacute; feito de couro com rebites de ferro. Voc&ecirc; recebe +2 em For&ccedil;a.</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":25500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000100,"modifiedTime":1666662783383,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"PWx9hBiySNNchHbA","name":"Tomo dos Grandes Pensamentos","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/tomo-dos-grandes-pensamentos.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.PWx9hBiySNNchHbA"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este livro pesado contém exercícios para aprimorar o raciocínio e a memória, mas mesclado às palavras há um poderoso efeito mágico. Funciona como um Manual do Bom Exercício, mas fornece +1 de Inteligência.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000101,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"PihGn7sFqQLTc7IC","name":"Botas Velozes","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/botas-velozes.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.PihGn7sFqQLTc7IC"}},"system":{"description":{"value":"<p>Voc&ecirc; recebe +3m em seu deslocamento e pode lan&ccedil;ar @UUID[Compendium.tormenta20.magias.XWEJNZMs6Wb9uUHF]{Velocidade}&nbsp;(apenas sobre voc&ecirc; mesmo).</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":25500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000101,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"PymQTrvR91CIsUlW","name":"Símbolo Abençoado","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/simbolo-abencoado.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.PymQTrvR91CIsUlW"}},"system":{"description":{"value":"Um colar com o símbolo de um dos deuses do Panteão, feito de metal para resistir a viagens e aventuras. Se você for devoto desse deus, o custo de suas magias divinas diminui em –1 PM. Apenas inventores devotos do deus em questão podem fabricar um símbolo abençoado.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000101,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"R5crK6nqk3zwOjiz","name":"Carapaça Demoníaca","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/carapaca-demoniaca.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.R5crK6nqk3zwOjiz"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>armadura completa macabra reforçada guardiã</strong> é forjada para fazer com que seu usuário pareça um demônio — o elmo tem o formato de uma cabeça demoníaca com chifres e o usuário enxerga através da boca aberta e repleta de dentes. Se você for devoto de uma divindade do Mal, a armadura exala energia negativa, fazendo os seus ataques corpo a corpo causarem +1d8 de dano de trevas.</p><p style=\"text-align:justify;\"><b>Reforçada</b> Placas adicionais, uma camada extra de cota de malha ou acolchoamento, proteção dobrada nas juntas e áreas vulneráveis... O bônus na Defesa e a penalidade de armadura de uma armadura ou escudo com esta modificação aumentam em +1. Uma armadura não pode ser reforçada e delicada.</p><p style=\"text-align:justify;\"><b>Guardião</b> O item emite um campo de força que desvia ataques. O bônus na Defesa do item aumenta em +4. Pré-requisito:defensor.</p><p style=\"text-align:justify;\">Macabro. Um item macabro é pintado com sangue seco, esculpido na forma de uma caveira ou decorado com pedaços de orelhas, dedos e olhos. Essa aparência assustadora fornece um bônus de +2 em testes de Intimidação, mas impõe uma penalidade de –2 em testes de Diplomacia.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":25,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":15,"penalidade":-6,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000101,"modifiedTime":1666662790247,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"RJYF7ocMNcZqOm4j","name":"Pingente da Saúde","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/pingente.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.RJYF7ocMNcZqOm4j"}},"system":{"description":{"value":"O usuário desta joia verde em um cordão de prata recebe imunidade a doenças e venenos. Os efeitos só se ativam após uma semana de uso.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000102,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"SNw2I6JAd0ukMx8B","name":"Elmo do Teletransporte","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/elmo-teletransporte.webp","effects":[{"label":"Elmo do Teletransporte","icon":"icons/svg/upgrade.svg","origin":"Item.SNw2I6JAd0ukMx8B","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":true,"durationScene":false,"self":false,"attack":false,"skill":false,"ability":false,"power":false,"equipment":false,"spell":true,"consumable":false,"items":"Salto Dimensional;Teletransporte","aumenta":false,"custo":"-1"}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":true,"_id":"adsmMuThM2NVsyfv","changes":[],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.SNw2I6JAd0ukMx8B"}},"system":{"description":{"value":"<p>Voc&ecirc; pode lan&ccedil;ar @UUID[Compendium.tormenta20.magias.FxAlmaFR7sYRJD5z]{Salto Dimensional} e @UUID[Compendium.tormenta20.magias.ZUQneRqpDjJKRO5n]{Teletransporte}, mas apenas em voc&ecirc; mesmo. Caso j&aacute; conhe&ccedil;a as magias, o custo para lan&ccedil;&aacute;-las diminui em &ndash;1 PM.</p>","chat":"","unidentified":""},"source":"T20, pg. 344 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":30000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000102,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"THhPyfQnEvjY7b4w","name":"Ferraduras da Velocidade","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/ferraduras-da-velocidade.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.THhPyfQnEvjY7b4w"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este conjunto de ferraduras pode ser fixado nos cascos de um cavalo (ou outro aliado montaria, a critério do mestre) para aumentar seu deslocamento em +3m.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000103,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"TlNcV8TJ62EXQMm8","name":"Cajado da Vida","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/cajado-da-vida.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.TlNcV8TJ62EXQMm8"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este bordão formidável branco com runas prateadas é valorizado por curandeiros. Quando você lança uma magia de cura, ela cura +2 pontos de vida por dado.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","impacto",""],["@for","",""],["+2","impacto",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"-","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000104,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"UUHcUX4NovvA4h1C","name":"Manto da Aranha","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manto-da-aranha.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.UUHcUX4NovvA4h1C"}},"system":{"description":{"value":"Este manto é feito de seda negra com fios de prata bordados. Você recebe deslocamento de escalada igual ao seu deslocamento terrestre, +5 em testes de resistência contra venenos e imunidade a teias mundanas ou mágicas. Além disso, pode lançar <i>Teia</i>. Caso já conheça a magia, o custo para lançá-la diminui em –1 PM.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000104,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"UncHq3oaHPx2AuPx","name":"Caveira Maldita","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/caveira-maldita.webp","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>Esta pedra esculpida em formato de cr&acirc;nio gera permanentemente o efeito da magia @UUID[Compendium.tormenta20.magias.tJI1ESr2Mcxtx95L]{Profanar}, com o pr&oacute;prio cr&acirc;nio como ponto de origem. Mortos-vivos e devotos de deuses do Mal na &aacute;rea de efeito recebem +2 em testes e Defesa</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":10500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[],"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666278939302,"modifiedTime":1666662783383,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"VBaB5hQmTMj1YcMD","name":"Manto do Fascínio","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manto-do-fascinio.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.VBaB5hQmTMj1YcMD"}},"system":{"description":{"value":"Este manto de veludo possui bordados de ouro. Você recebe +2 em Carisma.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000105,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"VBjVXrxkC1a7P2t3","name":"Braceletes de Bronze","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bracelete-bronze.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.VBjVXrxkC1a7P2t3"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Estes braceletes protegem seu usuário com um campo de força invisível, porém tangível. Você recebe +4 em Defesa, cumulativo com outros itens mágicos, mas não com armaduras.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":16500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":4,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000105,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}

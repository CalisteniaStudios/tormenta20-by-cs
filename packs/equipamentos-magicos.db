{"_id":"XWrD4ro0POzaimEr","name":"Anel do Sustento","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.XWrD4ro0POzaimEr"}},"system":{"description":{"value":"Você não precisa comer ou beber e precisa dormir apenas duas horas por noite para descansar. Os efeitos do anel só se ativam após uma semana de uso.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":3000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000105,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"Yiw7Y6JtQm81gJt1","name":"Coroa Majestosa","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/coroa.webp","effects":[{"label":"Coroa Majestosa","icon":"systems/tormenta20/icons/itens/itens-magicos/coroa.webp","origin":"Item.Yiw7Y6JtQm81gJt1","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"kDQPShgcIw357inz","changes":[{"key":"system.atributos.car.value","mode":2,"value":"2","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.Yiw7Y6JtQm81gJt1"}},"system":{"description":{"value":"<p>Esta coroa de ouro possui dezenas de pedras preciosas. Voc&ecirc; recebe +2 em Carisma.</p>","chat":"","unidentified":""},"source":"T20, pg. 344 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":25500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000106,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"Z6LZT0QE6N1XrJ5u","name":"Escudo do Eclipse","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/escudo-do-eclipse.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.Z6LZT0QE6N1XrJ5u"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>escudo pesado defensor</strong> é completamente negro e parece absorver a luz. Ele fornece resistência a trevas 10 e causa +1d8 de dano de trevas num ataque. Além disso, você pode gastar uma ação de movimento e 2 PM para lançar <i>Escuridão</i>.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":7,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"escudo","armadura":{"value":4,"penalidade":-2,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000106,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"asJJmcBkZ5TP6Mnp","name":"Braçadeiras do Arqueiro","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bracadeiras-do-arqueiro.webp","effects":[{"label":"Braçadeiras do Arqueiro","icon":"systems/tormenta20/icons/itens/itens-magicos/bracadeiras-do-arqueiro.webp","origin":"Item.asJJmcBkZ5TP6Mnp","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"N0bXSMfLiLyi2AZJ","changes":[{"key":"system.modificadores.dano.ad","mode":2,"value":"2","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.asJJmcBkZ5TP6Mnp"}},"system":{"description":{"value":"Estes protetores de punho fornecem +2 em rolagens de dano com armas de ataque à distância.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":21000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000106,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"bdKVwpmbKOOjF7gO","name":"Escudo Espinhoso","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/escudo-espinhoso.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.bdKVwpmbKOOjF7gO"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>escudo pesado defensor</strong> é coberto de espinhos. Você pode gastar uma ação de movimento e 2 PM para disparar um espinho em um alvo em alcance curto. O espinho acerta automaticamente e causa [[/r 1d10+2]] pontos de dano de perfuração.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":7,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"escudo","armadura":{"value":4,"penalidade":-2,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000106,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"cwlpIzSBlx11nMmi","name":"Armadura da Luz","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/armadura-da-luz.webp","effects":[{"label":"Resistencia a dano","icon":"systems/tormenta20/icons/itens/itens-magicos/armadura-da-luz.webp","origin":"Item.cwlpIzSBlx11nMmi","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"JgDx0P1BcV4EtZMK","changes":[{"key":"system.tracos.resistencias.dano.value","mode":2,"value":"@car","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.cwlpIzSBlx11nMmi"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>armadura completa banhada a ouro reforçada guardiã zelosa</strong> possui o símbolo da Justiça gravado no peitoral. Se você possuir um código de conduta (de honra, do herói...) ou for devoto de uma divindade do Bem, recebe resistência a dano igual ao seu modificador de Carisma.</p><p style=\"text-align:justify;\"><b>Reforçada</b> Placas adicionais, uma camada extra de cota de malha ou acolchoamento, proteção dobrada nas juntas e áreas vulneráveis... O bônus na Defesa e a penalidade de armadura de uma armadura ou escudo com esta modificação aumentam em +1. Uma armadura não pode ser reforçada e delicada.</p><p style=\"text-align:justify;\"><b>Banhada a ouro</b> Uma modificação favorita de nobres pomposos ou aventureiros que acabaram de enriquecer. Um item banhado a ouro concede um bônus de +2 em testes de Diplomacia. O mestre pode mudar o bônus para uma penalidade de –2, caso você esteja interagindo com pessoas que desprezam tal ostentação. Além disso, pode atrair a cobiça de ladrões.</p><p style=\"text-align:justify;\"><b>Guardião</b> O item emite um campo de força que desvia ataques. O bônus na Defesa do item aumenta em +4. Pré-requisito:defensor.</p><p style=\"text-align:justify;\"><b>Zeloso</b> Uma vez por rodada, se um aliado adjacente for alvo de um ataque, você pode gastar 1 PM para se tornar o alvo do ataque, que então é resolvido normalmente.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":25,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":15,"penalidade":-6,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000107,"modifiedTime":1666662790247,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"dL1mC5IMyt8nniom","name":"Arco do Poder","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/arco-poder.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.dL1mC5IMyt8nniom"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">O arco do poder conta como um <strong>arco longo formidável</strong>, mas parece apenas um pedaço de um arco &mdash; não tem corda e não aceita flechas. Contudo, quando você o empunha e faz o gesto de puxar a corda inexistente, o arco cria uma corda e uma flecha de energia dourada. O arco do poder é capaz de ler suas intenç&otilde;es, produzindo diferentes tipos de flechas energéticas a sua escolha.</p>\n<p style=\"text-align:justify;\"><strong>Flecha normal.</strong> [[/r 3d8]] pontos de dano de essência.</p>\n<p style=\"text-align:justify;\"><strong>Flecha piedosa.</strong> [[/r 4d8]] pontos de dano não letal.</p>\n<p style=\"text-align:justify;\"><strong>Flecha explosiva.</strong> [[/r 3d6]] de dano de fogo no alvo e em todas as criaturas adjacentes a ele (essas têm direito a um teste de Reflexos contra CD 20 para reduzir o dano &agrave; metade). &bull; Flecha-rede. Não causa dano, mas deixa a vítima agarrada por uma rede de energia. A criatura pode se soltar passando em um teste de Força (CD 20). A rede se dissipa quando a criatura se solta ou no fim da cena.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":1.5,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["pont","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["3d8","perfuracao",""],["@for","",""],["2","perfuracao",""]],"versatil":""}],"criticoM":20,"criticoX":3,"alcance":"","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":true,"dms":true,"dup":false,"lev":false,"mun":true,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":true,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000107,"modifiedTime":1666662796831,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"dxsoRAc3W1CaQMQE","name":"Manual do Bom Exercício","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/manual-do-bom-exercicio.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.dxsoRAc3W1CaQMQE"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este tomo volumoso contém exercícios de musculação, mas escondido entre as palavras há um poderoso efeito mágico. Ler o livro leva uma semana e aumenta seu valor de Força em +1 permanentemente. Um valor de atributo pode aumentar no máximo em +5 pelo uso de livros e da magia Desejo. Assim que o livro é lido, a magia desaparece de suas páginas e ele se torna um item mundano.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000107,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"eAsClXIWZNoFXiqW","name":"Anel da Energia","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.eAsClXIWZNoFXiqW"}},"system":{"description":{"value":"Você recebe +5 PM. Os efeitos do anel só se ativam após um dia de uso.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":21000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000108,"modifiedTime":1666662783381,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"eOt8kUx5MUnGAiLB","name":"Anel do Escudo Mental","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.eOt8kUx5MUnGAiLB"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Você recebe imunidade a magias de adivinhação.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":9000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000108,"modifiedTime":1666662783382,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"eWqbWJ4vZUyEIVLF","name":"Braceletes de Ouro","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/bracelete-ouro.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.eWqbWJ4vZUyEIVLF"}},"system":{"description":{"value":"<p style=\"text-align: justify;\">Como @UUID[Compendium.tormenta20.equipamentos-magicos.VBjVXrxkC1a7P2t3]{Braceletes de Bronze}, mas fornece +8 na Defesa.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":64500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":8,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000109,"modifiedTime":1666662783383,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"gLUFfRX1CAtvtQPr","name":"Pingente da Sensatez","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/pingente.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.gLUFfRX1CAtvtQPr"}},"system":{"description":{"value":"Esta pequena pérola é ligada a uma corrente leve e usada como um colar. Você recebe +2 em Sabedoria.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000110,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"goKcWiXKZdwMlXqn","name":"Manual da Saúde Corporal","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/manual-da-saude-corporal.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.goKcWiXKZdwMlXqn"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este tomo volumoso contém exercícios de resistência e dietas saudáveis, mas suas palavras trazem um poderoso efeito mágico. Funciona como um Manual do Bom Exercício, mas fornece +1 de Constituição.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000110,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"gwR3rksYtoGjOu6g","name":"Corda da Escalada","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/corda-da-escalada.webp","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>Esta corda de 15m &eacute;&nbsp; bastante fina, mas forte o suficiente para suportar at&eacute; seis criaturas M&eacute;dias (ou 120 espa&ccedil;os). Com um comando (uma a&ccedil;&atilde;o de movimento), a corda se move em qualquer dire&ccedil;&atilde;o (incluindo para cima) a 3m por rodada, fixando-se firmemente onde voc&ecirc; quiser. Ela pode se desamarrar e voltar da mesma forma</p>","chat":"","unidentified":""},"source":"T20, pg. 343 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":3000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"rolls":[],"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1666279219627,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"iFaZtyir56zrjir9","name":"Besta Explosiva","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/besta-explosiva.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.iFaZtyir56zrjir9"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>besta pesada formidável</strong> é feita de madeira escurecida, similar a carvão. Quando usa uma besta explosiva, você pode gastar 3 PM para transformar o virote disparado por ela em uma Bola de Fogo. </p><p style=\"text-align:justify;\">Você pode mirar esta Bola de Fogo em uma criatura ou em um ponto no chão em alcance médio.No primeiro caso, faça um ataque contra o alvo. Se acertar, ele sofre o dano do disparo mais [[/r 6d6]] de fogo. Além disso, todas as criaturas a até 6m do alvo sofrem 6d6 pontos de dano de fogo (Ref reduz à metade). Porém, se o ataque errar, o virote se desfaz em uma nuvem de cinzas inofensivas.No segundo caso, ela funciona como a magia de mesmo nome. Nenhum teste de ataque é necessário e todas as criaturas a 6m do ponto escolhido sofrem [[/r 6d6]] pontos de dano de fogo (Ref reduz à metade).</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":4,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["pont","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d12","perfuracao",""],["","",""],["+2","perfuracao",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":true,"dms":true,"dup":false,"lev":false,"mun":true,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":true,"duasMaos":true,"dupla":false,"leve":false,"municao":true,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":3},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000111,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"jhdwYNYHEozyC6wy","name":"Maça do Terror","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/maca-do-terror.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.jhdwYNYHEozyC6wy"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>maça formidável</strong> é feita com um osso e um crânio e permite que você lance a magia Amedrontar. Caso já conheça a magia, o custo para lançá-la diminui em –1 PM.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":6,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","impacto",""],["@for","",""],["+2","impacto",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"0","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000111,"modifiedTime":1666662796833,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"kAGIu4l3y638MMUv","name":"Escudo do Leão","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/escudo-do-leao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.kAGIu4l3y638MMUv"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>escudo pesado defensor</strong> é forjado como uma cabeça de leão rugindo. Uma vez por rodada, você pode gastar 2 PM para fazer a cabeça criar vida e morder uma criatura adjacente. A mordida acerta automaticamente e causa [[/r 2d6+2]] de dano de perfuração.</p><p style=\"text-align:justify;\"><b>Defensor</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":7,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"escudo","armadura":{"value":4,"penalidade":-2,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000111,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"kWyrsaHHLRoujCLC","name":"Escudo do Deus-Sol","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/escudo-do-deus-sol.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.kWyrsaHHLRoujCLC"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este <strong>escudo pesado guardião</strong> é forjado na forma de um sol estilizado. Você pode gastar uma ação padrão e 10 PM para fazê-lo emitir uma luz brilhante e quente num cone com alcance curto. A luz gera os efeitos da magia Visão da Verdade e causa [[/r 6d6]] pontos de dano de fogo em todos os seus inimigos (mortos-vivos e criaturas vulneráveis a luz solar sofrem [[/r 6d8]] pontos de dano). Você pode gastar 1 PM no início de cada um de seus turnos para manter a luz.</p><p style=\"text-align:justify;\"><b>Guardião</b> O item emite um campo de força que desvia ataques. O bônus na Defesa do item aumenta em +4. Pré-requisito: defensor.</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":7,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"escudo","armadura":{"value":6,"penalidade":-2,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000111,"modifiedTime":1666662790248,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"kd0YD9KZOz0tpBBA","name":"Manoplas da Força do Ogro","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manoplas-da-forca-do-ogro.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.kd0YD9KZOz0tpBBA"}},"system":{"description":{"value":"Este par de luvas é feito de couro grosso com rebites de ferro. Você recebe +2 em Força.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000112,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"lH4WuC99PGlKzRgc","name":"Vassoura Voadora","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/vassoura-voadora.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.lH4WuC99PGlKzRgc"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Com um comando, esta vassoura flutua, fornecendo deslocamento de voo 12m. A vassoura e pode carregar 2 criaturas Médias (ou 200kg). Se você estiver em alcance longo da vassoura, pode comandar o voo dela.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000112,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"lMOzFa02WRFQrfnA","name":"Anel da Regeneração","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.lMOzFa02WRFQrfnA"}},"system":{"description":{"value":"Você recebe Cura Acelerada 5. Os efeitos do anel só se ativam após um dia de uso.","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":150000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000112,"modifiedTime":1666662783381,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"n2GhiAzdK2Fv0atk","name":"Anel da Proteção","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.n2GhiAzdK2Fv0atk"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este anel desvia ataques contra seu usuário. Você recebe +2 de Defesa.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":9000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":2,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000113,"modifiedTime":1666662783381,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"nqrXpjRujHTalKhC","name":"Martelo dos Anões","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/martelo-de-doherimm.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.nqrXpjRujHTalKhC"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este martelo de guerra formidável é feito de pedra e aço. Quando empunhado por um anão, adquire o encanto arremesso e aumenta seu dano em +[[/r 1d8]] (ou +[[/r 2d8]] se usada contra criaturas Grandes ou maiores).</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2.5,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","impacto",""],["@for","",""],["+2","impacto",""]],"versatil":""}],"criticoM":20,"criticoX":3,"alcance":"Curto","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000113,"modifiedTime":1666662796833,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"oMZO36ZBHsOykHb0","name":"Orbe das Tempestades","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/orbe-da-tempestade.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.oMZO36ZBHsOykHb0"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta esfera de vidro com 20cm de diâmetro contém fumaça e raios em seu interior. Você pode lançar <i>Controlar o Clima</i> e <i>Fúria do Panteão</i>. Caso já conheça as magias, o custo para lançá-las diminui em –1 PM. Além disso, você e todos os seus aliados adjacentes ficam sob efeito de Suporte Ambiental.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000113,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"qEhhSwNSZmOAh8k4","name":"Manto do Morcego","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manto-do-morcego.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.qEhhSwNSZmOAh8k4"}},"system":{"description":{"value":"Este manto marrom escuro ou negro fornece +5 em Furtividade e permite que você fique pendurado de ponta-cabeça no teto, como um morcego. Além disso, você pode gastar uma ação padrão para segurar as pontas do manto e se transformar em um morcego. Seu tamanho muda para Minúsculo e você recebe deslocamento de voo 12m e uma arma natural de mordida (dano 1d4, perfuração). Em outros aspectos, isso funciona como a Forma Selvagem do druida. Você só pode se transformar em morcego à noite ou em ambientes escuros.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000114,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"qokba90bQZ9F5RBQ","name":"Flauta Fantasma","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/flauta-fantasma.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.qokba90bQZ9F5RBQ"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Você pode lançar <i>Esculpir Sons</i> sem pagar seu custo em PM. Você só pode usar a flauta fantasma se for treinado em Atuação.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000114,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"quofrh3DWIAAjHAI","name":"Anel de Invisibilidade","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel-invisilidade.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.quofrh3DWIAAjHAI"}},"system":{"description":{"value":"<p>Ao colocar este anel de prata, voc&ecirc; fica sob efeito de @UUID[Compendium.tormenta20.magias.A3RFvVgOvODWHtvc]{Invisibilidade}. O efeito termina se voc&ecirc; fizer um ataque ou lan&ccedil;ar uma magia ofensiva, mas voc&ecirc; pode tirar e recolocar o anel (uma a&ccedil;&atilde;o padr&atilde;o) para que ele volte a funcionar.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":21000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000115,"modifiedTime":1666662783381,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"rCji6G4Jys9QYjXh","name":"Torque do Vigor","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/torque-do-vigor.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.rCji6G4Jys9QYjXh"}},"system":{"description":{"value":"O acabamento deste colar ou bracelete remete a um animal poderoso, como um urso ou lobo. Você recebe +2 em Constituição.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000115,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"rIxUZtwLHeEfggsD","name":"Mochila de Carga","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/mochila-carga.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.rIxUZtwLHeEfggsD"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este item, que parece uma simples mochila de pano, está na verdade ligado a um espaço interdimensional — fazendo com que seja maior por dentro do que por fora. Você pode guardar até 100 kg dentro de uma mochila de carga, mas ela pesará no máximo 5 kg. Se a mochila for rasgada, os objetos em seu interior são destruídos. Criaturas vivas colocadas no interior da mochila podem sobreviver até 10 minutos, mas depois disso ficarão sem ar.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000115,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"s3q5ZBqb0BoRpeSq","name":"Cota Élfica","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/cota-elfica.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.s3q5ZBqb0BoRpeSq"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Composta de anéis finíssimos, esta <strong>cota de malha defensora de mitral</strong> parece ser feita de seda. Ela permite que você aplique seu bônus de Destreza na Defesa como se fosse uma armadura leve.</p><p style=\"text-align:justify;\"><b>Defensora</b> O item é encantado para desviar golpes. O bônus na Defesa do item aumenta em +2.</p><p style=\"text-align:justify;\">Mitral. Metal muito raro, o mitral é prateado e brilhante, tendo metade do peso do aço. Armaduras e escudos de mitral têm sua penalidade de armadura diminuída em 2. Armaduras pesadas de mitral permitem que seu usuário aplique até dois pontos de seu bônus de Destreza na Defesa</p>","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":20,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"pesada","armadura":{"value":8,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000116,"modifiedTime":1666662790247,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"sAFkdfHvHDqyZlZl","name":"Anel da Liberdade","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/anel.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.sAFkdfHvHDqyZlZl"}},"system":{"description":{"value":"<p>Forjado em ouro, este anel &eacute; uma rel&iacute;quia da Igreja da Ambi&ccedil;&atilde;o. Voc&ecirc; fica permanentemente sob efeito de @UUID[Compendium.tormenta20.magias.ELDmNrdpN7g8M3iJ]{Liberta&ccedil;&atilde;o}.</p>","chat":"","unidentified":""},"source":"T20, pg. 342 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":60000,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000116,"modifiedTime":1666662783381,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"sP4Nlz0cFAjxbzg5","name":"Medalhão da deusa da vida","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/medalhao-deusa-da-vida.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.sP4Nlz0cFAjxbzg5"}},"system":{"description":{"value":"Quando você é reduzido a 0 ou menos PV, esta joia emite uma explosão de energia positiva que cura 100 PV (antes que você caia). Este poder só se ativa uma vez por dia.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000116,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"suaTBu6MQmlEMxqB","name":"Garrafa da Fumaça Eterna","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/garrafa-da-fumaca-eterna.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.suaTBu6MQmlEMxqB"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Quando a tampa desta ânfora de metal é retirada, uma grande quantidade de fumaça é liberada, gerando o efeito da magia Névoa. A fumaça persiste até a garrafa ser tampada. Após isso, dissipa-se no fim da cena (ou após 4 rodadas, sob vento forte, ou 1 rodada, sob um vendaval).</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000116,"modifiedTime":1666662783385,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"tZZb0i0i1eg3E6BJ","name":"Língua do Deserto","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/lingua-do-deserto.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.tZZb0i0i1eg3E6BJ"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>cimitarra formidável</strong> é originária do deserto. Você pode gastar uma ação de movimento e 2 PM para transformar a l&acirc;mina dela em chamas até o fim da cena. Nessa condição, o dano da arma aumenta em um passo e passa a ser do tipo fogo. Você pode gastar uma ação de movimento e 2 PM para fazer as chamas brilharem com muita força. Isso deixa os inimigos em alcance curto desprevenidos por uma rodada.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","corte",""],["@for","",""],["+2","corte",""]],"versatil":""}],"criticoM":18,"criticoX":2,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":true,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":true,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000117,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"uUp6qw8AnoR6igO1","name":"Lança Animalesca","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/lanca-animalesca.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.uUp6qw8AnoR6igO1"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Espinhos e folhas vivas brotam desta lança formidável. Se você usar a habilidade Forma Selvagem, aplica o bônus de +2 em ataque e dano da lança animalesca em suas armas naturais.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":1.5,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","perfuracao",""],["@for","",""],["+2","perfuracao",""]],"versatil":""}],"criticoM":20,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":true,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":true,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000117,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"vHpWMHosmAzPmMIV","name":"Pulseiras da Celeridade","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/pulseiras-da-celeridade.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.vHpWMHosmAzPmMIV"}},"system":{"description":{"value":"Esta pulseira de platina aguça todos os seus movimentos. Você recebe +5 em Destreza.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000118,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"vcHZCbjaAe7Ttd1Q","name":"Tiara da Sapiência","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/coroa.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.vcHZCbjaAe7Ttd1Q"}},"system":{"description":{"value":"Esta tiara delicada possui uma gema que descansa sobre a testa. Você recebe +5 em Inteligência (mas não recebe perícias treinadas extras).","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000118,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"wVnn7FGD0t0BU11O","name":"Estola da Serenidade","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/estola-da-serenidade.webp","effects":[{"label":"Estola da Serenidade","icon":"systems/tormenta20/icons/itens/itens-magicos/estola-da-serenidade.webp","origin":"Item.wVnn7FGD0t0BU11O","tint":"#FFFFFF","flags":{"tormenta20":{"onuse":false,"durationScene":false}},"duration":{"startTime":null,"seconds":null,"combat":null,"rounds":null,"turns":null,"startRound":null,"startTurn":null},"disabled":false,"_id":"mklRrmedJcULuq03","changes":[{"key":"system.atributos.sab.value","mode":2,"value":"2","priority":null}],"transfer":true}],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.wVnn7FGD0t0BU11O"}},"system":{"description":{"value":"<p>Esta faixa de pano com inscri&ccedil;&otilde;es m&aacute;gicas &eacute; usada sobre a nuca, com as duas extremidades caindo paralelas na frente do corpo. Voc&ecirc; recebe +2 em Sabedoria.&nbsp;</p>","chat":"","unidentified":""},"source":"T20, pg. 344 (JdA)","equipado":false,"carregado":true,"peso":0,"espacos":1,"qtd":1,"preco":25500,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"acessorio","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000119,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"xasIzkosQaQ0Ln3Y","name":"Espelho da Oposição","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/espelho-da-oposicao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.xasIzkosQaQ0Ln3Y"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este item lembra um espelho normal com cerca de 1m de comprimento e 1,5m de altura. Pode ser fixado em qualquer superfície e ativado (ou desativado) com um comando. Quando uma criatura observa seu reflexo, o espelho cria uma cópia sua, com as mesmas habilidades e equipamento. A duplicata ataca a criatura original; quando um dos dois é derrotado, a duplicata e seus itens desaparecem.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000119,"modifiedTime":1666662783384,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"xvnLFzKVvqZPFOSM","name":"Tapete Voador","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/tapete-voador.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.xvnLFzKVvqZPFOSM"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Com um comando, este tapete flutua, fornecendo deslocamento de voo 12m. O tapete tem 3m x 3m e pode carregar seis criaturas Médias (ou 600kg). Se você estiver em alcance longo do tapete, pode comandar o voo dele.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000119,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"ykRLVOsNEnypuNUA","name":"Espada Sortuda","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/espada-sortuda.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.ykRLVOsNEnypuNUA"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Esta <strong>espada curta formidável</strong> é cravejada de brilhantes. Você recebe +2 nos testes de resistência e pode gastar 3 PM para rolar novamente um teste qualquer recém realizado (apenas uma vez por teste). Se possuir o poder Sortudo, em vez disso seu custo diminui em –1 PM.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":1,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["2","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d6","perfuracao",""],["@for","",""],["+2","perfuracao",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"","tipoUso":"sim","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000119,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"ylIVTOBIvhJggWhE","name":"Tomo da Liderança e Influência","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/tomo-da-lideranca-influencia.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.ylIVTOBIvhJggWhE"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este livro de encadernação luxuosa contém instruções detalhadas para convencer e inspirar os demais, mas as páginas escondem um poderoso efeito mágico. Funciona como um Manual do Bom Exercício, mas fornece +1 de Carisma.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000120,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"z8YmxSob2luUuWeM","name":"Tomo da Compreensão","type":"tesouro","img":"systems/tormenta20/icons/itens/itens-magicos/tomo-da-compreensao.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.z8YmxSob2luUuWeM"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Este livro volumoso contém ensinamentos para tornar o leitor mais cenatrado e aguçar sua percepção, mas também possui um poderoso efeito mágico. Funciona como um Manual do Bom Exercício, mas fornece +1 de Sabedoria.</p>","chat":"","unidentified":""},"source":"","carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"container":false,"rolls":[],"origin":"","tags":[],"chatFlavor":""},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000121,"modifiedTime":1666662783387,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"zKL5mWuHBsXAm4Fy","name":"Espada Baronial","type":"arma","img":"systems/tormenta20/icons/itens/itens-magicos/espada-baronial.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.zKL5mWuHBsXAm4Fy"}},"system":{"description":{"value":"<p style=\"text-align:justify;\">Estas espadas longas de guarda reta eram dadas por reis-imperadores a vassalos dignos. Uma espada baronial fornece +1 em testes de ataque e rolagens de dano. Este bônus aumenta em +1 se você possuir um código de conduta (de honra, do herói...), for devoto da Justiça ou for treinado em Nobreza. Os bônus são cumulativos — um personagem com um código de conduta, devoto da Justiça e treinado em Nobreza recebe +4 em ataque e dano.</p>","chat":"","unidentified":""},"source":"","equipado":0,"carregado":true,"peso":2,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"rolls":[{"name":"Ataque","key":"ataque0","type":"ataque","parts":[["1d20","",""],["luta","",""],["1","",""]],"versatil":""},{"name":"Dano","key":"dano1","type":"dano","parts":[["1d8","impacto",""],["@for","",""],["1","impacto",""]],"versatil":""}],"criticoM":19,"criticoX":2,"alcance":"-","tipoUso":"mar","propriedades":{"ada":false,"agi":false,"alo":false,"arr":false,"dst":false,"dms":false,"dup":false,"lev":false,"mun":false,"ver":false,"adaptavel":false,"agil":false,"alongada":false,"arremesso":false,"ataqueDistancia":false,"duasMaos":false,"dupla":false,"leve":false,"municao":false,"versatil":false},"encantos":{"arremesso":false,"lancinante":false},"ativacao":{"custo":null},"consume":{"type":"","target":"","amount":null,"mpMultiplier":false},"chatFlavor":"","origin":"","tags":[],"size":"normal","melhorias":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000121,"modifiedTime":1666662796832,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}
{"_id":"zPxlM4MNoKihGsDn","name":"Manto da Resistência","type":"equipamento","img":"systems/tormenta20/icons/itens/itens-magicos/manto-da-resistencia.webp","effects":[],"folder":null,"sort":0,"flags":{"core":{"sourceId":"Compendium.tormenta20.equipamentos-magicos.zPxlM4MNoKihGsDn"}},"system":{"description":{"value":"Este manto de tecido grosso e pesado protege seu usuário. Você recebe +2 em testes de resistência.","chat":"","unidentified":""},"source":"","equipado":false,"carregado":true,"peso":0,"espacos":0,"qtd":1,"preco":0,"pv":{"value":0,"min":0,"max":0},"rd":0,"tipo":"traje","armadura":{"value":0,"penalidade":0,"maxAtr":0},"rolls":[],"origin":"","tags":[],"chatFlavor":"","ativacao":{"custo":null},"melhorias":{},"encantos":{}},"ownership":{"default":0},"_stats":{"systemId":"tormenta20","systemVersion":"1.4.1002","coreVersion":"10.288","createdTime":1664314000121,"modifiedTime":1666662783386,"lastModifiedBy":"tIn9sSkrT3mDWirx"}}

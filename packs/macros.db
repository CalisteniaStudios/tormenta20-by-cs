{"name":"Descanso","permission":{"default":0},"type":"script","flags":{"core":{"sourceId":"Macro.jNwovWaSbfSnEssn"}},"scope":"global","command":"// Obs: isso não leva em conta habilidades (ex: Osteon, Golem e a origem Refugiado).\n//Selecione os tokens que devem descansar e use a macro.\n(async () => {\n  if (!token) {\n    ui.notifications.warn(\"Nenhum personagem selecionado!\");\n    return;\n  }\n\n  async function descanso(valor) {\n\t\tlet descricao = \"\";\n\t\tfor (let e of canvas.tokens.controlled) {\n\t\t\t\tconst nivel = e.actor.data.data.attributes.nivel.value;\n\t\t\t\tconst novoPV = clampNumber(e.actor.data.data.attributes.pv.value + Math.floor(valor * nivel), 0, e.actor.data.data.attributes.pv.max);\n\t\t\t\tconst novoPM = clampNumber(e.actor.data.data.attributes.pm.value + Math.floor(valor * nivel), 0, e.actor.data.data.attributes.pm.max);\n\t\t\t\te.actor.update({\"data.attributes.pv.value\":novoPV, \"data.attributes.pm.value\":novoPM});\n\t\t\t\tdescricao += `${e.actor.data.name} recuperou ${Math.floor(valor * nivel)} PM e PV.<br>`;\n\t\t}\n\t\tlet content = {\n\t\t\titem: {\n\t\t\t\tname: \"Descanso\",\n\t\t\t\timg: \"icons/svg/regen.svg\"\n\t\t\t},\n\t\t\tdata: {\n\t\t\t\tdescription: \"<p>\" + descricao + \"</p>\"\n\t\t\t}\n\t\t}\n\t\tlet template = \"systems/tormenta20/templates/chat/chat-card.html\";\n\t\tconst html = await renderTemplate(template, content);\n\t\tconst chatData = {\n\t\t\tuser: game.user._id,\n\t\t\ttype: CONST.CHAT_MESSAGE_TYPES.OTHER,\n\t\t\tcontent: html\n\t\t};\n\t\tChatMessage.create(chatData);\n  }\n\n  let dialogEditor = new Dialog({\n    title: `Descanso`,\n    content: ``,\n    buttons: {\n      ruim: {\n        label: `Ruim`,\n        callback: () => {\n          descanso(0.5);\n          dialogEditor.render(true);\n        }\n      },\n      normal: {\n        label: `Normal`,\n        callback: () => {\n          descanso(1);\n          dialogEditor.render(true);\n        }\n      },\n      confortavel: {\n        label: `Confortável`,\n        callback: () => {\n          descanso(2);\n          dialogEditor.render(true);\n        }\n      },\n      luxuoso: {\n        label: `Luxuoso`,\n        callback: () => {\n          descanso(3);\n          dialogEditor.render(true);\n        }\n      }\n    },\n    default: \"\",\n    close: () => {}\n  });\n\n  dialogEditor.render(true)\n})();","author":"qFZKRQ3n6QbDxQLO","img":"icons/svg/regen.svg","actorIds":[],"_id":"HYSJxBruKhuQdyQ6"}
{"name":"Sangrando","permission":{"default":0},"type":"script","flags":{"core":{"sourceId":"Macro.TR2jZSmmys915xUD"}},"scope":"global","command":"// Macro desenvolvida por Sapodinho#0859 inspirado no exemplo de BrunoCF086#7267.\n// Teste de Morte do Tormenta20;\n(async () => {\n\tif (!token) {\n\t\tui.notifications.warn(\"Nenhum personagem selecionado!\");\n\t\treturn;\n\t}\n\tconst rollMode = game.settings.get(\"core\", \"rollMode\");\n\tconst testeMorte = new Roll(`1d20 + ${token.actor.data.data.atributos.con.mod}`).roll();\n\tlet rolls = [testeMorte];\n\tif (testeMorte.total < 15) {\n\t\tlet d8 = new Roll(`1d6`).roll();\n\t\trolls.push(d8);\n\t}\n\n\tconst tokenHpMin = Math.min(-10, Math.floor(-Math.abs(token.actor.data.data.attributes.pv.max)/2));\n\tlet _rolls = [];\n\tfor (const roll of rolls){\n\t\troll.tipo = roll.dice[0]?.faces !== 20 ? \"roll--dano\" : roll._critical ? \"critico\" : roll.results[0] == 1 ? \"falha\" : \"\";\n\t\troll.title = roll.tipo ==\"roll--dano\"? \"Dano\" : \"\";\n\t\tawait roll.render().then((r)=> {_rolls.push(r)});\n\t}\n\tlet content = {\n\t\titem: {\n\t\t\tname: \"Teste de Morte\",\n\t\t\timg: \"icons/svg/blood.svg\"\n\t\t},\n\t\tdata: {\n\t\t\tdescription: \"<p>Se ficar com 0 PV ou menos, você cai inconsciente e começa a sangrar. No início de seu turno, faça um teste de Constituição (CD 15). Se passar, você estabiliza e não precisa mais fazer esse teste. Se falhar, você perde 1d6 pontos de vida e continua sangrando. Você deve repetir o teste a cada rodada, até estabilizar ou morrer. Um personagem sangrando pode ser estabilizado com um teste de Cura (CD 15) ou com qualquer efeito que cure pelo menos 1 PV.</p>\"\n\t\t},\n\t\t_rolls: _rolls,\n\t\trolls: rolls\n\t}\n\t\n\tif (game?.dice3d?.show) {\n\t\tlet wd = {\n\t\t\twhisper: ([\"gmroll\", \"blindroll\"].includes(rollMode) ? ChatMessage.getWhisperRecipients(\"GM\") \n\t\t\t\t: (rollMode === \"selfroll\" ? [game.user._id] : null)),\n\t\t\tblind: rollMode === \"blindroll\"\n\t\t}\n\t\tfor (const roll of rolls){\n\t\t\tgame.dice3d.showForRoll(roll, game.user, true, wd.whisper, wd.blind)\n\t\t}\n\t}\n\t\n\tlet template = \"systems/tormenta20/templates/chat/chat-card.html\";\n\tconst html = await renderTemplate(template, content);\n\tconst chatData = {\n\t\tuser: game.user._id,\n\t\ttype: CONST.CHAT_MESSAGE_TYPES.OTHER,\n\t\tcontent: html,\n\t\tspeaker: ChatMessage.getSpeaker({actor: this.actor, token})\n\t};\n\tChatMessage.create(chatData);\n})();","author":"qFZKRQ3n6QbDxQLO","img":"icons/svg/blood.svg","actorIds":[],"_id":"u7iKpwTpLE8df77S"}
{"name":"Confuso","permission":{"default":0},"type":"script","flags":{"core":{"sourceId":"Macro.OK6TesXExvWxoBbn"}},"scope":"global","command":"(async () =>{\n\t// Macro desenvolvido por BrunoCF086#7267. O macro opera os efeitos da Condição Confuso no sistema Tormenta20;\n\tif (!token) {\n    ui.notifications.warn(\"Nenhum personagem selecionado!\");\n    return;\n  }\n\tconst rollMode = game.settings.get(\"core\", \"rollMode\");\n\tlet d6 = new Roll(`1d6`).roll();\n\tlet rolls = [d6];\n\n\tfunction tabela(dado) {\n\t\tif (dado == 1) {\n\t\t\treturn tabela2()\n\t\t}\n\t\telse if (dado == 2 || dado == 3) return \"Não pode fazer ações, exceto reações, e fica balbuciando incoerentemente\";\n\t\telse if (dado == 4 || dado == 5) return \"Usa a arma que estiver empunhando para atacar a criatura mais próxima, ou a si mesmo se estiver sozinho (apenas role o dano)\";\n\t\telse if (dado == 6) return \"A condição termina e pode agir normalmente\";\n\t}\n\tfunction tabela2() {\n\t\tconst direcoes = [\"cima\", \"o canto superior-direito\", \"direita\", \"o canto inferior-direito\", \"baixo\", \"o canto inferior-esquerdo\", \"esquerda\", \"o canto superior esquerdo\"]\n\t\tlet d8 = new Roll(`1d8`).roll();\n\t\tlet direction = d8.total;\n\t\trolls.push(d8);\n\t\treturn \"Movimenta-se para \" + direcoes[direction-1];\n\t}\n\tlet _rolls = [];\n\tlet resultado = tabela(d6.total);\n\tfor (const roll of rolls){\n\t\troll.tipo = \"roll--dano\";\n\t\tif (roll.dice[0]?.faces == 8) roll.title = \"Direção\";\n\t\tawait roll.render().then((r)=> {_rolls.push(r)});\n\t}\n\tlet content = {\n\t\titem: {\n\t\t\tname: \"Confuso\",\n\t\t\timg: \"systems/tormenta20/icons/conditions/confuso.svg\"\n\t\t},\n\t\tdata: {\n\t\t\tdescription: \"<p>\" + resultado + \". </p>\"\n\t\t},\n\t\t_rolls: _rolls,\n\t\trolls: rolls\n\t}\n\t\n\tif (game?.dice3d?.show) {\n\t\tlet wd = {\n\t\t\twhisper: ([\"gmroll\", \"blindroll\"].includes(rollMode) ? ChatMessage.getWhisperRecipients(\"GM\") \n\t\t\t\t: (rollMode === \"selfroll\" ? [game.user._id] : null)),\n\t\t\tblind: rollMode === \"blindroll\"\n\t\t}\n\t\tfor (const roll of rolls){\n\t\t\tgame.dice3d.showForRoll(roll, game.user, true, wd.whisper, wd.blind)\n\t\t}\n\t}\n\n\tlet template = \"systems/tormenta20/templates/chat/chat-card.html\";\n\tconst html = await renderTemplate(template, content);\n\tconst chatData = {\n\t\tuser: game.user._id,\n\t\ttype: CONST.CHAT_MESSAGE_TYPES.OTHER,\n\t\tcontent: html,\n\t\tspeaker: ChatMessage.getSpeaker({actor: this.actor, token})\n\t};\n\tChatMessage.create(chatData);\n})()","author":"qFZKRQ3n6QbDxQLO","img":"systems/tormenta20/icons/conditions/confuso.svg","actorIds":[],"_id":"x7urV68SDejp1pu0"}

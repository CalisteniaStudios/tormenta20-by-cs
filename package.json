{
  "name": "tormenta20",
  "version": "1.0.0",
  "description": "CSS compiler for the tormenta20 system",
  "scripts": {
    "build": "npm run build:code && npm run build:copy && npm run build:css && npm run build:db",
    "build:code": "rollup tormenta20.mjs -f es -o ./dist/tormenta20.mjs -p node-resolve -m --sourcemapFile tormenta20.mjs",
    "build:copy": "node ./utils/copy.mjs",
    "build:css": "lessc less/tormenta20.less ./dist/tormenta20.css",
    "build:db": "node ./utils/packs.mjs package pack",
    "build:source": "node ./utils/packs.mjs package unpack",
    "lint": "eslint --ext .js,.cjs,.mjs .",
    "lint:fix": "eslint --ext .js,.cjs,.mjs --fix .",
    "lint:warnings": "eslint --max-warnings 0 --ext .js,.cjs,.mjs .",
    "lint:errors": "eslint --quiet --ext .js,.cjs,.mjs .",
    "lint:fix:errors": "eslint --quiet --ext .js,.cjs,.mjs --fix .",
    "watch": "less-watch-compiler less/ ./dist tormenta20.less"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "John Doe",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@babel/eslint-parser": "^7.27.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "@foundryvtt/foundryvtt-cli": "^1.0.4",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@stylistic/eslint-plugin-js": "^1.8.1",
    "eslint": "^9.26.0",
    "fancy-log": "^2.0.0",
    "fs-extra": "^11.2.0",
    "globals": "^16.0.0",
    "js-yaml": "^4.1.0",
    "less-watch-compiler": "^1.16.3",
    "lessc": "^1.0.2",
    "rollup": "^4.40.1",
    "yargs": "^17.7.2"
  }
}

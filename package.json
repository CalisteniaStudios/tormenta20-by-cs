{
  "name": "tormenta20",
  "version": "1.0.0",
  "description": "CSS compiler for the tormenta20 system",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -cw",
    "build:packs": "node ./utils/packs.mjs package pack",
    "build:ci": "npm run build:packs && rollup -c",
    "lint": "eslint --ext .js,.cjs,.mjs .",
    "lint:fix": "eslint --ext .js,.cjs,.mjs --fix .",
    "lint:warnings": "eslint --max-warnings 0 --ext .js,.cjs,.mjs .",
    "lint:errors": "eslint --quiet --ext .js,.cjs,.mjs .",
    "lint:fix:errors": "eslint --quiet --ext .js,.cjs,.mjs --fix ."
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "John Doe",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@babel/eslint-parser": "^7.27.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.26.0",
    "@foundryvtt/foundryvtt-cli": "^1.0.4",
    "@guanghechen/rollup-plugin-copy": "^6.0.7",
    "@stylistic/eslint-plugin-js": "^1.8.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "fancy-log": "^2.0.0",
    "fs-extra": "^11.2.0",
    "globals": "^16.0.0",
    "js-yaml": "^4.1.0",
    "less-watch-compiler": "^1.16.3",
    "lessc": "^1.0.2",
    "rollup": "^4.40.1",
    "rollup-plugin-postcss": "^4.0.2",
    "yargs": "^17.7.2"
  }
}

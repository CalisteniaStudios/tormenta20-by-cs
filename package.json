{
  "name": "tormenta20",
  "version": "1.0.0",
  "description": "CSS compiler for the tormenta20 system",
  "scripts": {
    "build": "gulp",
    "compile": "gulp css",
    "watch": "gulp watch",
    "link": "node ./utils/create-symlinks.mjs",
    "lint": "eslint --ext .js,.cjs,.mjs .",
    "lint:fix": "eslint --ext .js,.cjs,.mjs --fix .",
    "lint:warnings": "eslint --max-warnings 0 --ext .js,.cjs,.mjs .",
    "lint:errors": "eslint --quiet --ext .js,.cjs,.mjs .",
    "lint:fix:errors": "eslint --quiet --ext .js,.cjs,.mjs --fix ."
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "John Doe",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@babel/eslint-parser": "^7.27.0",
    "@stylistic/eslint-plugin-js": "^1.8.1",
    "@typhonjs-fvtt/eslint-config-foundry.js": "^0.8.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jsdoc": "^46.10.1",
    "gulp": "^5.0.0",
    "gulp-autoprefixer": "^9.0.0",
    "gulp-less": "^5.0.0",
    "gulp-sass": "^6.0.1",
    "gulp-sourcemaps": "^3.0.0"
  }
}

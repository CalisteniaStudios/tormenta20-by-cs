<form class="{{cssClass}} flexcol" autocomplete="off">
	{{!-- Item Sheet Header --}}
	{{> "tormenta20.item-header"}}
	{{!-- Item Sheet Navigation --}}
	<nav class="sheet-tabs tabs" data-group="primary">
		<a class="item active" data-tab="details">{{ localize "T20.Details" }}</a>
	</nav>

	{{!-- Item Sheet Body --}}
	<section class="sheet-body">

		{{!-- Details Tab --}}
		<div class="tab details" data-group="primary" data-tab="details">

			<div class="form-group">
				<label>{{ localize "T20.Abilities" }}</label>
				<div class="flexrow">
					{{#each system.atributos as |atr key|}}
					<div class="flexcol" style="flex-basis: 33%">
						<label>{{localize (lookup ../config.atributos key)}}</label>
						<input type="number" name="system.atributos.{{key}}" value="{{atr}}" />
					</div>
					{{/each}}
				</div>
				<p class="notes"></p>
			</div>

			<div class="form-group">
				<label>{{ localize "T20.AbilityFreeChoice" }}</label>
				<div class="flexrow">
					{{#each system.atributosEscolhaLivre as |atr key|}}
					<div style="flex-basis: 33%">
						<label>{{localize (lookup ../config.atributos key)}}</label>
						<input type="checkbox" name="system.atributosEscolhaLivre.{{key}}" {{checked atr}} />
					</div>
					{{/each}}
				</div>
				<p class="notes">{{ localize "T20.AbilityFreeChoiceHint"}}</p>
			</div>

			<div class="form-group">
				<label>{{ localize "T20.Movement" }}</label>
				<div class="flexrow">
					{{#each config.movementTypes as |mov key|}}
					<div class="flexcol" style="flex-basis: 33%">
						<label>{{mov}}</label>
						<input type="number" name="system.movement.{{key}}" value="{{lookup @root.system.movement key}}" />
					</div>
					{{/each}}
					<div class="flexcol" style="flex-basis: 33%">
						<label>{{localize "T20.MovementHover"}}</label>
						<input type="checkbox" name="system.movement.hover" {{checked system.movement.hover}}>
					</div>
				</div>
				<p class="notes"></p>
			</div>

			<div class="form-group">
				<label>{{ localize "T20.Size" }}</label>
				<div class="form-field">
					<select class="actor-size" name="system.tracos.tamanho">
						{{selectOptions config.actorSizes selected=system.tamanho}}
					</select>
				</div>
			</div>
		</div>

	</section>
</form>
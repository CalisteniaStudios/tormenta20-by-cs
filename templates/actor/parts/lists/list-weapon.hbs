<ol class="item-list">
	<li class="item flexrow item-header">
		<div class="item-name flex2">{{ localize 'T20.Weapons'}}</div>
		<div class="item-rolls flex2">{{ localize 'T20.Attack'}} ({{ localize 'T20.Damage'}}, {{ localize 'T20.Critical'}})</div>
		<div class="item-qty">{{ localize 'T20.QuantityAbbr' }}</div>
		<div class="item-weight">{{localize 'T20.SlotsAbbr'}}</div>
		{{#if @root.isCharacter }}
		<div class="item-equipped" data-tooltip="{{localize 'T20.Equipped'}}">
			<i class="fa-solid fa-hand-back-fist"></i>
		</div>
		{{/if}}
	</li>
	{{#each actor.inventario.arma.items as |item id|}}
		<li class="item flexrow" data-item-id="{{item._id}}">
			<div class="item-name flexrow rollable flex2">
				<div class="item-image" tabindex="0" role="button" aria-label="{{item.name}}" style="background-image: url('{{item.img}}')"></div>
				<label>{{item.name}}</label>
			</div>

			<div class="item-rolls flex2">
				{{"t20-itemLabels" item}}
			</div>

			<div class="item-qty">
				{{#if ../owner}}
					<input type="text" data-dtype="Number" placeholder="0" classe="item-qty" value="{{item.system.qtd}}">
				{{else}}
					{{item.system.qtd}}
				{{/if}}
			</div>
			<div class="item-weight">{{item.espacosTotal}}</div>
			{{#if @root.isCharacter }}
				<div class="item-equipped">
					{{#if @root.equipmentSlots}}
						{{#if (and item.system.equipado2.type item.equipado.slot)}}
							<span class="fa-stack">
								{{{item.equipado.icon1}}}
								{{{item.equipado.icon2}}}
							</span>
						{{/if}}
					{{else}}
						{{#if item.system.equipado}}
							<i class="fa-solid fa-hand-back-fist"></i>
						{{/if}}
					{{/if}}
				</div>
			{{/if}}
		</li>
	{{/each}}
</ol>
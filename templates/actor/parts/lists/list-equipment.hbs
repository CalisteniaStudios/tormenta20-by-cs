<ol class="item-list">
	<li class="item flexrow item-header">
		<div class="item-name flex2">{{ localize 'T20.Equipment'}}</div>
		<div class="item-def" data-tooltip="{{ localize 'T20.Defense'}} / {{ localize 'T20.ArmorPenalty'}}"><i class="fa-solid fa-shield"></i> / <i class="fa-solid fa-person-hiking"></i></div>
		<div class="item-qty">{{ localize 'T20.QuantityAbbr' }}</div>
		<div class="item-weight">{{localize 'T20.SlotsAbbr'}}</div>
		{{#if @root.isCharacter }}
		<div class="item-equipped" data-tooltip="{{localize 'T20.Equipped'}}">
			<i class="fa-solid fa-hand-back-fist"></i>
		</div>
		{{/if}}
	</li>
	{{#each actor.inventario.equipamento.items as |item id|}}
		<li class="item flexrow" data-item-id="{{item._id}}">
			<div class="item-name flex2 flexrow rollable edit-favoritos">
				<div class="item-image" style="background-image: url('{{item.img}}')"></div>
				<label>{{item.name}}</label>
			</div>
			<div class="item-def">
				{{numberFormat item.system.armadura.value sign=true}} / {{item.system.armadura.penalidade}}
			</div>
			<div class="item-qty">
				{{#if ../owner}}
					<input type="text" data-dtype="Number" placeholder="0" classe="item-qty" value="{{item.system.qtd}}">
				{{else}}
					{{item.system.qtd}}
				{{/if}}
			</div>
			<div class="item-weight">{{item.espacosTotal}}</div>
			{{#if @root.isCharacter }}
				<div class="item-equipped">
					{{#if @root.equipmentSlots}}
						{{#if (and item.system.equipado2.type item.equipado.slot)}}
							<span class="fa-stack">
								{{{item.equipado.icon1}}}
								{{{item.equipado.icon2}}}
							</span>
						{{/if}}
					{{else}}
						{{#if item.system.equipado}}
							<i class="fas fa-shield-alt"></i>
						{{/if}}
					{{/if}}
				</div>
			{{/if}}
		</li>
	{{/each}}
</ol>
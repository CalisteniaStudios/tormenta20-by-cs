<div class="tab comodos" data-group="primary" data-tab="comodos">
	<div class="form-group stacked">
		<div class="form-fields">
			{{#if comodosPoderes.length}}
			<div style="display: flex; flex-direction: column; gap: 0.5em;">
				{{#each comodosPoderes as |comodo idx|}}
				<ul class="item-list">
					<li class="item item-header flexrow">
						<div class="item-name">{{comodo.name}}</div>
					</li>
					{{#if comodo.item}}
					<li class="item flexrow" data-item-id="{{comodo.item._id}}">
						<div class="item-name flexrow rollable flex2" data-label="{{comodo.item.name}}">
							<div class="item-image" style="background-image: url('{{comodo.item.img}}')"></div>
							<label>{{comodo.item.name}}</label>
						</div>
					</li>
					{{/if}}
					{{#if comodo.mobilias.length}}
					<li>
						<ul class="item-list" style="margin-left:2em;">
							{{#each comodo.mobilias as |mobilia|}}
							<li class="item flexrow" data-item-id="{{mobilia._id}}">
								<div class="item-name flexrow flex2" data-label="{{mobilia.name}}">
									<div class="item-image" style="background-image: url('{{mobilia.img}}')"></div>
									<label>{{mobilia.name}}</label>
								</div>
							</li>
							{{/each}}
						</ul>
					</li>
					{{/if}}
				</ul>
				{{/each}}
			</div>
			{{/if}}
		</div>
	</div>
</div>